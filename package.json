{
    "name": "pielarmonia",
    "private": true,
    "scripts": {
        "test": "npx playwright test",
        "test:calendar-contract": "npx playwright test tests/calendar-google-contract.spec.js",
        "test:calendar-write": "npx playwright test tests/calendar-google-write.spec.js",
        "test:phase2": "npx playwright test tests/phase2-calendar-consistency.spec.js",
        "test:phase2:probe": "node bin/run-phase2-flakiness.js --runs=3 --max-failures=0 --command=\"npm run test:phase2\"",
        "test:critical:agenda": "npx playwright test tests/calendar-google-contract.spec.js tests/phase2-calendar-consistency.spec.js",
        "test:critical:funnel": "npx playwright test tests/funnel-event-api.spec.js tests/funnel-retention-admin.spec.js tests/funnel-tracking.spec.js",
        "test:figo-contract": "npx playwright test tests/figo-chat-contract.spec.js",
        "test:chat-booking-calendar-errors": "npx playwright test tests/chat-booking-calendar-errors.spec.js",
        "test:admin-availability-readonly": "npx playwright test tests/admin-availability-readonly.spec.js",
        "test:frontend:qa:services": "npx playwright test tests/service-pages-qa.spec.js",
        "test:frontend:qa:public": "npx playwright test tests/homepage.spec.js tests/telemedicina-conversion-qa.spec.js tests/service-pages-qa.spec.js tests/mobile-overflow-regression.spec.js tests/deferred-content-fallback.spec.js tests/home-deferred-hydration.spec.js tests/cookie-consent.spec.js tests/legal.spec.js",
        "test:frontend:qa:admin": "npx playwright test tests/admin.spec.js tests/admin-navigation-responsive.spec.js tests/admin-appointments-responsive.spec.js tests/admin-availability-responsive.spec.js tests/admin-availability-readonly.spec.js tests/funnel-retention-admin.spec.js",
        "test:frontend:qa:block": "npm run test:frontend:qa:public && npm run test:frontend:qa:admin",
        "test:frontend:qa:closeout": "npm run test:frontend:qa:block && npx playwright test tests/booking.spec.js tests/pricing-layout.spec.js tests/funnel-tracking.spec.js tests/chat-mobile-layout.spec.js tests/chat-booking-calendar-errors.spec.js tests/version-consistency.spec.js",
        "test:headed": "npx playwright test --headed",
        "test:ui": "npx playwright test --ui",
        "test:php": "php tests/run-php-tests.php",
        "lint": "npm run lint:js && npm run lint:php",
        "lint:js": "eslint .",
        "lint:php": "node bin/lint-php-syntax.js",
        "build": "rollup -c && npm run build:html",
        "build:html": "node bin/build-html.js templates/index.template.html index.html && node bin/build-html.js templates/telemedicina.template.html telemedicina.html",
        "bundle:deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File ./PREPARAR-PAQUETE-DESPLIEGUE.ps1 -IncludeTooling",
        "verify:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File ./VERIFICAR-DESPLIEGUE.ps1 -Domain https://pielarmonia.com",
        "verify:prod:fast": "powershell -NoProfile -ExecutionPolicy Bypass -File ./VERIFICAR-DESPLIEGUE.ps1 -Domain https://pielarmonia.com -RequireStableDataDir -RequireBackupHealthy -SkipAssetHashChecks -AssetHashRetryCount 1 -AssetHashRetryDelaySec 2",
        "smoke:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File ./SMOKE-PRODUCCION.ps1 -Domain https://pielarmonia.com -TestFigoPost",
        "gate:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File ./GATE-POSTDEPLOY.ps1 -Domain https://pielarmonia.com",
        "gate:prod:fast": "powershell -NoProfile -ExecutionPolicy Bypass -File ./GATE-POSTDEPLOY.ps1 -Domain https://pielarmonia.com -SkipBenchmark -SkipAssetHashChecks -AssetHashRetryCount 1 -AssetHashRetryDelaySec 2 -VerifyRetryAttempts 1 -VerifyRetryDelaySec 30 -RequireStableDataDir -RequireBackupHealthy -RequireBackupReceiverReady -RequireCronReady",
        "gate:prod:backend": "powershell -NoProfile -ExecutionPolicy Bypass -File ./GATE-POSTDEPLOY.ps1 -Domain https://pielarmonia.com -SkipAssetHashChecks",
        "gate:prod:hash-strict": "powershell -NoProfile -ExecutionPolicy Bypass -File ./GATE-POSTDEPLOY.ps1 -Domain https://pielarmonia.com -ForceAssetHashChecks",
        "gate:prod:strict": "powershell -NoProfile -ExecutionPolicy Bypass -File ./GATE-POSTDEPLOY.ps1 -Domain https://pielarmonia.com -RequireStableDataDir -RequireBackupHealthy -RequireBackupReceiverReady -RequireCronReady",
        "nightly:stability": "npm run gate:prod && npm run test:critical:agenda && npm run test:critical:funnel",
        "monitor:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File ./MONITOR-PRODUCCION.ps1 -Domain https://pielarmonia.com",
        "report:weekly:prod": "powershell -NoProfile -ExecutionPolicy Bypass -File ./REPORTE-SEMANAL-PRODUCCION.ps1 -Domain https://pielarmonia.com",
        "git:sync:main:safe": "node bin/sync-main-safe.js --remote origin --branch main",
        "verify:sentry:events": "node bin/verify-sentry-events.js",
        "prod:readiness:summary": "node bin/prod-readiness-summary.js",
        "format": "prettier --write .",
        "agent:sync": "node agent-orchestrator.js sync",
        "agent:status": "node agent-orchestrator.js status",
        "agent:intake": "node agent-orchestrator.js intake --strict",
        "agent:score": "node agent-orchestrator.js score",
        "agent:stale": "node agent-orchestrator.js stale --strict",
        "agent:reconcile": "node agent-orchestrator.js reconcile --strict",
        "agent:budget": "node agent-orchestrator.js budget --json",
        "agent:conflicts": "node agent-orchestrator.js conflicts --strict",
        "agent:handoffs": "node agent-orchestrator.js handoffs",
        "agent:handoffs:lint": "node agent-orchestrator.js handoffs lint",
        "agent:policy:lint": "node agent-orchestrator.js policy lint",
        "agent:codex": "node agent-orchestrator.js codex",
        "agent:codex-check": "node agent-orchestrator.js codex-check",
        "agent:leases": "node agent-orchestrator.js leases status --json",
        "agent:board:doctor": "node agent-orchestrator.js board doctor --json",
        "agent:board:legacy:check": "node bin/board-legacy-drift-guard.js --check --json",
        "agent:board:legacy:normalize": "node bin/board-legacy-drift-guard.js --write --json",
        "agent:board:resolve-revision": "node bin/resolve-board-revision-conflict.js --file AGENT_BOARD.yaml --json",
        "agent:board:archive:preview": "node bin/archive-agent-board.js --json",
        "agent:board:archive:apply": "node bin/archive-agent-board.js --apply --json",
        "agent:task": "node agent-orchestrator.js task",
        "agent:test": "node --test tests-node/agent-orchestrator-cli.test.js tests-node/agent-orchestrator-json-contract.test.js tests-node/agent-governance-summary.test.js tests-node/agent-queue-sync-workflow-contract.test.js tests-node/workspace-hygiene-contract.test.js tests-node/run-php-cs-fixer-wrapper.test.js tests-node/php-governance-contract.test.js tests-node/resolve-board-revision-conflict.test.js tests-node/weekly-kpi-workflow-contract.test.js tests-node/nightly-stability-workflow-contract.test.js tests-node/post-deploy-fast-workflow-contract.test.js tests-node/agent-board-weekly-snapshot-workflow-contract.test.js tests-node/archive-agent-board.test.js tests-node/sync-main-safe.test.js tests-node/orchestrator/core-io.test.js tests-node/orchestrator/core-queues.test.js tests-node/orchestrator/core-parsers.test.js tests-node/orchestrator/core-serializers.test.js tests-node/orchestrator/conflicts-engine.test.js tests-node/orchestrator/handoffs-engine.test.js tests-node/orchestrator/codex-mirror-engine.test.js tests-node/orchestrator/task-guards.test.js tests-node/orchestrator/task-create-engine.test.js tests-node/orchestrator/metrics-engine.test.js tests-node/orchestrator/status-engine.test.js tests-node/orchestrator/diagnostics.test.js tests-node/orchestrator/policy-config.test.js tests-node/orchestrator/intake-engine.test.js tests-node/orchestrator/board-leases-engine.test.js tests-node/orchestrator/board-doctor-engine.test.js tests-node/orchestrator/board-events-engine.test.js",
        "agent:summary": "node bin/agent-governance-summary.js",
        "agent:summary:local": "node bin/agent-governance-summary.js --profile local",
        "agent:summary:ci": "node bin/agent-governance-summary.js --profile ci",
        "agent:metrics": "node agent-orchestrator.js metrics",
        "agent:metrics:baseline": "node agent-orchestrator.js metrics baseline",
        "agent:validate": "php bin/validate-agent-governance.php",
        "agent:gate": "npm run agent:test && npm run agent:board:legacy:check && npm run agent:conflicts && npm run agent:handoffs:lint && npm run agent:policy:lint && npm run agent:codex-check && npm run agent:validate",
        "agent:jules:dispatch": "node jules-dispatch.js dispatch",
        "agent:jules:reconcile": "node jules-dispatch.js reconcile",
        "agent:kimi:dispatch": "node kimi-run.js --dispatch --no-diff",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.php": "node bin/run-php-cs-fixer.js fix",
        "*.{js,mjs,cjs,json,md}": "prettier --write",
        "*.{js,mjs,cjs}": "eslint --fix"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.58.2",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-strip": "^3.0.4",
        "@rollup/plugin-terser": "^0.4.4",
        "cssnano": "^7.1.2",
        "eslint": "^10.0.0",
        "eslint-plugin-playwright": "^2.7.0",
        "globals": "^17.3.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "prettier": "^3.8.1",
        "purgecss": "^8.0.0",
        "rollup": "^4.58.0"
    }
}
