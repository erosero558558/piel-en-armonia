{
  "name": "aurora-derm",
  "private": true,
  "scripts": {
    "dev":              "php -S 127.0.0.1:8000 bin/local-stage-router.php",
    "lint":             "npm run lint:php && npm run test:routes",
    "lint:php":         "node bin/lint-php-syntax.js",
    "test":             "npm run lint && npm run test:php",
    "test:routes":      "node bin/check-route-integrity.js",
    "test:php":         "php vendor/bin/phpunit --testsuite Smoke 2>&1 || echo 'PHPUnit no disponible — ejecuta composer install primero'",
    "test:smoke":       "SMOKE_URL=http://127.0.0.1:8000 node --test tests-node/backend-only-smoke.test.js",
    "prune":            "node bin/prune.js",
    "prune:delete":     "node bin/prune.js --delete",
    "backup":           "bash ops/backup.sh",
    "ops:install-crons":"crontab -l 2>/dev/null | cat - ops/crontab.txt | crontab -"
  }
}