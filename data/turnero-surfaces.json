            "family": "desktop",
            "route": "/operador-turnos.html",
            "productName": "Turnero Operador",
            "artifactBase": "TurneroOperador",
            "executableName": "TurneroOperador",
            "appId": "com.pielarmonia.turnero.operator",
            "webFallbackUrl": "/operador-turnos.html",
            "guideUrl": "/app-downloads/?surface=operator",
            "updateChannel": "pilot",
            "catalog": {
                "title": "Operador",
                "eyebrow": "Genius Numpad 1000",
                "description": "Llamado, re-llamado, completar y no show con el numpad en el PC del consultorio.",
                "qrTarget": "prepared",
                "notes": [
                    "Conecta el receptor USB del Genius Numpad 1000 al PC operador, no a la TV.",
                    "Si el Enter del numpad no llega como `NumpadEnter`, calibra la tecla externa dentro de la app.",
                    "Usa `C1 fijo` o `C2 fijo` cuando ese equipo quede dedicado a un consultorio."
                ]
            },
            "ops": {
                "installHub": {
                    "eyebrow": "Recepcion + consultorio",
                    "title": "Operador",
                    "description": "Superficie diaria para llamar, re-llamar, completar y operar con el Genius Numpad 1000.",
                    "recommendedFor": "PC operador",
                    "notes": [
                        "Conecta aqui el receptor USB 2.4 GHz del numpad.",
                        "La app desktop ahora puede quedar configurada como C1, C2 o modo libre desde el primer arranque."
                    ]
                },
                "telemetry": {
                    "title": "Operador",
                    "emptySummary": "Todavia no hay senal del equipo operador. Abre la app o el fallback web para registrar heartbeat."
                }
            },
            "launchDefaults": {
                "station": "c1",
                "lock": false,
                "one_tap": false
            },
            "release": {
                "artifactName": "turnero-desktop-operator"
            },
            "desktop": {
                "buildDir": "src/apps/turnero-desktop",
                "distDir": "src/apps/turnero-desktop/dist/operator",
                "supportsAutoUpdate": true
            },
            "targets": {
                "win": {
                    "label": "Windows",
                    "downloadPath": "operator/win",
                    "manualFile": "TurneroOperadorSetup.exe",
                    "updatePath": "operator/win",
                    "updateFile": "TurneroOperadorSetup.exe",
                    "feedFile": "latest.yml"
                },
                "mac": {
                    "label": "macOS",
                    "downloadPath": "operator/mac",
                    "manualFile": "TurneroOperador.dmg",
                    "updatePath": "operator/mac",
                    "updateFile": "TurneroOperador.zip",
                    "feedFile": "latest-mac.yml"
                }
            }
        },
