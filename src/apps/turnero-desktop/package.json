{
    "name": "turnero-desktop",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "author": "Aurora Derm",
    "description": "Shells desktop para Turnero Operador y Turnero Kiosco conectados al backend central.",
    "main": "src/main.mjs",
    "scripts": {
        "dev:surface": "node scripts/dev.mjs",
        "dev:operator": "node scripts/dev.mjs --surface operator",
        "dev:kiosk": "node scripts/dev.mjs --surface kiosk",
        "build:surface": "node scripts/build.mjs",
        "build:operator:win": "node scripts/build.mjs --surface operator --platform win",
        "build:operator:mac": "node scripts/build.mjs --surface operator --platform mac",
        "build:kiosk:win": "node scripts/build.mjs --surface kiosk --platform win",
        "build:kiosk:mac": "node scripts/build.mjs --surface kiosk --platform mac",
        "test": "node --test test/*.test.mjs"
    },
    "turneroDesktop": {
        "surface": "operator",
        "baseUrl": "https://pielarmonia.com",
        "launchMode": "fullscreen",
        "autoStart": true,
        "updateChannel": "stable",
        "updateBaseUrl": "https://pielarmonia.com/desktop-updates/"
    },
    "dependencies": {
        "electron-updater": "^6.6.2"
    },
    "devDependencies": {
        "electron": "^35.0.0",
        "electron-builder": "^26.0.12"
    }
}
