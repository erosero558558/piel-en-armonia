---
import '../styles/public-v6/index.css';
import PublicHeaderV6 from '../components/public-v6/PublicHeaderV6.astro';
import PublicFooterV6 from '../components/public-v6/PublicFooterV6.astro';

const {
    title = 'Aurora Derm',
    description = '',
    locale = 'es',
    canonicalPath = '/es/',
    alternatePath = '/en/',
    pathname = '/es/',
    navModel = {},
    templateId = 'public_v6',
    ogImageSrc = '',
    preloadImageSrc = '',
    preloadImageSrcSet = '',
    preloadImageSizes = '',
    preloadImageType = 'image/webp',
    rssFeedPath = '',
} = Astro.props;

const hasText = (value) => typeof value === 'string' && value.trim().length > 0;
const normalizeText = (value) => (hasText(value) ? value.trim() : '');
const normalizePath = (value, fallback) => {
    const raw = normalizeText(value) || fallback;
    if (!raw) return '/';
    if (/^https?:\/\//i.test(raw)) return raw;
    const withLeading = raw.startsWith('/') ? raw : `/${raw}`;
    return withLeading.endsWith('/') ? withLeading : `${withLeading}/`;
};
const normalizeResourcePath = (value) => {
    const raw = normalizeText(value);
    if (!raw) return '';
    if (/^https?:\/\//i.test(raw)) return raw;
    return raw.startsWith('/') ? raw : `/${raw}`;
};
const safeLocale = locale === 'en' ? 'en' : 'es';
const safeTitle = normalizeText(title) || 'Aurora Derm';
const safeDescription = normalizeText(description);
const safeTemplateId = normalizeText(templateId) || 'public_v6';
const origin = 'https://pielarmonia.com';
const canonical = new URL(normalizePath(canonicalPath, safeLocale === 'en' ? '/en/' : '/es/'), origin).toString();
const hasAlternate = hasText(alternatePath);
const alternate = hasAlternate
    ? new URL(
          normalizePath(
              alternatePath,
              safeLocale === 'en' ? '/es/' : '/en/'
          ),
          origin
      ).toString()
    : '';
const safePathname = normalizePath(pathname, safeLocale === 'en' ? '/en/' : '/es/');
const xDefault = hasAlternate
    ? safeLocale === 'en'
        ? alternate
        : canonical
    : canonical;
const fontsHref =
    'https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Newsreader:opsz,wght@6..72,500;6..72,600;6..72,700&display=swap';
const parseSrcSetCandidates = (value) =>
    normalizeText(value)
        .split(',')
        .map((entry) => {
            const parts = entry.trim().split(/\s+/);
            const href = normalizeText(parts[0]);
            const width = Number.parseInt(String(parts[1] || '').replace(/w$/i, ''), 10);
            return href
                ? {
                      href,
                      width: Number.isFinite(width) ? width : null,
                  }
                : null;
        })
        .filter(Boolean);
const pickPreloadImageHref = (src, srcset) => {
    const fallback = normalizeText(src);
    const candidates = parseSrcSetCandidates(srcset);
    if (!candidates.length) {
        return fallback;
    }
    const preferred =
        candidates.find((candidate) => candidate.width === 800) ||
        candidates.find(
            (candidate) =>
                typeof candidate.width === 'number' &&
                candidate.width >= 760 &&
                candidate.width <= 960
        ) ||
        candidates.find(
            (candidate) => typeof candidate.width === 'number' && candidate.width > 800
        ) ||
        candidates[candidates.length - 1];
    return preferred?.href || fallback;
};
const toOgImageUrl = (value) => {
    const raw = normalizeText(value);
    const fallback = '/images/optimized/v6-clinic-brand-hero-wide.jpg';
    if (!raw) {
        return new URL(fallback, origin).toString();
    }
    if (/^https?:\/\//i.test(raw)) {
        return raw;
    }
    const normalized = raw.startsWith('/') ? raw : `/${raw}`;
    const jpgPath = normalized.replace(/\.webp$/i, '.jpg');
    return new URL(jpgPath, origin).toString();
};

const preloadHref = pickPreloadImageHref(preloadImageSrc, preloadImageSrcSet);
const preloadSrcSet = normalizeText(preloadImageSrcSet);
const preloadSizes = normalizeText(preloadImageSizes);
const preloadType = normalizeText(preloadImageType);
const ogImage = toOgImageUrl(ogImageSrc);
const rssFeed = normalizeResourcePath(rssFeedPath)
    ? new URL(normalizeResourcePath(rssFeedPath), origin).toString()
    : '';
const shellUi = navModel?.ui?.shell && typeof navModel.ui.shell === 'object' ? navModel.ui.shell : {};
const skipToContent = normalizeText(shellUi.skipToContent);
const backToTop = normalizeText(shellUi.backToTop);

const flags = {
    version: 'v6-r2',
    locale: safeLocale,
    templateId: safeTemplateId,
    fromScratch: true,
};
const flagsJson = JSON.stringify(flags);
---

<!doctype html>
<html lang={safeLocale}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{safeTitle}</title>
        <meta name="description" content={safeDescription} />
        <meta name="robots" content="index,follow,max-image-preview:large" />
        <link rel="canonical" href={canonical} />
        {
            hasAlternate ? (
                <link
                    rel="alternate"
                    href={alternate}
                    hreflang={safeLocale === 'es' ? 'en' : 'es'}
                />
            ) : null
        }
        <link rel="alternate" href={canonical} hreflang={safeLocale} />
        <link rel="alternate" href={xDefault} hreflang="x-default" />
        <meta property="og:type" content="website" />
        <meta property="og:site_name" content={navModel?.brand?.logo || 'Aurora Derm'} />
        <meta property="og:title" content={safeTitle} />
        <meta property="og:description" content={safeDescription} />
        <meta property="og:url" content={canonical} />
        <meta property="og:image" content={ogImage} />
        {
            rssFeed ? (
                <link
                    rel="alternate"
                    type="application/rss+xml"
                    title="Aurora Derm Blog RSS"
                    href={rssFeed}
                />
            ) : null
        }
        <meta name="theme-color" content="#090d13" />
        <link rel="icon" href="/favicon.ico" sizes="any" />
        {
            preloadHref ? (
                <link
                    rel="preload"
                    as="image"
                    href={preloadHref}
                    type={preloadType || undefined}
                    imagesrcset={preloadSrcSet || undefined}
                    imagesizes={preloadSizes || undefined}
                    fetchpriority="high"
                />
            ) : null
        }
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link rel="stylesheet" href={fontsHref} media="print" onload="this.media='all'" />
        <noscript><link rel="stylesheet" href={fontsHref} /></noscript>
        <script src="/js/aurora-nprogress.js" defer></script>
        <script src="/js/public-v6-shell.js?v=public-v6-shell-20260315-r3" defer></script>
        <script src="/js/aurora-header.js" defer></script>
        <script is:inline set:html={`window.__PUBLIC_V6_FLAGS = ${flagsJson};`}></script>
        <!-- GA4 Integration -->
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
        <script is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', 'G-XXXXXXXXXX');
        </script>
    </head>
    <body data-public-shell data-public-shell-version="v6" data-public-surface={safePathname} data-public-template-id={safeTemplateId}>
        {skipToContent ? <a class="v6-skip-link" href="#main-content">{skipToContent}</a> : null}
        <PublicHeaderV6 navModel={navModel} />
        <main id="main-content" class="v6-main">
            <slot />
        </main>
        <PublicFooterV6 navModel={navModel} locale={safeLocale} />

        <!-- Floating WhatsApp -->
        <a href="https://wa.me/593982453672" class="v6-floating-whatsapp" target="_blank" rel="noopener noreferrer" aria-label="Escríbenos por WhatsApp">
            <svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
        </a>

        {backToTop ? <button class="v6-back-to-top" type="button" data-v6-back-top aria-label={backToTop}>^</button> : null}
    </body>
</html>
