---
const { title = 'Aurora Derm V8' } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <style>
            :root {
                --v8-color-text-main: #0f1720;
                --v8-color-text-muted: rgba(34, 46, 60, 0.72);
                --v8-color-surface: #f3f6f9;
                --v8-space-sm: 1rem;
                font-family: 'Instrument Sans', system-ui, sans-serif;
            }

            body {
                margin: 0;
                min-height: 100vh;
                background:
                    radial-gradient(circle at top left, rgba(199, 163, 109, 0.12), transparent 32%),
                    linear-gradient(180deg, #eef3f7 0%, #f7fafc 100%);
                color: var(--v8-color-text-main);
            }

            .tester-box {
                max-width: 960px;
                margin: 0 auto;
                padding: 96px 24px;
            }
        </style>
    </head>
    <body>
        <slot />
    </body>
</html>
