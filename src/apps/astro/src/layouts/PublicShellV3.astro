---
import '../styles/public-v3.css';
import '../styles/public-v3-motion.css';
import PublicNavBarV3 from '../components/public-v3/PublicNavBarV3.astro';
import PublicFooterV3 from '../components/public-v3/PublicFooterV3.astro';
import LegacyRuntimeBridgeV3 from '../components/public-v3/LegacyRuntimeBridgeV3.astro';
import { getV4Catalog } from '../lib/content.js';

const {
    title = 'Piel en Armonia',
    description = '',
    locale = 'es',
    canonicalPath = '/es/',
    alternatePath = '/en/',
    pathname = '/es/',
    navModel,
    compatServiceBookingHref = '',
} = Astro.props;

const origin = 'https://pielarmonia.com';
const canonical = new URL(canonicalPath, origin).toString();
const alternate = new URL(alternatePath, origin).toString();
const xDefault = locale === 'en' ? alternate : canonical;
const compatBookingHref = locale === 'en' ? '/en/#citas' : '/es/#citas';
const compatSwitchHref = navModel?.switchHref || alternatePath;
const v4Catalog = getV4Catalog();
const featureDefaults = v4Catalog?.feature_flags_defaults || {};

const parseFlagBool = (value, fallback) => {
    const raw = String(value ?? '').trim().toLowerCase();
    if (!raw) return fallback;
    if (['1', 'true', 'yes', 'on'].includes(raw)) return true;
    if (['0', 'false', 'no', 'off'].includes(raw)) return false;
    return fallback;
};

const parseFlagRatio = (value, fallback) => {
    const parsed = Number(value);
    if (!Number.isFinite(parsed)) return fallback;
    if (parsed < 0) return 0;
    if (parsed > 1) return 1;
    return parsed;
};

const normalizeLocaleFlag = (value) => {
    const raw = String(value ?? '')
        .trim()
        .toLowerCase();
    return ['es', 'en'].includes(raw) ? raw : '';
};

const defaultEnabled = parseFlagBool(featureDefaults.public_v4_enabled, true);
const defaultRatio = parseFlagRatio(featureDefaults.public_v4_ratio, 1);
const defaultForcedLocale = normalizeLocaleFlag(
    featureDefaults.public_v4_force_locale
);
const defaultKillSwitch = parseFlagBool(
    featureDefaults.public_v4_kill_switch,
    false
);

const v4Enabled = parseFlagBool(
    import.meta.env.PUBLIC_PUBLIC_V4_ENABLED,
    defaultEnabled
);
const v4Ratio = parseFlagRatio(import.meta.env.PUBLIC_PUBLIC_V4_RATIO, defaultRatio);
const v4ForcedLocale = normalizeLocaleFlag(
    import.meta.env.PUBLIC_PUBLIC_V4_FORCE_LOCALE || defaultForcedLocale
);
const v4KillSwitch = parseFlagBool(
    import.meta.env.PUBLIC_PUBLIC_V4_KILL_SWITCH,
    defaultKillSwitch
);
const publicV4Flags = {
    public_v4_enabled: v4Enabled,
    public_v4_ratio: Number.isFinite(v4Ratio) ? v4Ratio : 1,
    public_v4_force_locale: v4ForcedLocale,
    public_v4_kill_switch: v4KillSwitch,
};
const publicV4FlagsJson = JSON.stringify(publicV4Flags);
---

<!doctype html>
<html lang={locale}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="robots" content="index,follow,max-image-preview:large" />
        <link rel="canonical" href={canonical} />
        <link rel="alternate" href={alternate} hreflang={locale === 'es' ? 'en' : 'es'} />
        <link rel="alternate" href={canonical} hreflang={locale} />
        <link rel="alternate" href={xDefault} hreflang="x-default" />
        <meta property="og:type" content="website" />
        <meta property="og:site_name" content="Piel en Armonia" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonical} />
        <meta property="og:image" content="https://pielarmonia.com/images/optimized/showcase-hero.jpg" />
        <meta name="theme-color" content="#050608" />
        <link rel="icon" href="/favicon.ico" sizes="any" />
        <link rel="manifest" href="/manifest.json" />
        <script src="/js/public-v3-shell.js?v=public-v4-shell-20260301-v1" defer></script>
        <script src="/js/service-navigation-analytics.js?v=service-analytics-20260301-v6" defer></script>
        <script is:inline set:html={`window.__PUBLIC_V4_FLAGS = ${publicV4FlagsJson};`}></script>
    </head>
    <body
        data-public-shell
        data-public-shell-version="v3"
        data-public-surface={pathname}
        data-public-v4-enabled={v4Enabled ? 'true' : 'false'}
        data-public-v4-ratio={Number.isFinite(v4Ratio) ? String(v4Ratio) : '1'}
        data-public-v4-force-locale={v4ForcedLocale}
        data-public-v4-kill-switch={v4KillSwitch ? 'true' : 'false'}
    >
        <a class="public-skip-link" href="#main-content">{locale === 'en' ? 'Skip to content' : 'Saltar al contenido'}</a>
        <div hidden aria-hidden="true" data-public-contract-links>
            <a class="public-contract-link nav-sony-lang-compat" href={compatSwitchHref}>
                {locale === 'en' ? 'Spanish route bridge' : 'English route bridge'}
            </a>
            <a class="public-contract-link public-contract-link--booking" href={compatBookingHref}>
                {locale === 'en' ? 'Localized booking bridge' : 'Puente de reserva localizada'}
            </a>
            {compatServiceBookingHref ? (
                <a class="public-contract-link public-contract-link--service" href={compatServiceBookingHref}>
                    {locale === 'en' ? 'Service booking hint bridge' : 'Puente de service hint'}
                </a>
            ) : null}
        </div>
        <PublicNavBarV3 navModel={navModel} />
        <main id="main-content">
            <slot />
        </main>
        <PublicFooterV3 locale={locale} footer={navModel.footer} />
        <LegacyRuntimeBridgeV3 locale={locale} />
    </body>
</html>
