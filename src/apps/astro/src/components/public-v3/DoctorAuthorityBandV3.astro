---
const { doctors = [], locale = 'es' } = Astro.props;
---

<section class="doctor-band" data-doctor-band>
    <div class="doctor-band__head">
        <p>{locale === 'en' ? 'Medical authority' : 'Autoridad medica'}</p>
        <h2>{locale === 'en' ? 'Two clear medical leads, each attached to visible service routes.' : 'Dos lideres medicos claros, cada uno conectado a rutas de servicio visibles.'}</h2>
    </div>
    <div class="doctor-band__cards">
        {
            doctors.map((doctor) => (
                <article class="doctor-band__card">
                    <img src={doctor.media} alt={doctor.name} loading="lazy" />
                    <div>
                        <p>{doctor.role}</p>
                        <h3>{doctor.name}</h3>
                        <p>{doctor.deck}</p>
                        <ul>
                            {doctor.services.map((service) => <li><a href={service.href}>{service.label}</a></li>)}
                        </ul>
                    </div>
                </article>
            ))
        }
    </div>
</section>

