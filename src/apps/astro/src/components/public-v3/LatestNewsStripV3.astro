---
const { items = [], locale = 'es' } = Astro.props;
---

<section class="latest-strip" data-latest-news>
    <h2>{locale === 'en' ? 'Latest' : 'Actualidad'}</h2>
    <div class="latest-strip__items">
        {
            items.map((item) => (
                <a href={item.href} class="latest-strip__item">
                    <span>{item.eyebrow}</span>
                    <strong>{item.title}</strong>
                </a>
            ))
        }
    </div>
</section>

