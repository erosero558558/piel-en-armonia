---
import ResponsiveMediaImageV3 from './ResponsiveMediaImageV3.astro';

const { families = [], filters = null, locale = 'es' } = Astro.props;
---

<section class="services-editorial-grid" data-services-grid>
    {
        filters ? (
            <div class="services-editorial-grid__filters" data-services-filters>
                <label>
                    <span>{locale === 'en' ? 'Intent' : 'Intencion'}</span>
                    <select data-filter-intent>
                        <option value="">{locale === 'en' ? 'All intents' : 'Todas las intenciones'}</option>
                        {
                            (filters.intents || []).map((item) => (
                                <option value={item.id}>{item.label}</option>
                            ))
                        }
                    </select>
                </label>
                <label>
                    <span>{locale === 'en' ? 'Audience' : 'Audiencia'}</span>
                    <select data-filter-audience>
                        <option value="">{locale === 'en' ? 'All audiences' : 'Todas las audiencias'}</option>
                        {
                            (filters.audiences || []).map((item) => (
                                <option value={item.id}>{item.label}</option>
                            ))
                        }
                    </select>
                </label>
            </div>
        ) : null
    }
    {
        families.map((family) => (
            <section class="services-editorial-grid__family" id={`family-${family.id}`} data-family-section={family.id}>
                <div class="services-editorial-grid__feature">
                    <ResponsiveMediaImageV3
                        media={family.mediaMeta || family.media}
                        fallbackSrc={family.media}
                        fallbackAlt={family.label}
                        loading="lazy"
                        sizes="(max-width: 1000px) 100vw, 420px"
                    />
                    <div>
                        <p>{family.label}</p>
                        <h2>{family.featured.title}</h2>
                        <p>{family.deck}</p>
                        <a href={family.featured.href} class="hero-stage__cta hero-stage__cta--primary" data-analytics-event="open_public_cta" data-entry-surface="services_editorial_feature" data-cta-target="service_detail" data-service-slug={family.featured.slug} data-service-category={family.id} data-catalog-category={family.id} data-catalog-intent="all">{family.featured.cta}</a>
                    </div>
                </div>
                <div class="services-editorial-grid__cards">
                    {
                        family.cards.map((card) => (
                            <article
                                class="service-card-v3"
                                data-service-card
                                data-card-category={family.id}
                                data-card-intents={(card.intents || []).join(',')}
                                data-card-audience={(card.audienceKeys || []).join(',')}
                            >
                                <p>{card.label}</p>
                                <h3>{card.title}</h3>
                                <p>{card.deck}</p>
                                <div class="service-card-v3__meta">
                                    <span>{card.duration}</span>
                                    <span>{card.priceLabel}</span>
                                </div>
                                <a href={card.href} class="public-link-arrow">{card.cta}</a>
                            </article>
                        ))
                    }
                </div>
            </section>
        ))
    }
</section>
