---
import ResponsiveMediaImageV3 from './ResponsiveMediaImageV3.astro';

const { stories = [], locale = 'es' } = Astro.props;
---

<section class="featured-stories" data-featured-story>
    {
        stories.map((story) => (
            <article class:list={['featured-story', story.alignment === 'right' && 'is-reverse']}>
                <div class="featured-story__media">
                    <ResponsiveMediaImageV3
                        media={story.mediaMeta || story.media}
                        fallbackSrc={story.media}
                        fallbackAlt={story.title}
                        loading="lazy"
                        sizes="(max-width: 1000px) 100vw, 52vw"
                    />
                </div>
                <div class="featured-story__copy">
                    <p>{story.eyebrow}</p>
                    <h2>{story.title}</h2>
                    <p>{story.deck}</p>
                    <a href={story.href} class="public-link-arrow">{locale === 'en' ? 'Explore' : 'Explorar'}</a>
                </div>
            </article>
        ))
    }
</section>
