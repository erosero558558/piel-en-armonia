---
const { stories = [], locale = 'es' } = Astro.props;
---

<section class="featured-stories" data-featured-story>
    {
        stories.map((story) => (
            <article class:list={['featured-story', story.alignment === 'right' && 'is-reverse']}>
                <div class="featured-story__media"><img src={story.media} alt={story.title} loading="lazy" /></div>
                <div class="featured-story__copy">
                    <p>{story.eyebrow}</p>
                    <h2>{story.title}</h2>
                    <p>{story.deck}</p>
                    <a href={story.href} class="public-link-arrow">{locale === 'en' ? 'Explore' : 'Explorar'}</a>
                </div>
            </article>
        ))
    }
</section>

