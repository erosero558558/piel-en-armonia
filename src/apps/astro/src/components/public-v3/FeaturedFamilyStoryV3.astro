---
import ResponsiveMediaImageV3 from './ResponsiveMediaImageV3.astro';

const { families = [] } = Astro.props;
---

<section class="featured-family-story-v3" data-featured-family-story>
    {
        families.map((family) => (
            <article class="featured-story">
                <div class="featured-story__media">
                    <ResponsiveMediaImageV3
                        media={family.mediaMeta || family.media}
                        fallbackSrc={family.media}
                        fallbackAlt={family.label}
                        loading="lazy"
                        sizes="(max-width: 1000px) 100vw, 52vw"
                    />
                </div>
                <div class="featured-story__copy">
                    <p>{family.label}</p>
                    <h2>{family.featured.title}</h2>
                    <p>{family.deck}</p>
                    <a href={family.featured.href} class="public-link-arrow">{family.featured.cta}</a>
                </div>
            </article>
        ))
    }
</section>
