---
import { getDictionary, legalBasePath } from '../../lib/content.js';

const { locale = 'es' } = Astro.props;

const dict = getDictionary(locale);
const cookiesHref = `${legalBasePath(locale)}cookies/`;
---

<div id="cookieBanner" class="cookie-banner" role="dialog" aria-live="polite">
    <p class="cookie-text" data-i18n="cookie_banner_text">{dict.cookie_banner_text}</p>
    <div class="cookie-actions">
        <button
            type="button"
            class="btn btn-secondary cookie-btn"
            id="cookieRejectBtn"
            data-i18n="cookie_reject"
        >
            {dict.cookie_reject}
        </button>
        <button
            type="button"
            class="btn btn-primary cookie-btn"
            id="cookieAcceptBtn"
            data-i18n="cookie_accept"
        >
            {dict.cookie_accept}
        </button>
        <a href={cookiesHref} class="cookie-link" data-i18n="cookie_more">{dict.cookie_more}</a>
    </div>
</div>
