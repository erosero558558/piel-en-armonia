---
const { eyebrow = '', points = [], locale = 'es', tone = 'silver' } = Astro.props;
---

<section class="service-evidence-v3" data-who-it-fits data-section-tone={tone}>
    <div><p>{eyebrow}</p><h2>{locale === 'en' ? 'Cases that usually fit telemedicine first.' : 'Casos que suelen encajar primero en telemedicina.'}</h2></div>
    <div class="service-evidence-v3__grid">
        {points.map((point) => <article><p>{point}</p></article>)}
    </div>
</section>

