const selected = copy[locale] || copy.es;
const selectedVariant = selected.variants?.[variant] || selected.variants.home;
const surfaceMap = {
    home: 'entry_decision_home',
    hub: 'entry_decision_hub',
    telemedicine: 'entry_decision_telemedicine',
};
const surface = surfaceMap[variant] || surfaceMap.home;
const targetContextMap = {
    booking: {
        category: 'clinical',
        intent: 'diagnosis',
    },
    telemedicine: {
        category: 'all',
        intent: 'remote',
    },
    whatsapp: {
        category: 'all',
        intent: 'all',
    },
};
---

<section
    class="sony-section sony-section--compact sony-entry-decision"
    data-entry-decision
    data-entry-decision-variant={variant}
>
    <div class="sony-section__head">
        <p>{selected.eyebrow}</p>
        <h2>{selectedVariant.title}</h2>
        <span>{selectedVariant.description}</span>
    </div>
    <div class="sony-entry-decision__grid">
        {
            selectedVariant.cards.map((card) => (
                <article
                    class={`sony-entry-decision__card sony-entry-decision__card--${card.tone}${activeTarget === card.target ? ' sony-entry-decision__card--active' : ''}`}
                    data-entry-decision-card
                    data-entry-target={card.target}
                    data-entry-active={activeTarget === card.target ? 'true' : 'false'}
                >
                    <span>{card.step}</span>
                    <h3>{card.title}</h3>
                    <p>{card.body}</p>
                    <a
                        class="sony-btn sony-btn--ghost"
                        href={card.href}
                        target={card.external ? '_blank' : undefined}
                        rel={card.external ? 'noopener noreferrer' : undefined}
                        data-analytics-event="open_public_cta"
                        data-entry-surface={surface}
                        data-cta-target={card.target}
                        data-service-category={targetContextMap[card.target]?.category || 'all'}
                        data-service-intent={targetContextMap[card.target]?.intent || 'all'}
                        data-catalog-category={targetContextMap[card.target]?.category || 'all'}
                        data-catalog-intent={targetContextMap[card.target]?.intent || 'all'}
                        aria-current={activeTarget === card.target ? 'page' : undefined}
                    >
                        {activeTarget === card.target && variant === 'telemedicine'
                            ? locale === 'en'
                                ? 'Current route'
                                : 'Ruta actual'
                            : card.cta}
                    </a>
                </article>
            ))
        }
    </div>
</section>
