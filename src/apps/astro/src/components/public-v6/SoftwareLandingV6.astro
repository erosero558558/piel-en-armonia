---
import '../../styles/public-v6/software.css';
import PageHeadV6 from './PageHeadV6.astro';
import SoftwareMockupV6 from './SoftwareMockupV6.astro';

const { page = {}, locale = 'es', navModel = {} } = Astro.props;

const pageHeadUi =
    navModel?.ui?.pageHead && typeof navModel.ui.pageHead === 'object'
        ? navModel.ui.pageHead
        : {};
const breadcrumb = Array.isArray(page?.breadcrumb) ? page.breadcrumb : [];
const hero = page?.hero && typeof page.hero === 'object' ? page.hero : {};
const focus = page?.focus && typeof page.focus === 'object' ? page.focus : {};
const modules = page?.modules && typeof page.modules === 'object' ? page.modules : {};
const journeys =
    page?.journeys && typeof page.journeys === 'object' ? page.journeys : {};
const surfaces =
    page?.surfaces && typeof page.surfaces === 'object' ? page.surfaces : {};
const nativeApps =
    page?.nativeApps && typeof page.nativeApps === 'object' ? page.nativeApps : {};
const integrations =
    page?.integrations && typeof page.integrations === 'object'
        ? page.integrations
        : {};
const pricing =
    page?.pricing && typeof page.pricing === 'object' ? page.pricing : {};
const security =
    page?.security && typeof page.security === 'object' ? page.security : {};
const faq = page?.faq && typeof page.faq === 'object' ? page.faq : {};
const finalCta =
    page?.finalCta && typeof page.finalCta === 'object' ? page.finalCta : {};
const switchLabel = navModel?.header?.switchLabel || '';
const switchHref = navModel?.header?.switchHref || '#';
const menuLabel = navModel?.header?.menuLabel || '';

const heroActions = Array.isArray(hero.actions) ? hero.actions : [];
const heroMetrics = Array.isArray(hero.metrics) ? hero.metrics : [];
const heroPanels = Array.isArray(hero.panels) ? hero.panels : [];
const focusCards = Array.isArray(focus.cards) ? focus.cards : [];
const moduleCards = Array.isArray(modules.cards) ? modules.cards : [];
const journeyLanes = Array.isArray(journeys.lanes) ? journeys.lanes : [];
const surfaceCards = Array.isArray(surfaces.cards) ? surfaces.cards : [];
const nativeAppCards = Array.isArray(nativeApps.cards) ? nativeApps.cards : [];
const integrationGroups = Array.isArray(integrations.groups)
    ? integrations.groups
    : [];
const pricingPlans = Array.isArray(pricing.plans) ? pricing.plans : [];
const securityCards = Array.isArray(security.cards) ? security.cards : [];
const faqItems = Array.isArray(faq.items) ? faq.items : [];
const finalActions = Array.isArray(finalCta.actions) ? finalCta.actions : [];
const finalLinks = Array.isArray(finalCta.links) ? finalCta.links : [];
const hasLandingProofLinks = finalLinks.length > 0;
const suiteStory =
    page?.suiteStory && typeof page.suiteStory === 'object' ? page.suiteStory : {};
const suiteStoryCurrent =
    suiteStory?.current && typeof suiteStory.current === 'object'
        ? suiteStory.current
        : null;
const suiteStoryNext =
    suiteStory?.next && typeof suiteStory.next === 'object' ? suiteStory.next : null;
const suiteStoryLabels =
    suiteStory?.labels && typeof suiteStory.labels === 'object'
        ? suiteStory.labels
        : {};
const hasSuiteStory = Boolean(
    suiteStoryCurrent &&
        suiteStoryCurrent.label &&
        (suiteStoryCurrent.deck || suiteStoryNext?.href)
);
const demoState =
    page?.demoState && typeof page.demoState === 'object' ? page.demoState : {};
const proof =
    demoState?.proof && typeof demoState.proof === 'object' ? demoState.proof : {};
const proofItems = Array.isArray(proof.items) ? proof.items : [];
const hasProof = Boolean((proof.title || proof.deck) && proofItems.length);
const demoStateJson = JSON.stringify(demoState);

const hasModules = Boolean(modules.title && moduleCards.length);
const hasJourneys = Boolean(journeys.title && journeyLanes.length);
const hasSurfaces = Boolean(surfaces.title && surfaceCards.length);
const hasNativeApps = Boolean(nativeApps.title && nativeAppCards.length);
const hasIntegrations = Boolean(integrations.title && integrationGroups.length);
const hasPricing = Boolean(pricing.title && pricingPlans.length);
const hasSecurity = Boolean(security.title && securityCards.length);
const hasFaq = Boolean(faq.title && faqItems.length);
const hasFinalCta = Boolean(finalCta.title || finalCta.deck || finalActions.length);
const hasFocus = Boolean((focus.title || focus.deck) && focusCards.length);

const leadModuleCard = moduleCards.find((card) => card?.featured) || moduleCards[0] || null;
const supportModuleCards = leadModuleCard
    ? moduleCards.filter((card) => card !== leadModuleCard)
    : [];

const sectionDefs = [
    hasJourneys ? { id: 'v6-suite-journeys', label: journeys.title } : null,
    hasModules ? { id: 'v6-suite-modules', label: modules.title } : null,
    hasSurfaces ? { id: 'v6-suite-surfaces', label: surfaces.title } : null,
    hasNativeApps ? { id: 'v6-suite-native-apps', label: nativeApps.title } : null,
    hasIntegrations
        ? { id: 'v6-suite-integrations', label: integrations.title }
        : null,
    hasPricing ? { id: 'v6-suite-pricing', label: pricing.title } : null,
    hasSecurity ? { id: 'v6-suite-security', label: security.title } : null,
    hasFaq ? { id: 'v6-suite-faq', label: faq.title } : null,
].filter((item) => item && item.label);

const menuItems = sectionDefs.map((item) => ({
    label: item.label,
    href: `#${item.id}`,
}));
const normalizeText = (value) =>
    typeof value === 'string' && value.trim().length ? value.trim() : '';
const normalizeHref = (value) => {
    const raw = normalizeText(value);
    return raw && raw !== '#' ? raw : '';
};
const normalizePath = (value) => {
    const raw = normalizeHref(value);
    if (!raw) return '';
    return raw.endsWith('/') ? raw : `${raw}/`;
};
const suiteMapItems = Array.isArray(page?.suiteMap)
    ? page.suiteMap
          .map((item) => {
              const href = normalizePath(item?.href);
              const label = normalizeText(item?.label);
              const pageKey = normalizeText(item?.pageKey);
              if (!href || !label || !pageKey) {
                  return null;
              }
              return {
                  href,
                  label,
                  eyebrow: normalizeText(item?.eyebrow),
                  deck: normalizeText(item?.deck),
                  index: normalizeText(item?.index),
                  isActive: pageKey === 'landing',
              };
          })
          .filter(Boolean)
    : [];
const resolveMockupKind = (mockup) => {
    const kind = normalizeText(mockup?.kind);
    return ['phone', 'status', 'dashboard'].includes(kind) ? kind : 'status';
};
const formatOrder = (value) => String(value).padStart(2, '0');

const actionClass = (variant = 'secondary') => [
    'v6-suite-action',
    variant === 'primary'
        ? 'is-primary'
        : variant === 'ghost'
            ? 'is-ghost'
            : 'is-secondary',
];
---

<PageHeadV6
    breadcrumb={breadcrumb}
    heading={page.heading}
    locale={locale}
    switchLabel={switchLabel}
    switchHref={switchHref}
    menuLabel={menuLabel}
    menuItems={menuItems}
    copy={pageHeadUi}
/>

<section class="v6-suite-hero">
    <div class="v6-suite-shell v6-suite-hero__shell">
        <div class="v6-suite-hero__copy">
            {hero.eyebrow ? <p class="v6-suite-eyebrow">{hero.eyebrow}</p> : null}
            {hero.title ? <h2>{hero.title}</h2> : null}
            {hero.deck ? <p class="v6-suite-lead">{hero.deck}</p> : null}

            {
                Array.isArray(hero.pills) && hero.pills.length ? (
                    <ul class="v6-suite-pills">
                        {hero.pills.map((pill) => <li>{pill}</li>)}
                    </ul>
                ) : null
            }

            {
                heroActions.length ? (
                    <div class="v6-suite-actions">
                        {heroActions.map((action) => (
                            <a class:list={actionClass(action.variant)} href={action.href} data-commercial-cta={action.commercialCta}>
                                {action.label}
                            </a>
                        ))}
                    </div>
                ) : null
            }
        </div>

        <div class="v6-suite-hero__stage">
            <div class="v6-suite-hero__board">
                {
                    heroMetrics.length ? (
                        <div class="v6-suite-metrics">
                            {heroMetrics.map((metric) => (
                                <article class="v6-suite-metric">
                                    {metric.status ? <span class="v6-suite-metric__status" data-v6-suite-status={metric.status}>{metric.status}</span> : null}
                                    <strong>{metric.value}</strong>
                                    <h3>{metric.label}</h3>
                                    {metric.detail ? <p>{metric.detail}</p> : null}
                                    {metric.capturedAt ? <time class="v6-suite-metric__time" datetime={metric.capturedAt}>VERIFIED • {metric.capturedAt.split('T')[0]}</time> : null}
                                </article>
                            ))}
                        </div>
                    ) : null
                }

                {
                    heroPanels.length ? (
                        <div class="v6-suite-panel-grid">
                            {heroPanels.map((panel) => (
                                <article class="v6-suite-panel">
                                    {panel.eyebrow ? <p>{panel.eyebrow}</p> : null}
                                    <h3>{panel.title}</h3>
                                    {panel.copy ? <span>{panel.copy}</span> : null}
                                </article>
                            ))}
                        </div>
                    ) : null
                }
            </div>
        </div>
    </div>
</section>

{
    hasProof ? (
        <section class="v6-suite-proof-band" data-v6-turnero-proof="landing">
            <div class="v6-suite-shell">
                <div class="v6-suite-proof">
                    <header class="v6-suite-proof__head">
                        {proof.eyebrow ? <p class="v6-suite-eyebrow">{proof.eyebrow}</p> : null}
                        {proof.title ? <h2>{proof.title}</h2> : null}
                        {proof.deck ? <span>{proof.deck}</span> : null}
                    </header>
                    <div class="v6-suite-proof__grid">
                        {proofItems.map((item) => (
                            <article class="v6-suite-proof__card" data-v6-turnero-proof-card={item.id}>
                                {item.status ? <span class="v6-suite-proof__status" data-v6-suite-status={item.status}>{item.status}</span> : null}
                                <p>{item.label}</p>
                                <strong>{item.value}</strong>
                                {item.detail ? <span>{item.detail}</span> : null}
                                {item.capturedAt ? <time class="v6-suite-proof__time" datetime={item.capturedAt}>VERIFIED • {item.capturedAt.split('T')[0]}</time> : null}
                            </article>
                        ))}
                    </div>
                    {
                        hasLandingProofLinks ? (
                            <div class="v6-suite-proof__spine">
                                <div class="v6-suite-proof__spine-head">
                                    <p class="v6-suite-eyebrow">
                                        {locale === 'es'
                                            ? 'Abrir piloto real'
                                            : 'Open the live pilot'}
                                    </p>
                                    <h3>
                                        {locale === 'es'
                                            ? 'Las cuatro superficies que convierten el deck en producto.'
                                            : 'The four surfaces that turn the deck into a real product.'}
                                    </h3>
                                    <span>
                                        {locale === 'es'
                                            ? 'Llegada, recepcion, consultorio y sala enlazadas como una sola prueba de compra.'
                                            : 'Arrival, reception, consult room, and room display linked as one buying proof.'}
                                    </span>
                                </div>
                                <div
                                    class="v6-suite-proof-links is-proof-band"
                                    data-v6-turnero-proof-links="landing"
                                >
                                    {finalLinks.map((link, index) => (
                                        <a
                                            class="v6-suite-proof-link"
                                            href={link.href}
                                            data-v6-turnero-presentation-link
                                            data-v6-turnero-presentation-link-order={formatOrder(index + 1)}
                                        >
                                            {link.eyebrow ? <span>{link.eyebrow}</span> : null}
                                            <strong>{link.label}</strong>
                                            {link.note ? <small>{link.note}</small> : null}
                                        </a>
                                    ))}
                                </div>
                            </div>
                        ) : null
                    }
                </div>
            </div>
        </section>
    ) : null
}

<script
    type="application/json"
    data-v6-turnero-demo-state="landing"
    set:html={demoStateJson}
></script>

{
    suiteMapItems.length ? (
        <section class="v6-suite-map-band" data-v6-suite-map="landing">
            <div class="v6-suite-shell">
                <div class="v6-suite-map">
                    {suiteMapItems.map((item) => (
                        <a
                            class:list={['v6-suite-map__item', item.isActive && 'is-active']}
                            href={item.href}
                            data-v6-suite-map-link
                            aria-current={item.isActive ? 'page' : undefined}
                        >
                            <span class="v6-suite-map__index">{item.index}</span>
                            {item.eyebrow ? <p>{item.eyebrow}</p> : null}
                            <strong>{item.label}</strong>
                            {item.deck ? <span>{item.deck}</span> : null}
                        </a>
                    ))}
                </div>
            </div>
        </section>
    ) : null
}

{
    menuItems.length ? (
        <div class="v6-suite-rail-shell" data-v6-suite-rail="landing">
            <div class="v6-suite-shell">
                <nav class="v6-suite-rail" data-v6-section-nav="software" aria-label={pageHeadUi.pageNavigationLabel || ''}>
                    {menuItems.map((item) => (
                        <a data-v6-section-link href={item.href}>{item.label}</a>
                    ))}
                </nav>
            </div>
        </div>
    ) : null
}

{
    hasJourneys ? (
        <section
            id="v6-suite-journeys"
            class="v6-suite-section is-muted is-storyboard"
            data-v6-suite-landing-section="storyboard"
            data-v6-suite-landing-section-order="01"
        >
            <div class="v6-suite-shell">
                <header class="v6-suite-section__head">
                    <div class="v6-suite-landing-tag" data-v6-suite-landing-tag>
                        <span>01</span>
                    </div>
                    {journeys.eyebrow ? <p>{journeys.eyebrow}</p> : null}
                    <h2>{journeys.title}</h2>
                    {journeys.deck ? <span>{journeys.deck}</span> : null}
                </header>

                <div class="v6-suite-grid v6-suite-grid--four v6-suite-storyboard">
                    {journeyLanes.map((lane, index) => (
                        <article
                            class:list={[
                                'v6-suite-lane',
                                'v6-suite-storyboard-lane',
                                index === 0 && 'is-priority',
                            ]}
                            data-v6-suite-journey-lane
                            data-v6-suite-storyboard-lane
                            data-v6-suite-journey-order={formatOrder(index + 1)}
                        >
                            <div class="v6-suite-lane__tag">
                                {lane.indexLabel || formatOrder(index + 1)}
                            </div>
                            {lane.eyebrow ? <p>{lane.eyebrow}</p> : null}
                            {lane.buyerLens ? (
                                <span class="v6-suite-storyboard-lane__lens">
                                    {lane.buyerLens}
                                </span>
                            ) : null}
                            <h3>{lane.title}</h3>
                            {lane.proofLabel ? (
                                <span class="v6-suite-storyboard-lane__proof">
                                    {lane.proofLabel}
                                </span>
                            ) : null}
                            <ol>
                                {lane.steps.map((step, stepIndex) => (
                                    <li>
                                        <span>{formatOrder(stepIndex + 1)}</span>
                                        <p>{step}</p>
                                    </li>
                                ))}
                            </ol>
                            {lane.href && lane.ctaLabel ? (
                                <a class="v6-suite-inline-link" href={lane.href}>
                                    {lane.ctaLabel}
                                    <span aria-hidden="true">></span>
                                </a>
                            ) : null}
                        </article>
                    ))}
                </div>
            </div>
        </section>
    ) : null
}

{
    hasModules ? (
        <section
            id="v6-suite-modules"
            class="v6-suite-section is-operations is-live-proof"
            data-v6-suite-landing-section="live-proof"
            data-v6-suite-landing-section-order="02"
        >
            <div class="v6-suite-shell">
                <header class="v6-suite-section__head">
                    <div class="v6-suite-landing-tag" data-v6-suite-landing-tag>
                        <span>02</span>
                    </div>
                    {modules.eyebrow ? <p>{modules.eyebrow}</p> : null}
                    <h2>{modules.title}</h2>
                    {modules.deck ? <span>{modules.deck}</span> : null}
                </header>

                <div class="v6-suite-ops-layout">
                    {
                        leadModuleCard ? (
                            <article
                                class:list={['v6-suite-card', 'v6-suite-module-feature']}
                                data-v6-suite-module-card
                                data-v6-suite-module-role="lead"
                                data-v6-suite-module-card-order="01"
                            >
                                {leadModuleCard.eyebrow ? <p>{leadModuleCard.eyebrow}</p> : null}
                                {leadModuleCard.lens ? (
                                    <span class="v6-suite-module-card__lens">
                                        {leadModuleCard.lens}
                                    </span>
                                ) : null}
                                <h3>{leadModuleCard.title}</h3>
                                {leadModuleCard.copy ? <span>{leadModuleCard.copy}</span> : null}
                                {leadModuleCard.meta ? (
                                    <strong class="v6-suite-module-card__meta">
                                        {leadModuleCard.meta}
                                    </strong>
                                ) : null}
                                {Array.isArray(leadModuleCard.bullets) &&
                                leadModuleCard.bullets.length ? (
                                    <ul>
                                        {leadModuleCard.bullets.map((bullet) => (
                                            <li>{bullet}</li>
                                        ))}
                                    </ul>
                                ) : null}
                                {leadModuleCard.href && leadModuleCard.ctaLabel ? (
                                    <a
                                        class="v6-suite-inline-link"
                                        href={leadModuleCard.href}
                                        data-v6-turnero-proof-link
                                    >
                                        {leadModuleCard.ctaLabel}
                                        <span aria-hidden="true">></span>
                                    </a>
                                ) : null}
                            </article>
                        ) : null
                    }

                    <div class="v6-suite-module-support">
                        {supportModuleCards.map((card, index) => (
                            <article
                                class:list={['v6-suite-card', 'v6-suite-card--support']}
                                data-v6-suite-module-card
                                data-v6-suite-module-role="support"
                                data-v6-suite-module-card-order={formatOrder(index + 2)}
                            >
                                {card.eyebrow ? <p>{card.eyebrow}</p> : null}
                                {card.lens ? (
                                    <span class="v6-suite-module-card__lens">
                                        {card.lens}
                                    </span>
                                ) : null}
                                <h3>{card.title}</h3>
                                {card.copy ? <span>{card.copy}</span> : null}
                                {card.meta ? (
                                    <strong class="v6-suite-module-card__meta">
                                        {card.meta}
                                    </strong>
                                ) : null}
                                {Array.isArray(card.bullets) && card.bullets.length ? (
                                    <ul>
                                        {card.bullets.map((bullet) => <li>{bullet}</li>)}
                                    </ul>
                                ) : null}
                                {card.href && card.ctaLabel ? (
                                    <a
                                        class="v6-suite-inline-link"
                                        href={card.href}
                                        data-v6-turnero-proof-link
                                    >
                                        {card.ctaLabel}
                                        <span aria-hidden="true">></span>
                                    </a>
                                ) : null}
                            </article>
                        ))}
                    </div>
                </div>
            </div>
        </section>
    ) : null
}

{
    hasSurfaces ? (
        <section
            id="v6-suite-surfaces"
            class="v6-suite-section"
            data-v6-suite-landing-section="public-proof"
            data-v6-suite-landing-section-order="03"
        >
            <div class="v6-suite-shell">
                <header class="v6-suite-section__head">
                    <div class="v6-suite-landing-tag" data-v6-suite-landing-tag>
                        <span>03</span>
                    </div>
                    {surfaces.eyebrow ? <p>{surfaces.eyebrow}</p> : null}
                    <h2>{surfaces.title}</h2>
                    {surfaces.deck ? <span>{surfaces.deck}</span> : null}
                </header>

                <div class="v6-suite-surface-grid">
                    {surfaceCards.map((card, index) => (
                        <article
                            class:list={[
                                'v6-suite-surface-card',
                                `is-${resolveMockupKind(card.mockup)}`,
                            ]}
                            data-v6-suite-surface-card
                            data-v6-suite-surface-kind={resolveMockupKind(card.mockup)}
                            data-v6-suite-card-index={index + 1}
                        >
                            <div class="v6-suite-surface-card__copy">
                                <div class="v6-suite-surface-card__tag">
                                    <span>{formatOrder(index + 1)}</span>
                                </div>
                                {card.eyebrow ? <p>{card.eyebrow}</p> : null}
                                <h3>{card.title}</h3>
                                {card.copy ? <span>{card.copy}</span> : null}
                                <a class="v6-suite-inline-link" href={card.href}>
                                    {card.ctaLabel}
                                    <span aria-hidden="true">></span>
                                </a>
                            </div>
                            <div class="v6-suite-surface-card__stage">
                                <SoftwareMockupV6 mockup={card.mockup} compact={true} />
                            </div>
                        </article>
                    ))}
                </div>
            </div>
        </section>
    ) : null
}

{
    hasFocus ? (
        <section class="v6-suite-focus-band" data-v6-suite-focus="landing">
            <div class="v6-suite-shell">
                <div class="v6-suite-focus">
                    <header class="v6-suite-section__head v6-suite-focus__head">
                        {focus.eyebrow ? <p>{focus.eyebrow}</p> : null}
                        {focus.title ? <h2>{focus.title}</h2> : null}
                        {focus.deck ? <span>{focus.deck}</span> : null}
                    </header>

                    <div class="v6-suite-focus__grid">
                        {focusCards.map((card, index) => (
                            <article
                                class:list={[
                                    'v6-suite-focus-card',
                                    card.highlight && 'is-highlight',
                                ]}
                                data-v6-suite-focus-card
                                data-v6-suite-focus-card-order={formatOrder(index + 1)}
                            >
                                <div class="v6-suite-focus-card__tag" aria-hidden="true">
                                    <span>{formatOrder(index + 1)}</span>
                                </div>
                                {card.eyebrow ? <p>{card.eyebrow}</p> : null}
                                <h3>{card.title}</h3>
                                {card.copy ? <span>{card.copy}</span> : null}
                                {Array.isArray(card.items) && card.items.length ? (
                                    <ul>
                                        {card.items.map((item) => <li>{item}</li>)}
                                    </ul>
                                ) : null}
                                {card.href && card.ctaLabel ? (
                                    <a class="v6-suite-inline-link" href={card.href}>
                                        {card.ctaLabel}
                                        <span aria-hidden="true">></span>
                                    </a>
                                ) : null}
                            </article>
                        ))}
                    </div>
                </div>
            </div>
        </section>
    ) : null
}

{
    hasNativeApps ? (
        <section
            id="v6-suite-native-apps"
            class="v6-suite-section"
            data-v6-suite-landing-section="native"
            data-v6-suite-landing-section-order="04"
        >
            <div class="v6-suite-shell">
                <header class="v6-suite-section__head">
                    <div class="v6-suite-landing-tag" data-v6-suite-landing-tag>
                        <span>04</span>
                    </div>
                    {nativeApps.eyebrow ? <p>{nativeApps.eyebrow}</p> : null}
                    <h2>{nativeApps.title}</h2>
                    {nativeApps.deck ? <span>{nativeApps.deck}</span> : null}
                </header>

                <div class="v6-suite-grid v6-suite-grid--three v6-suite-native-grid">
                    {nativeAppCards.map((card) => (
                        <article
                            class:list={['v6-suite-card', 'v6-suite-card--native']}
                            data-v6-suite-native-card
                            data-v6-suite-native-surface={card.surfaceId}
                        >
                            <div class="v6-suite-native-card__head">
                                {card.eyebrow ? <p>{card.eyebrow}</p> : null}
                                {card.targetSummary ? (
                                    <span class="v6-suite-native-card__target">
                                        {card.targetSummary}
                                    </span>
                                ) : null}
                            </div>
                            <h3>{card.title}</h3>
                            {card.readinessBadge ? (
                                <span class="v6-suite-badge v6-suite-badge--readiness" data-v6-suite-status={card.readinessBadge}>
                                    {card.readinessBadge}
                                </span>
                            ) : null}
                            {card.copy ? <span>{card.copy}</span> : null}
                            {Array.isArray(card.bullets) && card.bullets.length ? (
                                <ul>
                                    {card.bullets.map((bullet) => <li>{bullet}</li>)}
                                </ul>
                            ) : null}
                            <div class="v6-suite-actions v6-suite-actions--compact">
                                <a class:list={actionClass('primary')} href={card.guideHref}>
                                    {card.guideLabel}
                                </a>
                                {card.webHref ? (
                                    <a class:list={actionClass('ghost')} href={card.webHref}>
                                        {card.webLabel}
                                    </a>
                                ) : null}
                            </div>
                        </article>
                    ))}
                </div>
            </div>
        </section>
    ) : null
}

{
    hasIntegrations ? (
        <section id="v6-suite-integrations" class="v6-suite-section is-slate">
            <div class="v6-suite-shell">
                <header class="v6-suite-section__head">
                    {integrations.eyebrow ? <p>{integrations.eyebrow}</p> : null}
                    <h2>{integrations.title}</h2>
                    {integrations.deck ? <span>{integrations.deck}</span> : null}
                </header>

                <div class="v6-suite-grid v6-suite-grid--three">
                    {integrationGroups.map((group) => (
                        <article class="v6-suite-card v6-suite-card--dark">
                            <h3>{group.title}</h3>
                            <ul>
                                {group.items.map((item) => <li>{item}</li>)}
                            </ul>
                        </article>
                    ))}
                </div>
            </div>
        </section>
    ) : null
}

{
    hasPricing ? (
        <section id="v6-suite-pricing" class="v6-suite-section">
            <div class="v6-suite-shell">
                <header class="v6-suite-section__head">
                    {pricing.eyebrow ? <p>{pricing.eyebrow}</p> : null}
                    <h2>{pricing.title}</h2>
                    {pricing.deck ? <span>{pricing.deck}</span> : null}
                </header>

                <div class="v6-suite-grid v6-suite-grid--three">
                    {pricingPlans.map((plan) => (
                        <article class:list={['v6-suite-plan', plan.highlight && 'is-highlight']}>
                            <header>
                                <p>{plan.name}</p>
                                <h3>{plan.price}</h3>
                                {plan.note ? <span>{plan.note}</span> : null}
                            </header>
                            {plan.fit ? <p class="v6-suite-plan__fit">{plan.fit}</p> : null}
                            {plan.features.length ? (
                                <ul>
                                    {plan.features.map((feature) => <li>{feature}</li>)}
                                </ul>
                            ) : null}
                            <a class:list={actionClass(plan.highlight ? 'primary' : 'secondary')} href={plan.ctaHref} data-commercial-cta={plan.commercialCta}>
                                {plan.ctaLabel}
                            </a>
                        </article>
                    ))}
                </div>
            </div>
        </section>
    ) : null
}

{
    hasSecurity ? (
        <section id="v6-suite-security" class="v6-suite-section is-muted">
            <div class="v6-suite-shell">
                <header class="v6-suite-section__head">
                    {security.eyebrow ? <p>{security.eyebrow}</p> : null}
                    <h2>{security.title}</h2>
                    {security.deck ? <span>{security.deck}</span> : null}
                </header>

                <div class="v6-suite-grid v6-suite-grid--three">
                    {securityCards.map((card) => (
                        <article class="v6-suite-card">
                            <h3>{card.title}</h3>
                            <ul>
                                {card.items.map((item) => <li>{item}</li>)}
                            </ul>
                        </article>
                    ))}
                </div>
            </div>
        </section>
    ) : null
}

{
    hasFaq ? (
        <section id="v6-suite-faq" class="v6-suite-section">
            <div class="v6-suite-shell">
                <header class="v6-suite-section__head">
                    {faq.eyebrow ? <p>{faq.eyebrow}</p> : null}
                    <h2>{faq.title}</h2>
                </header>

                <div class="v6-suite-faq">
                    {faqItems.map((item, index) => (
                        <details class="v6-suite-faq__item" open={index === 0}>
                            <summary>{item.question}</summary>
                            <p>{item.answer}</p>
                        </details>
                    ))}
                </div>
            </div>
        </section>
    ) : null
}

{
    hasFinalCta ? (
        <section class="v6-suite-final is-commercial" data-v6-suite-landing-final="cta">
            <div class="v6-suite-shell v6-suite-final__shell">
                <div>
                    {finalCta.title ? <h2>{finalCta.title}</h2> : null}
                    {finalCta.deck ? <p>{finalCta.deck}</p> : null}
                </div>
                {
                    finalActions.length ? (
                        <div class="v6-suite-actions">
                            {finalActions.map((action) => (
                                <a class:list={actionClass(action.variant)} href={action.href} data-commercial-cta={action.commercialCta}>
                                    {action.label}
                                </a>
                            ))}
                        </div>
                    ) : null
                }
            </div>
        </section>
    ) : null
}
