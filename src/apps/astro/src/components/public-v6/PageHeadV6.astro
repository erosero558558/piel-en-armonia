---
const {
    breadcrumb = [],
    heading = '',
    locale = 'es',
    switchHref = '#',
    switchLabel = '',
    menuLabel = '',
    menuItems = [],
    copy = {},
} = Astro.props;

const crumbs = Array.isArray(breadcrumb) ? breadcrumb : [];
const activeLang = locale === 'en' ? 'EN' : 'ES';
const safeMenuItems = Array.isArray(menuItems)
    ? menuItems.filter((item) => item && item.href && item.label)
    : [];
const menuPanelId = 'v6-page-menu-panel';
const breadcrumbAria = copy.breadcrumbAria || '';
const languageSwitchAria = copy.languageSwitchAria || '';
const pageNavigationLabel = copy.pageNavigationLabel || '';
const pageNavigationTitle = copy.pageNavigationTitle || '';
const noSections = copy.noSections || '';
---

<section class="v6-corp-head" data-v6-page-head>
    <div class="v6-corp-head__inner">
        <div class="v6-corp-head__top">
            <nav class="v6-corp-head__crumbs" aria-label={breadcrumbAria}>
                {
                    crumbs.map((item, index) => (
                        <>
                            <a href={item.href}>{item.label}</a>
                            {index < crumbs.length - 1 ? <span aria-hidden="true">></span> : null}
                        </>
                    ))
                }
            </nav>
            <div class="v6-corp-head__tools" data-v6-page-tools>
                <div class="v6-corp-head__lang" aria-label={languageSwitchAria}>
                    {switchLabel ? (
                        <a class="v6-corp-head__lang-option" href={switchHref}>
                            {switchLabel}
                        </a>
                    ) : null}
                    <span aria-hidden="true">/</span>
                    <strong class="v6-corp-head__lang-option is-active">{activeLang}</strong>
                </div>
                <button
                    class="v6-corp-head__menu"
                    type="button"
                    data-v6-page-menu
                    aria-expanded="false"
                    aria-haspopup="true"
                    aria-controls={menuPanelId}
                >
                    {menuLabel}
                    <span class="v6-corp-head__menu-icon" aria-hidden="true">v</span>
                </button>
                <div
                    id={menuPanelId}
                    class="v6-corp-head__menu-panel"
                    data-v6-page-menu-panel
                    aria-label={pageNavigationLabel}
                    hidden
                >
                    <p>{pageNavigationTitle}</p>
                    {
                        safeMenuItems.length ? (
                            <ul>
                                {
                                    safeMenuItems.map((item) => (
                                        <li>
                                            <a data-v6-page-menu-link href={item.href}>{item.label}</a>
                                        </li>
                                    ))
                                }
                            </ul>
                        ) : (
                            <p class="v6-corp-head__menu-empty">
                                {noSections}
                            </p>
                        )
                    }
                </div>
            </div>
        </div>
        <h1>{heading}</h1>
    </div>
</section>
