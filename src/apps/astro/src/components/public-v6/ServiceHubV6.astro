---
import '../../styles/public-v6/hub.css';

import BookingStatusV6 from './BookingStatusV6.astro';
import PageHeadV6 from './PageHeadV6.astro';

const { page = {}, locale = 'es', navModel = {} } = Astro.props;
const breadcrumb = Array.isArray(page.breadcrumb) ? page.breadcrumb : [];
const sections = Array.isArray(page.sections) ? page.sections : [];
const featured = Array.isArray(page.featured) ? page.featured : [];
const initiatives = Array.isArray(page.initiatives) ? page.initiatives : [];
const ui = page?.ui && typeof page.ui === 'object' ? page.ui : {};
const menuUi = ui.menu && typeof ui.menu === 'object' ? ui.menu : {};
const featuredUi = ui.featured && typeof ui.featured === 'object' ? ui.featured : {};
const initiativesUi = ui.initiatives && typeof ui.initiatives === 'object' ? ui.initiatives : {};
const pageHeadUi = navModel?.ui?.pageHead && typeof navModel.ui.pageHead === 'object' ? navModel.ui.pageHead : {};
const hasText = (value) => typeof value === 'string' && value.trim().length > 0;
const normalizeText = (value) => (hasText(value) ? value.trim() : '');
const normalizeHref = (value) => {
    const raw = normalizeText(value);
    return raw && raw !== '#' ? raw : '';
};
const makeMenuItem = (label, href) => (hasText(label) ? { label: label.trim(), href } : null);
const normalizeCard = (item) => {
    const title = normalizeText(item?.title);
    const href = normalizeHref(item?.href);
    const image = normalizeText(item?.image);
    const srcset = normalizeText(item?.srcset);
    const alt = normalizeText(item?.alt) || title;
    const category = normalizeText(item?.category);
    const copy = normalizeText(item?.copy);
    return title && href && image
        ? { title, href, image, srcset, alt, category, copy }
        : null;
};
const safeFeatured = featured.map(normalizeCard).filter(Boolean);
const safeSections = sections
    .map((section, index) => {
        const id = normalizeText(section?.id) || `section-${index + 1}`;
        const title = normalizeText(section?.title);
        const deck = normalizeText(section?.deck);
        const cards = Array.isArray(section?.cards) ? section.cards.map(normalizeCard).filter(Boolean) : [];
        return title && cards.length ? { id, title, deck, cards } : null;
    })
    .filter(Boolean);
const safeInitiatives = initiatives.map(normalizeCard).filter(Boolean);
const sectionLinks = safeSections.map((section) => ({ id: section.id, title: section.title }));
const pageMenuItems = [];
if (safeFeatured.length) {
    const featuredItem = makeMenuItem(menuUi.featured || '', '#v6-hub-featured');
    if (featuredItem) {
        pageMenuItems.push(featuredItem);
    }
}
pageMenuItems.push(
    ...sectionLinks
        .map((section) => makeMenuItem(section.title, `#v6-${section.id}`))
        .filter(Boolean)
);
if (safeInitiatives.length) {
    const initiativesItem = makeMenuItem(menuUi.initiatives || '', '#v6-hub-initiatives');
    if (initiativesItem) {
        pageMenuItems.push(initiativesItem);
    }
}
const switchLabel = normalizeText(navModel?.header?.switchLabel);
const switchHref = normalizeHref(navModel?.header?.switchHref);
const menuLabel = normalizeText(navModel?.header?.menuLabel);
const ctaLabel = normalizeText(ui.ctaLabel);
const routeLabel = normalizeText(ui.routeLabel);
const sectionLabelPrefix = normalizeText(ui.sectionLabelPrefix);
const railAria = normalizeText(ui.railAria);
const heroImageSrc = normalizeText(page?.heroImage?.src);
const heroImageSrcSet = normalizeText(page?.heroImage?.srcset);
const heroImageAlt = normalizeText(page?.heroImage?.alt) || normalizeText(page.heading);
const introTitle = normalizeText(page.introTitle);
const introDeck = normalizeText(page.introDeck);
const totalRoutes = safeSections.reduce((total, section) => total + section.cards.length, 0);
const heroSummaryLabel = locale === 'en' ? 'Clinical map' : 'Mapa clinico';
const catalogCardSizes = '(max-width: 720px) 100vw, (max-width: 1100px) 50vw, 33vw';
const initiativeCardSizes = '(max-width: 720px) 100vw, (max-width: 1100px) 50vw, 28vw';
const hubStats = [
    {
        label: locale === 'en' ? 'Active routes' : 'Rutas activas',
        value: String(totalRoutes).padStart(2, '0'),
    },
    {
        label: locale === 'en' ? 'Clinical blocks' : 'Bloques clinicos',
        value: String(safeSections.length).padStart(2, '0'),
    },
    safeFeatured[0]
        ? {
              label: locale === 'en' ? 'Suggested start' : 'Entrada sugerida',
              value: safeFeatured[0].title,
          }
        : null,
].filter(Boolean);
---

<PageHeadV6
    breadcrumb={breadcrumb}
    heading={page.heading}
    locale={locale}
    switchLabel={switchLabel}
    switchHref={switchHref}
    menuLabel={menuLabel}
    menuItems={pageMenuItems}
    copy={pageHeadUi}
/>

{
    heroImageSrc ? (
        <section class="v6-page-hero-media v6-page-hero-media--hub">
            <div class="v6-hub-hero-shell">
                <figure class="v6-hub-hero-shell__media">
                    <img
                        src={heroImageSrc}
                        srcset={heroImageSrcSet || undefined}
                        sizes="100vw"
                        alt={heroImageAlt}
                        loading="eager"
                        decoding="sync"
                        fetchpriority="high"
                    />
                </figure>
                {
                    introTitle || introDeck || hubStats.length ? (
                        <div class="v6-hub-hero-shell__summary">
                            <p class="v6-hub-hero-shell__eyebrow">{heroSummaryLabel}</p>
                            {introTitle ? <h2>{introTitle}</h2> : null}
                            {introDeck ? <p>{introDeck}</p> : null}
                            {
                                hubStats.length ? (
                                    <div class="v6-hub-hero-shell__stats" aria-hidden="true">
                                        {
                                            hubStats.map((item) => (
                                                <article class="v6-hub-hero-shell__stat">
                                                    <span>{item.label}</span>
                                                    <strong>{item.value}</strong>
                                                </article>
                                            ))
                                        }
                                    </div>
                                ) : null
                            }
                        </div>
                    ) : null
                }
            </div>
        </section>
    ) : null
}

{
    (introTitle || introDeck) && !heroImageSrc ? (
        <section class="v6-page-intro">
            {introTitle ? <h2>{introTitle}</h2> : null}
            {introDeck ? <p>{introDeck}</p> : null}
        </section>
    ) : null
}

{
    safeFeatured.length ? (
        <section id="v6-hub-featured" class="v6-hub-featured" data-v6-hub-featured>
            <header class="v6-hub-featured__head">
                {featuredUi.eyebrow ? <p>{featuredUi.eyebrow}</p> : null}
                {featuredUi.title ? <h2>{featuredUi.title}</h2> : null}
            </header>
            <div class="v6-hub-featured__grid">
                {
                    safeFeatured.map((item, index) => (
                        <a class:list={['v6-catalog-card', 'v6-catalog-card--feature', index === 0 && 'is-lead']} href={item.href} data-v6-hub-featured-card>
                            <figure>
                                <img
                                    src={item.image}
                                    srcset={item.srcset || undefined}
                                    sizes={catalogCardSizes}
                                    alt={item.alt}
                                    loading="lazy"
                                    decoding="async"
                                    fetchpriority="low"
                                />
                            </figure>
                            <div class="v6-catalog-card__meta">
                                {item.category ? <p><span>{item.category}</span></p> : null}
                                <h3>{item.title}</h3>
                                {item.copy ? <p>{item.copy}</p> : null}
                                {ctaLabel ? (
                                    <strong>
                                        {ctaLabel}
                                        <span aria-hidden="true">></span>
                                    </strong>
                                ) : null}
                            </div>
                        </a>
                    ))
                }
            </div>
        </section>
    ) : null
}

{
    sectionLinks.length ? (
        <nav class="v6-catalog-rail" data-v6-catalog-rail data-v6-section-nav="catalog" aria-label={railAria || undefined}>
            {
                sectionLinks.map((section) => (
                    <a data-v6-section-link href={`#v6-${section.id}`}>{section.title}</a>
                ))
            }
        </nav>
    ) : null
}

<section class="v6-catalog-stream" data-v6-service-grid>
    {
        safeSections.map((section, sectionIndex) => (
            <article class="v6-catalog-block" id={`v6-${section.id}`} data-v6-catalog-block>
                <header class="v6-catalog-block__head">
                    <div>
                        {sectionLabelPrefix ? <p>{sectionLabelPrefix} {String(sectionIndex + 1).padStart(2, '0')}</p> : null}
                        <h2>{section.title}</h2>
                        {section.deck ? <span class="v6-catalog-block__deck">{section.deck}</span> : null}
                    </div>
                    <strong class="v6-catalog-block__count">
                        {String(section.cards.length).padStart(2, '0')}{routeLabel ? ` ${routeLabel}` : ''}
                    </strong>
                </header>
                <div class:list={['v6-catalog-grid', section.cards.length >= 4 && 'is-four']}>
                    {
                        section.cards.map((card, cardIndex) => (
                            <a
                                class:list={[
                                    'v6-catalog-card',
                                    `is-tone-${(sectionIndex % 3) + 1}`,
                                    cardIndex === 0 && 'is-lead',
                                ]}
                                href={card.href}
                                data-v6-catalog-card
                            >
                                <figure>
                                    <img
                                        src={card.image}
                                        srcset={card.srcset || undefined}
                                        sizes={catalogCardSizes}
                                        alt={card.alt}
                                        loading="lazy"
                                        decoding="async"
                                        fetchpriority="low"
                                    />
                                </figure>
                                <div class="v6-catalog-card__meta">
                                    {card.category ? <p><span>{card.category}</span></p> : null}
                                    <h3>{card.title}</h3>
                                    {card.copy ? <p>{card.copy}</p> : null}
                                    {ctaLabel ? (
                                        <strong>
                                            {ctaLabel}
                                            <span aria-hidden="true">></span>
                                        </strong>
                                    ) : null}
                                </div>
                            </a>
                        ))
                    }
                </div>
            </article>
        ))
    }
</section>

{
    safeInitiatives.length ? (
        <section id="v6-hub-initiatives" class="v6-hub-initiatives" data-v6-hub-initiatives>
            <header class="v6-hub-initiatives__head">
                {initiativesUi.eyebrow ? <p>{initiativesUi.eyebrow}</p> : null}
                {initiativesUi.title ? <h2>{initiativesUi.title}</h2> : null}
            </header>
            <div class="v6-hub-initiatives__grid">
                {
                    safeInitiatives.map((item) => (
                        <a href={item.href} data-v6-hub-initiative-card>
                            <figure>
                                <img
                                    src={item.image}
                                    srcset={item.srcset || undefined}
                                    sizes={initiativeCardSizes}
                                    alt={item.alt}
                                    loading="lazy"
                                    decoding="async"
                                    fetchpriority="low"
                                />
                            </figure>
                            <div>
                                {item.category ? <p><span>{item.category}</span></p> : null}
                                <h3>{item.title}</h3>
                                {item.copy ? <p>{item.copy}</p> : null}
                                {ctaLabel ? (
                                    <strong>
                                        {ctaLabel}
                                        <span aria-hidden="true">></span>
                                    </strong>
                                ) : null}
                            </div>
                        </a>
                    ))
                }
            </div>
        </section>
    ) : null
}

<BookingStatusV6 status={page.bookingStatus} locale={locale} sectionId="v6-booking-status" />

<style>
    .v6-page-hero-media--hub {
        background:
            radial-gradient(circle at top left, rgba(199, 163, 109, 0.2), transparent 28%),
            radial-gradient(circle at 82% 18%, rgba(146, 165, 187, 0.18), transparent 32%),
            linear-gradient(180deg, #05070b 0%, #0d1726 100%);
        padding: 24px clamp(18px, 3vw, 32px) 34px;
    }

    .v6-hub-hero-shell {
        max-width: 1480px;
        margin: 0 auto;
        position: relative;
    }

    .v6-hub-hero-shell__media {
        margin: 0;
        overflow: hidden;
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 30px 70px rgba(3, 8, 20, 0.34);
        background: rgba(6, 15, 28, 0.7);
    }

    .v6-hub-hero-shell__media img {
        display: block;
        width: 100%;
        height: clamp(360px, 44vw, 640px);
        object-fit: cover;
        object-position: center 36%;
    }

    .v6-hub-hero-shell__summary {
        position: absolute;
        right: clamp(20px, 4vw, 44px);
        bottom: clamp(20px, 4vw, 40px);
        width: min(380px, calc(100% - 40px));
        border-radius: 24px;
        background:
            radial-gradient(circle at top right, rgba(199, 163, 109, 0.16), transparent 34%),
            linear-gradient(180deg, rgba(10, 15, 22, 0.94), rgba(16, 24, 38, 0.96));
        border: 1px solid rgba(255, 255, 255, 0.12);
        box-shadow: 0 24px 52px rgba(4, 15, 34, 0.28);
        padding: clamp(20px, 2.2vw, 30px);
        display: grid;
        gap: 16px;
        backdrop-filter: blur(16px);
    }

    .v6-hub-hero-shell__eyebrow,
    .v6-hub-hero-shell__summary h2,
    .v6-hub-hero-shell__summary > p:last-of-type,
    .v6-hub-hero-shell__stat span,
    .v6-hub-hero-shell__stat strong {
        margin: 0;
    }

    .v6-hub-hero-shell__eyebrow {
        color: rgba(199, 163, 109, 0.88);
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 11px;
        font-weight: 700;
    }

    .v6-hub-hero-shell__summary h2 {
        color: #f4f7fb;
        font-size: clamp(34px, 3vw, 46px);
        line-height: 1.04;
        letter-spacing: -0.03em;
    }

    .v6-hub-hero-shell__summary > p:last-of-type {
        color: rgba(219, 227, 237, 0.76);
        font-size: clamp(16px, 1.18vw, 20px);
        line-height: 1.55;
    }

    .v6-hub-hero-shell__stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
    }

    .v6-hub-hero-shell__stat {
        min-height: 106px;
        border-radius: 18px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.05);
        padding: 14px 15px 16px;
        display: grid;
        align-content: start;
        gap: 8px;
    }

    .v6-hub-hero-shell__stat span {
        color: rgba(185, 197, 212, 0.72);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 10px;
        font-weight: 700;
    }

    .v6-hub-hero-shell__stat strong {
        color: #f4f7fb;
        font-size: clamp(20px, 1.85vw, 28px);
        line-height: 1.14;
        letter-spacing: -0.02em;
    }

    @media (max-width: 1100px) {
        .v6-hub-hero-shell__summary {
            width: min(360px, calc(100% - 32px));
        }

        .v6-hub-hero-shell__stats {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (max-width: 720px) {
        .v6-page-hero-media--hub {
            padding: 16px 16px 24px;
        }

        .v6-hub-hero-shell__media {
            border-radius: 18px;
        }

        .v6-hub-hero-shell__media img {
            height: 280px;
        }

        .v6-hub-hero-shell__summary {
            position: static;
            width: 100%;
            margin-top: 14px;
            border-radius: 20px;
            padding: 18px 16px;
            backdrop-filter: none;
        }

        .v6-hub-hero-shell__stats {
            grid-template-columns: 1fr;
        }
    }
</style>
