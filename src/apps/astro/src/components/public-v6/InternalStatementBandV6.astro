---
const {
    variant = 'service',
    statement = {},
} = Astro.props;

const safeStatement = statement && typeof statement === 'object' ? statement : {};
const eyebrow = safeStatement.eyebrow || '';
const title = safeStatement.title || '';
const body = safeStatement.body || '';
const signature = safeStatement.signature || '';
const image = safeStatement.image || '';
const alt = safeStatement.alt || '';
---

<section
    class:list={['v6-statement-band', `is-${variant}`]}
    data-v6-statement-band
    data-v6-statement-band-variant={variant}
>
    <figure class="v6-statement-band__media">
        <img src={image} alt={alt} loading="lazy" decoding="async" />
    </figure>
    <div class="v6-statement-band__content">
        <p>{eyebrow}</p>
        <h2>{title}</h2>
        <p>{body}</p>
        <strong>{signature}</strong>
    </div>
</section>
