---
import '../../styles/public-v6/internal.css';

import BookingStatusV6 from './BookingStatusV6.astro';
import InternalStatementBandV6 from './InternalStatementBandV6.astro';
import PageHeadV6 from './PageHeadV6.astro';

const {
    service = {},
    locale = 'es',
    navModel = {},
    servicePath = '#',
    hubPath = '#',
    related = [],
    ui = {},
} = Astro.props;

const pageHeadUi = navModel?.ui?.pageHead && typeof navModel.ui.pageHead === 'object' ? navModel.ui.pageHead : {};
const menuUi = ui?.menu && typeof ui.menu === 'object' ? ui.menu : {};
const breadcrumbUi = ui?.breadcrumb && typeof ui.breadcrumb === 'object' ? ui.breadcrumb : {};
const thesisUi = ui?.thesis && typeof ui.thesis === 'object' ? ui.thesis : {};
const statementUi = ui?.statement && typeof ui.statement === 'object' ? ui.statement : {};
const railUi = ui?.rail && typeof ui.rail === 'object' ? ui.rail : {};
const glanceUi = ui?.glance && typeof ui.glance === 'object' ? ui.glance : {};
const sectionsUi = ui?.sections && typeof ui.sections === 'object' ? ui.sections : {};
const bookingStatusUi =
    ui?.bookingStatus && typeof ui.bookingStatus === 'object'
        ? ui.bookingStatus
        : {};

const hasText = (value) => typeof value === 'string' && value.trim().length > 0;
const normalizeText = (value) => (hasText(value) ? value.trim() : '');
const normalizeHref = (value) => {
    const raw = normalizeText(value);
    return raw && raw !== '#' ? raw : '';
};
const makeMenuItem = (label, href) => (hasText(label) ? { label: label.trim(), href } : null);
const switchLabel = normalizeText(navModel?.header?.switchLabel);
const switchHref = normalizeHref(navModel?.header?.switchHref);
const menuLabel = normalizeText(navModel?.header?.menuLabel);
const serviceTitle = normalizeText(service.title);
const serviceCategory = normalizeText(service.category);
const serviceSummary = normalizeText(service.summary);
const serviceLead = normalizeText(service.lead);
const serviceHeroImage = normalizeText(service.heroImage);
const serviceHeroSrcset = normalizeText(service.heroImageSrcset);
const serviceHeroAlt = normalizeText(service.heroAlt) || serviceTitle;
const serviceStatementImage = normalizeText(service.statementImage);
const serviceStatementSrcset = normalizeText(service.statementImageSrcset);
const serviceStatementAlt = normalizeText(service.statementAlt);
const checkpoints = Array.isArray(service.bullets) ? service.bullets.map(normalizeText).filter(Boolean) : [];
const processSteps = Array.isArray(service.process) ? service.process.map(normalizeText).filter(Boolean) : [];
const faqItems = Array.isArray(service.faq) ? service.faq : [];
const faqAnswers = Array.isArray(service.faqAnswers) ? service.faqAnswers : [];
const faqModels = faqItems
    .map((question, index) => ({
        question: normalizeText(question),
        answer: normalizeText(faqAnswers[index]),
    }))
    .filter((item) => hasText(item.question) && hasText(item.answer));
const safeRelated = (Array.isArray(related) ? related : [])
    .map((item) => {
        const title = normalizeText(item?.title);
        const href = normalizeHref(item?.href);
        const heroImage = normalizeText(item?.cardImage || item?.heroImage);
        const heroSrcset = normalizeText(item?.cardImageSrcset || item?.heroImageSrcset);
        const heroAlt = normalizeText(item?.cardAlt) || title;
        const category = normalizeText(item?.category);
        const summary = normalizeText(item?.summary);
        return title && href && heroImage ? { title, href, heroImage, heroSrcset, heroAlt, category, summary } : null;
    })
    .filter(Boolean);
const hasGlance = Boolean(serviceCategory || checkpoints.length || processSteps.length);
const sectionMenuItems = [];
if (hasGlance) {
    const glanceItem = makeMenuItem(menuUi.glance || '', '#v6-service-glance');
    if (glanceItem) {
        sectionMenuItems.push(glanceItem);
    }
}
if (checkpoints.length) {
    const checkpointsItem = makeMenuItem(menuUi.checkpoints || '', '#v6-service-checkpoints');
    if (checkpointsItem) {
        sectionMenuItems.push(checkpointsItem);
    }
}
if (processSteps.length) {
    const processItem = makeMenuItem(menuUi.process || '', '#v6-service-process');
    if (processItem) {
        sectionMenuItems.push(processItem);
    }
}
if (faqModels.length) {
    const faqItem = makeMenuItem(menuUi.faq || '', '#v6-service-faq');
    if (faqItem) {
        sectionMenuItems.push(faqItem);
    }
}
const socialProof = service.socialProof && typeof service.socialProof === 'object' ? service.socialProof : null;
if (socialProof) {
    const socialProofItem = makeMenuItem(socialProof.title || '', '#v6-service-casos-clinicos');
    if (socialProofItem) {
        sectionMenuItems.push(socialProofItem);
    }
}
if (safeRelated.length) {
    const relatedItem = makeMenuItem(menuUi.related || '', '#v6-service-related');
    if (relatedItem) {
        sectionMenuItems.push(relatedItem);
    }
}
const bookingStatus = {
    eyebrow: normalizeText(bookingStatusUi.eyebrow),
    title: normalizeText(bookingStatusUi.title),
    description: normalizeText(bookingStatusUi.description),
    ctaLabel: normalizeText(bookingStatusUi.ctaLabel),
    ctaHref: normalizeHref(bookingStatusUi.ctaHref),
};
const hasBookingStatus = Boolean(
    bookingStatus.eyebrow ||
    bookingStatus.title ||
    bookingStatus.description ||
    (bookingStatus.ctaLabel && bookingStatus.ctaHref)
);
const bookingMenuItem = hasBookingStatus ? makeMenuItem(menuUi.booking || '', '#v6-booking-status') : null;
if (bookingMenuItem) {
    sectionMenuItems.push(bookingMenuItem);
}

const breadcrumb = [
    { label: normalizeText(breadcrumbUi.home), href: locale === 'en' ? '/en/' : '/es/' },
    { label: normalizeText(breadcrumbUi.hub), href: normalizeHref(hubPath) },
    { label: serviceTitle, href: normalizeHref(servicePath) },
];
const thesisEyebrow = normalizeText(thesisUi.eyebrow);
const thesisTitle = `${serviceTitle} ${normalizeText(thesisUi.titleSuffix)}`.trim();
const thesisBody = normalizeText(thesisUi.body);
const statementTitleTemplate = normalizeText(statementUi.titleTemplate) || '{service}';
const statement = {
    eyebrow: normalizeText(statementUi.eyebrow),
    title: statementTitleTemplate.replace('{service}', serviceTitle),
    body: serviceLead,
    signature: normalizeText(statementUi.signature),
    image: serviceStatementImage || normalizeText(statementUi.image),
    imageSrcset: serviceStatementSrcset || normalizeText(statementUi.imageSrcset || statementUi.srcset),
    alt: serviceStatementAlt || normalizeText(statementUi.alt),
};
const relatedCta = normalizeText(ui.relatedCta);
const faqPrefix = normalizeText(ui.faqPrefix);
const railTitle = normalizeText(railUi.title);
const railAria = normalizeText(railUi.aria);
const heroSummaryLabel = locale === 'en' ? 'Clinical route' : 'Ruta clinica';
const heroPanelTitle =
    locale === 'en' ? 'Clear route for this service' : 'Ruta clara para este servicio';
const heroJumpLabel = locale === 'en' ? 'Jump to' : 'Ir a';
const serviceInternalTitle =
    locale === 'en' ? 'What this route clarifies first' : 'Esto ordena primero';
const serviceInternalBody = [
    checkpoints[0]
        ? locale === 'en'
            ? `We usually start by clarifying ${checkpoints[0].toLowerCase()}.`
            : `Solemos empezar por aclarar ${checkpoints[0].toLowerCase()}.`
        : '',
    processSteps[0]
        ? locale === 'en'
            ? `The first move is ${processSteps[0].toLowerCase()}.`
            : `El primer movimiento suele ser ${processSteps[0].toLowerCase()}.`
        : '',
    locale === 'en'
        ? 'From there we adjust expectations, follow-up timing, and whether staying on this route still makes the best clinical sense.'
        : 'Desde ahi ajustamos expectativas, tiempos de control y si seguir en esta ruta sigue siendo la decision clinica mas clara.',
]
    .filter(Boolean)
    .join(' ');
const glanceCards = [
    normalizeText(glanceUi.routeType) && serviceCategory ? { label: normalizeText(glanceUi.routeType), value: serviceCategory } : null,
    normalizeText(glanceUi.checkpoints) ? { label: normalizeText(glanceUi.checkpoints), value: String(checkpoints.length) } : null,
    normalizeText(glanceUi.processStages) ? { label: normalizeText(glanceUi.processStages), value: String(processSteps.length) } : null,
].filter(Boolean);
const heroMenuItems = sectionMenuItems.slice(0, 3);
---

<PageHeadV6
    breadcrumb={breadcrumb}
    heading={serviceTitle}
    locale={locale}
    switchLabel={switchLabel}
    switchHref={switchHref}
    menuLabel={menuLabel}
    menuItems={sectionMenuItems}
    copy={pageHeadUi}
/>

{
    serviceHeroImage ? (
        <section class="v6-page-hero-media is-internal v6-page-hero-media--service" data-v6-internal-hero>
            <div class="v6-service-hero-shell">
                <figure class="v6-service-hero-shell__media">
                    <img
                        src={serviceHeroImage}
                        srcset={serviceHeroSrcset || undefined}
                        sizes="(max-width: 1100px) 100vw, 62vw"
                        alt={serviceHeroAlt}
                        loading="eager"
                        decoding="sync"
                        fetchpriority="high"
                    />
                </figure>
                <aside class="v6-service-hero-shell__panel">
                    <p class="v6-service-hero-shell__eyebrow">{heroSummaryLabel}</p>
                    <h2>{heroPanelTitle}</h2>
                    {serviceCategory ? <strong class="v6-service-hero-shell__category">{serviceCategory}</strong> : null}
                    {serviceSummary ? <p>{serviceSummary}</p> : null}
                    {
                        glanceCards.length ? (
                            <div class="v6-service-hero-shell__stats" aria-hidden="true">
                                {
                                    glanceCards.map((item) => (
                                        <article>
                                            <span>{item.label}</span>
                                            <strong>{item.value}</strong>
                                        </article>
                                    ))
                                }
                            </div>
                        ) : null
                    }
                    {
                        heroMenuItems.length ? (
                            <div class="v6-service-hero-shell__links">
                                <span>{heroJumpLabel}</span>
                                <div>
                                    {
                                        heroMenuItems.map((item) => (
                                            <a href={item.href}>{item.label}</a>
                                        ))
                                    }
                                </div>
                            </div>
                        ) : null
                    }
                </aside>
            </div>
        </section>
    ) : null
}

{
    serviceInternalTitle || serviceInternalBody ? (
        <section class="v6-internal-message" data-v6-internal-message>
            {serviceInternalTitle ? <h2>{serviceInternalTitle}</h2> : null}
            {serviceInternalBody ? <p>{serviceInternalBody}</p> : null}
        </section>
    ) : null
}

<InternalStatementBandV6 statement={statement} variant="service" />

{
    thesisEyebrow || thesisTitle || thesisBody ? (
        <section class="v6-internal-thesis" data-v6-internal-thesis>
            {thesisEyebrow ? <p>{thesisEyebrow}</p> : null}
            {thesisTitle ? <h2>{thesisTitle}</h2> : null}
            {thesisBody ? <p>{thesisBody}</p> : null}
        </section>
    ) : null
}

<div class="v6-internal-shell" data-v6-internal-shell>
    {
        sectionMenuItems.length || railTitle ? (
            <aside class="v6-internal-rail" data-v6-internal-rail>
                {railTitle ? <p>{railTitle}</p> : null}
                {
                    sectionMenuItems.length ? (
                        <nav data-v6-section-nav="internal" aria-label={railAria || undefined}>
                            {
                                sectionMenuItems.map((item) => (
                                    <a data-v6-section-link href={item.href}>{item.label}</a>
                                ))
                            }
                        </nav>
                    ) : null
                }
            </aside>
        ) : null
    }

    <div class="v6-internal-shell__body">
        {
            glanceCards.length ? (
                <section id="v6-service-glance" class="v6-service-glance v6-service-glance--shell">
                    {
                        glanceCards.map((item, index) => (
                            <article class:list={[index === 0 && 'is-lead']}>
                                <p class="v6-service-glance__index">{String(index + 1).padStart(2, '0')}</p>
                                <p class="v6-service-glance__label">{item.label}</p>
                                <h3>{item.value}</h3>
                            </article>
                        ))
                    }
                </section>
            ) : null
        }

        <section class="v6-service-detail v6-service-detail--shell">
            {
                checkpoints.length ? (
                    <article id="v6-service-checkpoints" class="v6-service-detail__column v6-service-detail__column--checkpoints">
                        <header class="v6-service-detail__head">
                            <p class="v6-service-detail__index">01</p>
                            {sectionsUi.checkpointsTitle ? <h3>{sectionsUi.checkpointsTitle}</h3> : null}
                        </header>
                        <ul class="v6-service-checklist">
                            {
                                checkpoints.map((item) => (
                                    <li>
                                        <span class="v6-service-checklist__dot" aria-hidden="true"></span>
                                        <p>{item}</p>
                                    </li>
                                ))
                            }
                        </ul>
                    </article>
                ) : null
            }

            {
                processSteps.length ? (
                    <article id="v6-service-process" class="v6-service-detail__column v6-service-detail__column--process">
                        <header class="v6-service-detail__head">
                            <p class="v6-service-detail__index">02</p>
                            {sectionsUi.processTitle ? <h3>{sectionsUi.processTitle}</h3> : null}
                        </header>
                        <ol class="v6-service-process">
                            {
                                processSteps.map((item, index) => (
                                    <li>
                                        <span>{String(index + 1).padStart(2, '0')}</span>
                                        <p>{item}</p>
                                    </li>
                                ))
                            }
                        </ol>
                    </article>
                ) : null
            }

            {
                faqModels.length ? (
                    <article id="v6-service-faq" class="v6-service-detail__column v6-service-detail__column--faq v6-service-detail__full">
                        <header class="v6-service-detail__head">
                            <p class="v6-service-detail__index">03</p>
                            {sectionsUi.faqTitle ? <h3>{sectionsUi.faqTitle}</h3> : null}
                        </header>
                        <div class="v6-service-faq-grid">
                            {
                                faqModels.map((item, index) => (
                                    <article class="v6-service-faq-card">
                                        {faqPrefix ? <p class="v6-service-faq-card__index">{`${faqPrefix}${index + 1}`}</p> : null}
                                        <h4>{item.question}</h4>
                                        <small>{item.answer}</small>
                                    </article>
                                ))
                            }
                        </div>
                    </article>
                ) : null
            }
        </section>

        {
            socialProof ? (
                <section id="v6-service-casos-clinicos" class="v6-service-detail v6-service-detail--shell">
                    <article class="v6-service-detail__column v6-service-detail__full">
                        <header class="v6-service-detail__head">
                            <p class="v6-service-detail__index">04</p>
                            <h3>{socialProof.title}</h3>
                        </header>
                        
                        <p style="margin-bottom: 24px; color: var(--pub-text-muted); font-size: var(--text-md);">{socialProof.intro}</p>

                        <div class="social-proof-widget">
                            <blockquote class="social-proof-quote">
                                "{socialProof.quote}"
                            </blockquote>
                            <div class="social-proof-meta">
                                <div class="social-proof-author">{socialProof.author}</div>
                                <div class="social-proof-service">{socialProof.serviceInfo}</div>
                            </div>
                            
                            <details class="social-proof-before-after">
                                <summary>{locale === 'en' ? 'View documented case (Images)' : 'Ver caso clínico documentado (Imágenes)'}</summary>
                                <div class="social-proof-images">
                                    <div class="image-box">
                                        <span>{socialProof.beforeLabel}</span>
                                        <div style="background-color: var(--pub-bg-surface); height: 260px; border-radius: var(--radius-md); display:flex; flex-direction: column; align-items:center; justify-content:center; border: 1px dashed var(--pub-border); color: var(--color-stone-400);">
                                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 8px;"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                                            <span style="display:block; font-size:var(--text-xs); margin-top:8px;">{locale === 'en' ? 'Photo Archive 01' : 'Archivo Fotográfico 01'}</span>
                                        </div>
                                    </div>
                                    <div class="image-box">
                                        <span>{socialProof.afterLabel}</span>
                                        <div style="background-color: var(--pub-bg-surface); height: 260px; border-radius: var(--radius-md); display:flex; flex-direction: column; align-items:center; justify-content:center; border: 1px dashed var(--pub-border); color: var(--color-stone-400);">
                                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 8px;"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                                            <span style="display:block; font-size:var(--text-xs); margin-top:8px;">{locale === 'en' ? 'Photo Archive 02' : 'Archivo Fotográfico 02'}</span>
                                        </div>
                                    </div>
                                </div>
                            </details>
                        </div>
                    </article>
                </section>
            ) : null
        }

        {
            safeRelated.length ? (
                <section id="v6-service-related" class="v6-related-grid v6-related-grid--shell">
                    {sectionsUi.relatedTitle ? <h2>{sectionsUi.relatedTitle}</h2> : null}
                    <div class="v6-related-grid__cards">
                        {
                            safeRelated.map((item, index) => (
                                <a href={item.href} class:list={[index === 0 && 'is-lead']}>
                                    <figure class="v6-related-grid__media">
                                        <img
                                            src={item.heroImage}
                                            srcset={item.heroSrcset || undefined}
                                            sizes="(max-width: 720px) 100vw, (max-width: 1100px) 50vw, 30vw"
                                            alt={item.heroAlt}
                                            loading="lazy"
                                            decoding="async"
                                            fetchpriority="low"
                                        />
                                    </figure>
                                    <div class="v6-related-grid__meta">
                                        <p class="v6-related-grid__index">{String(index + 1).padStart(2, '0')}</p>
                                        {item.category ? <p class="v6-related-grid__category">{item.category}</p> : null}
                                        <h3>{item.title}</h3>
                                        {item.summary ? <p class="v6-related-grid__summary">{item.summary}</p> : null}
                                        {relatedCta ? <strong>{relatedCta}</strong> : null}
                                    </div>
                                </a>
                            ))
                        }
                    </div>
                </section>
            ) : null
        }
    </div>
</div>

<BookingStatusV6
    status={bookingStatus}
    locale={locale}
    sectionId="v6-booking-status"
    serviceSlug={normalizeText(service.slug)}
    surface="service"
/>

<section
    class="v6-service-results-disclaimer"
    data-v6-service-results-disclaimer
    style="max-width:1260px;margin:18px auto 0;padding:0 clamp(16px,2vw,24px) 8px;color:rgba(219,227,237,.72);font-size:13px;line-height:1.55;text-align:center"
>
    <p style="margin:0">Los resultados var&iacute;an. Consulte a nuestro especialista.</p>
</section>

<style>
    .v6-page-hero-media--service {
        background:
            radial-gradient(circle at top left, rgba(199, 163, 109, 0.2), transparent 28%),
            radial-gradient(circle at 82% 18%, rgba(146, 165, 187, 0.14), transparent 30%),
            linear-gradient(180deg, #05070b 0%, #0d1726 100%);
        padding: 20px clamp(18px, 3vw, 28px) 8px;
    }

    .v6-service-hero-shell {
        max-width: 1320px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.65fr);
        gap: clamp(18px, 2vw, 26px);
        align-items: center;
    }

    .v6-service-hero-shell__media {
        margin: 0;
        overflow: hidden;
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: #121b28;
        box-shadow: 0 28px 58px rgba(8, 13, 20, 0.24);
    }

    .v6-service-hero-shell__media img {
        display: block;
        width: 100%;
        height: clamp(320px, 31vw, 470px);
        object-fit: cover;
        object-position: center;
    }

    .v6-service-hero-shell__panel {
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background:
            radial-gradient(circle at top right, rgba(199, 163, 109, 0.16), transparent 36%),
            linear-gradient(180deg, rgba(10, 15, 22, 0.96) 0%, rgba(16, 24, 38, 0.96) 100%);
        box-shadow: 0 24px 48px rgba(8, 13, 20, 0.24);
        padding: clamp(22px, 2.1vw, 30px);
        display: grid;
        gap: 14px;
    }

    .v6-service-hero-shell__eyebrow,
    .v6-service-hero-shell__panel h2,
    .v6-service-hero-shell__category,
    .v6-service-hero-shell__panel > p,
    .v6-service-hero-shell__stats span,
    .v6-service-hero-shell__stats strong,
    .v6-service-hero-shell__links span {
        margin: 0;
    }

    .v6-service-hero-shell__eyebrow,
    .v6-service-hero-shell__links span,
    .v6-service-hero-shell__stats span {
        color: rgba(199, 163, 109, 0.88);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 10px;
        font-weight: 700;
    }

    .v6-service-hero-shell__panel h2 {
        color: #f4f7fb;
        font-family: var(--v6-font-display);
        font-size: clamp(32px, 2.55vw, 42px);
        line-height: 1.04;
        letter-spacing: -0.04em;
    }

    .v6-service-hero-shell__category {
        color: rgba(185, 197, 212, 0.82);
        font-size: 13px;
        line-height: 1.4;
    }

    .v6-service-hero-shell__panel > p {
        color: rgba(219, 227, 237, 0.76);
        font-size: clamp(16px, 1.12vw, 19px);
        line-height: 1.55;
    }

    .v6-service-hero-shell__stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
    }

    .v6-service-hero-shell__stats article {
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.08);
        padding: 12px 13px 13px;
        display: grid;
        gap: 6px;
        min-height: 88px;
    }

    .v6-service-hero-shell__stats strong {
        color: #f4f7fb;
        font-size: clamp(17px, 1.45vw, 24px);
        line-height: 1.16;
    }

    .v6-service-hero-shell__links {
        display: grid;
        gap: 8px;
        padding-top: 2px;
    }

    .v6-service-hero-shell__links div {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .v6-service-hero-shell__links a {
        display: inline-flex;
        align-items: center;
        min-height: 34px;
        padding: 0 12px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.05);
        color: #f4f7fb;
        font-size: 13px;
        line-height: 1.3;
    }

    .v6-service-hero-shell__links a:hover,
    .v6-service-hero-shell__links a:focus-visible {
        border-color: rgba(199, 163, 109, 0.72);
        background: rgba(199, 163, 109, 0.12);
    }

    @media (max-width: 1100px) {
        .v6-service-hero-shell {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 720px) {
        .v6-page-hero-media--service {
            padding: 14px 16px 0;
        }

        .v6-service-hero-shell__media,
        .v6-service-hero-shell__panel {
            border-radius: 20px;
        }

        .v6-service-hero-shell__media img {
            height: 300px;
