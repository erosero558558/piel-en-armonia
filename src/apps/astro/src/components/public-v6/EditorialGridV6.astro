---
const { section = {} } = Astro.props;
const hasText = (value) => typeof value === 'string' && value.trim().length > 0;
const allowedSizes = new Set(['standard', 'wide', 'tall']);
const cards = (Array.isArray(section.cards) ? section.cards : [])
    .map((card) => {
        const size = hasText(card?.size) ? card.size.trim() : 'standard';
        const type = hasText(card?.type) ? card.type.trim() : 'info';
        return {
            href: hasText(card?.href) ? card.href.trim() : '',
            image: hasText(card?.image) ? card.image.trim() : '',
            srcset: hasText(card?.srcset) ? card.srcset.trim() : '',
            alt: hasText(card?.alt) ? card.alt.trim() : '',
            category: hasText(card?.category) ? card.category.trim() : '',
            title: hasText(card?.title) ? card.title.trim() : '',
            copy: hasText(card?.copy) ? card.copy.trim() : '',
            type: type === 'video' ? 'video' : 'info',
            size: allowedSizes.has(size) ? size : 'standard',
        };
    })
    .filter((card) => card.href && card.image && card.title && card.copy);
const eyebrow = hasText(section.eyebrow) ? section.eyebrow.trim() : '';
const title = hasText(section.title) ? section.title.trim() : '';
const deck = hasText(section.deck) ? section.deck.trim() : '';
const ctaLabel = hasText(section.ctaLabel) ? section.ctaLabel.trim() : '';
---

{
    cards.length ? (
        <section class="v6-editorial" data-v6-editorial>
            <div class="v6-editorial__head">
                {eyebrow ? <p>{eyebrow}</p> : null}
                {title ? <h2>{title}</h2> : null}
                {deck ? <p>{deck}</p> : null}
            </div>

            <div class="v6-editorial__grid">
                {
                    cards.map((card, index) => (
                        <article class:list={['v6-editorial__card', `is-${card.size}`, `is-slot-${index + 1}`, card.type === 'video' && 'is-video']}>
                            <a href={card.href}>
                                <figure>
                                    <img
                                        src={card.image}
                                        srcset={card.srcset || undefined}
                                        sizes="(max-width: 720px) 100vw, (max-width: 1100px) 50vw, 34vw"
                                        alt={card.alt || card.title}
                                        loading="lazy"
                                        decoding="async"
                                        fetchpriority="low"
                                    />
                                    {card.type === 'video' ? <span class="v6-editorial__play" aria-hidden="true">{'>'}</span> : null}
                                </figure>
                                <div class="v6-editorial__meta">
                                    <span class="v6-editorial__index">{String(index + 1).padStart(2, '0')}</span>
                                    {card.category ? <p>{card.category}</p> : null}
                                    <h3>{card.title}</h3>
                                    <p>{card.copy}</p>
                                    {
                                        ctaLabel ? (
                                            <span class="v6-editorial__cta">
                                                {ctaLabel}
                                                <strong aria-hidden="true">{'>'}</strong>
                                            </span>
                                        ) : null
                                    }
                                </div>
                            </a>
                        </article>
                    ))
                }
            </div>
        </section>
    ) : null
}
