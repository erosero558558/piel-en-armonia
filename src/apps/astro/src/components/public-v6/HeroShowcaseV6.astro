---
const { hero = {} } = Astro.props;
const hasText = (value) => typeof value === 'string' && value.trim().length > 0;
const normalizeText = (value) => (hasText(value) ? value.trim() : '');
const slides = (Array.isArray(hero.slides) ? hero.slides : [])
    .map((slide, index) => ({
        id: normalizeText(slide?.id) || `v6-hero-slide-${index + 1}`,
        category: normalizeText(slide?.category),
        title: normalizeText(slide?.title),
        description: normalizeText(slide?.description),
        image: normalizeText(slide?.image),
        srcset: normalizeText(slide?.srcset),
        alt: normalizeText(slide?.alt),
        href: normalizeText(slide?.href),
    }))
    .filter((slide) => slide.title && slide.description && slide.image && slide.href)
    .map((slide) => ({
        ...slide,
        alt: slide.alt || slide.title,
        imageKind: slide.image.includes('/v6-clinic-doctor-') ? 'portrait' : 'scene',
    }));
const autoplayMs = Number(hero.autoplayMs || 7000);
const safeAutoplay = Number.isFinite(autoplayMs) && autoplayMs > 1000 ? autoplayMs : 7000;
const first = slides[0] || null;
const labels = hero.labels && typeof hero.labels === 'object' ? hero.labels : {};
const badges = (Array.isArray(hero.badges) ? hero.badges : [])
    .map((badge, index) => ({
        id: normalizeText(badge?.id) || `v6-hero-badge-${index + 1}`,
        text: normalizeText(badge?.text),
    }))
    .filter((badge) => badge.text);
const safeLabels = {
    prev: normalizeText(labels.prev),
    next: normalizeText(labels.next),
    pause: normalizeText(labels.pause),
    play: normalizeText(labels.play),
    openRoute: normalizeText(labels.openRoute),
    indicators: normalizeText(labels.indicators),
    indicatorItemPrefix: normalizeText(labels.indicatorItemPrefix),
};
const indicatorPrefix = safeLabels.indicatorItemPrefix;
const hasHero = Boolean(
    first &&
        safeLabels.prev &&
        safeLabels.next &&
        safeLabels.pause &&
        safeLabels.play &&
        safeLabels.openRoute &&
        safeLabels.indicators
);
const totalSlides = String(slides.length).padStart(2, '0');

const buildIndicatorLabel = (slide, index) => {
    const base = [indicatorPrefix, String(index + 1)].filter(Boolean).join(' ');
    const descriptor = slide?.category || slide?.title || '';
    return descriptor ? `${base}: ${descriptor}` : base;
};
---

{
    hasHero ? (
        <section
            class="v6-hero"
            data-v6-hero
            data-v6-state="playing"
            data-v6-autoplay-ms={safeAutoplay}
            data-v6-progress-ms={safeAutoplay}
            data-v6-label-play={safeLabels.play}
            data-v6-label-pause={safeLabels.pause}
            tabindex="0"
        >
            <div class="v6-hero__viewport">
                <div class="v6-hero__stage">
                    {
                        slides.map((slide, index) => (
                            <article
                                class:list={['v6-hero__slide', `is-${slide.imageKind}`, index === 0 && 'is-active']}
                                data-v6-slide
                                data-v6-index={index}
                                data-v6-category={slide.category}
                                data-v6-title={slide.title}
                                data-v6-description={slide.description}
                            >
                                <img
                                    src={slide.image}
                                    srcset={slide.srcset || undefined}
                                    sizes="(max-width: 900px) 100vw, 32vw"
                                    alt={slide.alt}
                                    loading={index === 0 ? 'eager' : 'lazy'}
                                    decoding="async"
                                    fetchpriority={index === 0 ? 'high' : 'low'}
                                />
                                <a class="v6-hero__play" href={slide.href} aria-label={safeLabels.openRoute}>
                                    <span aria-hidden="true">{'>'}</span>
                                </a>
                                <div class="v6-hero__card-caption" aria-hidden="true">
                                    {slide.category ? <p>{slide.category}</p> : null}
                                    <h2>{slide.title}</h2>
                                    <span>{String(index + 1).padStart(2, '0')} / {totalSlides}</span>
                                </div>
                            </article>
                        ))
                    }
                </div>
            </div>

            <div class="v6-hero__band" aria-live="polite">
                <div class="v6-hero__band-shell">
                    <button type="button" class="v6-hero__nav v6-hero__nav--prev" data-v6-prev>
                        <span aria-hidden="true">{'<'}</span>
                        <span class="v6-hero__nav-label">{safeLabels.prev}</span>
                    </button>
                    <div class="v6-hero__center">
                        <div class="v6-hero__text">
                            <p data-v6-band-category>{first.category}</p>
                            <h1 data-v6-band-title>{first.title}</h1>
                            <p data-v6-band-description>{first.description}</p>
                        </div>
                        {
                            badges.length ? (
                                <div
                                    class="v6-hero__trust"
                                    data-v6-hero-badges
                                    data-v6-reveal
                                    data-v6-reveal-state="hidden"
                                >
                                    {
                                        badges.map((badge, index) => (
                                            <div
                                                class="v6-hero__trust-badge"
                                                data-v6-hero-badge
                                                data-v6-hero-badge-id={badge.id}
                                                style={`--v6-hero-badge-delay: ${index * 90}ms;`}
                                            >
                                                <span>{badge.text}</span>
                                            </div>
                                        ))
                                    }
                                </div>
                            ) : null
                        }
                        <div class="v6-hero__meta">
                            <div class="v6-hero__indicators" role="tablist" aria-label={safeLabels.indicators}>
                                {
                                    slides.map((slide, index) => (
                                        <button
                                            type="button"
                                            class:list={['v6-hero__indicator', index === 0 && 'is-active']}
                                            data-v6-indicator
                                            data-v6-target={index}
                                            role="tab"
                                            aria-selected={index === 0 ? 'true' : 'false'}
                                            aria-label={buildIndicatorLabel(slide, index)}
                                        >
                                            <span class="v6-hero__indicator-track" aria-hidden="true">
                                                <span class="v6-hero__indicator-fill" data-v6-indicator-fill></span>
                                            </span>
                                        </button>
                                    ))
                                }
                            </div>
                            <div class="v6-hero__controls">
                                <button type="button" data-v6-toggle aria-pressed="false">{safeLabels.pause}</button>
                            </div>
                        </div>
                    </div>
                    <button type="button" class="v6-hero__nav v6-hero__nav--next" data-v6-next>
                        <span aria-hidden="true">{'>'}</span>
                        <span class="v6-hero__nav-label">{safeLabels.next}</span>
                    </button>
                </div>
            </div>
        </section>
    ) : null
}

<style>
    .v6-hero__slide.is-scene img {
        object-position: center 34%;
    }

    .v6-hero__slide.is-portrait img {
        object-fit: contain;
        object-position: center top;
        padding: 26px 18px 0;
        background:
            radial-gradient(circle at top center, rgba(199, 163, 109, 0.2), transparent 34%),
            linear-gradient(180deg, rgba(18, 27, 40, 0.94), rgba(10, 15, 22, 0.96));
    }

    .v6-hero__card-caption {
        display: grid;
        gap: 6px;
    }

    .v6-hero__card-caption span {
        color: rgba(241, 245, 251, 0.74);
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 10px;
        font-weight: 700;
    }

    @media (max-width: 900px) {
        .v6-hero__slide.is-portrait img {
            padding: 18px 12px 0;
        }
    }
</style>
