---
const { navModel = {} } = Astro.props;

const hasText = (value) => typeof value === 'string' && value.trim().length > 0;
const locale = navModel?.locale === 'en' ? 'en' : 'es';
const header = navModel?.header && typeof navModel.header === 'object' ? navModel.header : {};
const mega = navModel?.mega && typeof navModel.mega === 'object' ? navModel.mega : {};
const brand = navModel?.brand && typeof navModel.brand === 'object' ? navModel.brand : {};
const headerUi = navModel?.ui?.header && typeof navModel.ui.header === 'object' ? navModel.ui.header : {};
const links = (Array.isArray(header.links) ? header.links : [])
    .map((item) => ({
        id: hasText(item?.id) ? item.id.trim() : '',
        label: hasText(item?.label) ? item.label.trim() : '',
        href: hasText(item?.href) ? item.href.trim() : '',
        kind: item?.kind === 'mega' ? 'mega' : 'standard',
    }))
    .filter((item) => item.label && item.href);

const normalizePath = (value) => {
    const raw = String(value || '').trim();
    if (!raw) return '/';
    const withLeading = raw.startsWith('/') ? raw : `/${raw}`;
    return withLeading.endsWith('/') ? withLeading : `${withLeading}/`;
};

const currentPath = normalizePath(navModel?.pathname || '/');
const homeHref = locale === 'en' ? '/en/' : '/es/';
const brandLogo = hasText(brand.logo) ? brand.logo.trim() : '';
const brandTag = hasText(brand.tag) ? brand.tag.trim() : '';

const isActive = (href) => {
    const target = normalizePath(href);
    if (target === '/es/' || target === '/en/' || target === '/') {
        return currentPath === target;
    }
    return currentPath === target || currentPath.startsWith(target);
};

const megaLink = links.find((item) => item.kind === 'mega') || null;
const standardLinks = links.filter((item) => item.kind !== 'mega');
const megaColumns = (Array.isArray(mega.columns) ? mega.columns : [])
    .map((column, index) => {
        const context = column?.context && typeof column.context === 'object' ? column.context : {};
        const items = (Array.isArray(column?.items) ? column.items : [])
            .map((item) => ({
                label: hasText(item?.label) ? item.label.trim() : '',
                href: hasText(item?.href) ? item.href.trim() : '',
                children: (Array.isArray(item?.children) ? item.children : [])
                    .map((child) => ({
                        label: hasText(child?.label) ? child.label.trim() : '',
                        href: hasText(child?.href) ? child.href.trim() : '',
                    }))
                    .filter((child) => child.label && child.href),
            }))
            .filter((item) => item.label && item.href);
        return {
            id: hasText(column?.id) ? column.id.trim() : `v6-mega-column-${index + 1}`,
            heading: hasText(column?.heading) ? column.heading.trim() : '',
            context: {
                eyebrow: hasText(context?.eyebrow) ? context.eyebrow.trim() : '',
                title: hasText(context?.title) ? context.title.trim() : '',
                deck: hasText(context?.deck) ? context.deck.trim() : '',
                href: hasText(context?.href) ? context.href.trim() : '',
            },
            items,
        };
    })
    .filter(
        (column) =>
            column.heading &&
            column.context.eyebrow &&
            column.context.title &&
            column.context.href &&
            column.items.length
    );
const megaPanelId = 'v6-mega-panel';
const searchPanelId = 'v6-search-panel';
const megaLabel = hasText(mega.title) ? mega.title.trim() : '';
const megaCloseLabel = hasText(mega.closeLabel) ? mega.closeLabel.trim() : '';
const megaRootHref = megaLink?.href || '';
const menuLabel = hasText(header.menuLabel) ? header.menuLabel.trim() : '';
const closeMenuLabel = hasText(header.closeMenuLabel) ? header.closeMenuLabel.trim() : '';
const searchLabel = hasText(header.searchLabel) ? header.searchLabel.trim() : '';
const contactLabel = hasText(header.contactLabel) ? header.contactLabel.trim() : '';
const contactHref = hasText(header.contactHref) ? header.contactHref.trim() : '';
const switchLabel = hasText(header.switchLabel) ? header.switchLabel.trim() : '';
const switchHref = hasText(header.switchHref) ? header.switchHref.trim() : '';
const primaryNavAria = hasText(headerUi.primaryNavAria) ? headerUi.primaryNavAria.trim() : '';
const megaCategoryTabsAria = hasText(headerUi.megaCategoryTabsAria) ? headerUi.megaCategoryTabsAria.trim() : '';
const openCategoryLabel = hasText(headerUi.openCategoryLabel) ? headerUi.openCategoryLabel.trim() : '';
const mobileNavAria = hasText(headerUi.mobileNavAria) ? headerUi.mobileNavAria.trim() : '';
const searchUi =
    headerUi?.search && typeof headerUi.search === 'object'
        ? headerUi.search
        : {};
const searchDialogAria = hasText(searchUi.dialogAria) ? searchUi.dialogAria.trim() : '';
const searchEyebrow = hasText(searchUi.eyebrow) ? searchUi.eyebrow.trim() : '';
const searchInputLabel = hasText(searchUi.inputLabel) ? searchUi.inputLabel.trim() : '';
const searchPlaceholder = hasText(searchUi.placeholder) ? searchUi.placeholder.trim() : '';
const searchHint = hasText(searchUi.hint) ? searchUi.hint.trim() : '';
const searchResultsAria = hasText(searchUi.resultsAria) ? searchUi.resultsAria.trim() : '';
const searchEmptyTitle = hasText(searchUi.emptyTitle) ? searchUi.emptyTitle.trim() : '';
const searchEmptyBody = hasText(searchUi.emptyBody) ? searchUi.emptyBody.trim() : '';
const searchCloseLabel = hasText(searchUi.closeLabel) ? searchUi.closeLabel.trim() : '';
const searchResultsLimit =
    Number.isFinite(Number(searchUi.resultsLimit)) && Number(searchUi.resultsLimit) > 0
        ? String(Math.max(1, Math.trunc(Number(searchUi.resultsLimit))))
        : '8';
const customSearchEntries = Array.isArray(header.searchEntries) ? header.searchEntries : [];
const searchEntries = [];
const searchKeys = new Set();

const addSearchEntry = (entry) => {
    if (!entry || typeof entry !== 'object') return;
    const label = hasText(entry.label) ? entry.label.trim() : '';
    const href = hasText(entry.href) ? entry.href.trim() : '';
    if (!label || !href) return;
    const key = href;
    if (searchKeys.has(key)) return;
    searchKeys.add(key);
    searchEntries.push({
        label,
        href,
        eyebrow: hasText(entry.eyebrow) ? entry.eyebrow.trim() : '',
        deck: hasText(entry.deck) ? entry.deck.trim() : '',
    });
};

customSearchEntries.forEach((entry) => addSearchEntry(entry));

const searchIndexJson = JSON.stringify(searchEntries);
const hasMega = Boolean(megaLink && megaLabel && megaCloseLabel && megaRootHref && megaColumns.length);
const hasSearch =
    Boolean(
        searchEntries.length &&
            searchLabel &&
            searchDialogAria &&
            searchInputLabel &&
            searchPlaceholder &&
            searchResultsAria &&
            searchEmptyTitle &&
            searchEmptyBody &&
            searchCloseLabel
    );
const hasContact = Boolean(contactLabel && contactHref);
const hasSwitch = Boolean(switchLabel && switchHref);
const hasDrawer = Boolean(menuLabel && (links.length || hasMega || hasSwitch || hasContact));
---

<header class="v6-header" data-v6-header>
    <div class="v6-header__bar">
        <a class="v6-header__logo" href={homeHref}>
            {brandLogo ? <span class="v6-header__logo-mark">{brandLogo}</span> : null}
            {brandTag ? <small class="v6-header__logo-tag">{brandTag}</small> : null}
        </a>

        <nav class="v6-header__nav" aria-label={primaryNavAria}>
            {
                standardLinks.slice(0, 1).map((link) => (
                    <a class:list={['v6-header__link', isActive(link.href) && 'is-active']} href={link.href}>{link.label}</a>
                ))
            }
            {
                hasMega ? (
                    <button
                        class:list={['v6-header__link', isActive(megaLink.href) && 'is-active']}
                        type="button"
                        data-v6-mega-trigger
                        aria-haspopup="true"
                        aria-expanded="false"
                        aria-controls={megaPanelId}
                    >
                        {megaLink.label}
                    </button>
                ) : null
            }
            {
                standardLinks.slice(1).map((link) => (
                    <a class:list={['v6-header__link', isActive(link.href) && 'is-active']} href={link.href}>{link.label}</a>
                ))
            }
        </nav>

        <div class="v6-header__actions">
            {hasContact ? <a class="v6-header__contact" href={contactHref} target="_blank" rel="noopener noreferrer">{contactLabel}</a> : null}
            {
                hasSearch ? (
                    <button
                        class="v6-header__search"
                        type="button"
                        data-v6-search-open
                        aria-label={searchLabel}
                        aria-haspopup="dialog"
                        aria-expanded="false"
                        aria-controls={searchPanelId}
                    >
                        <span aria-hidden="true">&#9906;</span>
                    </button>
                ) : null
            }
            {hasDrawer ? <button class="v6-header__menu" type="button" data-v6-drawer-open aria-label={menuLabel}>{menuLabel}</button> : null}
        </div>
    </div>

    {
        hasMega ? (
    <div id={megaPanelId} class="v6-mega" data-v6-mega hidden>
        <div class="v6-mega__shell">
            <div class="v6-mega__head">
                <a class="v6-mega__root" href={megaRootHref} data-v6-mega-focusable>
                    <span>{megaLabel}</span>
                    <span class="v6-mega__arrow" aria-hidden="true">&gt;</span>
                </a>
                <button type="button" data-v6-mega-close aria-label={megaCloseLabel}>&times;</button>
            </div>

            <div class="v6-mega__menu" data-v6-mega-layout>
                <nav
                    class="v6-mega__categories"
                    data-v6-mega-categories
                    aria-label={megaCategoryTabsAria}
                >
                    {
                        megaColumns.map((column, index) => {
                            const detailPanelId = `v6-mega-detail-${index + 1}`;
                            return (
                                <button
                                    class:list={['v6-mega__tab', index === 0 && 'is-active']}
                                    type="button"
                                    data-v6-mega-tab
                                    data-v6-mega-focusable
                                    data-v6-target={detailPanelId}
                                    aria-controls={detailPanelId}
                                    aria-selected={index === 0 ? 'true' : 'false'}
                                >
                                    <span>{column.heading}</span>
                                    <span class="v6-mega__arrow" aria-hidden="true">&gt;</span>
                                </button>
                            );
                        })
                    }
                </nav>

                <div class="v6-mega__details" data-v6-mega-details>
                    {
                        megaColumns.map((column, index) => {
                            const context = column.context;
                            const sectionHref = context.href;
                            const detailPanelId = `v6-mega-detail-${index + 1}`;
                            return (
                                <section
                                    id={detailPanelId}
                                    class:list={['v6-mega__section', 'v6-mega__detail', index === 0 && 'is-active']}
                                    data-v6-mega-section
                                    data-v6-mega-detail
                                    data-v6-column-id={column.id || detailPanelId}
                                    hidden={index !== 0}
                                >
                                    <a class="v6-mega__context" href={sectionHref} data-v6-mega-focusable>
                                        <p>{context.eyebrow}</p>
                                        <h3>{context.title}</h3>
                                        {context.deck ? <p>{context.deck}</p> : null}
                                        {
                                            openCategoryLabel ? (
                                                <strong>
                                                    {openCategoryLabel}
                                                    <span aria-hidden="true">&gt;</span>
                                                </strong>
                                            ) : null
                                        }
                                    </a>

                                    <ul class="v6-mega__items">
                                        {(column.items || []).map((item) => (
                                            <li>
                                                <a href={item.href} data-v6-mega-focusable>
                                                    <span>{item.label}</span>
                                                    <span class="v6-mega__arrow" aria-hidden="true">&gt;</span>
                                                </a>
                                                {
                                                    Array.isArray(item.children) && item.children.length ? (
                                                        <ul class="v6-mega__subitems">
                                                            {item.children.map((child) => (
                                                                <li>
                                                                    <a href={child.href} data-v6-mega-focusable>
                                                                        <span class="v6-mega__branch" aria-hidden="true">L</span>
                                                                        <span>{child.label}</span>
                                                                    </a>
                                                                </li>
                                                            ))}
                                                        </ul>
                                                    ) : null
                                                }
                                            </li>
                                        ))}
                                    </ul>
                                </section>
                            );
                        })
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="v6-mega-backdrop" data-v6-mega-backdrop hidden></div>
        ) : null
    }

    {
        hasDrawer ? (
    <div class="v6-drawer" data-v6-drawer hidden>
        <div class="v6-drawer__scrim" data-v6-drawer-close></div>
        <aside class="v6-drawer__panel" aria-label={mobileNavAria}>
            <header>
                {brandLogo ? <strong>{brandLogo}</strong> : null}
                {closeMenuLabel ? <button type="button" data-v6-drawer-close>{closeMenuLabel}</button> : null}
            </header>
            <nav>
                {
                    links.map((link) => (
                        <a href={link.href}>
                            <span>{link.label}</span>
                            <span aria-hidden="true">&gt;</span>
                        </a>
                    ))
                }
            </nav>
            {
                hasMega ? (
            <section class="v6-drawer__mega">
                <h3>{megaLabel}</h3>
                {
                    megaColumns.map((column, index) => (
                        <article class="v6-drawer__group">
                            <button
                                type="button"
                                class:list={['v6-drawer__group-toggle', index === 0 && 'is-active']}
                                data-v6-drawer-group-toggle
                                data-v6-target={`v6-drawer-group-${index + 1}`}
                                aria-controls={`v6-drawer-group-${index + 1}`}
                                aria-expanded={index === 0 ? 'true' : 'false'}
                            >
                                <span>{column.heading}</span>
                                <span aria-hidden="true">+</span>
                            </button>
                            <div id={`v6-drawer-group-${index + 1}`} data-v6-drawer-group-panel hidden={index !== 0}>
                                <ul>
                                    {(column.items || []).map((item) => (
                                        <li>
                                            <a href={item.href}>
                                                <span>{item.label}</span>
                                                <span aria-hidden="true">&gt;</span>
                                            </a>
                                            {
                                                Array.isArray(item.children) && item.children.length ? (
                                                    <ul class="v6-drawer__subitems">
                                                        {item.children.map((child) => <li><a href={child.href}>{child.label}</a></li>)}
                                                    </ul>
                                                ) : null
                                            }
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        </article>
                    ))
                }
            </section>
                ) : null
            }
            <footer>
                {hasSwitch ? <a href={switchHref}>{switchLabel}</a> : null}
                {hasContact ? <a href={contactHref} target="_blank" rel="noopener noreferrer">{contactLabel}</a> : null}
            </footer>
        </aside>
    </div>
        ) : null
    }

    {
        hasSearch ? (
    <div
        id={searchPanelId}
        class="v6-search"
        data-v6-search
        data-v6-search-index={searchIndexJson}
        data-v6-search-empty-title={searchEmptyTitle}
        data-v6-search-empty-body={searchEmptyBody}
        data-v6-search-results-limit={searchResultsLimit}
        hidden
    >
        <div class="v6-search__scrim" data-v6-search-close></div>
        <section class="v6-search__dialog" role="dialog" aria-modal="true" aria-label={searchDialogAria}>
            <div class="v6-search__head">
                <div class="v6-search__intro">
                    {searchEyebrow ? <p>{searchEyebrow}</p> : null}
                    <h2>{searchLabel}</h2>
                </div>
                <button type="button" data-v6-search-close aria-label={searchCloseLabel}>&times;</button>
            </div>

            <label class="v6-search__field">
                <span>{searchInputLabel}</span>
                <input
                    type="search"
                    data-v6-search-input
                    placeholder={searchPlaceholder}
                    autocomplete="off"
                    spellcheck="false"
                />
            </label>

            {searchHint ? <p class="v6-search__hint">{searchHint}</p> : null}

            <ul class="v6-search__results" data-v6-search-results aria-label={searchResultsAria}></ul>
        </section>
    </div>
        ) : null
    }
</header>
