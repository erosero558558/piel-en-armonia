---
const { navModel = {} } = Astro.props;

const hasText = (value) => typeof value === 'string' && value.trim().length > 0;
const locale = navModel?.locale === 'en' ? 'en' : 'es';
const brand = navModel?.brand && typeof navModel.brand === 'object' ? navModel.brand : {};
const brandLogo = hasText(brand.logo) ? brand.logo.trim() : 'Aurora Derm';

const homeHref = locale === 'en' ? '/en/' : '/es/';
---

<header class="reborn-navbar-pill" data-v6-header>
    <a class="reborn-navbar-pill__logo" href={homeHref}>
        <span aria-label={brandLogo}>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2L2 22H22L12 2Z" fill="currentColor"/>
            </svg>
        </span>
    </a>

    <div class="reborn-navbar-pill__actions">
        <a class="reborn-navbar-pill__cta" href="/portal/agendar">Agendar</a>
        <button class="reborn-navbar-pill__burger" type="button" aria-label="Menu" data-v6-drawer-open="true">
            <svg viewBox="0 0 24 24">
                <path d="M4 8H20M4 16H20" />
            </svg>
        </button>
    </div>

    <div class="v6-drawer" data-v6-drawer hidden>
        <div class="v6-drawer__scrim" data-v6-drawer-close></div>
        <aside class="v6-drawer__panel" data-v6-drawer-panel>
            <nav class="v6-drawer__nav">
                <a href={homeHref} data-v6-drawer-focusable>Inicio</a>
                <a href="/portal/agendar" data-v6-drawer-focusable>Agendar</a>
            </nav>
            <button type="button" data-v6-drawer-close data-v6-drawer-focusable aria-label="Close menu">Cerrar</button>
        </aside>
    </div>
</header>
