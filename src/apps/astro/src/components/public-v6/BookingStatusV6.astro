---
const { status = {}, sectionId = '' } = Astro.props;
const eyebrow = status.eyebrow || '';
const title = status.title || '';
const description = status.description || '';
const ctaLabel = status.ctaLabel || '';
const ctaHref = status.ctaHref || '#';
---

<section id={sectionId || undefined} class="v6-booking-status" data-v6-booking-status>
    <p>{eyebrow}</p>
    <h2>{title}</h2>
    <p>{description}</p>
    <a href={ctaHref}>{ctaLabel}</a>
</section>
