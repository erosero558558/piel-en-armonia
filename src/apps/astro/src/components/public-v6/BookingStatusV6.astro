---
import '../../styles/public-v6/booking-status.css';
import { resolveBookingStatus } from '../../lib/public-v6-booking-status.js';

const {
    status = {},
    locale = 'es',
    sectionId = '',
    serviceSlug = '',
    surface = 'generic',
} = Astro.props;
const hasText = (value) => typeof value === 'string' && value.trim().length > 0;
const resolvedStatus = resolveBookingStatus(status, { locale, surface, serviceSlug });
const eyebrow = hasText(resolvedStatus.eyebrow) ? resolvedStatus.eyebrow.trim() : '';
const title = hasText(resolvedStatus.title) ? resolvedStatus.title.trim() : '';
const description = hasText(resolvedStatus.description) ? resolvedStatus.description.trim() : '';
const ctaLabel = hasText(resolvedStatus.ctaLabel) ? resolvedStatus.ctaLabel.trim() : '';
const ctaHref = hasText(resolvedStatus.ctaHref) ? resolvedStatus.ctaHref.trim() : '';
const hasSection = Boolean(eyebrow || title || description || (ctaLabel && ctaHref));
---

{
    hasSection ? (
        <section id={sectionId || undefined} class="v6-booking-status" data-v6-booking-status>
            <div class="v6-booking-status__shell">
                <div class="v6-booking-status__copy">
                    {(eyebrow || title) ? (
                        <div class="v6-booking-status__head">
                            <span class="v6-booking-status__signal" aria-hidden="true"></span>
                            <div class="v6-booking-status__title-group">
                                {eyebrow ? <p class="v6-booking-status__eyebrow">{eyebrow}</p> : null}
                                {title ? <h2>{title}</h2> : null}
                            </div>
                        </div>
                    ) : null}
                    {description ? <p class="v6-booking-status__description">{description}</p> : null}
                </div>

                {
                    ctaLabel && ctaHref ? (
                        <div class="v6-booking-status__actions">
                            <a href={ctaHref}>
                                <span>{ctaLabel}</span>
                                <span aria-hidden="true">></span>
                            </a>
                        </div>
                    ) : null
                }
            </div>
        </section>
    ) : null
}
