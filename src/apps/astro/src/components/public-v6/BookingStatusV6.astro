---
const { status = {}, sectionId = '' } = Astro.props;
const hasText = (value) => typeof value === 'string' && value.trim().length > 0;
const eyebrow = hasText(status.eyebrow) ? status.eyebrow.trim() : '';
const title = hasText(status.title) ? status.title.trim() : '';
const description = hasText(status.description) ? status.description.trim() : '';
const ctaLabel = hasText(status.ctaLabel) ? status.ctaLabel.trim() : '';
const ctaHref = hasText(status.ctaHref) ? status.ctaHref.trim() : '';
const hasSection = Boolean(eyebrow || title || description || (ctaLabel && ctaHref));
---

{
    hasSection ? (
        <section id={sectionId || undefined} class="v6-booking-status" data-v6-booking-status>
            {eyebrow ? <p>{eyebrow}</p> : null}
            {title ? <h2>{title}</h2> : null}
            {description ? <p>{description}</p> : null}
            {ctaLabel && ctaHref ? <a href={ctaHref}>{ctaLabel}</a> : null}
        </section>
    ) : null
}
