---
import '../../styles/public-v6/preconsultation.css';

import BookingStatusV6 from './BookingStatusV6.astro';
import PageHeadV6 from './PageHeadV6.astro';

const { page = {}, locale = 'es', navModel = {} } = Astro.props;

const hasText = (value) => typeof value === 'string' && value.trim().length > 0;
const normalizeText = (value) => (hasText(value) ? value.trim() : '');
const normalizeHref = (value) => {
    const raw = normalizeText(value);
    return raw && raw !== '#' ? raw : '';
};
const makeMenuItem = (label, href) => {
    const safeLabel = normalizeText(label);
    const safeHref = normalizeHref(href);
    return safeLabel && safeHref ? { label: safeLabel, href: safeHref } : null;
};

const pageHeadUi = navModel?.ui?.pageHead && typeof navModel.ui.pageHead === 'object' ? navModel.ui.pageHead : {};
const breadcrumb = Array.isArray(page?.breadcrumb) ? page.breadcrumb : [];
const sections = Array.isArray(page?.sections) ? page.sections : [];
const pageMenuItems = sections.map((item) => makeMenuItem(item?.label, item?.href)).filter(Boolean);
const hero = page?.hero && typeof page.hero === 'object' ? page.hero : {};
const reasons = Array.isArray(page?.reasons) ? page.reasons : [];
const checklists = Array.isArray(page?.checklists) ? page.checklists : [];
const form = page?.form && typeof page.form === 'object' ? page.form : {};
const response = page?.response && typeof page.response === 'object' ? page.response : {};
const responseSteps = Array.isArray(response?.steps) ? response.steps : [];
const support = page?.support && typeof page.support === 'object' ? page.support : {};
const supportStatus = {
    eyebrow: normalizeText(support.eyebrow),
    title: normalizeText(support.title),
    description: normalizeText(support.description),
    ctaLabel: normalizeText(support.ctaLabel),
    ctaHref: normalizeHref(support.ctaHref),
};
---

<PageHeadV6
    breadcrumb={breadcrumb}
    heading={page.heading}
    locale={locale}
    switchLabel=""
    switchHref=""
    menuLabel={page.menuLabel}
    menuItems={pageMenuItems}
    copy={pageHeadUi}
/>

<section class="v6-pre-hero" data-v6-pre-hero>
    <div class="v6-pre-hero__shell">
        <div class="v6-pre-hero__copy">
            {normalizeText(hero.eyebrow) ? <p class="v6-pre-hero__eyebrow">{hero.eyebrow}</p> : null}
            {normalizeText(hero.title) ? <h2>{hero.title}</h2> : null}
            {normalizeText(hero.body) ? <p class="v6-pre-hero__body">{hero.body}</p> : null}
            {
                Array.isArray(hero?.highlights) && hero.highlights.length ? (
                    <div class="v6-pre-hero__highlights" aria-hidden="true">
                        {
                            hero.highlights.map((item) => (
                                <article class="v6-pre-hero__metric">
                                    <span>{normalizeText(item?.label)}</span>
                                    <strong>{normalizeText(item?.value)}</strong>
                                </article>
                            ))
                        }
                    </div>
                ) : null
            }
        </div>

        <aside class="v6-pre-hero__panel">
            {normalizeText(hero.panelEyebrow) ? <p>{hero.panelEyebrow}</p> : null}
            {normalizeText(hero.panelTitle) ? <h3>{hero.panelTitle}</h3> : null}
            {
                Array.isArray(hero?.panelItems) && hero.panelItems.length ? (
                    <ul>
                        {
                            hero.panelItems.map((item) => (
                                <li>{normalizeText(item)}</li>
                            ))
                        }
                    </ul>
                ) : null
            }
            {normalizeText(hero.panelCtaLabel) ? <a href="#v6-pre-form">{hero.panelCtaLabel}</a> : null}
        </aside>
    </div>
</section>

{
    reasons.length ? (
        <section id="v6-pre-why" class="v6-pre-reasons" data-v6-pre-reasons>
            <div class="v6-pre-reasons__head">
                <p>Cuando conviene usar esta ruta</p>
                <h2>No es un chatbot ni un formulario de marketing.</h2>
                <p>
                    Es una entrada clinica para que el equipo humano reciba el caso con mejor contexto y menos ida y vuelta.
                </p>
            </div>
            <div class="v6-pre-reasons__grid">
                {
                    reasons.map((item) => (
                        <article class="v6-pre-reasons__card">
                            <p>{normalizeText(item?.eyebrow)}</p>
                            <h3>{normalizeText(item?.title)}</h3>
                            <p>{normalizeText(item?.copy)}</p>
                        </article>
                    ))
                }
            </div>
        </section>
    ) : null
}

<div class="v6-pre-shell">
    {
        checklists.length ? (
            <section id="v6-pre-checklist" class="v6-pre-checklists" data-v6-pre-checklists>
                <div class="v6-pre-checklists__head">
                    <p>Checklist rapido</p>
                    <h2>Prepare solo lo que cambia la respuesta.</h2>
                </div>
                <div class="v6-pre-checklists__grid">
                    {
                        checklists.map((group) => (
                            <article class="v6-pre-checklists__card">
                                <h3>{normalizeText(group?.title)}</h3>
                                <ul>
                                    {
                                        Array.isArray(group?.items)
                                            ? group.items.map((item) => <li>{normalizeText(item)}</li>)
                                            : null
                                    }
                                </ul>
                            </article>
                        ))
                    }
                </div>
            </section>
        ) : null
    }

    <section
        id="v6-pre-form"
        class="v6-pre-form-section"
        data-v6-pre-form-root
        data-upload-url="/api.php?resource=transfer-proof"
        data-submit-url="/api.php?resource=patient-cases"
        data-max-files="3"
        data-max-bytes="5242880"
        data-storage-error="Hoy no podemos recibir fotos clinicas desde este formulario. Escribanos por WhatsApp para coordinar el siguiente paso."
    >
        <div class="v6-pre-form-layout">
            <article class="v6-pre-form-card" data-v6-pre-form-card>
                <div class="v6-pre-form-card__head">
                    {normalizeText(form.eyebrow) ? <p>{form.eyebrow}</p> : null}
                    {normalizeText(form.title) ? <h2>{form.title}</h2> : null}
                    {normalizeText(form.description) ? <p>{form.description}</p> : null}
                </div>

                <form class="v6-pre-form" data-preconsultation-form novalidate>
                    <div class="v6-pre-form__field">
                        <label for="pre-name">Nombre y apellido</label>
                        <input id="pre-name" name="name" type="text" maxlength="150" autocomplete="name" required />
                    </div>

                    <div class="v6-pre-form__field">
                        <label for="pre-whatsapp">WhatsApp</label>
                        <input
                            id="pre-whatsapp"
                            name="whatsapp"
                            type="tel"
                            maxlength="20"
                            autocomplete="tel"
                            inputmode="tel"
                            pattern="[0-9+()\\s-]{7,20}"
                            required
                        />
                    </div>

                    <div class="v6-pre-form__field">
                        <label for="pre-skin-type">Tipo de piel</label>
                        <select id="pre-skin-type" name="skinType" required>
                            <option value="">Seleccione una opcion</option>
                            <option value="seca">Seca</option>
                            <option value="mixta">Mixta</option>
                            <option value="grasa">Grasa</option>
                            <option value="sensible">Sensible</option>
                            <option value="acneica">Acneica</option>
                            <option value="atopica">Atopica</option>
                            <option value="normal">Normal</option>
                        </select>
                    </div>

                    <div class="v6-pre-form__field is-full">
                        <label for="pre-condition">Condicion o motivo</label>
                        <textarea
                            id="pre-condition"
                            name="condition"
                            rows="5"
                            maxlength="1000"
                            placeholder="Cuente que nota, desde cuando empezo, si cambia, pica, duele o sangra."
                            required
                        ></textarea>
                    </div>

                    <div class="v6-pre-form__field is-full">
                        <label for="pre-photos">Fotos clinicas opcionales</label>
                        <input
                            id="pre-photos"
                            name="photos"
                            type="file"
                            accept="image/jpeg,image/png,image/webp"
                            multiple
                        />
                        <p class="v6-pre-form__hint" data-preconsultation-photo-note>{normalizeText(form.photoHint)}</p>
                        <ul class="v6-pre-form__files" data-preconsultation-photo-list></ul>
                    </div>

                    <label class="v6-pre-form__consent">
                        <input id="pre-consent" name="privacyConsent" type="checkbox" value="1" required />
                        <span>
                            Acepto el tratamiento de datos clinicos para orientar el siguiente paso dermatologico.
                        </span>
                    </label>

                    {normalizeText(form.disclaimer) ? <p class="v6-pre-form__disclaimer">{form.disclaimer}</p> : null}

                    <div class="v6-pre-form__actions">
                        <button type="submit" data-preconsultation-submit>{normalizeText(form.submitLabel) || 'Enviar'}</button>
                        {
                            supportStatus.ctaLabel && supportStatus.ctaHref ? (
                                <a href={supportStatus.ctaHref} target="_blank" rel="noopener noreferrer">
                                    {normalizeText(form.secondaryCtaLabel) || supportStatus.ctaLabel}
                                </a>
                            ) : null
                        }
                    </div>

                    <div class="v6-pre-form__status" data-preconsultation-status role="status" aria-live="polite" hidden></div>

                    <article class="v6-pre-form__success" data-preconsultation-success hidden>
                        <p>Preconsulta recibida</p>
                        <h3>Frontdesk ya tiene el caso.</h3>
                        <p data-preconsultation-success-body></p>
                    </article>
                </form>
            </article>

            <aside class="v6-pre-sidecar">
                <div class="v6-pre-sidecar__head">
                    <p>{normalizeText(response.eyebrow)}</p>
                    <h2>{normalizeText(response.title)}</h2>
                </div>

                {
                    responseSteps.length ? (
                        <ol class="v6-pre-sidecar__steps">
                            {
                                responseSteps.map((item) => (
                                    <li>
                                        <h3>{normalizeText(item?.title)}</h3>
                                        <p>{normalizeText(item?.copy)}</p>
                                    </li>
                                ))
                            }
                        </ol>
                    ) : null
                }

                {
                    normalizeText(response.noteLabel) && normalizeText(response.noteValue) ? (
                        <div class="v6-pre-sidecar__note">
                            <span>{response.noteLabel}</span>
                            <strong>{response.noteValue}</strong>
                        </div>
                    ) : null
                }
            </aside>
        </div>
    </section>
</div>

<section id="v6-pre-response" class="v6-pre-response" data-v6-pre-response>
    <div class="v6-pre-response__shell">
        <div>
            <p>Que revisa el equipo</p>
            <h2>La respuesta no sale por azar.</h2>
        </div>
        <div class="v6-pre-response__grid">
            <article>
                <strong>Motivo y tiempo</strong>
                <p>Si el cambio es nuevo, recurrente o ya viene con escalada previa.</p>
            </article>
            <article>
                <strong>Fotos utilizables</strong>
                <p>Si la imagen sirve para orientar o si conviene pedir otra toma antes de decidir.</p>
            </article>
            <article>
                <strong>Siguiente paso</strong>
                <p>WhatsApp, teledermatologia o cita presencial, segun el riesgo y la claridad del caso.</p>
            </article>
        </div>
    </div>
</section>

<BookingStatusV6 status={supportStatus} />

<script is:inline>
    (() => {
        const root = document.querySelector('[data-v6-pre-form-root]');
        if (!(root instanceof HTMLElement)) {
            return;
        }

        const form = root.querySelector('[data-preconsultation-form]');
        const submitButton = root.querySelector('[data-preconsultation-submit]');
        const statusNode = root.querySelector('[data-preconsultation-status]');
        const successNode = root.querySelector('[data-preconsultation-success]');
        const successBody = root.querySelector('[data-preconsultation-success-body]');
        const photoNote = root.querySelector('[data-preconsultation-photo-note]');
        const photoList = root.querySelector('[data-preconsultation-photo-list]');
        const fileInput = root.querySelector('#pre-photos');

        if (!(form instanceof HTMLFormElement) || !(submitButton instanceof HTMLButtonElement)) {
            return;
        }

        const uploadUrl = root.dataset.uploadUrl || '/api.php?resource=transfer-proof';
        const submitUrl = root.dataset.submitUrl || '/api.php?resource=patient-cases';
        const maxFiles = Number.parseInt(root.dataset.maxFiles || '3', 10) || 3;
        const maxBytes = Number.parseInt(root.dataset.maxBytes || '5242880', 10) || 5242880;
        const storageErrorMessage =
            root.dataset.storageError ||
            'Hoy no podemos recibir fotos clinicas desde este formulario.';
        const defaultSubmitLabel = submitButton.textContent || 'Enviar';
        const allowedMimeTypes = new Set(['image/jpeg', 'image/png', 'image/webp']);

        const setStatus = (state, message) => {
            if (!(statusNode instanceof HTMLElement)) {
                return;
            }

            const safeMessage = typeof message === 'string' ? message.trim() : '';
            if (!safeMessage) {
                statusNode.hidden = true;
                statusNode.textContent = '';
                statusNode.removeAttribute('data-state');
                return;
            }

            statusNode.hidden = false;
            statusNode.dataset.state = state;
            statusNode.textContent = safeMessage;
        };

        const setPending = (pending) => {
            submitButton.disabled = pending;
            submitButton.textContent = pending ? 'Enviando...' : defaultSubmitLabel;
            if (pending) {
                form.setAttribute('aria-busy', 'true');
            } else {
                form.removeAttribute('aria-busy');
            }
        };

        const listSelectedFiles = () => {
            if (!(fileInput instanceof HTMLInputElement)) {
                return [];
            }
            return Array.from(fileInput.files || []);
        };

        const renderSelectedFiles = () => {
            const files = listSelectedFiles();
            if (photoList instanceof HTMLElement) {
                photoList.innerHTML = files.map((file) => `<li>${file.name}</li>`).join('');
            }
            if (photoNote instanceof HTMLElement) {
                if (files.length === 0) {
                    photoNote.textContent = 'Hasta 3 fotos JPG, PNG o WEBP de maximo 5 MB cada una.';
                } else {
                    photoNote.textContent = `${files.length} foto${files.length === 1 ? '' : 's'} lista${files.length === 1 ? '' : 's'} para subir.`;
                }
            }
        };

        const payloadError = (payload, fallback) => {
            if (payload && typeof payload === 'object') {
                if (payload.code === 'clinical_storage_not_ready') {
                    return storageErrorMessage;
                }
                if (typeof payload.error === 'string' && payload.error.trim()) {
                    return payload.error.trim();
                }
                if (
                    payload.data &&
                    typeof payload.data === 'object' &&
                    typeof payload.data.error === 'string' &&
                    payload.data.error.trim()
                ) {
                    return payload.data.error.trim();
                }
            }
            return fallback;
        };

        const parseJson = async (response) => {
            try {
                return await response.json();
            } catch (error) {
                return null;
            }
        };

        const validateFiles = (files) => {
            if (files.length > maxFiles) {
                return `Puede subir hasta ${maxFiles} fotos.`;
            }

            for (const file of files) {
                if (!allowedMimeTypes.has(file.type)) {
                    return 'Use solo JPG, PNG o WEBP.';
                }
                if (file.size <= 0) {
                    return `El archivo ${file.name} esta vacio.`;
                }
                if (file.size > maxBytes) {
                    return `El archivo ${file.name} supera 5 MB.`;
                }
            }

            return '';
        };

        const uploadPhotos = async (files) => {
            const uploaded = [];
            for (let index = 0; index < files.length; index += 1) {
                const file = files[index];
                setStatus('pending', `Subiendo foto ${index + 1} de ${files.length}...`);
                const requestBody = new FormData();
                requestBody.append('proof', file);

                const response = await fetch(uploadUrl, {
                    method: 'POST',
                    body: requestBody,
                    credentials: 'same-origin',
                });
                const payload = await parseJson(response);

                if (!response.ok || !(payload && payload.ok)) {
                    throw new Error(payloadError(payload, `No se pudo subir ${file.name}.`));
                }

                const transferProofPath =
                    payload &&
                    payload.data &&
                    typeof payload.data.transferProofPath === 'string'
                        ? payload.data.transferProofPath.trim()
                        : '';
                const transferProofName =
                    payload &&
                    payload.data &&
                    typeof payload.data.transferProofName === 'string'
                        ? payload.data.transferProofName.trim()
                        : file.name;

                if (!transferProofPath) {
                    throw new Error(`La foto ${file.name} no devolvio una ruta valida.`);
                }

                uploaded.push({
                    path: transferProofPath,
                    name: transferProofName || file.name,
                });
            }

            return uploaded;
        };

        if (fileInput instanceof HTMLInputElement) {
            fileInput.addEventListener('change', () => {
                renderSelectedFiles();
                setStatus('', '');
            });
        }

        form.addEventListener('submit', async (event) => {
            event.preventDefault();
            setStatus('', '');
            if (successNode instanceof HTMLElement) {
                successNode.hidden = true;
            }

            const files = listSelectedFiles();
            const fileError = validateFiles(files);
            if (fileError) {
                setStatus('error', fileError);
                return;
            }

            if (!form.reportValidity()) {
                setStatus('error', 'Revise los campos obligatorios antes de enviar.');
                return;
            }

            const formData = new FormData(form);
            const payload = {
                name: String(formData.get('name') || '').trim(),
                whatsapp: String(formData.get('whatsapp') || '').trim(),
                skinType: String(formData.get('skinType') || '').trim(),
                condition: String(formData.get('condition') || '').trim(),
                privacyConsent: formData.get('privacyConsent') === '1',
            };

            setPending(true);

            try {
                const uploadedPhotos = await uploadPhotos(files);
                payload.casePhotoPaths = uploadedPhotos.map((item) => item.path);
                payload.casePhotoNames = uploadedPhotos.map((item) => item.name);

                setStatus('pending', 'Registrando el caso para frontdesk...');

                const response = await fetch(submitUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        Accept: 'application/json',
                    },
                    credentials: 'same-origin',
                    body: JSON.stringify(payload),
                });
                const result = await parseJson(response);

                if (!response.ok || !(result && result.ok)) {
                    throw new Error(payloadError(result, 'No se pudo registrar la preconsulta.'));
                }

                const caseId =
                    result &&
                    result.data &&
                    typeof result.data.caseId === 'string'
                        ? result.data.caseId.trim()
                        : '';
                const whatsapp =
                    result &&
                    result.data &&
                    typeof result.data.whatsapp === 'string'
                        ? result.data.whatsapp.trim()
                        : payload.whatsapp;

                setStatus('success', 'Preconsulta enviada. Frontdesk respondera por WhatsApp con el siguiente paso.');
                if (successNode instanceof HTMLElement) {
                    successNode.hidden = false;
                }
                if (successBody instanceof HTMLElement) {
                    successBody.textContent = caseId
                        ? `Caso ${caseId} registrado y listo para revision humana. Le escribiremos al ${whatsapp || payload.whatsapp}.`
                        : `Caso registrado y listo para revision humana. Le escribiremos al ${whatsapp || payload.whatsapp}.`;
                }

                form.reset();
                renderSelectedFiles();
                if (successNode instanceof HTMLElement) {
                    successNode.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                }
            } catch (error) {
                const message =
                    error instanceof Error && error.message
                        ? error.message
                        : 'No se pudo enviar la preconsulta.';
                setStatus('error', message);
            } finally {
                setPending(false);
            }
        });

        renderSelectedFiles();
    })();
</script>
