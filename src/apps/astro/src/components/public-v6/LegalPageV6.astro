---
import PageHeadV6 from './PageHeadV6.astro';
import InternalStatementBandV6 from './InternalStatementBandV6.astro';

const {
    page = {},
    indexItems = [],
    legalPages = {},
    currentSlug = '',
    locale = 'es',
    navModel = {},
    ui = {},
} = Astro.props;

const pageHeadUi = navModel?.ui?.pageHead && typeof navModel.ui.pageHead === 'object' ? navModel.ui.pageHead : {};
const menuUi = ui?.menu && typeof ui.menu === 'object' ? ui.menu : {};
const thesisUi = ui?.thesis && typeof ui.thesis === 'object' ? ui.thesis : {};
const statementUi = ui?.statement && typeof ui.statement === 'object' ? ui.statement : {};
const internalMessageUi = ui?.internalMessage && typeof ui.internalMessage === 'object' ? ui.internalMessage : {};
const breadcrumbUi = ui?.breadcrumb && typeof ui.breadcrumb === 'object' ? ui.breadcrumb : {};
const sectionLabel = ui.sectionLabel || '';
const blockLabel = ui.blockLabel || '';
const clausesLabel = ui.clausesLabel || '';

const switchLabel = navModel?.header?.switchLabel || '';
const switchHref = navModel?.header?.switchHref || '#';
const menuLabel = navModel?.header?.menuLabel || '';
const sections = Array.isArray(page.sections) ? page.sections : [];
const safeLegalPages = legalPages && typeof legalPages === 'object' ? legalPages : {};
const sectionHighlights = sections.slice(0, 3).map((section) => ({
    title: section.title,
    count: Array.isArray(section.items) ? section.items.length : 0,
}));
const indexCards = indexItems.map((item, index) => {
    const source = safeLegalPages[item.slug] && typeof safeLegalPages[item.slug] === 'object'
        ? safeLegalPages[item.slug]
        : {};
    const sourceSections = Array.isArray(source.sections) ? source.sections : [];
    const clauses = sourceSections.reduce((total, section) => {
        const rows = Array.isArray(section.items) ? section.items.length : 0;
        return total + rows;
    }, 0);

    return {
        slug: item.slug,
        title: item.title,
        href: item.href,
        summary: source.summary || '',
        image: source.heroImage || page.heroImage,
        sectionLabel: `${sectionLabel} ${String(index + 1).padStart(2, '0')}`.trim(),
        clauses,
    };
});
const sectionModels = sections.map((section, index) => ({
    ...section,
    items: Array.isArray(section.items) ? section.items : [],
    anchorId: `v6-legal-section-${index + 1}`,
}));
const pageMenuItems = [
    {
        label: menuUi.legalIndex || '',
        href: '#v6-legal-tabs',
    },
];

if (sectionHighlights.length) {
    pageMenuItems.push({
        label: menuUi.clausesSummary || '',
        href: '#v6-legal-summary',
    });
}

if (indexCards.length) {
    pageMenuItems.push({
        label: menuUi.policyIndex || '',
        href: '#v6-legal-index-grid',
    });
}

sectionModels.forEach((section) => {
    if (section.title) {
        pageMenuItems.push({
            label: section.title,
            href: `#${section.anchorId}`,
        });
    }
});

const breadcrumb = [
    { label: breadcrumbUi.home || '', href: locale === 'en' ? '/en/' : '/es/' },
    { label: breadcrumbUi.legal || '', href: locale === 'en' ? '/en/legal/terms/' : '/es/legal/terminos/' },
];
const thesisEyebrow = thesisUi.eyebrow || '';
const thesisTitle = thesisUi.title || '';
const thesisBody = thesisUi.body || '';
const statement = {
    eyebrow: statementUi.eyebrow || '',
    title: statementUi.title || '',
    body: page.summary || internalMessageUi.description || '',
    signature: statementUi.signature || '',
    image: statementUi.image || '',
    alt: statementUi.alt || '',
};
---

<PageHeadV6
    breadcrumb={breadcrumb}
    heading={page.heading}
    locale={locale}
    switchLabel={switchLabel}
    switchHref={switchHref}
    menuLabel={menuLabel}
    menuItems={pageMenuItems}
    copy={pageHeadUi}
/>

<section class="v6-page-hero-media is-internal" data-v6-internal-hero>
    <img src={page.heroImage} alt={page.heading} loading="eager" fetchpriority="high" />
</section>

<nav id="v6-legal-tabs" class="v6-legal-tabs" aria-label={menuUi.legalIndex || ''}>
    {
        indexItems.map((item) => (
            <a class:list={[item.slug === currentSlug && 'is-active']} href={item.href}>{item.title}</a>
        ))
    }
</nav>

<section class="v6-internal-message" data-v6-internal-message>
    <h2>{page.summary}</h2>
    <p>{internalMessageUi.description || ''}</p>
</section>

<InternalStatementBandV6 statement={statement} variant="legal" />

<section class="v6-internal-thesis" data-v6-internal-thesis>
    <p>{thesisEyebrow}</p>
    <h2>{thesisTitle}</h2>
    <p>{thesisBody}</p>
</section>

{
    indexCards.length ? (
        <section id="v6-legal-index-grid" class="v6-legal-index-grid" data-v6-legal-index>
            {
                indexCards.map((item) => (
                    <a class:list={[item.slug === currentSlug && 'is-active']} href={item.href}>
                        <figure>
                            <img src={item.image} alt={item.title} loading="lazy" decoding="async" />
                        </figure>
                        <div>
                            <p>{item.sectionLabel}</p>
                            <h3>{item.title}</h3>
                            <p>{item.summary}</p>
                            <strong>
                                {`${item.clauses} ${clausesLabel}`.trim()}
                            </strong>
                        </div>
                    </a>
                ))
            }
        </section>
    ) : null
}

{
    sectionHighlights.length ? (
        <section id="v6-legal-summary" class="v6-legal-summary">
            {
                sectionHighlights.map((item, index) => (
                    <article>
                        <p>{sectionLabel}</p>
                        <h3>{item.title}</h3>
                        <small>{`${blockLabel} ${String(index + 1).padStart(2, '0')}`.trim()}</small>
                        <strong>{`${item.count} ${clausesLabel}`.trim()}</strong>
                    </article>
                ))
            }
        </section>
    ) : null
}

<section class="v6-legal-sections">
    {
        sectionModels.map((section, sectionIndex) => (
            <article id={section.anchorId} data-v6-legal-block>
                <header>
                    <p>{`${sectionLabel} ${String(sectionIndex + 1).padStart(2, '0')}`.trim()}</p>
                    <h3>{section.title}</h3>
                    <strong>{`${section.items.length} ${clausesLabel}`.trim()}</strong>
                </header>
                <ol>
                    {section.items.map((item, itemIndex) => (
                        <li>
                            <span>{String(itemIndex + 1).padStart(2, '0')}</span>
                            <p>{item}</p>
                        </li>
                    ))}
                </ol>
            </article>
        ))
    }
</section>
