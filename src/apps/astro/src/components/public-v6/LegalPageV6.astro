---
import PageHeadV6 from './PageHeadV6.astro';
import InternalStatementBandV6 from './InternalStatementBandV6.astro';

const {
    page = {},
    indexItems = [],
    legalPages = {},
    currentSlug = '',
    locale = 'es',
    navModel = {},
    ui = {},
} = Astro.props;

const pageHeadUi = navModel?.ui?.pageHead && typeof navModel.ui.pageHead === 'object' ? navModel.ui.pageHead : {};
const menuUi = ui?.menu && typeof ui.menu === 'object' ? ui.menu : {};
const thesisUi = ui?.thesis && typeof ui.thesis === 'object' ? ui.thesis : {};
const statementUi = ui?.statement && typeof ui.statement === 'object' ? ui.statement : {};
const internalMessageUi = ui?.internalMessage && typeof ui.internalMessage === 'object' ? ui.internalMessage : {};
const breadcrumbUi = ui?.breadcrumb && typeof ui.breadcrumb === 'object' ? ui.breadcrumb : {};
const hasText = (value) => typeof value === 'string' && value.trim().length > 0;
const normalizeText = (value) => (hasText(value) ? value.trim() : '');
const normalizeHref = (value) => {
    const raw = normalizeText(value);
    return raw && raw !== '#' ? raw : '';
};
const sectionLabel = normalizeText(ui.sectionLabel);
const blockLabel = normalizeText(ui.blockLabel);
const clausesLabel = normalizeText(ui.clausesLabel);
const makeMenuItem = (label, href) => (hasText(label) ? { label: label.trim(), href } : null);

const switchLabel = normalizeText(navModel?.header?.switchLabel);
const switchHref = normalizeHref(navModel?.header?.switchHref);
const menuLabel = normalizeText(navModel?.header?.menuLabel);
const sections = Array.isArray(page.sections) ? page.sections : [];
const safeLegalPages = legalPages && typeof legalPages === 'object' ? legalPages : {};
const safeIndexItems = (Array.isArray(indexItems) ? indexItems : [])
    .map((item) => {
        const slug = normalizeText(item?.slug);
        const title = normalizeText(item?.title);
        const href = normalizeHref(item?.href);
        return slug && title && href ? { slug, title, href } : null;
    })
    .filter(Boolean);
const sectionModels = sections
    .map((section, index) => {
        const title = normalizeText(section?.title);
        const items = Array.isArray(section?.items) ? section.items.map(normalizeText).filter(Boolean) : [];
        return title && items.length
            ? {
                title,
                items,
                anchorId: `v6-legal-section-${index + 1}`,
            }
            : null;
    })
    .filter(Boolean);
const sectionHighlights = sectionModels.slice(0, 3).map((section) => ({
    title: section.title,
    count: section.items.length,
}));
const indexCards = safeIndexItems.map((item, index) => {
    const source = safeLegalPages[item.slug] && typeof safeLegalPages[item.slug] === 'object'
        ? safeLegalPages[item.slug]
        : {};
    const sourceSections = Array.isArray(source.sections) ? source.sections : [];
    const clauses = sourceSections.reduce((total, section) => {
        const rows = Array.isArray(section.items) ? section.items.length : 0;
        return total + rows;
    }, 0);

    return {
        slug: item.slug,
        title: item.title,
        href: item.href,
        summary: normalizeText(source.summary),
        image: normalizeText(source.heroImage),
        sectionLabel: `${sectionLabel} ${String(index + 1).padStart(2, '0')}`.trim(),
        clauses,
    };
}).filter((item) => item.title && item.href && item.image);
const pageMenuItems = [
    makeMenuItem(menuUi.legalIndex || '', '#v6-legal-tabs'),
].filter(Boolean);

if (sectionHighlights.length) {
    const clausesItem = makeMenuItem(menuUi.clausesSummary || '', '#v6-legal-summary');
    if (clausesItem) {
        pageMenuItems.push(clausesItem);
    }
}

if (indexCards.length) {
    const policyItem = makeMenuItem(menuUi.policyIndex || '', '#v6-legal-index-grid');
    if (policyItem) {
        pageMenuItems.push(policyItem);
    }
}

sectionModels.forEach((section) => {
    const item = makeMenuItem(section.title, `#${section.anchorId}`);
    if (item) {
        pageMenuItems.push(item);
    }
});

const breadcrumb = [
    { label: normalizeText(breadcrumbUi.home), href: locale === 'en' ? '/en/' : '/es/' },
    { label: normalizeText(breadcrumbUi.legal), href: locale === 'en' ? '/en/legal/terms/' : '/es/legal/terminos/' },
];
const thesisEyebrow = normalizeText(thesisUi.eyebrow);
const thesisTitle = normalizeText(thesisUi.title);
const thesisBody = normalizeText(thesisUi.body);
const statement = {
    eyebrow: normalizeText(statementUi.eyebrow),
    title: normalizeText(statementUi.title),
    body: normalizeText(page.summary),
    signature: normalizeText(statementUi.signature),
    image: normalizeText(statementUi.image),
    alt: normalizeText(statementUi.alt),
};
const heroImage = normalizeText(page.heroImage);
const heading = normalizeText(page.heading);
const summary = normalizeText(page.summary);
const internalDescription = normalizeText(internalMessageUi.description);
---

<PageHeadV6
    breadcrumb={breadcrumb}
    heading={heading}
    locale={locale}
    switchLabel={switchLabel}
    switchHref={switchHref}
    menuLabel={menuLabel}
    menuItems={pageMenuItems}
    copy={pageHeadUi}
/>

{
    heroImage ? (
        <section class="v6-page-hero-media is-internal" data-v6-internal-hero>
            <img src={heroImage} alt={heading} loading="eager" fetchpriority="high" />
        </section>
    ) : null
}

{
    safeIndexItems.length ? (
        <nav id="v6-legal-tabs" class="v6-legal-tabs" aria-label={normalizeText(menuUi.legalIndex) || undefined}>
            {
                safeIndexItems.map((item) => (
                    <a class:list={[item.slug === currentSlug && 'is-active']} href={item.href} aria-current={item.slug === currentSlug ? 'page' : undefined}>{item.title}</a>
                ))
            }
        </nav>
    ) : null
}

{
    summary || internalDescription ? (
        <section class="v6-internal-message" data-v6-internal-message>
            {summary ? <h2>{summary}</h2> : null}
            {internalDescription ? <p>{internalDescription}</p> : null}
        </section>
    ) : null
}

<InternalStatementBandV6 statement={statement} variant="legal" />

{
    thesisEyebrow || thesisTitle || thesisBody ? (
        <section class="v6-internal-thesis" data-v6-internal-thesis>
            {thesisEyebrow ? <p>{thesisEyebrow}</p> : null}
            {thesisTitle ? <h2>{thesisTitle}</h2> : null}
            {thesisBody ? <p>{thesisBody}</p> : null}
        </section>
    ) : null
}

{
    indexCards.length ? (
        <section id="v6-legal-index-grid" class="v6-legal-index-grid" data-v6-legal-index>
            {
                indexCards.map((item) => (
                    <a class:list={[item.slug === currentSlug && 'is-active']} href={item.href}>
                        <figure>
                            <img src={item.image} alt={item.title} loading="lazy" decoding="async" />
                        </figure>
                        <div>
                            {item.sectionLabel ? <p>{item.sectionLabel}</p> : null}
                            <h3>{item.title}</h3>
                            {item.summary ? <p>{item.summary}</p> : null}
                            {clausesLabel ? <strong>{`${item.clauses} ${clausesLabel}`.trim()}</strong> : null}
                        </div>
                    </a>
                ))
            }
        </section>
    ) : null
}

{
    sectionHighlights.length ? (
        <section id="v6-legal-summary" class="v6-legal-summary">
            {
                sectionHighlights.map((item, index) => (
                    <article>
                        {sectionLabel ? <p>{sectionLabel}</p> : null}
                        <h3>{item.title}</h3>
                        {blockLabel ? <small>{`${blockLabel} ${String(index + 1).padStart(2, '0')}`.trim()}</small> : null}
                        {clausesLabel ? <strong>{`${item.count} ${clausesLabel}`.trim()}</strong> : null}
                    </article>
                ))
            }
        </section>
    ) : null
}

<section class="v6-legal-sections">
    {
        sectionModels.map((section, sectionIndex) => (
            <article id={section.anchorId} data-v6-legal-block>
                <header>
                    {sectionLabel ? <p>{`${sectionLabel} ${String(sectionIndex + 1).padStart(2, '0')}`.trim()}</p> : null}
                    <h3>{section.title}</h3>
                    {clausesLabel ? <strong>{`${section.items.length} ${clausesLabel}`.trim()}</strong> : null}
                </header>
                <ol>
                    {section.items.map((item, itemIndex) => (
                        <li>
                            <span>{String(itemIndex + 1).padStart(2, '0')}</span>
                            <p>{item}</p>
                        </li>
                    ))}
                </ol>
            </article>
        ))
    }
</section>
