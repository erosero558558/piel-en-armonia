---
import '../../styles/public-v6/internal.css';

import BookingStatusV6 from './BookingStatusV6.astro';
import PageHeadV6 from './PageHeadV6.astro';

const { page = {}, locale = 'es', navModel = {} } = Astro.props;
const hasText = (value) => typeof value === 'string' && value.trim().length > 0;
const normalizeText = (value) => (hasText(value) ? value.trim() : '');
const normalizeHref = (value) => {
    const raw = normalizeText(value);
    return raw && raw !== '#' ? raw : '';
};
const normalizeLink = (item) => {
    const label = normalizeText(item?.label);
    const href = normalizeHref(item?.href);
    return label && href ? { label, href } : null;
};
const makeMenuItem = (label, href) => (hasText(label) ? { label: label.trim(), href } : null);
const pageHeadUi =
    navModel?.ui?.pageHead && typeof navModel.ui.pageHead === 'object'
        ? navModel.ui.pageHead
        : {};
const switchLabel = normalizeText(navModel?.header?.switchLabel);
const switchHref = normalizeHref(navModel?.header?.switchHref);
const menuLabel = normalizeText(navModel?.header?.menuLabel);
const breadcrumb = Array.isArray(page.breadcrumb)
    ? page.breadcrumb.map(normalizeLink).filter(Boolean)
    : [];
const hero = page?.hero && typeof page.hero === 'object' ? page.hero : {};
const editorial = page?.editorial && typeof page.editorial === 'object' ? page.editorial : {};
const bookingStatus =
    page?.bookingStatus && typeof page.bookingStatus === 'object'
        ? page.bookingStatus
        : {};
const cards = Array.isArray(editorial.cards)
    ? editorial.cards
          .map((card, index) => {
              const href = normalizeHref(card?.href);
              const image = normalizeText(card?.image);
              const srcset = normalizeText(card?.srcset);
              const category = normalizeText(card?.category);
              const title = normalizeText(card?.title);
              const copy = normalizeText(card?.copy);
              const ctaLabel = normalizeText(card?.ctaLabel);
              const alt = normalizeText(card?.alt) || title;
              return href && image && title && copy
                  ? {
                        href,
                        image,
                        srcset,
                        category,
                        title,
                        copy,
                        ctaLabel,
                        alt,
                        index: String(index + 1).padStart(2, '0'),
                    }
                  : null;
          })
          .filter(Boolean)
    : [];
const categories = Array.isArray(page.categories)
    ? page.categories
          .map((item, index) => {
              const id = normalizeText(item?.id) || `v6-blog-track-${index + 1}`;
              const label = normalizeText(item?.label);
              const count = normalizeText(item?.count);
              return label ? { id, label, count } : null;
          })
          .filter(Boolean)
    : [];
const tracks = Array.isArray(page.tracks)
    ? page.tracks
          .map((track, index) => {
              const id = normalizeText(track?.id) || `v6-blog-track-${index + 1}`;
              const eyebrow = normalizeText(track?.eyebrow);
              const title = normalizeText(track?.title);
              const deck = normalizeText(track?.deck);
              const bullets = Array.isArray(track?.bullets)
                  ? track.bullets.map(normalizeText).filter(Boolean)
                  : [];
              const links = Array.isArray(track?.links)
                  ? track.links.map(normalizeLink).filter(Boolean)
                  : [];
              return title && (bullets.length || links.length)
                  ? {
                        id,
                        eyebrow,
                        title,
                        deck,
                        bullets,
                        links,
                        index: String(index + 1).padStart(2, '0'),
                    }
                  : null;
          })
          .filter(Boolean)
    : [];
const pageMenuItems = [
    makeMenuItem(normalizeText(page?.ui?.overviewLabel), '#v6-blog-grid'),
    makeMenuItem(normalizeText(page?.ui?.categoriesLabel), '#v6-blog-categories'),
    makeMenuItem(normalizeText(page?.ui?.tracksLabel), tracks[0] ? `#${tracks[0].id}` : ''),
    makeMenuItem(normalizeText(page?.ui?.ctaLabel), '#v6-blog-cta'),
].filter(Boolean);
const railTitle = normalizeText(page?.ui?.railTitle);
const railAria = normalizeText(page?.ui?.railAria);
const heroStats = Array.isArray(hero?.stats)
    ? hero.stats
          .map((item) => {
              const label = normalizeText(item?.label);
              const value = normalizeText(item?.value);
              return label && value ? { label, value } : null;
          })
          .filter(Boolean)
    : [];
---

<PageHeadV6
    breadcrumb={breadcrumb}
    heading={page.heading}
    locale={locale}
    switchLabel={switchLabel}
    switchHref={switchHref}
    menuLabel={menuLabel}
    menuItems={pageMenuItems}
    copy={pageHeadUi}
/>

<section class="v6-page-hero-media is-internal v6-page-hero-media--blog" data-v6-blog-hero>
    <div class="v6-blog-hero-shell">
        <figure class="v6-blog-hero-shell__media">
            <img
                src={normalizeText(hero?.image?.src)}
                srcset={normalizeText(hero?.image?.srcset) || undefined}
                sizes="(max-width: 1100px) 100vw, 60vw"
                alt={normalizeText(hero?.image?.alt) || normalizeText(page.heading)}
                loading="eager"
                decoding="sync"
                fetchpriority="high"
            />
        </figure>
        <aside class="v6-blog-hero-shell__panel">
            {hero.eyebrow ? <p class="v6-blog-hero-shell__eyebrow">{hero.eyebrow}</p> : null}
            {hero.title ? <h2>{hero.title}</h2> : null}
            {hero.deck ? <p class="v6-blog-hero-shell__deck">{hero.deck}</p> : null}
            {
                heroStats.length ? (
                    <div class="v6-blog-hero-shell__stats" aria-hidden="true">
                        {
                            heroStats.map((item) => (
                                <article>
                                    <span>{item.label}</span>
                                    <strong>{item.value}</strong>
                                </article>
                            ))
                        }
                    </div>
                ) : null
            }
        </aside>
    </div>
</section>

{
    categories.length ? (
        <section id="v6-blog-categories" class="v6-blog-category-strip" data-v6-blog-categories>
            <header class="v6-blog-category-strip__head">
                {page?.ui?.categoriesEyebrow ? <p>{page.ui.categoriesEyebrow}</p> : null}
                {page?.ui?.categoriesTitle ? <h2>{page.ui.categoriesTitle}</h2> : null}
            </header>
            <div class="v6-blog-category-strip__grid" role="list">
                {
                    categories.map((item) => (
                        <a href={`#${item.id}`} role="listitem" data-v6-blog-chip>
                            <span>{item.label}</span>
                            {item.count ? <strong>{item.count}</strong> : null}
                        </a>
                    ))
                }
            </div>
        </section>
    ) : null
}

{
    cards.length ? (
        <section id="v6-blog-grid" class="v6-blog-editorial" data-v6-blog-grid>
            <div class="v6-blog-editorial__head">
                {editorial.eyebrow ? <p>{editorial.eyebrow}</p> : null}
                {editorial.title ? <h2>{editorial.title}</h2> : null}
                {editorial.deck ? <p>{editorial.deck}</p> : null}
            </div>
            <div class="v6-blog-editorial__grid">
                {
                    cards.map((card, index) => (
                        <article class:list={['v6-blog-editorial__card', index === 0 && 'is-lead']} data-v6-blog-card>
                            <a href={card.href}>
                                <figure>
                                    <img
                                        src={card.image}
                                        srcset={card.srcset || undefined}
                                        sizes="(max-width: 720px) 100vw, (max-width: 1100px) 50vw, 34vw"
                                        alt={card.alt}
                                        loading="lazy"
                                        decoding="async"
                                        fetchpriority="low"
                                    />
                                </figure>
                                <div class="v6-blog-editorial__meta">
                                    <span class="v6-blog-editorial__index">{card.index}</span>
                                    {card.category ? <p>{card.category}</p> : null}
                                    <h3>{card.title}</h3>
                                    <p>{card.copy}</p>
                                    <strong>
                                        {card.ctaLabel || normalizeText(page?.ui?.cardCtaLabel)}
                                        <span aria-hidden="true">></span>
                                    </strong>
                                </div>
                            </a>
                        </article>
                    ))
                }
            </div>
        </section>
    ) : null
}

<div class="v6-internal-shell v6-blog-shell" data-v6-blog-shell>
    {
        tracks.length || railTitle ? (
            <aside class="v6-internal-rail" data-v6-internal-rail>
                {railTitle ? <p>{railTitle}</p> : null}
                {
                    tracks.length ? (
                        <nav data-v6-section-nav="internal" aria-label={railAria || undefined}>
                            {
                                tracks.map((track) => (
                                    <a data-v6-section-link href={`#${track.id}`}>{track.title}</a>
                                ))
                            }
                        </nav>
                    ) : null
                }
            </aside>
        ) : null
    }

    <div class="v6-internal-shell__body">
        {
            tracks.map((track, index) => (
                <article id={track.id} class:list={['v6-blog-track', index === 0 && 'is-lead']} data-v6-blog-track>
                    <header class="v6-blog-track__head">
                        <div>
                            {track.eyebrow ? <p>{track.eyebrow}</p> : null}
                            <h3>{track.title}</h3>
                        </div>
                        <strong>{track.index}</strong>
                    </header>
                    {track.deck ? <p class="v6-blog-track__deck">{track.deck}</p> : null}
                    {
                        track.bullets.length ? (
                            <ul class="v6-blog-track__list">
                                {
                                    track.bullets.map((item) => (
                                        <li>{item}</li>
                                    ))
                                }
                            </ul>
                        ) : null
                    }
                    {
                        track.links.length ? (
                            <div class="v6-blog-track__links">
                                {
                                    track.links.map((link) => (
                                        <a href={link.href}>{link.label}</a>
                                    ))
                                }
                            </div>
                        ) : null
                    }
                </article>
            ))
        }
    </div>
</div>

<BookingStatusV6
    status={bookingStatus}
    locale={locale}
    sectionId="v6-blog-cta"
    surface="blog"
/>

<style>
    #v6-blog-grid,
    #v6-blog-categories,
    [data-v6-blog-track] {
        scroll-margin-top: 148px;
    }

    .v6-page-hero-media--blog {
        padding: 18px clamp(18px, 3vw, 28px) 10px;
        background:
            radial-gradient(circle at top left, rgba(199, 163, 109, 0.2), transparent 30%),
            radial-gradient(circle at 84% 16%, rgba(146, 165, 187, 0.14), transparent 28%),
            linear-gradient(180deg, #05070b 0%, #0c1522 100%);
    }

    .v6-blog-hero-shell {
        max-width: 1320px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: minmax(0, 1.3fr) minmax(320px, 0.7fr);
        gap: clamp(18px, 2vw, 26px);
        align-items: center;
    }

    .v6-blog-hero-shell__media {
        margin: 0;
        overflow: hidden;
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: #101826;
        box-shadow: 0 28px 58px rgba(8, 13, 20, 0.24);
    }

    .v6-blog-hero-shell__media img {
        display: block;
        width: 100%;
        height: clamp(320px, 31vw, 470px);
        object-fit: cover;
        object-position: center;
    }

    .v6-blog-hero-shell__panel {
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background:
            radial-gradient(circle at top right, rgba(199, 163, 109, 0.16), transparent 34%),
            linear-gradient(180deg, rgba(10, 15, 22, 0.96) 0%, rgba(16, 24, 38, 0.98) 100%);
        padding: clamp(22px, 2.1vw, 30px);
        display: grid;
        gap: 14px;
        box-shadow: 0 24px 46px rgba(8, 13, 20, 0.2);
    }

    .v6-blog-hero-shell__eyebrow,
    .v6-blog-hero-shell__deck,
    .v6-blog-hero-shell h2,
    .v6-blog-hero-shell__stats span,
    .v6-blog-hero-shell__stats strong {
        margin: 0;
    }

    .v6-blog-hero-shell__eyebrow,
    .v6-blog-hero-shell__stats span {
        color: rgba(199, 163, 109, 0.92);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 10px;
        font-weight: 700;
    }

    .v6-blog-hero-shell h2 {
        color: #f4f7fb;
        font-family: var(--v6-font-display);
        font-size: clamp(32px, 2.7vw, 44px);
        line-height: 1.04;
        letter-spacing: -0.04em;
    }

    .v6-blog-hero-shell__deck {
        color: rgba(219, 227, 237, 0.8);
        font-size: clamp(16px, 1.1vw, 19px);
        line-height: 1.58;
    }

    .v6-blog-hero-shell__stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
    }

    .v6-blog-hero-shell__stats article {
        min-height: 86px;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.08);
        padding: 12px 13px 13px;
        display: grid;
        gap: 6px;
    }

    .v6-blog-hero-shell__stats strong {
        color: #f4f7fb;
        font-size: clamp(17px, 1.45vw, 24px);
        line-height: 1.14;
    }

    .v6-blog-category-strip,
    .v6-blog-editorial {
        max-width: 1320px;
        margin: 24px auto 0;
        padding: 0 24px;
    }

    .v6-blog-category-strip__head,
    .v6-blog-editorial__head {
        display: grid;
        gap: 8px;
    }

    .v6-blog-category-strip__head p,
    .v6-blog-category-strip__head h2,
    .v6-blog-editorial__head p,
    .v6-blog-editorial__head h2 {
        margin: 0;
    }

    .v6-blog-category-strip__head p:first-child,
    .v6-blog-editorial__head p:first-child {
        color: rgba(111, 127, 146, 0.9);
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 11px;
        font-weight: 700;
    }

    .v6-blog-category-strip__head h2,
    .v6-blog-editorial__head h2 {
        color: var(--v6-color-ink);
        font-family: var(--v6-font-accent);
        font-size: clamp(34px, 2.8vw, 48px);
        line-height: 1.04;
        letter-spacing: -0.04em;
    }

    .v6-blog-category-strip__grid {
        margin-top: 18px;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
    }

    .v6-blog-category-strip__grid a {
        min-height: 82px;
        display: grid;
        align-content: space-between;
        gap: 10px;
        padding: 14px 16px;
        border-radius: 18px;
        border: 1px solid rgba(202, 210, 220, 0.92);
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(244, 247, 250, 0.94) 100%);
        box-shadow: 0 18px 34px rgba(10, 18, 28, 0.08);
        color: var(--v6-color-ink);
    }

    .v6-blog-category-strip__grid a:hover,
    .v6-blog-category-strip__grid a:focus-visible {
        transform: translateY(-1px);
        box-shadow: 0 22px 38px rgba(10, 18, 28, 0.12);
    }

    .v6-blog-category-strip__grid span,
    .v6-blog-category-strip__grid strong {
        margin: 0;
    }

    .v6-blog-category-strip__grid span {
        font-size: 14px;
        line-height: 1.4;
    }

    .v6-blog-category-strip__grid strong {
        color: rgba(199, 163, 109, 0.94);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 11px;
    }

    .v6-blog-editorial__head p:last-child {
        max-width: 1040px;
        color: rgba(18, 24, 35, 0.7);
        font-size: 18px;
        line-height: 1.52;
    }

    .v6-blog-editorial__grid {
        margin-top: 26px;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 22px;
    }

    .v6-blog-editorial__card {
        border-radius: 22px;
        overflow: hidden;
        border: 1px solid rgba(202, 210, 220, 0.92);
        background: rgba(255, 255, 255, 0.94);
        box-shadow: 0 22px 42px rgba(10, 18, 28, 0.1);
        transition: transform 180ms ease, box-shadow 180ms ease;
    }

    .v6-blog-editorial__card.is-lead {
        grid-column: span 2;
        background:
            linear-gradient(180deg, rgba(10, 15, 22, 0.98) 0%, rgba(16, 24, 38, 0.98) 100%);
        border-color: rgba(16, 24, 38, 0.98);
        box-shadow: 0 30px 56px rgba(9, 15, 24, 0.22);
    }

    .v6-blog-editorial__card:hover,
    .v6-blog-editorial__card:focus-within {
        transform: translateY(-4px);
        box-shadow: 0 26px 46px rgba(10, 18, 28, 0.16);
    }

    .v6-blog-editorial__card a {
        min-height: 100%;
        display: grid;
        color: inherit;
    }

    .v6-blog-editorial__card figure {
        margin: 0;
    }

    .v6-blog-editorial__card img {
        display: block;
        width: 100%;
        height: 278px;
        object-fit: cover;
    }

    .v6-blog-editorial__card.is-lead img {
        height: 320px;
    }

    .v6-blog-editorial__meta {
        padding: 18px 18px 22px;
        display: grid;
        align-content: start;
        gap: 8px;
    }

    .v6-blog-editorial__index,
    .v6-blog-editorial__meta p,
    .v6-blog-editorial__meta h3,
    .v6-blog-editorial__meta strong {
        margin: 0;
    }

    .v6-blog-editorial__index,
    .v6-blog-editorial__meta p:first-of-type {
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 11px;
        font-weight: 700;
        color: rgba(111, 127, 146, 0.84);
    }

    .v6-blog-editorial__meta h3 {
        font-family: var(--v6-font-display);
        font-size: clamp(26px, 2vw, 38px);
        line-height: 1.08;
        letter-spacing: -0.03em;
    }

    .v6-blog-editorial__meta p:last-of-type {
        color: rgba(18, 24, 35, 0.7);
        font-size: 16px;
        line-height: 1.52;
    }

    .v6-blog-editorial__meta strong {
        margin-top: 4px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--v6-color-moss);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 12px;
    }

    .v6-blog-editorial__card.is-lead .v6-blog-editorial__index,
    .v6-blog-editorial__card.is-lead .v6-blog-editorial__meta p:first-of-type,
    .v6-blog-editorial__card.is-lead .v6-blog-editorial__meta strong {
        color: rgba(199, 163, 109, 0.92);
    }

    .v6-blog-editorial__card.is-lead .v6-blog-editorial__meta h3 {
        color: #f4f7fb;
    }

    .v6-blog-editorial__card.is-lead .v6-blog-editorial__meta p:last-of-type {
        color: rgba(219, 227, 237, 0.8);
    }

    .v6-blog-shell {
        margin-top: 24px;
    }

    .v6-blog-track {
        border-radius: 22px;
        border: 1px solid rgba(202, 210, 220, 0.92);
        background: rgba(255, 255, 255, 0.96);
        padding: 20px 22px 22px;
        box-shadow: 0 22px 42px rgba(10, 18, 28, 0.08);
        display: grid;
        gap: 14px;
    }

    .v6-blog-track.is-lead {
        background:
            radial-gradient(circle at top right, rgba(199, 163, 109, 0.12), transparent 34%),
            linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 250, 252, 0.98) 100%);
    }

    .v6-blog-track__head {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: flex-start;
    }

    .v6-blog-track__head p,
    .v6-blog-track__head h3,
    .v6-blog-track__head strong,
    .v6-blog-track__deck {
        margin: 0;
    }

    .v6-blog-track__head p {
        color: rgba(111, 127, 146, 0.9);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 11px;
        font-weight: 700;
    }

    .v6-blog-track__head h3 {
        margin-top: 8px;
        color: var(--v6-color-ink);
        font-family: var(--v6-font-display);
        font-size: clamp(28px, 2vw, 38px);
        line-height: 1.08;
        letter-spacing: -0.03em;
    }

    .v6-blog-track__head strong {
        min-width: 42px;
        min-height: 42px;
        display: grid;
        place-items: center;
        border-radius: 999px;
        background: rgba(199, 163, 109, 0.12);
        color: rgba(199, 163, 109, 0.96);
        font-size: 12px;
        letter-spacing: 0.16em;
    }

    .v6-blog-track__deck {
        color: rgba(18, 24, 35, 0.72);
        font-size: 16px;
        line-height: 1.58;
    }

    .v6-blog-track__list {
        margin: 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 10px;
    }

    .v6-blog-track__list li {
        position: relative;
        padding-left: 18px;
        color: rgba(18, 24, 35, 0.78);
        line-height: 1.55;
    }

    .v6-blog-track__list li::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.7em;
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: linear-gradient(180deg, rgba(199, 163, 109, 0.9), rgba(146, 165, 187, 0.82));
    }

    .v6-blog-track__links {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .v6-blog-track__links a {
        min-height: 38px;
        display: inline-flex;
        align-items: center;
        padding: 0 14px;
        border-radius: 999px;
        border: 1px solid rgba(199, 163, 109, 0.28);
        background: rgba(199, 163, 109, 0.08);
        color: var(--v6-color-moss);
        font-size: 14px;
        font-weight: 700;
    }

    .v6-blog-track__links a:hover,
    .v6-blog-track__links a:focus-visible {
        border-color: rgba(199, 163, 109, 0.62);
        background: rgba(199, 163, 109, 0.12);
    }

    @media (max-width: 1100px) {
        .v6-blog-hero-shell,
        .v6-blog-editorial__grid {
            grid-template-columns: 1fr;
        }

        .v6-blog-editorial__card.is-lead {
            grid-column: auto;
        }
    }

    @media (max-width: 900px) {
        .v6-blog-category-strip__grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .v6-blog-hero-shell__stats {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 720px) {
        .v6-page-hero-media--blog {
            padding: 14px 16px 0;
        }

        .v6-blog-category-strip,
        .v6-blog-editorial {
            padding: 0 16px;
