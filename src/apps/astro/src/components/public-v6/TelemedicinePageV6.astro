---
import BookingStatusV6 from './BookingStatusV6.astro';
import InternalStatementBandV6 from './InternalStatementBandV6.astro';
import PageHeadV6 from './PageHeadV6.astro';

const { page = {}, locale = 'es', navModel = {} } = Astro.props;
const pageHeadUi = navModel?.ui?.pageHead && typeof navModel.ui.pageHead === 'object' ? navModel.ui.pageHead : {};
const ui = page?.ui && typeof page.ui === 'object' ? page.ui : {};
const menuUi = ui?.menu && typeof ui.menu === 'object' ? ui.menu : {};
const thesisUi = ui?.thesis && typeof ui.thesis === 'object' ? ui.thesis : {};
const statementUi = ui?.statement && typeof ui.statement === 'object' ? ui.statement : {};
const internalMessageUi = ui?.internalMessage && typeof ui.internalMessage === 'object' ? ui.internalMessage : {};
const railUi = ui?.rail && typeof ui.rail === 'object' ? ui.rail : {};
const kpiUi = ui?.kpis && typeof ui.kpis === 'object' ? ui.kpis : {};
const initiativesUi = ui?.initiatives && typeof ui.initiatives === 'object' ? ui.initiatives : {};

const breadcrumb = Array.isArray(page.breadcrumb) ? page.breadcrumb : [];
const blocks = Array.isArray(page.blocks) ? page.blocks : [];
const initiativesRaw = Array.isArray(page.initiatives) ? page.initiatives : [];
const hasText = (value) => typeof value === 'string' && value.trim().length > 0;
const normalizeText = (value) => (hasText(value) ? value.trim() : '');
const normalizeHref = (value) => {
    const raw = normalizeText(value);
    return raw && raw !== '#' ? raw : '';
};
const makeMenuItem = (label, href) => (hasText(label) ? { label: label.trim(), href } : null);
const switchLabel = normalizeText(navModel?.header?.switchLabel);
const switchHref = normalizeHref(navModel?.header?.switchHref);
const menuLabel = normalizeText(navModel?.header?.menuLabel);
const blockModels = blocks
    .map((block, index) => {
        const title = normalizeText(block?.title);
        const mediaSrc = normalizeText(block?.image);
        const items = Array.isArray(block?.items) ? block.items.map(normalizeText).filter(Boolean) : [];
        return {
            title,
            items,
            mediaSrc,
            anchorId: `v6-tele-block-${index + 1}`,
        };
    })
    .filter((block) => block.title && block.items.length);
const totalCriteria = blockModels.reduce((total, block) => total + block.items.length, 0);
const initiatives = initiativesRaw
    .map((item) => ({
        title: normalizeText(item?.title),
        copy: normalizeText(item?.copy),
        image: normalizeText(item?.image),
        href: normalizeHref(item?.href),
    }))
    .filter((item) => hasText(item.title) && hasText(item.copy) && hasText(item.image) && hasText(item.href));

const pageMenuItems = blockModels
    .map((block) => makeMenuItem(block.title, `#${block.anchorId}`))
    .filter(Boolean);
if (initiatives.length) {
    const initiativesItem = makeMenuItem(menuUi.initiatives || '', '#v6-tele-initiatives');
    if (initiativesItem) {
        pageMenuItems.unshift(initiativesItem);
    }
}
const bookingStatus = page?.bookingStatus && typeof page.bookingStatus === 'object' ? page.bookingStatus : {};
const hasBookingStatus = Boolean(
    normalizeText(bookingStatus.eyebrow) ||
    normalizeText(bookingStatus.title) ||
    normalizeText(bookingStatus.description) ||
    (normalizeText(bookingStatus.ctaLabel) && normalizeHref(bookingStatus.ctaHref))
);
const bookingItem = hasBookingStatus ? makeMenuItem(menuUi.bookingStatus || '', '#v6-booking-status') : null;
if (bookingItem) {
    pageMenuItems.push(bookingItem);
}
const thesisEyebrow = normalizeText(thesisUi.eyebrow);
const thesisTitle = normalizeText(thesisUi.title);
const thesisBody = normalizeText(thesisUi.body);
const statement = {
    eyebrow: normalizeText(statementUi.eyebrow),
    title: normalizeText(statementUi.title),
    body: normalizeText(page.lead),
    signature: normalizeText(statementUi.signature),
    image: normalizeText(statementUi.image),
    alt: normalizeText(statementUi.alt),
};
const lead = normalizeText(page.lead);
const internalDescription = normalizeText(internalMessageUi.description);
const heroImageSrc = normalizeText(page?.heroImage?.src);
const heroImageSrcSet = normalizeText(page?.heroImage?.srcset);
const heroImageAlt = normalizeText(page?.heroImage?.alt) || normalizeText(page.heading);
const railTitle = normalizeText(railUi.title);
const railAria = normalizeText(railUi.aria);
const kpiCards = [
    normalizeText(kpiUi.blocks) ? { label: normalizeText(kpiUi.blocks), value: String(blockModels.length).padStart(2, '0') } : null,
    normalizeText(kpiUi.criteria) ? { label: normalizeText(kpiUi.criteria), value: String(totalCriteria).padStart(2, '0') } : null,
    normalizeText(kpiUi.model) && normalizeText(kpiUi.modelValue)
        ? { label: normalizeText(kpiUi.model), value: normalizeText(kpiUi.modelValue) }
        : null,
].filter(Boolean);
const blockCtaLabel = normalizeText(ui.blockCtaLabel);
const initiativesCtaLabel = normalizeText(initiativesUi.ctaLabel);
const initiativesAria = normalizeText(initiativesUi.aria);
---

<PageHeadV6
    breadcrumb={breadcrumb}
    heading={page.heading}
    locale={locale}
    switchLabel={switchLabel}
    switchHref={switchHref}
    menuLabel={menuLabel}
    menuItems={pageMenuItems}
    copy={pageHeadUi}
/>

{
    heroImageSrc ? (
        <section class="v6-page-hero-media is-internal" data-v6-internal-hero>
            <img src={heroImageSrc} srcset={heroImageSrcSet || undefined} alt={heroImageAlt} sizes="100vw" loading="eager" fetchpriority="high" />
        </section>
    ) : null
}

{
    lead || internalDescription ? (
        <section class="v6-internal-message" data-v6-internal-message>
            {lead ? <h2>{lead}</h2> : null}
            {internalDescription ? <p>{internalDescription}</p> : null}
        </section>
    ) : null
}

<InternalStatementBandV6 statement={statement} variant="tele" />

{
    thesisEyebrow || thesisTitle || thesisBody ? (
        <section class="v6-internal-thesis" data-v6-internal-thesis>
            {thesisEyebrow ? <p>{thesisEyebrow}</p> : null}
            {thesisTitle ? <h2>{thesisTitle}</h2> : null}
            {thesisBody ? <p>{thesisBody}</p> : null}
        </section>
    ) : null
}

<div class="v6-internal-shell" data-v6-internal-shell>
    {
        pageMenuItems.length || railTitle ? (
            <aside class="v6-internal-rail" data-v6-internal-rail>
                {railTitle ? <p>{railTitle}</p> : null}
                {
                    pageMenuItems.length ? (
                        <nav data-v6-section-nav="internal" aria-label={railAria || undefined}>
                            {
                                pageMenuItems.map((item) => (
                                    <a data-v6-section-link href={item.href}>{item.label}</a>
                                ))
                            }
                        </nav>
                    ) : null
                }
            </aside>
        ) : null
    }

    <div class="v6-internal-shell__body">
        {
            kpiCards.length ? (
                <section class="v6-tele-kpis v6-tele-kpis--shell" aria-label={normalizeText(kpiUi.aria) || undefined}>
                    {
                        kpiCards.map((item) => (
                            <article>
                                <p>{item.label}</p>
                                <h3>{item.value}</h3>
                            </article>
                        ))
                    }
                </section>
            ) : null
        }

        {
            initiatives.length ? (
                <section id="v6-tele-initiatives" class="v6-tele-initiatives v6-tele-initiatives--shell" aria-label={initiativesAria || undefined}>
                    {
                        initiatives.map((item) => (
                            <a href={item.href} data-v6-tele-initiative>
                                <figure>
                                    <img src={item.image} alt={item.title} loading="lazy" decoding="async" />
                                </figure>
                                <div>
                                    <h3>{item.title}</h3>
                                    <p>{item.copy}</p>
                                    {initiativesCtaLabel ? (
                                        <strong>
                                            {initiativesCtaLabel}
                                            <span aria-hidden="true">></span>
                                        </strong>
                                    ) : null}
                                </div>
                            </a>
                        ))
                    }
                </section>
            ) : null
        }

        <section class="v6-tele-grid v6-tele-grid--shell">
            {
                blockModels.map((block, index) => (
                    <article id={block.anchorId} class:list={[index === 0 && 'is-lead']} data-v6-tele-block>
                        {
                            block.mediaSrc ? (
                                <figure class="v6-tele-grid__media">
                                    <img src={block.mediaSrc} alt={block.title} loading="lazy" decoding="async" />
                                </figure>
                            ) : null
                        }
                        <div class="v6-tele-grid__body">
                            <p class="v6-tele-grid__index">{String(index + 1).padStart(2, '0')}</p>
                            <h3>{block.title}</h3>
                            <ul>
                                {block.items.map((item) => <li>{item}</li>)}
                            </ul>
                            {blockCtaLabel && hasBookingStatus ? (
                                <a href="#v6-booking-status">
                                    {blockCtaLabel}
                                    <span aria-hidden="true">></span>
                                </a>
                            ) : null}
                        </div>
                    </article>
                ))
            }
        </section>
    </div>
</div>

<BookingStatusV6 status={page.bookingStatus} sectionId="v6-booking-status" />

