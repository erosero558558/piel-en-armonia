---
import '../../styles/public-v6/internal.css';

import BookingStatusV6 from './BookingStatusV6.astro';
import InternalStatementBandV6 from './InternalStatementBandV6.astro';
import PageHeadV6 from './PageHeadV6.astro';

const { page = {}, locale = 'es', navModel = {} } = Astro.props;
const pageHeadUi = navModel?.ui?.pageHead && typeof navModel.ui.pageHead === 'object' ? navModel.ui.pageHead : {};
const ui = page?.ui && typeof page.ui === 'object' ? page.ui : {};
const menuUi = ui?.menu && typeof ui.menu === 'object' ? ui.menu : {};
const thesisUi = ui?.thesis && typeof ui.thesis === 'object' ? ui.thesis : {};
const statementUi = ui?.statement && typeof ui.statement === 'object' ? ui.statement : {};
const internalMessageUi = ui?.internalMessage && typeof ui.internalMessage === 'object' ? ui.internalMessage : {};
const railUi = ui?.rail && typeof ui.rail === 'object' ? ui.rail : {};
const kpiUi = ui?.kpis && typeof ui.kpis === 'object' ? ui.kpis : {};
const initiativesUi = ui?.initiatives && typeof ui.initiatives === 'object' ? ui.initiatives : {};

const breadcrumb = Array.isArray(page.breadcrumb) ? page.breadcrumb : [];
const blocks = Array.isArray(page.blocks) ? page.blocks : [];
const initiativesRaw = Array.isArray(page.initiatives) ? page.initiatives : [];
const hasText = (value) => typeof value === 'string' && value.trim().length > 0;
const normalizeText = (value) => (hasText(value) ? value.trim() : '');
const normalizeHref = (value) => {
    const raw = normalizeText(value);
    return raw && raw !== '#' ? raw : '';
};
const makeMenuItem = (label, href) => (hasText(label) ? { label: label.trim(), href } : null);
const switchLabel = normalizeText(navModel?.header?.switchLabel);
const switchHref = normalizeHref(navModel?.header?.switchHref);
const menuLabel = normalizeText(navModel?.header?.menuLabel);
const blockModels = blocks
    .map((block, index) => {
        const title = normalizeText(block?.title);
        const mediaSrc = normalizeText(block?.image);
        const mediaSrcSet = normalizeText(block?.srcset);
        const mediaAlt = normalizeText(block?.alt) || title;
        const items = Array.isArray(block?.items) ? block.items.map(normalizeText).filter(Boolean) : [];
        return {
            title,
            items,
            mediaSrc,
            mediaSrcSet,
            mediaAlt,
            anchorId: `v6-tele-block-${index + 1}`,
        };
    })
    .filter((block) => block.title && block.items.length);
const totalCriteria = blockModels.reduce((total, block) => total + block.items.length, 0);
const initiatives = initiativesRaw
    .map((item) => ({
        title: normalizeText(item?.title),
        copy: normalizeText(item?.copy),
        image: normalizeText(item?.image),
        srcset: normalizeText(item?.srcset),
        alt: normalizeText(item?.alt) || normalizeText(item?.title),
        href: normalizeHref(item?.href),
    }))
    .filter((item) => hasText(item.title) && hasText(item.copy) && hasText(item.image) && hasText(item.href));

const pageMenuItems = [];
const glanceItem = makeMenuItem(menuUi.glance || '', '#v6-tele-glance');
if (glanceItem) {
    pageMenuItems.push(glanceItem);
}
pageMenuItems.push(
    ...blockModels.map((block) => makeMenuItem(block.title, `#${block.anchorId}`)).filter(Boolean)
);
if (initiatives.length) {
    const initiativesItem = makeMenuItem(menuUi.initiatives || '', '#v6-tele-initiatives');
    if (initiativesItem) {
        pageMenuItems.push(initiativesItem);
    }
}
const bookingStatus = page?.bookingStatus && typeof page.bookingStatus === 'object' ? page.bookingStatus : {};
const hasBookingStatus = Boolean(
    normalizeText(bookingStatus.eyebrow) ||
    normalizeText(bookingStatus.title) ||
    normalizeText(bookingStatus.description) ||
    (normalizeText(bookingStatus.ctaLabel) && normalizeHref(bookingStatus.ctaHref))
);
const bookingItem = hasBookingStatus ? makeMenuItem(menuUi.bookingStatus || '', '#v6-booking-status') : null;
if (bookingItem) {
    pageMenuItems.push(bookingItem);
}
const thesisEyebrow = normalizeText(thesisUi.eyebrow);
const thesisTitle = normalizeText(thesisUi.title);
const thesisBody = normalizeText(thesisUi.body);
const statement = {
    eyebrow: normalizeText(statementUi.eyebrow),
    title: normalizeText(statementUi.title),
    body: normalizeText(page.lead),
    signature: normalizeText(statementUi.signature),
    image: normalizeText(statementUi.image),
    imageSrcset: normalizeText(statementUi.imageSrcset || statementUi.srcset),
    alt: normalizeText(statementUi.alt),
};
const lead = normalizeText(page.lead);
const internalDescription = normalizeText(internalMessageUi.description);
const internalMessageTitle =
    locale === 'en'
        ? 'Where remote care helps, and where it should switch'
        : 'Donde ayuda a distancia y donde conviene cambiar';
const heroImageSrc = normalizeText(page?.heroImage?.src);
const heroImageSrcSet = normalizeText(page?.heroImage?.srcset);
const heroImageAlt = normalizeText(page?.heroImage?.alt) || normalizeText(page.heading);
const railTitle = normalizeText(railUi.title);
const railAria = normalizeText(railUi.aria);
const kpiCards = [
    normalizeText(kpiUi.blocks) ? { label: normalizeText(kpiUi.blocks), value: String(blockModels.length).padStart(2, '0') } : null,
    normalizeText(kpiUi.criteria) ? { label: normalizeText(kpiUi.criteria), value: String(totalCriteria).padStart(2, '0') } : null,
    normalizeText(kpiUi.model) && normalizeText(kpiUi.modelValue)
        ? { label: normalizeText(kpiUi.model), value: normalizeText(kpiUi.modelValue) }
        : null,
].filter(Boolean);
const blockCtaLabel = normalizeText(ui.blockCtaLabel);
const initiativesCtaLabel = normalizeText(initiativesUi.ctaLabel);
const initiativesAria = normalizeText(initiativesUi.aria);
const heroSummaryLabel = locale === 'en' ? 'Teledermatology' : 'Teledermatologia';
const heroSummaryTitle =
    locale === 'en'
        ? 'Remote care with clear clinical thresholds'
        : 'Atencion remota con umbrales clinicos claros';
const heroBookingLabel =
    normalizeText(bookingStatus.ctaLabel) && normalizeHref(bookingStatus.ctaHref)
        ? {
              label: normalizeText(bookingStatus.ctaLabel),
              href: normalizeHref(bookingStatus.ctaHref),
          }
        : null;
const teleBlockVariants = ['fit', 'limit', 'handoff'];
---

<PageHeadV6
    breadcrumb={breadcrumb}
    heading={page.heading}
    locale={locale}
    switchLabel={switchLabel}
    switchHref={switchHref}
    menuLabel={menuLabel}
    menuItems={pageMenuItems}
    copy={pageHeadUi}
/>

{
    heroImageSrc ? (
        <section class="v6-page-hero-media is-internal v6-page-hero-media--tele" data-v6-internal-hero>
            <div class="v6-tele-hero-shell">
                <figure class="v6-tele-hero-shell__media">
                    <img
                        src={heroImageSrc}
                        srcset={heroImageSrcSet || undefined}
                        alt={heroImageAlt}
                        sizes="(max-width: 1100px) 100vw, 62vw"
                        loading="eager"
                        decoding="sync"
                        fetchpriority="high"
                    />
                </figure>
                <aside class="v6-tele-hero-shell__panel">
                    <p class="v6-tele-hero-shell__eyebrow">{heroSummaryLabel}</p>
                    <h2>{heroSummaryTitle}</h2>
                    {lead ? <p>{lead}</p> : null}
                    {
                        kpiCards.length ? (
                            <div class="v6-tele-hero-shell__chips" aria-hidden="true">
                                {
                                    kpiCards.map((item) => (
                                        <article>
                                            <span>{item.label}</span>
                                            <strong>{item.value}</strong>
                                        </article>
                                    ))
                                }
                            </div>
                        ) : null
                    }
                    {
                        heroBookingLabel ? (
                            <a class="v6-tele-hero-shell__cta" href={heroBookingLabel.href}>
                                {heroBookingLabel.label}
                                <span aria-hidden="true">></span>
                            </a>
                        ) : null
                    }
                </aside>
            </div>
        </section>
    ) : null
}

{
    internalMessageTitle || internalDescription ? (
        <section class="v6-internal-message" data-v6-internal-message>
            {internalMessageTitle ? <h2>{internalMessageTitle}</h2> : null}
            {internalDescription ? <p>{internalDescription}</p> : null}
        </section>
    ) : null
}

<InternalStatementBandV6 statement={statement} variant="tele" />

{
    thesisEyebrow || thesisTitle || thesisBody ? (
        <section class="v6-internal-thesis" data-v6-internal-thesis>
            {thesisEyebrow ? <p>{thesisEyebrow}</p> : null}
            {thesisTitle ? <h2>{thesisTitle}</h2> : null}
            {thesisBody ? <p>{thesisBody}</p> : null}
        </section>
    ) : null
}

<div class="v6-internal-shell" data-v6-internal-shell>
    {
        pageMenuItems.length || railTitle ? (
            <aside class="v6-internal-rail" data-v6-internal-rail>
                {railTitle ? <p>{railTitle}</p> : null}
                {
                    pageMenuItems.length ? (
                        <nav data-v6-section-nav="internal" aria-label={railAria || undefined}>
                            {
                                pageMenuItems.map((item) => (
                                    <a data-v6-section-link href={item.href}>{item.label}</a>
                                ))
                            }
                        </nav>
                    ) : null
                }
            </aside>
        ) : null
    }

    <div class="v6-internal-shell__body">
        {
            kpiCards.length ? (
                <section id="v6-tele-glance" class="v6-tele-kpis v6-tele-kpis--shell" aria-label={normalizeText(kpiUi.aria) || undefined}>
                    {
                        kpiCards.map((item) => (
                            <article>
                                <p>{item.label}</p>
                                <h3>{item.value}</h3>
                            </article>
                        ))
                    }
                </section>
            ) : null
        }

        {
            blockModels.length ? (
                <section class="v6-tele-grid v6-tele-grid--shell">
                    {
                        blockModels.map((block, index) => (
                            <article
                                id={block.anchorId}
                                class:list={[index === 0 && 'is-lead']}
                                data-v6-tele-block
                                data-v6-tele-block-variant={teleBlockVariants[index] || 'support'}
                            >
                                {
                                    block.mediaSrc ? (
                                        <figure class="v6-tele-grid__media">
                                            <img
                                                src={block.mediaSrc}
                                                srcset={block.mediaSrcSet || undefined}
                                                sizes="(max-width: 900px) 100vw, 40vw"
                                                alt={block.mediaAlt}
                                                loading="lazy"
                                                decoding="async"
                                                fetchpriority="low"
                                            />
                                        </figure>
                                    ) : null
                                }
                                <div class="v6-tele-grid__body">
                                    <p class="v6-tele-grid__index">{String(index + 1).padStart(2, '0')}</p>
                                    <h3>{block.title}</h3>
                                    <ul>
                                        {block.items.map((item) => <li>{item}</li>)}
                                    </ul>
                                    {blockCtaLabel && hasBookingStatus ? (
                                        <a href="#v6-booking-status">
                                            {blockCtaLabel}
                                            <span aria-hidden="true">></span>
                                        </a>
                                    ) : null}
                                </div>
                            </article>
                        ))
                    }
                </section>
            ) : null
        }

        {
            initiatives.length ? (
                <section id="v6-tele-initiatives" class="v6-tele-initiatives v6-tele-initiatives--shell" aria-label={initiativesAria || undefined}>
                    {
                        initiatives.map((item, index) => (
                            <a href={item.href} data-v6-tele-initiative>
                                <figure>
                                    <img
                                        src={item.image}
                                        srcset={item.srcset || undefined}
                                        sizes="(max-width: 720px) 100vw, (max-width: 1100px) 50vw, 30vw"
                                        alt={item.alt}
                                        loading="lazy"
                                        decoding="async"
                                        fetchpriority="low"
                                    />
                                </figure>
                                <div class="v6-tele-initiative-card__body">
                                    <p class="v6-tele-initiative-card__index">{String(index + 1).padStart(2, '0')}</p>
                                    <h3>{item.title}</h3>
                                    <p class="v6-tele-initiative-card__copy">{item.copy}</p>
                                    {initiativesCtaLabel ? (
                                        <strong class="v6-tele-initiative-card__cta">
                                            {initiativesCtaLabel}
                                            <span aria-hidden="true">></span>
                                        </strong>
                                    ) : null}
                                </div>
                            </a>
                        ))
                    }
                </section>
            ) : null
        }
    </div>
</div>

<BookingStatusV6 status={page.bookingStatus} sectionId="v6-booking-status" />

<style>
    .v6-page-hero-media--tele {
        background:
            radial-gradient(circle at top left, rgba(199, 163, 109, 0.2), transparent 28%),
            radial-gradient(circle at 82% 18%, rgba(146, 165, 187, 0.14), transparent 30%),
            linear-gradient(180deg, #05070b 0%, #0d1726 100%);
        padding: 20px clamp(18px, 3vw, 28px) 8px;
    }

    .v6-tele-hero-shell {
        max-width: 1320px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: minmax(0, 1.3fr) minmax(320px, 0.7fr);
        gap: clamp(18px, 2vw, 26px);
        align-items: center;
    }

    .v6-tele-hero-shell__media {
        margin: 0;
        overflow: hidden;
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: #121b28;
        box-shadow: 0 28px 58px rgba(8, 13, 20, 0.24);
    }

    .v6-tele-hero-shell__media img {
        display: block;
        width: 100%;
        height: clamp(320px, 31vw, 480px);
        object-fit: cover;
        object-position: center;
    }

    .v6-tele-hero-shell__panel {
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background:
            radial-gradient(circle at top right, rgba(199, 163, 109, 0.16), transparent 34%),
            linear-gradient(180deg, rgba(10, 15, 22, 0.96) 0%, rgba(16, 24, 38, 0.96) 100%);
        box-shadow: 0 24px 46px rgba(8, 13, 20, 0.24);
        padding: clamp(22px, 2.1vw, 30px);
        display: grid;
        gap: 14px;
    }

    .v6-tele-hero-shell__eyebrow,
    .v6-tele-hero-shell__panel h2,
    .v6-tele-hero-shell__panel > p,
    .v6-tele-hero-shell__support,
    .v6-tele-hero-shell__chips span,
    .v6-tele-hero-shell__chips strong {
        margin: 0;
    }

    .v6-tele-hero-shell__eyebrow,
    .v6-tele-hero-shell__chips span {
        color: rgba(199, 163, 109, 0.88);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 10px;
        font-weight: 700;
    }

    .v6-tele-hero-shell__panel h2 {
        color: #f4f7fb;
        font-family: var(--v6-font-display);
        font-size: clamp(32px, 2.6vw, 43px);
        line-height: 1.04;
        letter-spacing: -0.04em;
    }

    .v6-tele-hero-shell__panel > p,
    .v6-tele-hero-shell__support {
        color: rgba(219, 227, 237, 0.76);
        font-size: clamp(16px, 1.12vw, 19px);
        line-height: 1.56;
    }

    .v6-tele-hero-shell__support {
        color: rgba(185, 197, 212, 0.72);
    }

    .v6-tele-hero-shell__chips {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
    }

    .v6-tele-hero-shell__chips article {
        min-height: 86px;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.08);
        padding: 12px 13px 13px;
        display: grid;
        gap: 6px;
    }

    .v6-tele-hero-shell__chips strong {
        color: #f4f7fb;
        font-size: clamp(17px, 1.45vw, 24px);
        line-height: 1.15;
    }

    .v6-tele-hero-shell__cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        min-height: 44px;
        width: fit-content;
        padding: 0 18px;
        border-radius: 999px;
        background: linear-gradient(180deg, rgba(199, 163, 109, 0.22) 0%, rgba(199, 163, 109, 0.08) 100%);
        color: #f4f7fb;
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 0.01em;
        border: 1px solid rgba(199, 163, 109, 0.34);
        box-shadow: 0 14px 28px rgba(8, 13, 20, 0.18);
    }

    .v6-tele-hero-shell__cta:hover,
    .v6-tele-hero-shell__cta:focus-visible {
        background: linear-gradient(180deg, rgba(199, 163, 109, 0.3) 0%, rgba(199, 163, 109, 0.12) 100%);
    }

    @media (max-width: 1100px) {
        .v6-tele-hero-shell {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 720px) {
        .v6-page-hero-media--tele {
            padding: 14px 16px 0;
        }

        .v6-tele-hero-shell__media,
        .v6-tele-hero-shell__panel {
            border-radius: 20px;
        }

        .v6-tele-hero-shell__media img {
            height: 300px;
        }

        .v6-tele-hero-shell__panel {
            padding: 18px 16px;
        }

        .v6-tele-hero-shell__chips {
            grid-template-columns: 1fr;
        }
    }
</style>
