---
import '../../styles/public-v6/payment-checkout.css';

import PageHeadV6 from './PageHeadV6.astro';

const { page = {}, locale = 'es', navModel = {} } = Astro.props;

const hasText = (value) => typeof value === 'string' && value.trim().length > 0;
const normalizeText = (value) => (hasText(value) ? value.trim() : '');
const normalizeHref = (value) => {
    const raw = normalizeText(value);
    return raw && raw !== '#' ? raw : '';
};
const makeMenuItem = (label, href) => {
    const safeLabel = normalizeText(label);
    const safeHref = normalizeHref(href);
    return safeLabel && safeHref ? { label: safeLabel, href: safeHref } : null;
};

const pageHeadUi = navModel?.ui?.pageHead && typeof navModel.ui.pageHead === 'object' ? navModel.ui.pageHead : {};
const breadcrumb = Array.isArray(page?.breadcrumb) ? page.breadcrumb : [];
const sections = Array.isArray(page?.sections) ? page.sections : [];
const hero = page?.hero && typeof page.hero === 'object' ? page.hero : {};
const pageMenuItems = sections.map((item) => makeMenuItem(item?.label, item?.href)).filter(Boolean);
const supportHref = 'https://wa.me/593982453672?text=Hola%2C%20necesito%20ayuda%20con%20un%20checkout%20de%20Aurora%20Derm';
---

<PageHeadV6
    breadcrumb={breadcrumb}
    heading={page.heading}
    locale={locale}
    switchLabel=""
    switchHref=""
    menuLabel={page.menuLabel}
    menuItems={pageMenuItems}
    copy={pageHeadUi}
/>

<section class="v6-pay-hero" data-v6-pay-hero>
    <div class="v6-pay-hero__copy">
        {normalizeText(hero.eyebrow) ? <p class="v6-pay-hero__eyebrow">{hero.eyebrow}</p> : null}
        {normalizeText(hero.title) ? <h2>{hero.title}</h2> : null}
        {normalizeText(hero.body) ? <p class="v6-pay-hero__body">{hero.body}</p> : null}
        {
            Array.isArray(hero?.highlights) && hero.highlights.length ? (
                <div class="v6-pay-hero__highlights">
                    {
                        hero.highlights.map((item) => (
                            <article class="v6-pay-hero__metric">
                                <span>{normalizeText(item?.label)}</span>
                                <strong>{normalizeText(item?.value)}</strong>
                            </article>
                        ))
                    }
                </div>
            ) : null
        }
    </div>
    <aside class="v6-pay-hero__panel">
        <p>Antes de confirmar</p>
        <h3>El checkout queda util incluso si el cobro todavia no termina.</h3>
        <ul>
            <li>Tarjeta: confirma el cobro con Stripe y deja el recibo pagado.</li>
            <li>Transferencia: abre el recibo pendiente con referencia para seguir el caso.</li>
            <li>Efectivo: deja el pago reservado para caja en consultorio.</li>
        </ul>
        <a href="#v6-pay-form">Ir al checkout</a>
    </aside>
</section>

<div
    class="v6-pay-shell"
    data-v6-pay-root
    data-api-config="/api.php?resource=checkout-config"
    data-api-intent="/api.php?resource=checkout-intent"
    data-api-confirm="/api.php?resource=checkout-confirm"
    data-api-submit="/api.php?resource=checkout-submit"
    data-support-href={supportHref}
>
    <section id="v6-pay-form" class="v6-pay-form-card" data-v6-pay-form-card>
        <div class="v6-pay-section-head">
            <p>Checkout integrado</p>
            <h2>Monto, concepto y metodo en una sola superficie.</h2>
            <p>
                Sirve para cobrar consulta, anticipo, control o saldo. El recibo digital sale desde el mismo
                flujo para que frontdesk y paciente hablen sobre el mismo numero.
            </p>
        </div>

        <form class="v6-pay-form" data-checkout-form novalidate>
            <div class="v6-pay-field is-full">
                <label for="checkout-concept">Concepto</label>
                <input
                    id="checkout-concept"
                    name="concept"
                    type="text"
                    maxlength="160"
                    placeholder="Ejemplo: Consulta dermatologica, saldo de procedimiento o control de acne"
                    required
                />
            </div>

            <div class="v6-pay-field">
                <label for="checkout-amount">Monto (USD)</label>
                <input
                    id="checkout-amount"
                    name="amount"
                    type="text"
                    inputmode="decimal"
                    maxlength="20"
                    placeholder="40.00"
                    required
                />
            </div>

            <div class="v6-pay-field">
                <label for="checkout-name">Paciente o responsable</label>
                <input
                    id="checkout-name"
                    name="name"
                    type="text"
                    maxlength="150"
                    autocomplete="name"
                    required
                />
            </div>

            <div class="v6-pay-field">
                <label for="checkout-email">Correo</label>
                <input
                    id="checkout-email"
                    name="email"
                    type="email"
                    maxlength="254"
                    autocomplete="email"
                    placeholder="paciente@correo.com"
                />
            </div>

            <div class="v6-pay-field">
                <label for="checkout-whatsapp">WhatsApp</label>
                <input
                    id="checkout-whatsapp"
                    name="whatsapp"
                    type="tel"
                    maxlength="20"
                    autocomplete="tel"
                    inputmode="tel"
                    placeholder="+593 98 245 3672"
                />
            </div>

            <div class="v6-pay-field is-full">
                <label for="checkout-notes">Nota opcional</label>
                <textarea
                    id="checkout-notes"
                    name="notes"
                    rows="3"
                    maxlength="300"
                    placeholder="Ejemplo: saldo final, control a 15 dias o anticipo para procedimiento."
                ></textarea>
            </div>

            <div class="v6-pay-field is-full">
                <div class="v6-pay-methods-head">
                    <label>Metodo de pago</label>
                    <p>Puede cambiar de metodo sin perder monto ni concepto.</p>
                </div>
                <input type="hidden" name="paymentMethod" value="card" data-checkout-method-input />
                <div class="v6-pay-methods" data-checkout-methods>
                    <button type="button" class="v6-pay-method is-active" data-checkout-method="card">
                        <strong>Tarjeta</strong>
                        <span>Confirma el cobro al instante con Stripe.</span>
                    </button>
                    <button type="button" class="v6-pay-method" data-checkout-method="transfer">
                        <strong>Transferencia</strong>
                        <span>Genera el checkout pendiente y deja referencia para seguimiento.</span>
                    </button>
                    <button type="button" class="v6-pay-method" data-checkout-method="cash">
                        <strong>Efectivo</strong>
                        <span>Emite recibo pendiente para caja en consultorio.</span>
                    </button>
                </div>
            </div>

            <div class="v6-pay-method-panel" data-checkout-panel="card">
                <div class="v6-pay-panel-head">
                    <p>Pago con Stripe</p>
                    <h3>Confirme la tarjeta sin salir del checkout.</h3>
                </div>
                <div class="v6-pay-field">
                    <label for="checkout-cardholder">Nombre en la tarjeta</label>
                    <input
                        id="checkout-cardholder"
                        name="cardholderName"
                        type="text"
                        maxlength="150"
                        autocomplete="cc-name"
                        placeholder="Como aparece en la tarjeta"
                    />
                </div>
                <div class="v6-pay-field is-full">
                    <label for="checkout-stripe-element">Datos de tarjeta</label>
                    <div id="checkout-stripe-element" class="v6-pay-stripe" data-checkout-stripe-element></div>
                    <p class="v6-pay-inline-note" data-checkout-card-note>
                        Cargando Stripe para este checkout...
                    </p>
                </div>
            </div>

            <div class="v6-pay-method-panel" data-checkout-panel="transfer" hidden>
                <div class="v6-pay-panel-head">
                    <p>Transferencia bancaria</p>
                    <h3>Deje el cobro abierto y siga con el comprobante en el siguiente paso.</h3>
                </div>
                <article class="v6-pay-bank" data-checkout-bank>
                    <p data-checkout-bank-name>Banco Pichincha</p>
                    <strong data-checkout-bank-account>Cuenta de Ahorros: 2200160272</strong>
                    <span data-checkout-bank-owner>Titular: Rosero Caiza Javier Alejandro</span>
                </article>
                <div class="v6-pay-field is-full">
                    <label for="checkout-transfer-reference">Numero de referencia (opcional por ahora)</label>
                    <input
                        id="checkout-transfer-reference"
                        name="transferReference"
                        type="text"
                        maxlength="100"
                        inputmode="text"
                        placeholder="Ejemplo: TRX-9842"
                    />
                    <p class="v6-pay-inline-note">
                        En el siguiente hito sumaremos subida y verificacion del comprobante sin cambiar este checkout.
                    </p>
                </div>
            </div>

            <div class="v6-pay-method-panel" data-checkout-panel="cash" hidden>
                <div class="v6-pay-panel-head">
                    <p>Pago en consultorio</p>
                    <h3>Genere el recibo pendiente y cierre en caja presencial.</h3>
                </div>
                <div class="v6-pay-cash">
                    <p>
                        Este metodo deja el cobro marcado como pendiente de caja. Sirve para pacientes que prefieren
                        pagar al llegar o para procedimientos que se confirman el mismo dia.
                    </p>
                </div>
            </div>

            <div class="v6-pay-actions">
                <button type="submit" data-checkout-submit>Generar checkout</button>
                <a href={supportHref} target="_blank" rel="noopener noreferrer">
                    Necesito ayuda por WhatsApp
                </a>
            </div>

            <div class="v6-pay-status" data-checkout-status role="status" aria-live="polite" hidden></div>
        </form>
    </section>

    <aside id="v6-pay-methods" class="v6-pay-sidecar" data-v6-pay-sidecar>
        <div class="v6-pay-section-head">
            <p>Resumen vivo</p>
            <h2>El recibo sale desde el mismo dato que acaba de confirmar.</h2>
        </div>

        <article class="v6-pay-summary" data-checkout-summary>
            <dl>
                <div>
                    <dt>Concepto</dt>
                    <dd data-checkout-summary-concept>Sin definir todavia</dd>
                </div>
                <div>
                    <dt>Monto</dt>
                    <dd data-checkout-summary-amount>$0.00</dd>
                </div>
                <div>
                    <dt>Metodo</dt>
                    <dd data-checkout-summary-method>Tarjeta</dd>
                </div>
            </dl>
        </article>

        <article class="v6-pay-support">
            <p>Lo que deja listo esta pagina</p>
            <ul>
                <li>Un checkout persistido en backend aunque el metodo sea manual.</li>
                <li>Un numero de recibo digital para seguimiento por WhatsApp.</li>
                <li>La misma base para sumar validacion administrativa de transferencias.</li>
            </ul>
        </article>

        <article class="v6-pay-receipt-card" data-checkout-receipt hidden>
            <div class="v6-pay-receipt-card__head">
                <p>Recibo digital</p>
                <h2 data-checkout-receipt-number>PAY-00000000-000000</h2>
            </div>
            <dl class="v6-pay-receipt-card__grid">
                <div>
                    <dt>Concepto</dt>
                    <dd data-checkout-receipt-concept>-</dd>
                </div>
                <div>
                    <dt>Total</dt>
                    <dd data-checkout-receipt-amount>$0.00</dd>
                </div>
                <div>
                    <dt>Metodo</dt>
                    <dd data-checkout-receipt-method>-</dd>
                </div>
                <div>
                    <dt>Estado</dt>
                    <dd data-checkout-receipt-status>-</dd>
                </div>
                <div>
                    <dt>Paciente o responsable</dt>
                    <dd data-checkout-receipt-payer>-</dd>
                </div>
                <div>
                    <dt>Emitido</dt>
                    <dd data-checkout-receipt-issued>-</dd>
                </div>
                <div data-checkout-receipt-reference-row hidden>
                    <dt>Referencia</dt>
                    <dd data-checkout-receipt-reference>-</dd>
                </div>
            </dl>
            <div class="v6-pay-receipt-card__actions">
                <button type="button" data-checkout-print>Imprimir recibo</button>
                <a href={supportHref} target="_blank" rel="noopener noreferrer" data-checkout-receipt-whatsapp>
                    Compartir por WhatsApp
                </a>
            </div>
        </article>
    </aside>
</div>

<section id="v6-pay-receipt" class="v6-pay-lane" data-v6-pay-lane>
    <article class="v6-pay-lane__card">
        <p>Despues de generar el checkout</p>
        <h2>El recibo digital no reemplaza la operacion. La ordena.</h2>
        <ul>
            <li>Tarjeta deja el cobro como pagado apenas Stripe confirma.</li>
            <li>Transferencia deja un recibo pendiente para continuar con el comprobante.</li>
            <li>Efectivo deja el cobro abierto para caja en consultorio.</li>
        </ul>
    </article>
    <article class="v6-pay-lane__card">
        <p>Siguiente paso del sprint</p>
        <h2>La misma orden servira para verificar transferencias sin rehacer esta pagina.</h2>
        <ul>
            <li>La orden ya persiste concepto, monto, metodo y referencia.</li>
            <li>El recibo digital ya da un numero comun para paciente y frontdesk.</li>
            <li>Solo falta sumar comprobante y aprobacion administrativa sobre la misma base.</li>
        </ul>
    </article>
</section>

<script is:inline>
    (() => {
        const root = document.querySelector('[data-v6-pay-root]');
        if (!(root instanceof HTMLElement)) {
            return;
        }

        const form = root.querySelector('[data-checkout-form]');
        const methodInput = root.querySelector('[data-checkout-method-input]');
        const methodButtons = Array.from(root.querySelectorAll('[data-checkout-method]'));
        const methodPanels = Array.from(root.querySelectorAll('[data-checkout-panel]'));
        const statusNode = root.querySelector('[data-checkout-status]');
        const submitButton = root.querySelector('[data-checkout-submit]');
        const amountInput = root.querySelector('#checkout-amount');
        const conceptInput = root.querySelector('#checkout-concept');
        const nameInput = root.querySelector('#checkout-name');
        const emailInput = root.querySelector('#checkout-email');
        const whatsappInput = root.querySelector('#checkout-whatsapp');
        const cardholderInput = root.querySelector('#checkout-cardholder');
        const summaryConcept = root.querySelector('[data-checkout-summary-concept]');
        const summaryAmount = root.querySelector('[data-checkout-summary-amount]');
        const summaryMethod = root.querySelector('[data-checkout-summary-method]');
        const receiptNode = root.querySelector('[data-checkout-receipt]');
        const receiptNumberNode = root.querySelector('[data-checkout-receipt-number]');
        const receiptConceptNode = root.querySelector('[data-checkout-receipt-concept]');
        const receiptAmountNode = root.querySelector('[data-checkout-receipt-amount]');
        const receiptMethodNode = root.querySelector('[data-checkout-receipt-method]');
        const receiptStatusNode = root.querySelector('[data-checkout-receipt-status]');
        const receiptPayerNode = root.querySelector('[data-checkout-receipt-payer]');
        const receiptIssuedNode = root.querySelector('[data-checkout-receipt-issued]');
        const receiptReferenceNode = root.querySelector('[data-checkout-receipt-reference]');
        const receiptReferenceRow = root.querySelector('[data-checkout-receipt-reference-row]');
        const receiptWhatsappLink = root.querySelector('[data-checkout-receipt-whatsapp]');
        const bankNameNode = root.querySelector('[data-checkout-bank-name]');
        const bankAccountNode = root.querySelector('[data-checkout-bank-account]');
        const bankOwnerNode = root.querySelector('[data-checkout-bank-owner]');
        const cardNote = root.querySelector('[data-checkout-card-note]');
        const printButton = root.querySelector('[data-checkout-print]');
        const configUrl = root.dataset.apiConfig || '/api.php?resource=checkout-config';
        const intentUrl = root.dataset.apiIntent || '/api.php?resource=checkout-intent';
        const confirmUrl = root.dataset.apiConfirm || '/api.php?resource=checkout-confirm';
        const submitUrl = root.dataset.apiSubmit || '/api.php?resource=checkout-submit';
        const supportHref = root.dataset.supportHref || 'https://wa.me/593982453672';

        if (!(form instanceof HTMLFormElement) || !(methodInput instanceof HTMLInputElement)) {
            return;
        }

        const state = {
            config: null,
            stripe: null,
            cardElement: null,
            activeMethod: methodInput.value || 'card',
            busy: false,
        };

        const methodLabels = {
            card: 'Tarjeta',
            transfer: 'Transferencia',
            cash: 'Efectivo en consultorio',
        };

        const getText = (value, fallback = '') => {
            const safe = String(value || '').trim();
            return safe || fallback;
        };

        const formatCurrency = (value) => {
            const raw = String(value || '').trim();
            if (!raw) {
                return '$0.00';
            }

            const normalized = raw
                .replace(/[^0-9.,]/g, '')
                .replace(/,/g, (raw.includes('.') ? '' : '.'));
            const amount = Number.parseFloat(normalized);
            if (!Number.isFinite(amount)) {
                return '$0.00';
            }
            return `$${amount.toFixed(2)}`;
        };

        const showStatus = (message, tone = 'info') => {
            if (!(statusNode instanceof HTMLElement)) {
                return;
            }
            const text = getText(message);
            if (!text) {
                statusNode.hidden = true;
                statusNode.textContent = '';
                statusNode.dataset.tone = '';
                return;
            }
            statusNode.hidden = false;
            statusNode.dataset.tone = tone;
            statusNode.textContent = text;
        };

        const setBusy = (busy) => {
            state.busy = busy === true;
            if (submitButton instanceof HTMLButtonElement) {
                submitButton.disabled = state.busy;
                submitButton.textContent = state.busy ? 'Procesando...' : 'Generar checkout';
            }
        };

        const readQueryPrefill = () => {
            const url = new URL(window.location.href);
            const mapping = [
                ['concept', conceptInput],
                ['amount', amountInput],
                ['name', nameInput],
                ['email', emailInput],
                ['whatsapp', whatsappInput],
            ];

            mapping.forEach(([key, field]) => {
                if (!(field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement)) {
                    return;
                }
                const value = getText(url.searchParams.get(key));
                if (value && !field.value) {
                    field.value = value;
                }
            });

            if (cardholderInput instanceof HTMLInputElement && nameInput instanceof HTMLInputElement && !cardholderInput.value) {
                cardholderInput.value = nameInput.value;
            }
        };

        const updateSummary = () => {
            if (summaryConcept instanceof HTMLElement && conceptInput instanceof HTMLInputElement) {
                summaryConcept.textContent = getText(conceptInput.value, 'Sin definir todavia');
            }
            if (summaryAmount instanceof HTMLElement && amountInput instanceof HTMLInputElement) {
                summaryAmount.textContent = formatCurrency(amountInput.value);
            }
            if (summaryMethod instanceof HTMLElement) {
                summaryMethod.textContent = methodLabels[state.activeMethod] || 'Pendiente';
            }
        };

        const setActiveMethod = async (method) => {
            const safeMethod = ['card', 'transfer', 'cash'].includes(method) ? method : 'card';
            state.activeMethod = safeMethod;
            methodInput.value = safeMethod;

            methodButtons.forEach((button) => {
                const isActive = button.getAttribute('data-checkout-method') === safeMethod;
                button.classList.toggle('is-active', isActive);
            });

            methodPanels.forEach((panel) => {
                panel.hidden = panel.getAttribute('data-checkout-panel') !== safeMethod;
            });

            updateSummary();

            if (safeMethod === 'card') {
                await ensureStripeReady();
            }
        };

        const loadStripeSdk = () =>
            new Promise((resolve, reject) => {
                if (typeof window.Stripe === 'function') {
                    resolve(window.Stripe);
                    return;
                }

                const existing = document.querySelector('script[data-checkout-stripe-sdk="true"]');
                if (existing) {
                    existing.addEventListener('load', () => resolve(window.Stripe), { once: true });
                    existing.addEventListener('error', () => reject(new Error('No se pudo cargar Stripe SDK.')), {
                        once: true,
                    });
                    return;
                }

                const script = document.createElement('script');
                script.src = 'https://js.stripe.com/v3/';
                script.async = true;
                script.defer = true;
                script.dataset.checkoutStripeSdk = 'true';
                script.onload = () => resolve(window.Stripe);
                script.onerror = () => reject(new Error('No se pudo cargar Stripe SDK.'));
                document.head.appendChild(script);
            });

        const ensureStripeReady = async () => {
            if (!state.config || state.config.stripeEnabled !== true) {
                if (cardNote instanceof HTMLElement) {
                    cardNote.textContent = 'Tarjeta no disponible en este entorno. Puede seguir por transferencia o efectivo.';
                }
                return;
            }

            if (state.cardElement || !(cardNote instanceof HTMLElement)) {
                return;
            }

            const StripeCtor = await loadStripeSdk();
            if (typeof StripeCtor !== 'function') {
                throw new Error('Stripe no esta disponible en este navegador.');
            }

            const publishableKey = getText(state.config.publishableKey);
            if (!publishableKey) {
                throw new Error('Falta la llave publica de Stripe para este checkout.');
            }

            state.stripe = StripeCtor(publishableKey);
            const elements = state.stripe.elements();
            state.cardElement = elements.create('card', {
                hidePostalCode: true,
            });
            state.cardElement.mount('#checkout-stripe-element');
            cardNote.textContent = 'Tarjeta segura conectada. Puede confirmar el cobro aqui mismo.';
        };

        const fetchJson = async (url, options = {}) => {
            const response = await fetch(url, {
                method: options.method || 'GET',
                credentials: 'same-origin',
                headers: {
                    Accept: 'application/json',
                    'Content-Type': 'application/json',
                    ...(options.headers || {}),
                },
                body: options.body ? JSON.stringify(options.body) : undefined,
            });
            const payload = await response.json().catch(() => ({}));
            if (!response.ok || payload.ok === false) {
                throw new Error(payload.error || `HTTP ${response.status}`);
            }
            return payload.data || payload;
        };

        const collectPayload = () => {
            const transferReferenceField = root.querySelector('#checkout-transfer-reference');
            return {
                concept: conceptInput instanceof HTMLInputElement ? conceptInput.value : '',
                amount: amountInput instanceof HTMLInputElement ? amountInput.value : '',
                name: nameInput instanceof HTMLInputElement ? nameInput.value : '',
                email: emailInput instanceof HTMLInputElement ? emailInput.value : '',
                whatsapp: whatsappInput instanceof HTMLInputElement ? whatsappInput.value : '',
                notes: form.elements.namedItem('notes') instanceof HTMLTextAreaElement ? form.elements.namedItem('notes').value : '',
                paymentMethod: state.activeMethod,
                transferReference:
                    transferReferenceField instanceof HTMLInputElement ? transferReferenceField.value : '',
            };
        };

        const renderReceipt = (receipt) => {
            if (!(receiptNode instanceof HTMLElement)) {
                return;
            }

            const payer = receipt && receipt.payer && typeof receipt.payer === 'object' ? receipt.payer : {};
            const reference = getText(receipt?.transferReference);
            const payerParts = [getText(payer.name), getText(payer.email), getText(payer.whatsapp)].filter(Boolean);

            if (receiptNumberNode instanceof HTMLElement) {
                receiptNumberNode.textContent = getText(receipt?.receiptNumber, 'PAY-00000000-000000');
            }
            if (receiptConceptNode instanceof HTMLElement) {
                receiptConceptNode.textContent = getText(receipt?.concept, '-');
            }
            if (receiptAmountNode instanceof HTMLElement) {
                receiptAmountNode.textContent = getText(receipt?.amountLabel, '$0.00');
            }
            if (receiptMethodNode instanceof HTMLElement) {
                receiptMethodNode.textContent = getText(receipt?.paymentMethodLabel, '-');
            }
            if (receiptStatusNode instanceof HTMLElement) {
                receiptStatusNode.textContent = getText(receipt?.paymentStatusLabel, '-');
            }
            if (receiptPayerNode instanceof HTMLElement) {
                receiptPayerNode.textContent = payerParts.join(' · ') || '-';
            }
            if (receiptIssuedNode instanceof HTMLElement) {
                receiptIssuedNode.textContent = getText(receipt?.issuedAt, '-');
            }
            if (receiptReferenceNode instanceof HTMLElement) {
                receiptReferenceNode.textContent = reference || '-';
            }
            if (receiptReferenceRow instanceof HTMLElement) {
                receiptReferenceRow.hidden = !reference;
            }
            if (receiptWhatsappLink instanceof HTMLAnchorElement) {
                const message = encodeURIComponent(
                    `Hola, comparto el recibo ${getText(receipt?.receiptNumber)} de Aurora Derm por ${getText(
                        receipt?.amountLabel
                    )} (${getText(receipt?.paymentMethodLabel)}).`
                );
                receiptWhatsappLink.href = `${supportHref}${supportHref.includes('?') ? '&' : '?'}text=${message}`;
            }

            receiptNode.hidden = false;
            receiptNode.scrollIntoView({ behavior: 'smooth', block: 'start' });
        };

        const processCardCheckout = async (payload) => {
            if (!(cardholderInput instanceof HTMLInputElement) || !state.stripe || !state.cardElement) {
                throw new Error('Stripe todavia no esta listo para este checkout.');
            }

            const cardholderName = getText(cardholderInput.value, payload.name);
            if (!cardholderName) {
                throw new Error('Necesitamos el nombre del titular para continuar con la tarjeta.');
            }

            const intent = await fetchJson(intentUrl, {
                method: 'POST',
                body: payload,
            });

            const confirmation = await state.stripe.confirmCardPayment(intent.clientSecret, {
                payment_method: {
                    card: state.cardElement,
                    billing_details: {
                        name: cardholderName,
                        email: getText(payload.email),
                        phone: getText(payload.whatsapp),
                    },
                },
            });

            if (confirmation?.error) {
                throw new Error(confirmation.error.message || 'No se pudo completar el pago con tarjeta.');
            }

            const paymentIntentId = getText(
                confirmation?.paymentIntent?.id,
                intent.paymentIntentId
            );
            if (!paymentIntentId) {
                throw new Error('Stripe no devolvio el identificador del pago.');
            }

            return fetchJson(confirmUrl, {
                method: 'POST',
                body: {
                    orderId: intent.order?.id,
                    paymentIntentId,
                },
            });
        };

        const processOfflineCheckout = async (payload) =>
            fetchJson(submitUrl, {
                method: 'POST',
                body: payload,
            });

        const loadConfig = async () => {
            state.config = await fetchJson(configUrl);
            if (bankNameNode instanceof HTMLElement) {
                bankNameNode.textContent = getText(state.config?.bank?.bankName, 'Banco Pichincha');
            }
            if (bankAccountNode instanceof HTMLElement) {
                bankAccountNode.textContent = getText(
                    state.config?.bank?.account,
                    'Cuenta de Ahorros: 2200160272'
                );
            }
            if (bankOwnerNode instanceof HTMLElement) {
                bankOwnerNode.textContent = getText(
                    state.config?.bank?.owner,
                    'Titular: Rosero Caiza Javier Alejandro'
                );
            }

            const cardButton = root.querySelector('[data-checkout-method="card"]');
            if (cardButton instanceof HTMLButtonElement && state.config?.stripeEnabled !== true) {
                cardButton.disabled = true;
                cardButton.classList.add('is-disabled');
                if (state.activeMethod === 'card') {
                    setActiveMethod('transfer');
                }
            }
        };

        form.addEventListener('input', (event) => {
            if (event.target === nameInput && cardholderInput instanceof HTMLInputElement && !cardholderInput.value) {
                cardholderInput.value = nameInput.value;
            }
            updateSummary();
        });

        methodButtons.forEach((button) => {
            button.addEventListener('click', async () => {
                if (button instanceof HTMLButtonElement && button.disabled) {
                    return;
                }
                try {
                    await setActiveMethod(button.getAttribute('data-checkout-method') || 'card');
                    showStatus('');
                } catch (error) {
                    showStatus(error?.message || 'No se pudo preparar ese metodo.', 'error');
                }
            });
        });

        form.addEventListener('submit', async (event) => {
            event.preventDefault();
            if (state.busy) {
                return;
            }

            try {
                setBusy(true);
                showStatus(
                    state.activeMethod === 'card'
                        ? 'Iniciando checkout con tarjeta...'
                        : 'Generando recibo digital...',
                    'info'
                );

                const payload = collectPayload();
                const result =
                    state.activeMethod === 'card'
                        ? await processCardCheckout(payload)
                        : await processOfflineCheckout(payload);

                renderReceipt(result.receipt || {});
                showStatus('Checkout generado correctamente.', 'success');
            } catch (error) {
                showStatus(error?.message || 'No se pudo generar el checkout.', 'error');
            } finally {
                setBusy(false);
            }
        });

        if (printButton instanceof HTMLButtonElement) {
            printButton.addEventListener('click', () => {
                window.print();
            });
        }

        readQueryPrefill();
        updateSummary();
        loadConfig()
            .then(() => setActiveMethod(state.activeMethod))
            .catch((error) => {
                showStatus(error?.message || 'No se pudo cargar la configuracion del checkout.', 'error');
            });
    })();
</script>
