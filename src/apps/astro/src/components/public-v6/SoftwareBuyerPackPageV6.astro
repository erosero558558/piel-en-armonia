---
import { getWhatsappNumber } from '../../lib/whatsapp-config.js';
import '../../styles/public-v6/software.css';
import PageHeadV6 from './PageHeadV6.astro';

const { locale = 'es', navModel = {}, page = {} } = Astro.props;

const pageHeadUi =
    navModel?.ui?.pageHead && typeof navModel.ui.pageHead === 'object'
        ? navModel.ui.pageHead
        : {};
const breadcrumb = Array.isArray(page?.breadcrumb) ? page.breadcrumb : [];
const switchLabel = navModel?.header?.switchLabel || '';
const switchHref = navModel?.header?.switchHref || '';
const menuLabel = navModel?.header?.menuLabel || '';
const contactHref =
    navModel?.header?.contactHref ||
    `https://wa.me/${getWhatsappNumber()}?text=Hola%2C%20quiero%20evaluar%20Flow%20OS%20para%20una%20clinica%20dermatologica`;

const copy = {
    heroEyebrow: locale === 'en' ? 'Technical Spec' : 'Especificacion Tecnica',
    heroTitle: locale === 'en' ? 'Security & Implementation Scope' : 'Alcance de seguridad, operacion y piloto',
    heroDeck: locale === 'en' 
        ? 'A transparent outline of exactly what Aurora Derm migrates, secures, isolates, and expects during the 2-week implementation pilot. No surprises.'
        : 'Un resumen transparente de lo que Flow OS migra, asegura, aísla y espera durante el piloto de implementacion de 2 semanas. Sin sorpresas.',
    contactLabel: locale === 'en' ? 'Start implementation' : 'Iniciar piloto',

    sectionOps: locale === 'en' ? 'Operations & Security' : 'Operaciones y Seguridad',
    sectionScope: locale === 'en' ? 'Pilot Migration' : 'Migracion Piloto',
    sectionReqs: locale === 'en' ? 'Hardware & Fallbacks' : 'Hardware y Respaldo',

    opsTitle: locale === 'en' ? 'Built to pass technical audits' : 'Disenado para pasar escrutinio tecnico',
    opsItems: locale === 'en' ? [
        { key: 'Auth & Data', value: 'Immutable audit logs per-tenant. Cookie+CSRF protected endpoints.' },
        { key: 'Daily Backups', value: 'Encrypted daily and hourly differential snapshots.' },
        { key: 'AI Boundaries', value: 'OpenClaw models prepare prescriptions, but human physician approval is strictly required before execution.' },
        { key: 'Role Segregation', value: 'Receptionists cannot view deep clinical notes. Doctors cannot access billing configs.' }
    ] : [
        { key: 'Auth y Datos', value: 'Logs de auditoria inmutables por tenant. Endpoints mutables protegidos con Cookie+CSRF.' },
        { key: 'Backups', value: 'Snapshots encriptados diarios y diferenciales por hora.' },
        { key: 'Limites de IA', value: 'Los modelos OpenClaw preparan diagnosticos y protocolos, pero la firma medica humana es obligatoria para ejecutarlos.' },
        { key: 'Segregacion', value: 'Recepcionistas no pueden leer notas medicas. Medicos no acceden a configuraciones de facturacion corporativa.' }
    ],

    scopeTitle: locale === 'en' ? 'Exactly what migrates in 2 weeks' : 'Que migramos exactamente en 2 semanas',
    scopeItems: locale === 'en' ? [
        { key: 'In Scope: Core Baseline', value: 'We batch-import the last 12-24 months of active patient rosters (name, ID, contact).' },
        { key: 'In Scope: Inventory', value: 'Complete migration of your active product inventory and pricing tables.' },
        { key: 'Out of Scope: Historical Clinical', value: 'We do NOT migrate 10 years of unstructured PDF clinical histories or messy legacy text fields into core.' },
        { key: 'Out of Scope: Old Billing', value: 'We do NOT migrate legacy accounts receivable. The new tenant starts billing from Day 1 cleanly.' }
    ] : [
        { key: 'Incluido: Baseline', value: 'Importamos por lotes el registro de pacientes activos de los ultimos 12 a 24 meses (nombres, ID, contacto).' },
        { key: 'Incluido: Inventarios', value: 'Migramos listas activas de productos y catálogos de precios.' },
        { key: 'Excluido: Historico Clinico', value: 'NO migramos PDFs antiguos ni arrays de texto legacy de la HCE pasada de 10 anos. Solo partimos de la foto actual.' },
        { key: 'Excluido: Facturacion pasada', value: 'NO migramos cuentas por cobrar pasadas. El nuevo ERP factura limpio desde el Dia 1.' }
    ],

    reqTitle: locale === 'en' ? 'Hardware pre-requisites & guarantees' : 'Prerequisitos de hardware y garantias',
    reqItems: locale === 'en' ? [
        { key: 'Kiosk Requirements', value: 'A touchscreen PC or Android tablet natively running 1080p, and a standard thermal printer connected.' },
        { key: 'Network', value: 'Stable Wi-Fi or Ethernet. Telemedicine requires at least 15Mbps symmetrical.' },
        { key: 'Web Fallback Guarantee', value: 'If the Native Windows Operator or Android TV app fails for any physical reason, the web URL fallback handles 100% of the workflow instantly.' },
        { key: 'Implementation Labor', value: 'The clinic must designate 1 point-of-contact to hand over CSV exports and approve configuration rules in week one.' }
    ] : [
        { key: 'Requisitos del Kiosco', value: 'Tablet o PC Touchscreen a 1080p + una impresora termica genérica para tickets.' },
        { key: 'Conectividad', value: 'Wi-Fi robusto o Ethernet. Telemedicina exige 15Mbps asimetricos minimo.' },
        { key: 'Garantía de Respaldo Web', value: 'Si el ejecutable de Windows Operador o el APK de SalaTV fallan fisicamente, la URL web toma el 100% de la carga al instante.' },
        { key: 'Labor del Cliente', value: 'La clinica debe delegar 1 responsable tecnico que entregue los CSV iniciales y apruebe las reglas en la semana uno.' }
    ],

    finalEyebrow: locale === 'en' ? 'Commitment' : 'Compromiso',
    finalTitle: locale === 'en' ? 'No guesses, no bloated implementations.' : 'Cero adivinanzas, cero alcances inflados.',
    finalDeck: locale === 'en' ? 'We constrain the scope because long migrations fail. Ready to start your clean deployment?' : 'Acotamos la migracion porque las transiciones largas fallan. Listo para arrancar limpio?'
};

const actionClass = (variant = 'secondary') => [
    'v6-suite-action',
    variant === 'primary' ? 'is-primary' : variant === 'ghost' ? 'is-ghost' : 'is-secondary',
];

const menuItems = [
    { label: copy.sectionOps, href: '#v6-buyer-ops' },
    { label: copy.sectionScope, href: '#v6-buyer-scope' },
    { label: copy.sectionReqs, href: '#v6-buyer-reqs' }
];
---

<PageHeadV6
    breadcrumb={breadcrumb}
    heading={page.heading}
    locale={locale}
    switchLabel={switchLabel}
    switchHref={switchHref}
    menuLabel={menuLabel}
    menuItems={menuItems}
    copy={pageHeadUi}
/>

<div class="v6-suite-surface-page is-api-docs" data-v6-buyer-pack-page>
    <section class="v6-suite-surface-hero">
        <div class="v6-suite-shell v6-suite-surface-hero__shell">
            <div class="v6-suite-surface-hero__copy">
                <p class="v6-suite-eyebrow">{copy.heroEyebrow}</p>
                <h2>{copy.heroTitle}</h2>
                <p class="v6-suite-lead">{copy.heroDeck}</p>
                <div class="v6-suite-actions">
                    <a
                        class:list={actionClass('primary')}
                        href={contactHref}
                    >
                        {copy.contactLabel}
                    </a>
                </div>
            </div>
            <aside class="v6-suite-hero__board v6-suite-hero__board--surface v6-suite-api-docs-hero-board">
                <article class="v6-suite-surface-scene__headline">
                    <p>{locale === 'en' ? 'Blueprint' : 'Blueprint'}</p>
                    <h3>2 {locale === 'en' ? 'weeks to production' : 'semanas a prod'}</h3>
                    <span>SLA 99.9%</span>
                </article>
                <div class="v6-suite-metrics v6-suite-metrics--surface">
                    <article class="v6-suite-metric">
                        <strong>O(1)</strong>
                        <h3>Fallback Web</h3>
                        <p>{locale === 'en' ? 'Instant native backup' : 'Respaldo instantaneo'}</p>
                    </article>
                    <article class="v6-suite-metric">
                        <strong>100%</strong>
                        <h3>Audit Trails</h3>
                        <p>{locale === 'en' ? 'Immutable writes' : 'Escrituras inmutables'}</p>
                    </article>
                </div>
            </aside>
        </div>
    </section>

    <div class="v6-suite-shell v6-suite-surface-shell">
        <aside class="v6-suite-surface-rail" data-v6-suite-rail="surface">
            <p>{page.heading || ''}</p>
            <nav data-v6-section-nav="software-surface" aria-label={pageHeadUi.pageNavigationLabel || ''}>
                {menuItems.map((item) => (
                    <a data-v6-section-link href={item.href}>{item.label}</a>
                ))}
            </nav>
        </aside>

        <div class="v6-suite-surface-shell__body">
            <section
                id="v6-buyer-ops"
                class="v6-suite-section is-tight v6-suite-surface-block"
            >
                <header class="v6-suite-section__head">
                    <div class="v6-suite-surface-section-tag"><span>01</span></div>
                    <p>{copy.sectionOps}</p>
                    <h2>{copy.opsTitle}</h2>
                </header>
                <div class="v6-suite-api-docs-security-grid">
                    {copy.opsItems.map(item => (
                        <article class="v6-suite-card v6-suite-api-docs-security-card">
                            <h3>{item.key}</h3>
                            <p style="margin-top: 1rem;">{item.value}</p>
                        </article>
                    ))}
                </div>
            </section>

            <section
                id="v6-buyer-scope"
                class="v6-suite-section is-tight v6-suite-surface-block"
            >
                <header class="v6-suite-section__head">
                    <div class="v6-suite-surface-section-tag"><span>02</span></div>
                    <p>{copy.sectionScope}</p>
                    <h2>{copy.scopeTitle}</h2>
                </header>
                <div class="v6-suite-api-docs-security-grid">
                    {copy.scopeItems.map(item => (
                        <article class="v6-suite-card v6-suite-api-docs-security-card">
                            <h3>{item.key}</h3>
                            <p style="margin-top: 1rem;">{item.value}</p>
                        </article>
                    ))}
                </div>
            </section>

            <section
                id="v6-buyer-reqs"
                class="v6-suite-section is-tight v6-suite-surface-block"
            >
                <header class="v6-suite-section__head">
                    <div class="v6-suite-surface-section-tag"><span>03</span></div>
                    <p>{copy.sectionReqs}</p>
                    <h2>{copy.reqTitle}</h2>
                </header>
                <div class="v6-suite-api-docs-security-grid">
                    {copy.reqItems.map(item => (
                        <article class="v6-suite-card v6-suite-api-docs-security-card">
                            <h3>{item.key}</h3>
                            <p style="margin-top: 1rem;">{item.value}</p>
                        </article>
                    ))}
                </div>
            </section>

            <section
                id="v6-buyer-final"
                class="v6-suite-final is-inline v6-suite-surface-block"
            >
                <div class="v6-suite-final__shell">
                    <div>
                        <div class="v6-suite-surface-section-tag" data-v6-suite-surface-section-tag aria-hidden="true">
                            <span>04</span>
                        </div>
                        <p class="v6-suite-eyebrow">{copy.finalEyebrow}</p>
                        <h2>{copy.finalTitle}</h2>
                        <p>{copy.finalDeck}</p>
                    </div>
                    <div class="v6-suite-actions v6-suite-actions--final">
                        <a class:list={actionClass('primary')} href={contactHref}>
                            {copy.contactLabel}
                        </a>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>
