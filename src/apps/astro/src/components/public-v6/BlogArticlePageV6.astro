---
import '../../styles/public-v6/internal.css';

import BookingStatusV6 from './BookingStatusV6.astro';
import PageHeadV6 from './PageHeadV6.astro';

const { page = {}, locale = 'es', navModel = {} } = Astro.props;
const hasText = (value) => typeof value === 'string' && value.trim().length > 0;
const normalizeText = (value) => (hasText(value) ? value.trim() : '');
const normalizeHref = (value) => {
    const raw = normalizeText(value);
    return raw && raw !== '#' ? raw : '';
};
const normalizeLink = (item) => {
    const label = normalizeText(item?.label);
    const href = normalizeHref(item?.href);
    return label && href ? { label, href } : null;
};
const makeMenuItem = (label, href) =>
    hasText(label) && hasText(href) ? { label: label.trim(), href: href.trim() } : null;
const pageHeadUi =
    navModel?.ui?.pageHead && typeof navModel.ui.pageHead === 'object'
        ? navModel.ui.pageHead
        : {};
const switchLabel = normalizeText(navModel?.header?.switchLabel);
const switchHref = normalizeHref(navModel?.header?.switchHref);
const menuLabel = normalizeText(navModel?.header?.menuLabel);
const breadcrumb = Array.isArray(page.breadcrumb)
    ? page.breadcrumb.map(normalizeLink).filter(Boolean)
    : [];
const hero = page?.hero && typeof page.hero === 'object' ? page.hero : {};
const intro = page?.intro && typeof page.intro === 'object' ? page.intro : {};
const bookingStatus =
    page?.bookingStatus && typeof page.bookingStatus === 'object'
        ? page.bookingStatus
        : {};
const keyPoints = Array.isArray(page.keyPoints)
    ? page.keyPoints
          .map((item, index) => {
              const title = normalizeText(item?.title);
              const copy = normalizeText(item?.copy);
              const label = normalizeText(item?.label) || `Clave ${String(index + 1).padStart(2, '0')}`;
              return title && copy ? { title, copy, label } : null;
          })
          .filter(Boolean)
    : [];
const sections = Array.isArray(page.sections)
    ? page.sections
          .map((section, index) => {
              const id = normalizeText(section?.id) || `v6-blog-article-section-${index + 1}`;
              const eyebrow = normalizeText(section?.eyebrow);
              const title = normalizeText(section?.title);
              const body = Array.isArray(section?.body)
                  ? section.body.map(normalizeText).filter(Boolean)
                  : [];
              const bullets = Array.isArray(section?.bullets)
                  ? section.bullets.map(normalizeText).filter(Boolean)
                  : [];
              const links = Array.isArray(section?.links)
                  ? section.links.map(normalizeLink).filter(Boolean)
                  : [];
              return title && body.length
                  ? {
                        id,
                        eyebrow,
                        title,
                        body,
                        bullets,
                        links,
                        index: String(index + 1).padStart(2, '0'),
                    }
                  : null;
          })
          .filter(Boolean)
    : [];
const relatedServices = Array.isArray(page.relatedServices)
    ? page.relatedServices
          .map((item) => {
              const title = normalizeText(item?.title);
              const copy = normalizeText(item?.copy);
              const href = normalizeHref(item?.href);
              return title && copy && href ? { title, copy, href } : null;
          })
          .filter(Boolean)
    : [];
const articleMenuItems = [
    makeMenuItem(normalizeText(page?.ui?.introLabel), '#v6-blog-article-intro'),
    makeMenuItem(normalizeText(page?.ui?.keyPointsLabel), keyPoints.length ? '#v6-blog-article-kpis' : ''),
    ...sections.map((section) => makeMenuItem(section.title, `#${section.id}`)),
    makeMenuItem(
        normalizeText(page?.ui?.relatedLabel),
        relatedServices.length ? '#v6-blog-related' : ''
    ),
    makeMenuItem(normalizeText(page?.ui?.ctaLabel), '#v6-blog-cta'),
].filter(Boolean);
const railTitle = normalizeText(page?.ui?.railTitle);
const railAria = normalizeText(page?.ui?.railAria);
const heroStats = Array.isArray(hero?.stats)
    ? hero.stats
          .map((item) => {
              const label = normalizeText(item?.label);
              const value = normalizeText(item?.value);
              return label && value ? { label, value } : null;
          })
          .filter(Boolean)
    : [];
const introBody = Array.isArray(intro?.body)
    ? intro.body.map(normalizeText).filter(Boolean)
    : [];
---

<PageHeadV6
    breadcrumb={breadcrumb}
    heading={page.heading}
    locale={locale}
    switchLabel={switchLabel}
    switchHref={switchHref}
    menuLabel={menuLabel}
    menuItems={articleMenuItems}
    copy={pageHeadUi}
/>

<section class="v6-page-hero-media is-internal v6-page-hero-media--blog-article" data-v6-blog-article-hero>
    <div class="v6-blog-article-hero-shell">
        <figure class="v6-blog-article-hero-shell__media">
            <img
                src={normalizeText(hero?.image?.src)}
                srcset={normalizeText(hero?.image?.srcset) || undefined}
                sizes="(max-width: 1100px) 100vw, 60vw"
                alt={normalizeText(hero?.image?.alt) || normalizeText(page.heading)}
                loading="eager"
                decoding="sync"
                fetchpriority="high"
            />
        </figure>
        <aside class="v6-blog-article-hero-shell__panel">
            {hero.eyebrow ? <p class="v6-blog-article-hero-shell__eyebrow">{hero.eyebrow}</p> : null}
            {hero.title ? <h2>{hero.title}</h2> : null}
            {hero.deck ? <p class="v6-blog-article-hero-shell__deck" set:html={hero.deck}></p> : null}
            {
                heroStats.length ? (
                    <div class="v6-blog-article-hero-shell__stats" aria-hidden="true">
                        {
                            heroStats.map((item) => (
                                <article>
                                    <span>{item.label}</span>
                                    <strong>{item.value}</strong>
                                </article>
                            ))
                        }
                    </div>
                ) : null
            }
        </aside>
    </div>
</section>

{
    keyPoints.length ? (
        <section id="v6-blog-article-kpis" class="v6-blog-article-kpis" data-v6-blog-article-kpis>
            {
                keyPoints.map((item) => (
                    <article>
                        <p>{item.label}</p>
                        <h2>{item.title}</h2>
                        <span>{item.copy}</span>
                    </article>
                ))
            }
        </section>
    ) : null
}

<div class="v6-internal-shell v6-blog-article-shell" data-v6-blog-article>
    {
        articleMenuItems.length || railTitle ? (
            <aside class="v6-internal-rail" data-v6-internal-rail>
                {railTitle ? <p>{railTitle}</p> : null}
                {
                    articleMenuItems.length ? (
                        <nav data-v6-section-nav="internal" aria-label={railAria || undefined}>
                            {
                                articleMenuItems.map((item) => (
                                    <a data-v6-section-link href={item.href}>{item.label}</a>
                                ))
                            }
                        </nav>
                    ) : null
                }
            </aside>
        ) : null
    }

    <div class="v6-internal-shell__body">
        <div class="v6-blog-article-stream" data-v6-blog-article-body>
            {
                introBody.length ? (
                    <section id="v6-blog-article-intro" class="v6-blog-article-intro">
                        {intro?.eyebrow ? <p>{intro.eyebrow}</p> : null}
                        {intro?.title ? <h2>{intro.title}</h2> : null}
                        {
                            introBody.map((paragraph) => (
                                <p set:html={paragraph}></p>
                            ))
                        }
                    </section>
                ) : null
            }

            {
                sections.map((section, index) => (
                    <article
                        id={section.id}
                        class:list={['v6-blog-article-section', index === 0 && 'is-lead']}
                        data-v6-blog-article-section
                    >
                        <header class="v6-blog-article-section__head">
                            <div>
                                {section.eyebrow ? <p>{section.eyebrow}</p> : null}
                                <h2>{section.title}</h2>
                            </div>
                            <strong>{section.index}</strong>
                        </header>
                        <div class="v6-blog-article-section__prose">
                            {
                                section.body.map((paragraph) => (
                                    <p set:html={paragraph}></p>
                                ))
                            }
                        </div>
                        {
                            section.bullets.length ? (
                                <ul class="v6-blog-article-section__list">
                                    {
                                        section.bullets.map((item) => (
                                            <li>{item}</li>
                                        ))
                                    }
                                </ul>
                            ) : null
                        }
                        {
                            section.links.length ? (
                                <div class="v6-blog-article-section__links">
                                    {
                                        section.links.map((link) => (
                                            <a href={link.href}>{link.label}</a>
                                        ))
                                    }
                                </div>
                            ) : null
                        }
                    </article>
                ))
            }
        </div>

        {
            relatedServices.length ? (
                <section id="v6-blog-related" class="v6-blog-related" data-v6-blog-related>
                    <header class="v6-blog-related__head">
                        {page?.ui?.relatedEyebrow ? <p>{page.ui.relatedEyebrow}</p> : null}
                        {page?.ui?.relatedTitle ? <h2>{page.ui.relatedTitle}</h2> : null}
                    </header>
                    <div class="v6-blog-related__grid">
                        {
                            relatedServices.map((item) => (
                                <a href={item.href} data-v6-blog-related-link>
                                    <p>{item.title}</p>
                                    <h3>{item.copy}</h3>
                                    <strong>
                                        {normalizeText(page?.ui?.relatedCtaLabel)}
                                        <span aria-hidden="true">></span>
                                    </strong>
                                </a>
                            ))
                        }
                    </div>
                </section>
            ) : null
        }
    </div>
</div>

<BookingStatusV6
    status={bookingStatus}
    locale={locale}
    sectionId="v6-blog-cta"
    surface="blog"
/>

<style>
    #v6-blog-article-intro,
    #v6-blog-article-kpis,
    #v6-blog-related,
    [data-v6-blog-article-section] {
        scroll-margin-top: 148px;
    }

    .v6-page-hero-media--blog-article {
        padding: 18px clamp(18px, 3vw, 28px) 8px;
        background:
            radial-gradient(circle at top left, rgba(199, 163, 109, 0.22), transparent 30%),
            radial-gradient(circle at 84% 18%, rgba(146, 165, 187, 0.16), transparent 28%),
            linear-gradient(180deg, #05070b 0%, #0d1726 100%);
    }

    .v6-blog-article-hero-shell {
        max-width: 1320px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: minmax(0, 1.28fr) minmax(320px, 0.72fr);
        gap: clamp(18px, 2vw, 26px);
        align-items: center;
    }

    .v6-blog-article-hero-shell__media {
        margin: 0;
        overflow: hidden;
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: #101826;
        box-shadow: 0 28px 58px rgba(8, 13, 20, 0.24);
    }

    .v6-blog-article-hero-shell__media img {
        display: block;
        width: 100%;
        height: clamp(340px, 33vw, 500px);
        object-fit: cover;
    }

    .v6-blog-article-hero-shell__panel {
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background:
            radial-gradient(circle at top right, rgba(199, 163, 109, 0.16), transparent 34%),
            linear-gradient(180deg, rgba(10, 15, 22, 0.96) 0%, rgba(16, 24, 38, 0.98) 100%);
        box-shadow: 0 24px 46px rgba(8, 13, 20, 0.2);
        padding: clamp(22px, 2.1vw, 30px);
        display: grid;
        gap: 14px;
    }

    .v6-blog-article-hero-shell__eyebrow,
    .v6-blog-article-hero-shell__deck,
    .v6-blog-article-hero-shell h2,
    .v6-blog-article-hero-shell__stats span,
    .v6-blog-article-hero-shell__stats strong {
        margin: 0;
    }

    .v6-blog-article-hero-shell__eyebrow,
    .v6-blog-article-hero-shell__stats span {
        color: rgba(199, 163, 109, 0.92);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 10px;
        font-weight: 700;
    }

    .v6-blog-article-hero-shell h2 {
        color: #f4f7fb;
        font-family: var(--v6-font-display);
        font-size: clamp(32px, 2.7vw, 44px);
        line-height: 1.04;
        letter-spacing: -0.04em;
    }

    .v6-blog-article-hero-shell__deck {
        color: rgba(219, 227, 237, 0.82);
        font-size: clamp(16px, 1.1vw, 19px);
        line-height: 1.58;
    }

    .v6-blog-article-hero-shell__deck a {
        color: rgba(199, 163, 109, 0.96);
        border-bottom: 1px solid rgba(199, 163, 109, 0.44);
    }

    .v6-blog-article-hero-shell__stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
    }

    .v6-blog-article-hero-shell__stats article {
        min-height: 86px;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.08);
        padding: 12px 13px 13px;
        display: grid;
        gap: 6px;
    }

    .v6-blog-article-hero-shell__stats strong {
        color: #f4f7fb;
        font-size: clamp(16px, 1.35vw, 23px);
        line-height: 1.14;
    }

    .v6-blog-article-kpis,
    .v6-blog-related {
        max-width: 1320px;
        margin: 24px auto 0;
        padding: 0 24px;
    }

    .v6-blog-article-kpis {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
    }

    .v6-blog-article-kpis article {
        position: relative;
        border: 1px solid rgba(202, 210, 220, 0.92);
        background: rgba(255, 255, 255, 0.96);
        border-radius: 18px;
        padding: 16px 18px 18px;
        box-shadow: 0 18px 34px rgba(10, 18, 28, 0.08);
        display: grid;
        gap: 8px;
    }

    .v6-blog-article-kpis article::before {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        top: 0;
        height: 3px;
        background: linear-gradient(90deg, rgba(199, 163, 109, 0.86), rgba(146, 165, 187, 0.72));
    }

    .v6-blog-article-kpis p,
    .v6-blog-article-kpis h2,
    .v6-blog-article-kpis span {
        margin: 0;
    }

    .v6-blog-article-kpis p {
        color: rgba(111, 127, 146, 0.88);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 11px;
        font-weight: 700;
    }

    .v6-blog-article-kpis h2 {
        color: var(--v6-color-ink);
        font-family: var(--v6-font-display);
        font-size: clamp(24px, 1.9vw, 34px);
        line-height: 1.08;
        letter-spacing: -0.03em;
    }

    .v6-blog-article-kpis span {
        color: rgba(18, 24, 35, 0.72);
        font-size: 15px;
        line-height: 1.55;
    }

    .v6-blog-article-shell {
        margin-top: 24px;
    }

    .v6-blog-article-stream {
        display: grid;
        gap: 20px;
    }

    .v6-blog-article-intro,
    .v6-blog-article-section {
        border-radius: 22px;
        border: 1px solid rgba(202, 210, 220, 0.92);
        background: rgba(255, 255, 255, 0.98);
        box-shadow: 0 22px 42px rgba(10, 18, 28, 0.08);
        padding: 22px 24px 24px;
    }

    .v6-blog-article-section.is-lead {
        background:
            radial-gradient(circle at top right, rgba(199, 163, 109, 0.1), transparent 34%),
            linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 250, 252, 0.98) 100%);
    }

    .v6-blog-article-intro p,
    .v6-blog-article-intro h2,
    .v6-blog-article-section p,
    .v6-blog-article-section h2,
    .v6-blog-article-section h3,
    .v6-blog-article-section strong {
        margin: 0;
    }

    .v6-blog-article-intro > p:first-child,
    .v6-blog-article-section__head p {
        color: rgba(111, 127, 146, 0.9);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 11px;
        font-weight: 700;
    }

    .v6-blog-article-intro > h2,
    .v6-blog-article-section__head h2 {
        margin-top: 8px;
        color: var(--v6-color-ink);
        font-family: var(--v6-font-display);
        font-size: clamp(30px, 2.2vw, 40px);
        line-height: 1.08;
        letter-spacing: -0.03em;
    }

    .v6-blog-article-intro > p:not(:first-child),
    .v6-blog-article-section__prose p {
        color: rgba(18, 24, 35, 0.82);
        font-size: clamp(16px, 1.02vw, 18px);
        line-height: 1.74;
    }

    .v6-blog-article-intro > p:not(:first-child) + p,
    .v6-blog-article-section__prose p + p {
        margin-top: 14px;
    }

    .v6-blog-article-intro a,
    .v6-blog-article-section__prose a {
        color: var(--v6-color-moss);
        border-bottom: 1px solid rgba(91, 110, 91, 0.28);
        font-weight: 700;
    }

    .v6-blog-article-section__head {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: flex-start;
        margin-bottom: 16px;
    }

    .v6-blog-article-section__head strong {
        min-width: 44px;
        min-height: 44px;
        display: grid;
        place-items: center;
        border-radius: 999px;
        background: rgba(199, 163, 109, 0.12);
        color: rgba(199, 163, 109, 0.94);
        font-size: 12px;
        letter-spacing: 0.16em;
    }

    .v6-blog-article-section__list {
        margin: 18px 0 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 12px;
    }

    .v6-blog-article-section__list li {
        position: relative;
        padding-left: 18px;
        color: rgba(18, 24, 35, 0.8);
        line-height: 1.6;
    }

    .v6-blog-article-section__list li::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.72em;
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: linear-gradient(180deg, rgba(199, 163, 109, 0.9), rgba(146, 165, 187, 0.82));
    }

    .v6-blog-article-section__links {
        margin-top: 18px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .v6-blog-article-section__links a {
        min-height: 38px;
        display: inline-flex;
        align-items: center;
        padding: 0 14px;
        border-radius: 999px;
        border: 1px solid rgba(199, 163, 109, 0.3);
        background: rgba(199, 163, 109, 0.08);
        color: var(--v6-color-moss);
        font-size: 14px;
        font-weight: 700;
    }

    .v6-blog-article-section__links a:hover,
    .v6-blog-article-section__links a:focus-visible {
        border-color: rgba(199, 163, 109, 0.62);
        background: rgba(199, 163, 109, 0.12);
    }

    .v6-blog-related__head {
        display: grid;
        gap: 8px;
    }

    .v6-blog-related__head p,
    .v6-blog-related__head h2 {
        margin: 0;
    }

    .v6-blog-related__head p {
        color: rgba(111, 127, 146, 0.9);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 11px;
        font-weight: 700;
    }

    .v6-blog-related__head h2 {
        color: var(--v6-color-ink);
        font-family: var(--v6-font-accent);
        font-size: clamp(34px, 2.7vw, 46px);
        line-height: 1.05;
        letter-spacing: -0.04em;
    }

    .v6-blog-related__grid {
        margin-top: 20px;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
    }

    .v6-blog-related__grid a {
        min-height: 100%;
        display: grid;
        gap: 8px;
        padding: 18px 18px 20px;
        border-radius: 18px;
        border: 1px solid rgba(202, 210, 220, 0.92);
        background: rgba(255, 255, 255, 0.96);
        box-shadow: 0 18px 34px rgba(10, 18, 28, 0.08);
        color: var(--v6-color-ink);
    }

    .v6-blog-related__grid a:hover,
    .v6-blog-related__grid a:focus-visible {
        transform: translateY(-2px);
        box-shadow: 0 24px 40px rgba(10, 18, 28, 0.12);
    }

    .v6-blog-related__grid p,
    .v6-blog-related__grid h3,
    .v6-blog-related__grid strong {
        margin: 0;
    }

    .v6-blog-related__grid p {
        color: rgba(111, 127, 146, 0.9);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 11px;
        font-weight: 700;
    }

    .v6-blog-related__grid h3 {
        color: var(--v6-color-ink);
        font-family: var(--v6-font-display);
        font-size: clamp(22px, 1.7vw, 30px);
        line-height: 1.14;
        letter-spacing: -0.03em;
    }

    .v6-blog-related__grid strong {
        margin-top: 2px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--v6-color-moss);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 12px;
    }

    @media (max-width: 1100px) {
        .v6-blog-article-hero-shell,
        .v6-blog-related__grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 900px) {
        .v6-blog-article-kpis {
            grid-template-columns: 1fr;
        }

        .v6-blog-article-hero-shell__stats {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 720px) {
        .v6-page-hero-media--blog-article {
            padding: 14px 16px 0;
        }

        .v6-blog-article-kpis,
        .v6-blog-related {
            padding: 0 16px;
        }

        .v6-blog-article-hero-shell__media,
        .v6-blog-article-hero-shell__panel,
        .v6-blog-article-intro,
        .v6-blog-article-section {
            border-radius: 20px;
        }

        .v6-blog-article-hero-shell__media img {
            height: 300px;
        }

        .v6-blog-article-intro,
        .v6-blog-article-section {
            padding: 18px 16px 18px;
        }

        .v6-blog-article-section__head {
            display: grid;
        }
    }
</style>
