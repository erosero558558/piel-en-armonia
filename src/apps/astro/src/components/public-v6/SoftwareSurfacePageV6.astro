---
import '../../styles/public-v6/software.css';
import PageHeadV6 from './PageHeadV6.astro';
import SoftwareMockupV6 from './SoftwareMockupV6.astro';

const { page = {}, locale = 'es', navModel = {} } = Astro.props;

const pageHeadUi =
    navModel?.ui?.pageHead && typeof navModel.ui.pageHead === 'object'
        ? navModel.ui.pageHead
        : {};
const breadcrumb = Array.isArray(page?.breadcrumb) ? page.breadcrumb : [];
const hero = page?.hero && typeof page.hero === 'object' ? page.hero : {};
const mockup = page?.mockup && typeof page.mockup === 'object' ? page.mockup : {};
const steps = page?.steps && typeof page.steps === 'object' ? page.steps : {};
const advantages =
    page?.advantages && typeof page.advantages === 'object'
        ? page.advantages
        : {};
const connections =
    page?.connections && typeof page.connections === 'object'
        ? page.connections
        : {};
const finalCta =
    page?.finalCta && typeof page.finalCta === 'object' ? page.finalCta : {};
const switchLabel = navModel?.header?.switchLabel || '';
const switchHref = navModel?.header?.switchHref || '#';
const menuLabel = navModel?.header?.menuLabel || '';

const heroActions = Array.isArray(hero.actions) ? hero.actions : [];
const heroMetrics = Array.isArray(hero.metrics) ? hero.metrics : [];
const stepItems = Array.isArray(steps.items) ? steps.items : [];
const advantageCards = Array.isArray(advantages.cards) ? advantages.cards : [];
const connectionItems = Array.isArray(connections.items) ? connections.items : [];
const finalActions = Array.isArray(finalCta.actions) ? finalCta.actions : [];
const finalLinks = Array.isArray(finalCta.links) ? finalCta.links : [];
const suiteStory =
    page?.suiteStory && typeof page.suiteStory === 'object' ? page.suiteStory : {};
const suiteStoryCurrent =
    suiteStory?.current && typeof suiteStory.current === 'object'
        ? suiteStory.current
        : null;
const suiteStoryPrevious =
    suiteStory?.previous && typeof suiteStory.previous === 'object'
        ? suiteStory.previous
        : null;
const suiteStoryNext =
    suiteStory?.next && typeof suiteStory.next === 'object' ? suiteStory.next : null;
const suiteStoryLabels =
    suiteStory?.labels && typeof suiteStory.labels === 'object'
        ? suiteStory.labels
        : {};
const hasSuiteStory = Boolean(
    suiteStoryCurrent &&
        suiteStoryCurrent.label &&
        (suiteStoryCurrent.deck || suiteStoryPrevious?.href || suiteStoryNext?.href)
);
const demoState =
    page?.demoState && typeof page.demoState === 'object' ? page.demoState : {};
const proof =
    demoState?.proof && typeof demoState.proof === 'object' ? demoState.proof : {};
const proofItems = Array.isArray(proof.items) ? proof.items : [];
const hasProof = Boolean((proof.title || proof.deck) && proofItems.length);
const demoStateJson = JSON.stringify(demoState);

const hasShowcase = Boolean(mockup.title || mockup.rows?.length || mockup.chips?.length);
const hasSteps = Boolean(steps.title && stepItems.length);
const hasAdvantages = Boolean(advantages.title && advantageCards.length);
const hasConnections = Boolean(connections.title && connectionItems.length);
const hasFinalCta = Boolean(finalCta.title || finalCta.deck || finalActions.length);
const normalizeText = (value) =>
    typeof value === 'string' && value.trim().length ? value.trim() : '';
const normalizeHref = (value) => {
    const raw = normalizeText(value);
    return raw && raw !== '#' ? raw : '';
};
const normalizePath = (value) => {
    const raw = normalizeHref(value);
    if (!raw) return '';
    return raw.endsWith('/') ? raw : `${raw}/`;
};
const suiteMapItems = Array.isArray(page?.suiteMap)
    ? page.suiteMap
          .map((item) => {
              const href = normalizePath(item?.href);
              const label = normalizeText(item?.label);
              const pageKey = normalizeText(item?.pageKey);
              if (!href || !label || !pageKey) {
                  return null;
              }
              return {
                  href,
                  label,
                  eyebrow: normalizeText(item?.eyebrow),
                  deck: normalizeText(item?.deck),
                  index: normalizeText(item?.index),
                  isActive: pageKey === normalizeText(page?.pageKey),
              };
          })
          .filter(Boolean)
    : [];
const showcaseKind =
    ['phone', 'status', 'dashboard'].includes(normalizeText(mockup?.kind))
        ? normalizeText(mockup?.kind)
        : 'status';
const surfacePageKey = ['demo', 'status', 'dashboard'].includes(
    normalizeText(page?.pageKey)
)
    ? normalizeText(page.pageKey)
    : showcaseKind;
const stageIndex = String(suiteStory.currentIndex || 1).padStart(2, '0');
const stageTotal = String(suiteStory.total || 0).padStart(2, '0');
const isDemoSurface = surfacePageKey === 'demo';
const demoSandboxCopy =
    locale === 'en'
        ? {
              title: 'Interactive queue sandbox',
              eyebrow: 'Try the flow',
              deck: 'Run the public story end to end: kiosk check-in, ticket issued, and operator call from the same demo tenant.',
              stages: {
                  kiosk: 'Kiosk ready',
                  queued: 'Ticket issued',
                  called: 'Operator called',
              },
              kioskTitle: '1. Kiosk check-in',
              kioskDeck: 'Choose an arrival path and generate a sandbox ticket without leaving the page.',
              scheduled: 'I have an appointment',
              walkIn: 'Walk-in patient',
              kioskIdle: 'The kiosk is ready to issue the next sandbox ticket.',
              kioskQueued: 'The ticket is now attached to the demo queue.',
              kioskCalled: 'Check-in completed. The operator already called the ticket.',
              ticketTitle: '2. Issued ticket',
              ticketDeck: 'The same ticket becomes visible for the patient and the operator.',
              ticketCode: 'Ticket',
              ticketState: 'State',
              ticketChannel: 'Channel',
              ticketWait: 'Estimated wait',
              ticketIdle: 'Waiting for kiosk check-in',
              ticketQueued: 'Queued',
              ticketCalled: 'Called to room',
              operatorTitle: '3. Operator console',
              operatorDeck: 'The operator unlocks only after check-in and calls the same ticket shown above.',
              operatorIdle: 'Waiting for kiosk activity',
              operatorQueued: 'Ready to call the next ticket',
              operatorCalled: 'Ticket called in room',
              callAction: 'Call next ticket',
              resetAction: 'Reset demo',
              queueTitle: 'Live queue slice',
              queueCalling: 'Calling now',
              queueNext: 'Next in line',
              queueEmpty: 'No sandbox ticket generated yet.',
              scheduledChannel: 'Appointment QR',
              walkInChannel: 'Front desk',
              callRoomLabel: 'Room',
              waitNow: 'Now',
          }
        : {
              title: 'Sandbox interactivo del turnero',
              eyebrow: 'Prueba el flujo',
              deck: 'Recorre la historia publica completa: kiosco, ticket emitido y llamado del operador dentro del mismo tenant demo.',
              stages: {
                  kiosk: 'Kiosco listo',
                  queued: 'Turno emitido',
                  called: 'Operador lo llama',
              },
              kioskTitle: '1. Check-in en kiosco',
              kioskDeck: 'Elige una llegada y genera un ticket sandbox sin salir de la pagina.',
              scheduled: 'Tengo cita',
              walkIn: 'Soy walk-in',
              kioskIdle: 'El kiosco esta listo para emitir el siguiente ticket sandbox.',
              kioskQueued: 'El ticket ya quedo enlazado a la cola demo.',
              kioskCalled: 'Check-in completado. El operador ya llamo el ticket.',
              ticketTitle: '2. Turno emitido',
              ticketDeck: 'El mismo ticket queda visible para paciente y operador.',
              ticketCode: 'Turno',
              ticketState: 'Estado',
              ticketChannel: 'Canal',
              ticketWait: 'Espera estimada',
              ticketIdle: 'Esperando check-in del kiosco',
              ticketQueued: 'En cola',
              ticketCalled: 'Llamado a consultorio',
              operatorTitle: '3. Consola operador',
              operatorDeck: 'El operador se desbloquea solo cuando el check-in ya genero el ticket y llama exactamente el mismo turno.',
              operatorIdle: 'Esperando actividad del kiosco',
              operatorQueued: 'Listo para llamar el siguiente turno',
              operatorCalled: 'Turno llamado en consultorio',
              callAction: 'Llamar siguiente turno',
              resetAction: 'Reiniciar demo',
              queueTitle: 'Corte de cola en vivo',
              queueCalling: 'Llamando ahora',
              queueNext: 'Siguientes en cola',
              queueEmpty: 'Todavia no se genera un ticket sandbox.',
              scheduledChannel: 'QR cita',
              walkInChannel: 'Recepcion',
              callRoomLabel: 'Consultorio',
              waitNow: 'Ahora',
          };
const demoSandboxCopyJson = JSON.stringify(demoSandboxCopy);
const hasInteractiveDemo = isDemoSurface;
const sectionDefs = [
    hasShowcase
        ? { id: 'v6-suite-surface-demo', label: mockup.title || page.heading || '' }
        : null,
    hasInteractiveDemo
        ? { id: 'v6-suite-surface-sandbox', label: demoSandboxCopy.title }
        : null,
    hasSteps ? { id: 'v6-suite-surface-steps', label: steps.title } : null,
    hasAdvantages
        ? { id: 'v6-suite-surface-advantages', label: advantages.title }
        : null,
    hasConnections
        ? { id: 'v6-suite-surface-connections', label: connections.title }
        : null,
    hasFinalCta
        ? { id: 'v6-suite-surface-final', label: finalCta.title || page.heading || '' }
        : null,
].filter((item) => item && item.label);
const sectionIndexById = Object.fromEntries(
    sectionDefs.map((item, index) => [item.id, String(index + 1).padStart(2, '0')])
);
const menuItems = sectionDefs.map((item) => ({
    label: item.label,
    href: `#${item.id}`,
}));
const isStatusSurface = surfacePageKey === 'status';
const ticketStatusCopy =
    locale === 'en'
        ? {
              eyebrow: 'Live status',
              title: 'Live ticket status from your phone',
              deck: 'Scan the QR on the printed ticket to follow your place in line without returning to the kiosk.',
              ticket: 'Ticket',
              updated: 'Updated',
              refresh: 'Refresh now',
              position: 'Position',
              ahead: 'Ahead of you',
              wait: 'Estimated wait',
              consultorio: 'Room',
              callingNow: 'Calling now',
              noCallingNow: 'No rooms are calling right now.',
              nextTickets: 'Next in line',
              noNextTickets: 'No additional visible tickets waiting right now.',
              note: 'This panel refreshes every 15 seconds.',
              waiting: 'Waiting',
              called: 'You are being called',
              completed: 'Visit completed',
              noShow: 'Marked as no-show',
              cancelled: 'Ticket cancelled',
              unknown: 'Ticket status',
              loading: 'Looking up your ticket...',
              invalid: 'The ticket code is invalid.',
              notFound: 'We could not find that ticket. Double-check the printed code or ask reception for help.',
              loadError: 'We could not load your ticket right now.',
              waitingDetail: '{aheadCount} ticket(s) are ahead of you.',
              noPositionDetail: 'We are recalculating your place in line.',
              calledDetail: 'Please head to room {room}.',
              completedDetail: 'Your visit is already marked as completed.',
              noShowDetail: 'If you are still onsite, reception can help re-activate your arrival.',
              cancelledDetail: 'This ticket is no longer active.',
              waitNow: 'Now',
              localeTag: 'en-US',
          }
        : {
              eyebrow: 'Seguimiento en vivo',
              title: 'Estado en vivo desde tu telefono',
              deck: 'Escanea el QR del ticket impreso para seguir tu posicion sin volver al kiosco.',
              ticket: 'Ticket',
              updated: 'Actualizado',
              refresh: 'Actualizar ahora',
              position: 'Posicion',
              ahead: 'Delante tuyo',
              wait: 'Espera estimada',
              consultorio: 'Consultorio',
              callingNow: 'Llamando ahora',
              noCallingNow: 'No hay consultorios llamando en este momento.',
              nextTickets: 'Siguientes en cola',
              noNextTickets: 'No hay otros tickets visibles en espera.',
              note: 'Este panel se actualiza cada 15 segundos.',
              waiting: 'En espera',
              called: 'Lo estamos llamando',
              completed: 'Atencion finalizada',
              noShow: 'Marcado como no presentado',
              cancelled: 'Turno cancelado',
              unknown: 'Estado del turno',
              loading: 'Buscando tu turno...',
              invalid: 'El codigo del ticket no es valido.',
              notFound: 'No encontramos ese ticket. Revise el codigo impreso o pida apoyo en recepcion.',
              loadError: 'No pudimos cargar tu turno en este momento.',
              waitingDetail: 'Hay {aheadCount} turno(s) antes que el tuyo.',
              noPositionDetail: 'Estamos recalculando tu posicion.',
              calledDetail: 'Dirigete al consultorio {room}.',
              completedDetail: 'Tu visita ya figura como completada.',
              noShowDetail: 'Si sigues en la clinica, recepcion puede reactivar tu llegada.',
              cancelledDetail: 'Este ticket ya no esta activo.',
              waitNow: 'Ahora',
              localeTag: 'es-EC',
          };
const ticketStatusCopyJson = JSON.stringify(ticketStatusCopy);

const actionClass = (variant = 'secondary') => [
    'v6-suite-action',
    variant === 'primary'
        ? 'is-primary'
        : variant === 'ghost'
            ? 'is-ghost'
            : 'is-secondary',
];
---

<PageHeadV6
    breadcrumb={breadcrumb}
    heading={page.heading}
    locale={locale}
    switchLabel={switchLabel}
    switchHref={switchHref}
    menuLabel={menuLabel}
    menuItems={menuItems}
    copy={pageHeadUi}
/>

<div
    class:list={['v6-suite-surface-page', `is-${surfacePageKey}`, `kind-${showcaseKind}`]}
    data-v6-suite-surface-page={surfacePageKey}
    data-v6-suite-surface-kind={showcaseKind}
>
    <section class="v6-suite-surface-hero">
        <div class="v6-suite-shell v6-suite-surface-hero__shell">
            <div class="v6-suite-surface-hero__copy">
                {hero.eyebrow ? <p class="v6-suite-eyebrow">{hero.eyebrow}</p> : null}
                {hero.title ? <h2>{hero.title}</h2> : null}
                {hero.deck ? <p class="v6-suite-lead">{hero.deck}</p> : null}
                {
                    heroActions.length ? (
                        <div class="v6-suite-actions">
                            {heroActions.map((action) => (
                                <a class:list={actionClass(action.variant)} href={action.href}>
                                    {action.label}
                                </a>
                            ))}
                        </div>
                    ) : null
                }
            </div>

            {
                heroMetrics.length || hasSuiteStory ? (
                    <aside
                        class="v6-suite-hero__board v6-suite-hero__board--surface v6-suite-surface-scene"
                        data-v6-suite-surface-scene
                    >
                        <article class="v6-suite-surface-scene__headline">
                            <p>{suiteStoryLabels.progress || hero.eyebrow || page.heading}</p>
                            <div class="v6-suite-surface-scene__counter">
                                <strong>{stageIndex}</strong>
                                <span>/ {stageTotal}</span>
                            </div>
                            <h3>{suiteStoryCurrent?.label || page.heading}</h3>
                            {mockup.footer || suiteStoryCurrent?.deck ? (
                                <span>{mockup.footer || suiteStoryCurrent?.deck}</span>
                            ) : null}
                        </article>

                        {
                            hasSuiteStory ? (
                                <div class="v6-suite-surface-flow" data-v6-suite-surface-flow>
                                    {
                                        suiteStoryPrevious ? (
                                            <a
                                                class="v6-suite-surface-flow__node is-previous"
                                                href={suiteStoryPrevious.href}
                                                data-v6-suite-surface-flow-node="previous"
                                            >
                                                {suiteStoryLabels.previous ? (
                                                    <p>{suiteStoryLabels.previous}</p>
                                                ) : null}
                                                <strong>{suiteStoryPrevious.label}</strong>
                                                {suiteStoryPrevious.deck ? (
                                                    <span>{suiteStoryPrevious.deck}</span>
                                                ) : null}
                                            </a>
                                        ) : null
                                    }

                                    <article
                                        class="v6-suite-surface-flow__node is-current"
                                        data-v6-suite-surface-flow-current
                                        data-v6-suite-surface-flow-node="current"
                                    >
                                        <p>{suiteStoryCurrent?.pageKey || surfacePageKey}</p>
                                        <strong>{mockup.title || suiteStoryCurrent?.label || page.heading}</strong>
                                        {suiteStoryCurrent?.deck || hero.deck ? (
                                            <span>{suiteStoryCurrent?.deck || hero.deck}</span>
                                        ) : null}
                                    </article>

                                    {
                                        suiteStoryNext ? (
                                            <a
                                                class="v6-suite-surface-flow__node is-next"
                                                href={suiteStoryNext.href}
                                                data-v6-suite-surface-flow-node="next"
                                            >
                                                {suiteStoryLabels.next ? (
                                                    <p>{suiteStoryLabels.next}</p>
                                                ) : null}
                                                <strong>{suiteStoryNext.label}</strong>
                                                {suiteStoryNext.deck ? <span>{suiteStoryNext.deck}</span> : null}
                                            </a>
                                        ) : null
                                    }
                                </div>
                            ) : null
                        }

                        {
                            heroMetrics.length ? (
                                <div class="v6-suite-metrics v6-suite-metrics--surface">
                                    {heroMetrics.map((metric) => (
                                        <article class="v6-suite-metric">
                                            <strong>{metric.value}</strong>
                                            <h3>{metric.label}</h3>
                                            {metric.detail ? <p>{metric.detail}</p> : null}
                                        </article>
                                    ))}
                                </div>
                            ) : null
                        }
                    </aside>
                ) : null
            }
        </div>
    </section>

{
    hasProof ? (
        <section class="v6-suite-proof-band is-surface" data-v6-turnero-proof={surfacePageKey}>
            <div class="v6-suite-shell">
                <div class="v6-suite-proof">
                    <header class="v6-suite-proof__head">
                        {proof.eyebrow ? <p class="v6-suite-eyebrow">{proof.eyebrow}</p> : null}
                        {proof.title ? <h2>{proof.title}</h2> : null}
                        {proof.deck ? <span>{proof.deck}</span> : null}
                    </header>
                    <div class="v6-suite-proof__grid">
                        {proofItems.map((item) => (
                            <article class="v6-suite-proof__card" data-v6-turnero-proof-card={item.id}>
                                <p>{item.label}</p>
                                <strong>{item.value}</strong>
                                {item.detail ? <span>{item.detail}</span> : null}
                            </article>
                        ))}
                    </div>
                </div>
            </div>
        </section>
    ) : null
}

{
    suiteMapItems.length ? (
        <section class="v6-suite-map-band is-surface" data-v6-suite-map="surface">
            <div class="v6-suite-shell">
                <div class="v6-suite-map">
                    {suiteMapItems.map((item) => (
                        <a
                            class:list={['v6-suite-map__item', item.isActive && 'is-active']}
                            href={item.href}
                            data-v6-suite-map-link
                            aria-current={item.isActive ? 'page' : undefined}
                        >
                            <span class="v6-suite-map__index">{item.index}</span>
                            {item.eyebrow ? <p>{item.eyebrow}</p> : null}
                            <strong>{item.label}</strong>
                            {item.deck ? <span>{item.deck}</span> : null}
                        </a>
                    ))}
                </div>
            </div>
        </section>
    ) : null
}

{
    hasSuiteStory ? (
        <section class="v6-suite-progress-band is-surface" data-v6-suite-progress="surface">
            <div class="v6-suite-shell">
                <div
                    class:list={[
                        'v6-suite-progress',
                        suiteStoryPrevious && 'has-previous',
                        suiteStoryNext && 'has-next',
                    ]}
                >
                    {
                        suiteStoryPrevious ? (
                            <a
                                class="v6-suite-progress__nav is-previous"
                                href={suiteStoryPrevious.href}
                                data-v6-suite-progress-nav="previous"
                            >
                                {suiteStoryLabels.previous ? <p>{suiteStoryLabels.previous}</p> : null}
                                <strong>{suiteStoryPrevious.label}</strong>
                                {suiteStoryPrevious.deck ? <span>{suiteStoryPrevious.deck}</span> : null}
                            </a>
                        ) : null
                    }

                    <article
                        class="v6-suite-progress__current"
                        data-v6-suite-progress-current
                        data-v6-suite-page-key={page.pageKey || ''}
                    >
                        {suiteStoryLabels.progress ? (
                            <p class="v6-suite-progress__eyebrow">{suiteStoryLabels.progress}</p>
                        ) : null}
                        <div class="v6-suite-progress__stage">
                            <strong>{stageIndex}</strong>
                            <span>/ {stageTotal}</span>
                        </div>
                        <h2>{suiteStoryCurrent.label}</h2>
                        {suiteStoryCurrent.deck ? <span>{suiteStoryCurrent.deck}</span> : null}
                    </article>

                    {
                        suiteStoryNext ? (
                            <a
                                class="v6-suite-progress__nav is-next"
                                href={suiteStoryNext.href}
                                data-v6-suite-progress-nav="next"
                            >
                                {suiteStoryLabels.next ? <p>{suiteStoryLabels.next}</p> : null}
                                <strong>{suiteStoryNext.label}</strong>
                                {suiteStoryNext.deck ? <span>{suiteStoryNext.deck}</span> : null}
                            </a>
                        ) : null
                    }
                </div>
            </div>
        </section>
    ) : null
}

{
    isStatusSurface ? (
        <section
            class="v6-suite-ticket-status-band"
            data-v6-ticket-status-root
            data-api-url="/api.php?resource=queue-public-ticket"
            hidden
        >
            <div class="v6-suite-shell">
                <div class="v6-suite-ticket-status" data-v6-ticket-status-panel>
                    <div class="v6-suite-ticket-status__head">
                        <div class="v6-suite-ticket-status__head-copy">
                            <p class="v6-suite-eyebrow">{ticketStatusCopy.eyebrow}</p>
                            <h2>{ticketStatusCopy.title}</h2>
                            <span>{ticketStatusCopy.deck}</span>
                        </div>
                        <div class="v6-suite-ticket-status__ticket">
                            <span>{ticketStatusCopy.ticket}</span>
                            <strong data-v6-ticket-status-code>--</strong>
                            <small data-v6-ticket-status-updated>{ticketStatusCopy.updated}</small>
                        </div>
                    </div>

                    <div class="v6-suite-ticket-status__hero">
                        <article class="v6-suite-ticket-status__summary-card">
                            <p data-v6-ticket-status-state-label>{ticketStatusCopy.loading}</p>
                            <strong data-v6-ticket-status-detail>{ticketStatusCopy.deck}</strong>
                            <span data-v6-ticket-status-room></span>
                        </article>

                        <div class="v6-suite-ticket-status__metrics">
                            <article class="v6-suite-ticket-status__metric">
                                <span>{ticketStatusCopy.position}</span>
                                <strong data-v6-ticket-status-value="position">--</strong>
                            </article>
                            <article class="v6-suite-ticket-status__metric">
                                <span>{ticketStatusCopy.ahead}</span>
                                <strong data-v6-ticket-status-value="ahead">--</strong>
                            </article>
                            <article class="v6-suite-ticket-status__metric">
                                <span>{ticketStatusCopy.wait}</span>
                                <strong data-v6-ticket-status-value="wait">--</strong>
                            </article>
                        </div>
                    </div>

                    <div class="v6-suite-ticket-status__lanes">
                        <article class="v6-suite-ticket-status__lane">
                            <p>{ticketStatusCopy.callingNow}</p>
                            <ul data-v6-ticket-status-calling-list>
                                <li>{ticketStatusCopy.noCallingNow}</li>
                            </ul>
                        </article>
                        <article class="v6-suite-ticket-status__lane">
                            <p>{ticketStatusCopy.nextTickets}</p>
                            <ol data-v6-ticket-status-next-list>
                                <li>{ticketStatusCopy.noNextTickets}</li>
                            </ol>
                        </article>
                    </div>

                    <div class="v6-suite-ticket-status__footer">
                        <p data-v6-ticket-status-note>{ticketStatusCopy.note}</p>
                        <button
                            type="button"
                            class="v6-suite-action is-secondary"
                            data-v6-ticket-status-refresh
                        >
                            {ticketStatusCopy.refresh}
                        </button>
                    </div>

                    <p class="v6-suite-ticket-status__message" data-v6-ticket-status-message hidden></p>
                </div>
            </div>
        </section>
    ) : null
}

<div class="v6-suite-shell v6-suite-surface-shell">
    {
        menuItems.length ? (
            <aside class="v6-suite-surface-rail" data-v6-suite-rail="surface">
                <p>{page.heading || ''}</p>
                <nav data-v6-section-nav="software-surface" aria-label={pageHeadUi.pageNavigationLabel || ''}>
                    {menuItems.map((item) => (
                        <a data-v6-section-link href={item.href}>{item.label}</a>
                    ))}
                </nav>
            </aside>
        ) : null
    }

    <div class="v6-suite-surface-shell__body">
        {
            hasShowcase ? (
                <section
                    id="v6-suite-surface-demo"
                    class:list={[
                        'v6-suite-showcase',
                        'v6-suite-surface-block',
                        'is-showcase',
                        `is-${showcaseKind}`,
                    ]}
                    data-v6-suite-showcase
                    data-v6-suite-surface-section="showcase"
                    data-v6-suite-surface-section-order={sectionIndexById['v6-suite-surface-demo'] || ''}
                    data-v6-suite-surface-kind={showcaseKind}
                >
                    <div class="v6-suite-showcase__stage">
