                const refreshButton = root.querySelector(
                    '[data-v6-ticket-status-refresh]'
                );
                const callingList = root.querySelector(
                    '[data-v6-ticket-status-calling-list]'
                );
                const nextList = root.querySelector(
                    '[data-v6-ticket-status-next-list]'
                );
                const localeSwitch = document.querySelector(
                    '[data-v6-page-head] .v6-corp-head__lang-option[href]'
                );
                const metricNodes = {
                    position: root.querySelector(
                        '[data-v6-ticket-status-value="position"]'
                    ),
                    ahead: root.querySelector(
                        '[data-v6-ticket-status-value="ahead"]'
                    ),
                    wait: root.querySelector(
                        '[data-v6-ticket-status-value="wait"]'
                    ),
                };

                const formatCopy = (template, values = {}) =>
                    String(template || '').replace(/\{(\w+)\}/g, (_, key) =>
                        String(values[key] ?? '')
                    );

                const setMetric = (metric, value) => {
                    const node = metricNodes[metric];
                    if (node instanceof HTMLElement) {
                        node.textContent = value;
                    }
                };

                const setMessage = (message, state = 'info') => {
                    if (!(messageNode instanceof HTMLElement)) {
                        return;
                    }

                    const safeMessage =
                        typeof message === 'string' ? message.trim() : '';
                    if (!safeMessage) {
                        messageNode.hidden = true;
                        messageNode.textContent = '';
                        messageNode.removeAttribute('data-state');
                        return;
                    }

                    messageNode.hidden = false;
                    messageNode.dataset.state = state;
                    messageNode.textContent = safeMessage;
                };

                const formatDateTime = (isoDate) => {
                    if (!isoDate) {
                        return '';
                    }

                    const parsed = new Date(isoDate);
                    if (Number.isNaN(parsed.getTime())) {
                        return '';
                    }

                    try {
                        return new Intl.DateTimeFormat(copy.localeTag || undefined, {
                            day: '2-digit',
                            month: 'short',
                            hour: '2-digit',
                            minute: '2-digit',
                        }).format(parsed);
                    } catch (error) {
                        return isoDate;
                    }
                };

                const setUpdatedAt = (isoDate) => {
                    if (!(updatedNode instanceof HTMLElement)) {
                        return;
                    }

                    const formatted = formatDateTime(isoDate);
                    updatedNode.textContent = formatted
                        ? `${copy.updated || 'Updated'}: ${formatted}`
                        : copy.updated || 'Updated';
                };

                const preserveLocaleSwitch = () => {
                    if (!(localeSwitch instanceof HTMLAnchorElement)) {
                        return;
                    }

                    try {
                        const nextUrl = new URL(localeSwitch.href, window.location.origin);
                        nextUrl.searchParams.set('ticket', ticket || rawTicket);
                        localeSwitch.href =
                            nextUrl.pathname +
                            nextUrl.search +
                            nextUrl.hash;
                    } catch (error) {
                        // Ignore locale switch parsing errors in the static shell.
                    }
                };

                const clearList = (listNode) => {
                    if (!(listNode instanceof HTMLElement)) {
                        return;
                    }
                    while (listNode.firstChild) {
                        listNode.removeChild(listNode.firstChild);
                    }
                };

                const renderCallingNow = (items) => {
                    if (!(callingList instanceof HTMLElement)) {
                        return;
                    }

                    clearList(callingList);
                    if (!Array.isArray(items) || !items.length) {
                        const emptyItem = document.createElement('li');
                        emptyItem.textContent =
                            copy.noCallingNow || 'No live calls right now.';
                        callingList.appendChild(emptyItem);
                        return;
                    }

                    items.forEach((item) => {
                        const row = document.createElement('li');
                        const code = document.createElement('strong');
                        code.textContent = String(item?.ticketCode || '--');
                        const detail = document.createElement('span');
                        const room = Number.parseInt(
                            String(item?.assignedConsultorio || ''),
                            10
                        );
                        detail.textContent = Number.isFinite(room)
                            ? `${copy.consultorio || 'Room'} ${room}`
                            : copy.called || 'Called';
                        row.appendChild(code);
                        row.appendChild(detail);
                        callingList.appendChild(row);
                    });
                };

                const renderNextTickets = (items) => {
                    if (!(nextList instanceof HTMLElement)) {
                        return;
                    }

                    clearList(nextList);
                    if (!Array.isArray(items) || !items.length) {
                        const emptyItem = document.createElement('li');
                        emptyItem.textContent =
                            copy.noNextTickets || 'No visible waiting tickets.';
                        nextList.appendChild(emptyItem);
                        return;
                    }

                    items.forEach((item) => {
                        const row = document.createElement('li');
                        const code = document.createElement('strong');
                        code.textContent = String(item?.ticketCode || '--');
                        const detail = document.createElement('span');
                        const position = Number.parseInt(
                            String(item?.position || ''),
                            10
                        );
                        const wait = Number.parseInt(
                            String(item?.estimatedWaitMin || ''),
                            10
                        );
                        const chunks = [];
                        if (Number.isFinite(position)) {
                            chunks.push(`#${position}`);
                        }
                        if (Number.isFinite(wait)) {
                            chunks.push(`${wait} min`);
                        }
                        detail.textContent = chunks.join(' · ');
                        row.appendChild(code);
                        row.appendChild(detail);
                        nextList.appendChild(row);
                    });
                };

                const resetMetrics = () => {
                    setMetric('position', '--');
                    setMetric('ahead', '--');
                    setMetric('wait', '--');
                };

                const renderError = (message, code = '') => {
                    root.hidden = false;
                    if (panel instanceof HTMLElement) {
                        panel.dataset.state = 'error';
                    }
                    if (codeNode instanceof HTMLElement) {
                        codeNode.textContent = ticket || rawTicket || '--';
                    }
                    if (stateLabelNode instanceof HTMLElement) {
                        stateLabelNode.textContent = copy.unknown || 'Ticket status';
                    }
                    if (detailNode instanceof HTMLElement) {
                        detailNode.textContent = message || copy.loadError || '';
                    }
                    if (roomNode instanceof HTMLElement) {
                        roomNode.textContent = '';
                    }
                    setUpdatedAt('');
                    resetMetrics();
                    renderCallingNow([]);
                    renderNextTickets([]);
                    setMessage(message, code === 'queue_bad_request' ? 'error' : 'warning');
                };

                const renderState = (payload) => {
                    const ticketData =
                        payload && typeof payload === 'object' && payload.ticket
                            ? payload.ticket
                            : {};
                    const status = String(ticketData?.status || 'waiting');
                    const room = Number.parseInt(
                        String(ticketData?.assignedConsultorio || ''),
                        10
                    );
                    let label = copy.unknown || 'Ticket status';
                    let detail = copy.noPositionDetail || '';

                    if (status === 'waiting') {
                        label = copy.waiting || 'Waiting';
                        detail =
                            typeof payload?.aheadCount === 'number'
                                ? formatCopy(copy.waitingDetail, {
                                      aheadCount: String(payload.aheadCount),
                                  })
                                : copy.noPositionDetail || '';
                    } else if (status === 'called') {
                        label = copy.called || 'Called';
                        detail = Number.isFinite(room)
                            ? formatCopy(copy.calledDetail, { room: String(room) })
                            : copy.called || 'Called';
                    } else if (status === 'completed') {
                        label = copy.completed || 'Completed';
                        detail = copy.completedDetail || '';
                    } else if (status === 'no_show') {
                        label = copy.noShow || 'No-show';
                        detail = copy.noShowDetail || '';
                    } else if (status === 'cancelled') {
                        label = copy.cancelled || 'Cancelled';
                        detail = copy.cancelledDetail || '';
                    }

                    root.hidden = false;
                    if (panel instanceof HTMLElement) {
                        panel.dataset.state = status;
                    }
                    if (codeNode instanceof HTMLElement) {
                        codeNode.textContent = String(ticketData?.ticketCode || ticket || '--');
                    }
                    if (stateLabelNode instanceof HTMLElement) {
                        stateLabelNode.textContent = label;
                    }
                    if (detailNode instanceof HTMLElement) {
                        detailNode.textContent = detail;
                    }
                    if (roomNode instanceof HTMLElement) {
                        roomNode.textContent =
                            Number.isFinite(room) && status === 'called'
                                ? `${copy.consultorio || 'Room'} ${room}`
                                : '';
                    }

                    setMetric(
                        'position',
                        typeof payload?.position === 'number'
                            ? String(payload.position)
                            : '--'
                    );
                    setMetric(
                        'ahead',
                        typeof payload?.aheadCount === 'number'
                            ? String(payload.aheadCount)
                            : '--'
                    );
                    setMetric(
                        'wait',
                        typeof payload?.estimatedWaitMin === 'number'
                            ? `${payload.estimatedWaitMin} min`
                            : status === 'called'
                                ? copy.waitNow || 'Now'
                                : '--'
                    );
                    setUpdatedAt(
                        String(
                            payload?.updatedAt ||
                                ticketData?.calledAt ||
                                ticketData?.createdAt ||
                                ''
                        )
                    );
                    renderCallingNow(payload?.callingNow);
                    renderNextTickets(payload?.nextTickets);
                    setMessage('');
                };

                const resolveErrorMessage = (payload, responseStatus) => {
                    const code =
                        payload && typeof payload.code === 'string'
                            ? payload.code
                            : '';
                    const message =
                        payload && typeof payload.error === 'string'
                            ? payload.error
                            : '';

                    if (code === 'queue_bad_request') {
                        return {
                            code,
                            message: copy.invalid || message || 'Invalid ticket code.',
                        };
                    }
                    if (code === 'queue_ticket_not_found' || responseStatus === 404) {
                        return {
                            code: 'queue_ticket_not_found',
                            message:
                                copy.notFound ||
                                message ||
                                'Ticket not found.',
                        };
                    }
                    return {
                        code,
                        message: message || copy.loadError || 'Ticket lookup failed.',
                    };
                };

                let requestInFlight = false;
                const fetchStatus = async ({ manual = false } = {}) => {
                    if (requestInFlight) {
                        return;
                    }
                    requestInFlight = true;

                    if (manual) {
                        setMessage(copy.loading || 'Loading...', 'pending');
                    }
                    if (refreshButton instanceof HTMLButtonElement) {
                        refreshButton.disabled = true;
                    }

                    try {
                        const separator = apiUrl.includes('?') ? '&' : '?';
                        const response = await fetch(
                            `${apiUrl}${separator}ticket=${encodeURIComponent(ticket)}`,
                            {
                                method: 'GET',
                                headers: {
                                    Accept: 'application/json',
                                },
                                credentials: 'same-origin',
                            }
                        );
                        const payload = await response.json().catch(() => null);
                        if (!response.ok || !payload || payload.ok !== true) {
                            const errorState = resolveErrorMessage(
                                payload || {},
                                response.status
                            );
                            renderError(errorState.message, errorState.code);
                            return;
                        }

                        renderState(payload.data || {});
                    } catch (error) {
                        const message =
                            error instanceof Error && error.message
                                ? error.message
                                : copy.loadError || 'Ticket lookup failed.';
                        renderError(message);
                    } finally {
                        requestInFlight = false;
                        if (refreshButton instanceof HTMLButtonElement) {
                            refreshButton.disabled = false;
                        }
                    }
                };

                preserveLocaleSwitch();
                root.hidden = false;
                if (codeNode instanceof HTMLElement) {
                    codeNode.textContent = ticket || rawTicket || '--';
                }
                if (!isValidTicket) {
                    renderError(copy.invalid || 'Invalid ticket code.', 'queue_bad_request');
                    return;
                }

                if (refreshButton instanceof HTMLButtonElement) {
                    refreshButton.addEventListener('click', () => {
                        fetchStatus({ manual: true });
                    });
                }

                fetchStatus();
                window.setInterval(() => {
                    fetchStatus();
                }, 15000);
            })();
        </script>
    ) : null
}
