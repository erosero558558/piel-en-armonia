---
import '../../styles/public-v6/software.css';
import PageHeadV6 from './PageHeadV6.astro';
import SoftwareMockupV6 from './SoftwareMockupV6.astro';

const { page = {}, locale = 'es', navModel = {} } = Astro.props;

const pageHeadUi =
    navModel?.ui?.pageHead && typeof navModel.ui.pageHead === 'object'
        ? navModel.ui.pageHead
        : {};
const breadcrumb = Array.isArray(page?.breadcrumb) ? page.breadcrumb : [];
const hero = page?.hero && typeof page.hero === 'object' ? page.hero : {};
const mockup = page?.mockup && typeof page.mockup === 'object' ? page.mockup : {};
const steps = page?.steps && typeof page.steps === 'object' ? page.steps : {};
const advantages =
    page?.advantages && typeof page.advantages === 'object'
        ? page.advantages
        : {};
const connections =
    page?.connections && typeof page.connections === 'object'
        ? page.connections
        : {};
const finalCta =
    page?.finalCta && typeof page.finalCta === 'object' ? page.finalCta : {};
const switchLabel = navModel?.header?.switchLabel || '';
const switchHref = navModel?.header?.switchHref || '#';
const menuLabel = navModel?.header?.menuLabel || '';

const heroActions = Array.isArray(hero.actions) ? hero.actions : [];
const heroMetrics = Array.isArray(hero.metrics) ? hero.metrics : [];
const stepItems = Array.isArray(steps.items) ? steps.items : [];
const advantageCards = Array.isArray(advantages.cards) ? advantages.cards : [];
const connectionItems = Array.isArray(connections.items) ? connections.items : [];
const finalActions = Array.isArray(finalCta.actions) ? finalCta.actions : [];
const finalLinks = Array.isArray(finalCta.links) ? finalCta.links : [];
const suiteStory =
    page?.suiteStory && typeof page.suiteStory === 'object' ? page.suiteStory : {};
const suiteStoryCurrent =
    suiteStory?.current && typeof suiteStory.current === 'object'
        ? suiteStory.current
        : null;
const suiteStoryPrevious =
    suiteStory?.previous && typeof suiteStory.previous === 'object'
        ? suiteStory.previous
        : null;
const suiteStoryNext =
    suiteStory?.next && typeof suiteStory.next === 'object' ? suiteStory.next : null;
const suiteStoryLabels =
    suiteStory?.labels && typeof suiteStory.labels === 'object'
        ? suiteStory.labels
        : {};
const hasSuiteStory = Boolean(
    suiteStoryCurrent &&
        suiteStoryCurrent.label &&
        (suiteStoryCurrent.deck || suiteStoryPrevious?.href || suiteStoryNext?.href)
);
const demoState =
    page?.demoState && typeof page.demoState === 'object' ? page.demoState : {};
const proof =
    demoState?.proof && typeof demoState.proof === 'object' ? demoState.proof : {};
const proofItems = Array.isArray(proof.items) ? proof.items : [];
const hasProof = Boolean((proof.title || proof.deck) && proofItems.length);
const demoStateJson = JSON.stringify(demoState);

const hasShowcase = Boolean(mockup.title || mockup.rows?.length || mockup.chips?.length);
const hasSteps = Boolean(steps.title && stepItems.length);
const hasAdvantages = Boolean(advantages.title && advantageCards.length);
const hasConnections = Boolean(connections.title && connectionItems.length);
const hasFinalCta = Boolean(finalCta.title || finalCta.deck || finalActions.length);

const sectionDefs = [
    hasShowcase
        ? { id: 'v6-suite-surface-demo', label: mockup.title || page.heading || '' }
        : null,
    hasSteps ? { id: 'v6-suite-surface-steps', label: steps.title } : null,
    hasAdvantages
        ? { id: 'v6-suite-surface-advantages', label: advantages.title }
        : null,
    hasConnections
        ? { id: 'v6-suite-surface-connections', label: connections.title }
        : null,
    hasFinalCta ? { id: 'v6-suite-surface-final', label: finalCta.title || page.heading || '' } : null,
].filter((item) => item && item.label);
const sectionIndexById = Object.fromEntries(
    sectionDefs.map((item, index) => [item.id, String(index + 1).padStart(2, '0')])
);

const menuItems = sectionDefs.map((item) => ({
    label: item.label,
    href: `#${item.id}`,
}));
const normalizeText = (value) =>
    typeof value === 'string' && value.trim().length ? value.trim() : '';
const normalizeHref = (value) => {
    const raw = normalizeText(value);
    return raw && raw !== '#' ? raw : '';
};
const normalizePath = (value) => {
    const raw = normalizeHref(value);
    if (!raw) return '';
    return raw.endsWith('/') ? raw : `${raw}/`;
};
const suiteMapItems = Array.isArray(page?.suiteMap)
    ? page.suiteMap
          .map((item) => {
              const href = normalizePath(item?.href);
              const label = normalizeText(item?.label);
              const pageKey = normalizeText(item?.pageKey);
              if (!href || !label || !pageKey) {
                  return null;
              }
              return {
                  href,
                  label,
                  eyebrow: normalizeText(item?.eyebrow),
                  deck: normalizeText(item?.deck),
                  index: normalizeText(item?.index),
                  isActive: pageKey === normalizeText(page?.pageKey),
              };
          })
          .filter(Boolean)
    : [];
const showcaseKind =
    ['phone', 'status', 'dashboard'].includes(normalizeText(mockup?.kind))
        ? normalizeText(mockup?.kind)
        : 'status';
const surfacePageKey = ['demo', 'status', 'dashboard'].includes(
    normalizeText(page?.pageKey)
)
    ? normalizeText(page.pageKey)
    : showcaseKind;
const stageIndex = String(suiteStory.currentIndex || 1).padStart(2, '0');
const stageTotal = String(suiteStory.total || 0).padStart(2, '0');
const isStatusSurface = surfacePageKey === 'status';
const ticketStatusCopy =
    locale === 'en'
        ? {
              eyebrow: 'Live status',
              title: 'Live ticket status from your phone',
              deck: 'Scan the QR on the printed ticket to follow your place in line without returning to the kiosk.',
              ticket: 'Ticket',
              updated: 'Updated',
              refresh: 'Refresh now',
              position: 'Position',
              ahead: 'Ahead of you',
              wait: 'Estimated wait',
              consultorio: 'Room',
              callingNow: 'Calling now',
              noCallingNow: 'No rooms are calling right now.',
              nextTickets: 'Next in line',
              noNextTickets: 'No additional visible tickets waiting right now.',
              note: 'This panel refreshes every 15 seconds.',
              waiting: 'Waiting',
              called: 'You are being called',
              completed: 'Visit completed',
              noShow: 'Marked as no-show',
              cancelled: 'Ticket cancelled',
              unknown: 'Ticket status',
              loading: 'Looking up your ticket...',
              invalid: 'The ticket code is invalid.',
              notFound: 'We could not find that ticket. Double-check the printed code or ask reception for help.',
              loadError: 'We could not load your ticket right now.',
              waitingDetail: '{aheadCount} ticket(s) are ahead of you.',
              noPositionDetail: 'We are recalculating your place in line.',
              calledDetail: 'Please head to room {room}.',
              completedDetail: 'Your visit is already marked as completed.',
              noShowDetail: 'If you are still onsite, reception can help re-activate your arrival.',
              cancelledDetail: 'This ticket is no longer active.',
              waitNow: 'Now',
              localeTag: 'en-US',
          }
        : {
              eyebrow: 'Seguimiento en vivo',
              title: 'Estado en vivo desde tu telefono',
              deck: 'Escanea el QR del ticket impreso para seguir tu posicion sin volver al kiosco.',
              ticket: 'Ticket',
              updated: 'Actualizado',
              refresh: 'Actualizar ahora',
              position: 'Posicion',
              ahead: 'Delante tuyo',
              wait: 'Espera estimada',
              consultorio: 'Consultorio',
              callingNow: 'Llamando ahora',
              noCallingNow: 'No hay consultorios llamando en este momento.',
              nextTickets: 'Siguientes en cola',
              noNextTickets: 'No hay otros tickets visibles en espera.',
              note: 'Este panel se actualiza cada 15 segundos.',
              waiting: 'En espera',
              called: 'Lo estamos llamando',
              completed: 'Atencion finalizada',
              noShow: 'Marcado como no presentado',
              cancelled: 'Turno cancelado',
              unknown: 'Estado del turno',
              loading: 'Buscando tu turno...',
              invalid: 'El codigo del ticket no es valido.',
              notFound: 'No encontramos ese ticket. Revise el codigo impreso o pida apoyo en recepcion.',
              loadError: 'No pudimos cargar tu turno en este momento.',
              waitingDetail: 'Hay {aheadCount} turno(s) antes que el tuyo.',
              noPositionDetail: 'Estamos recalculando tu posicion.',
              calledDetail: 'Dirigete al consultorio {room}.',
              completedDetail: 'Tu visita ya figura como completada.',
              noShowDetail: 'Si sigues en la clinica, recepcion puede reactivar tu llegada.',
              cancelledDetail: 'Este ticket ya no esta activo.',
              waitNow: 'Ahora',
              localeTag: 'es-EC',
          };
const ticketStatusCopyJson = JSON.stringify(ticketStatusCopy);

const actionClass = (variant = 'secondary') => [
    'v6-suite-action',
    variant === 'primary'
        ? 'is-primary'
        : variant === 'ghost'
            ? 'is-ghost'
            : 'is-secondary',
];
---

<PageHeadV6
    breadcrumb={breadcrumb}
    heading={page.heading}
    locale={locale}
    switchLabel={switchLabel}
    switchHref={switchHref}
    menuLabel={menuLabel}
    menuItems={menuItems}
    copy={pageHeadUi}
/>

<div
    class:list={['v6-suite-surface-page', `is-${surfacePageKey}`, `kind-${showcaseKind}`]}
    data-v6-suite-surface-page={surfacePageKey}
    data-v6-suite-surface-kind={showcaseKind}
>
    <section class="v6-suite-surface-hero">
        <div class="v6-suite-shell v6-suite-surface-hero__shell">
            <div class="v6-suite-surface-hero__copy">
                {hero.eyebrow ? <p class="v6-suite-eyebrow">{hero.eyebrow}</p> : null}
                {hero.title ? <h2>{hero.title}</h2> : null}
                {hero.deck ? <p class="v6-suite-lead">{hero.deck}</p> : null}
                {
                    heroActions.length ? (
                        <div class="v6-suite-actions">
                            {heroActions.map((action) => (
                                <a class:list={actionClass(action.variant)} href={action.href}>
                                    {action.label}
                                </a>
                            ))}
                        </div>
                    ) : null
                }
            </div>

            {
                heroMetrics.length || hasSuiteStory ? (
                    <aside
                        class="v6-suite-hero__board v6-suite-hero__board--surface v6-suite-surface-scene"
                        data-v6-suite-surface-scene
                    >
                        <article class="v6-suite-surface-scene__headline">
                            <p>{suiteStoryLabels.progress || hero.eyebrow || page.heading}</p>
                            <div class="v6-suite-surface-scene__counter">
                                <strong>{stageIndex}</strong>
                                <span>/ {stageTotal}</span>
                            </div>
                            <h3>{suiteStoryCurrent?.label || page.heading}</h3>
                            {mockup.footer || suiteStoryCurrent?.deck ? (
                                <span>{mockup.footer || suiteStoryCurrent?.deck}</span>
                            ) : null}
                        </article>

                        {
                            hasSuiteStory ? (
                                <div class="v6-suite-surface-flow" data-v6-suite-surface-flow>
                                    {
                                        suiteStoryPrevious ? (
                                            <a
                                                class="v6-suite-surface-flow__node is-previous"
                                                href={suiteStoryPrevious.href}
                                                data-v6-suite-surface-flow-node="previous"
                                            >
                                                {suiteStoryLabels.previous ? (
                                                    <p>{suiteStoryLabels.previous}</p>
                                                ) : null}
                                                <strong>{suiteStoryPrevious.label}</strong>
                                                {suiteStoryPrevious.deck ? (
                                                    <span>{suiteStoryPrevious.deck}</span>
                                                ) : null}
                                            </a>
                                        ) : null
                                    }

                                    <article
                                        class="v6-suite-surface-flow__node is-current"
                                        data-v6-suite-surface-flow-current
                                        data-v6-suite-surface-flow-node="current"
                                    >
                                        <p>{suiteStoryCurrent?.pageKey || surfacePageKey}</p>
                                        <strong>{mockup.title || suiteStoryCurrent?.label || page.heading}</strong>
                                        {suiteStoryCurrent?.deck || hero.deck ? (
                                            <span>{suiteStoryCurrent?.deck || hero.deck}</span>
                                        ) : null}
                                    </article>

                                    {
                                        suiteStoryNext ? (
                                            <a
                                                class="v6-suite-surface-flow__node is-next"
                                                href={suiteStoryNext.href}
                                                data-v6-suite-surface-flow-node="next"
                                            >
                                                {suiteStoryLabels.next ? (
                                                    <p>{suiteStoryLabels.next}</p>
                                                ) : null}
                                                <strong>{suiteStoryNext.label}</strong>
                                                {suiteStoryNext.deck ? <span>{suiteStoryNext.deck}</span> : null}
                                            </a>
                                        ) : null
                                    }
                                </div>
                            ) : null
                        }

                        {
                            heroMetrics.length ? (
                                <div class="v6-suite-metrics v6-suite-metrics--surface">
                                    {heroMetrics.map((metric) => (
                                        <article class="v6-suite-metric">
                                            <strong>{metric.value}</strong>
                                            <h3>{metric.label}</h3>
                                            {metric.detail ? <p>{metric.detail}</p> : null}
                                        </article>
                                    ))}
                                </div>
                            ) : null
                        }
                    </aside>
                ) : null
            }
        </div>
    </section>

{
    hasProof ? (
        <section class="v6-suite-proof-band is-surface" data-v6-turnero-proof={surfacePageKey}>
            <div class="v6-suite-shell">
                <div class="v6-suite-proof">
                    <header class="v6-suite-proof__head">
                        {proof.eyebrow ? <p class="v6-suite-eyebrow">{proof.eyebrow}</p> : null}
                        {proof.title ? <h2>{proof.title}</h2> : null}
                        {proof.deck ? <span>{proof.deck}</span> : null}
                    </header>
                    <div class="v6-suite-proof__grid">
                        {proofItems.map((item) => (
                            <article class="v6-suite-proof__card" data-v6-turnero-proof-card={item.id}>
                                <p>{item.label}</p>
                                <strong>{item.value}</strong>
                                {item.detail ? <span>{item.detail}</span> : null}
                            </article>
                        ))}
                    </div>
                </div>
            </div>
        </section>
    ) : null
}

{
    suiteMapItems.length ? (
        <section class="v6-suite-map-band is-surface" data-v6-suite-map="surface">
            <div class="v6-suite-shell">
                <div class="v6-suite-map">
                    {suiteMapItems.map((item) => (
                        <a
                            class:list={['v6-suite-map__item', item.isActive && 'is-active']}
                            href={item.href}
                            data-v6-suite-map-link
                            aria-current={item.isActive ? 'page' : undefined}
                        >
                            <span class="v6-suite-map__index">{item.index}</span>
                            {item.eyebrow ? <p>{item.eyebrow}</p> : null}
                            <strong>{item.label}</strong>
                            {item.deck ? <span>{item.deck}</span> : null}
                        </a>
                    ))}
                </div>
            </div>
        </section>
    ) : null
}

{
    hasSuiteStory ? (
        <section class="v6-suite-progress-band is-surface" data-v6-suite-progress="surface">
            <div class="v6-suite-shell">
                <div
                    class:list={[
                        'v6-suite-progress',
                        suiteStoryPrevious && 'has-previous',
                        suiteStoryNext && 'has-next',
                    ]}
                >
                    {
                        suiteStoryPrevious ? (
                            <a
                                class="v6-suite-progress__nav is-previous"
                                href={suiteStoryPrevious.href}
                                data-v6-suite-progress-nav="previous"
                            >
                                {suiteStoryLabels.previous ? <p>{suiteStoryLabels.previous}</p> : null}
                                <strong>{suiteStoryPrevious.label}</strong>
                                {suiteStoryPrevious.deck ? <span>{suiteStoryPrevious.deck}</span> : null}
                            </a>
                        ) : null
                    }

                    <article
                        class="v6-suite-progress__current"
                        data-v6-suite-progress-current
                        data-v6-suite-page-key={page.pageKey || ''}
                    >
                        {suiteStoryLabels.progress ? (
                            <p class="v6-suite-progress__eyebrow">{suiteStoryLabels.progress}</p>
                        ) : null}
                        <div class="v6-suite-progress__stage">
                            <strong>{stageIndex}</strong>
                            <span>/ {stageTotal}</span>
                        </div>
                        <h2>{suiteStoryCurrent.label}</h2>
                        {suiteStoryCurrent.deck ? <span>{suiteStoryCurrent.deck}</span> : null}
                    </article>

                    {
                        suiteStoryNext ? (
                            <a
                                class="v6-suite-progress__nav is-next"
                                href={suiteStoryNext.href}
                                data-v6-suite-progress-nav="next"
                            >
                                {suiteStoryLabels.next ? <p>{suiteStoryLabels.next}</p> : null}
                                <strong>{suiteStoryNext.label}</strong>
                                {suiteStoryNext.deck ? <span>{suiteStoryNext.deck}</span> : null}
                            </a>
                        ) : null
                    }
                </div>
            </div>
        </section>
    ) : null
}

{
    isStatusSurface ? (
        <section
            class="v6-suite-ticket-status-band"
            data-v6-ticket-status-root
            data-api-url="/api.php?resource=queue-public-ticket"
            hidden
        >
            <div class="v6-suite-shell">
                <div class="v6-suite-ticket-status" data-v6-ticket-status-panel>
                    <div class="v6-suite-ticket-status__head">
                        <div class="v6-suite-ticket-status__head-copy">
                            <p class="v6-suite-eyebrow">{ticketStatusCopy.eyebrow}</p>
                            <h2>{ticketStatusCopy.title}</h2>
                            <span>{ticketStatusCopy.deck}</span>
                        </div>
                        <div class="v6-suite-ticket-status__ticket">
                            <span>{ticketStatusCopy.ticket}</span>
                            <strong data-v6-ticket-status-code>--</strong>
                            <small data-v6-ticket-status-updated>{ticketStatusCopy.updated}</small>
                        </div>
                    </div>

                    <div class="v6-suite-ticket-status__hero">
                        <article class="v6-suite-ticket-status__summary-card">
                            <p data-v6-ticket-status-state-label>{ticketStatusCopy.loading}</p>
                            <strong data-v6-ticket-status-detail>{ticketStatusCopy.deck}</strong>
                            <span data-v6-ticket-status-room></span>
                        </article>

                        <div class="v6-suite-ticket-status__metrics">
                            <article class="v6-suite-ticket-status__metric">
                                <span>{ticketStatusCopy.position}</span>
                                <strong data-v6-ticket-status-value="position">--</strong>
                            </article>
                            <article class="v6-suite-ticket-status__metric">
                                <span>{ticketStatusCopy.ahead}</span>
                                <strong data-v6-ticket-status-value="ahead">--</strong>
                            </article>
                            <article class="v6-suite-ticket-status__metric">
                                <span>{ticketStatusCopy.wait}</span>
                                <strong data-v6-ticket-status-value="wait">--</strong>
                            </article>
                        </div>
                    </div>

                    <div class="v6-suite-ticket-status__lanes">
                        <article class="v6-suite-ticket-status__lane">
                            <p>{ticketStatusCopy.callingNow}</p>
                            <ul data-v6-ticket-status-calling-list>
                                <li>{ticketStatusCopy.noCallingNow}</li>
                            </ul>
                        </article>
                        <article class="v6-suite-ticket-status__lane">
                            <p>{ticketStatusCopy.nextTickets}</p>
                            <ol data-v6-ticket-status-next-list>
                                <li>{ticketStatusCopy.noNextTickets}</li>
                            </ol>
                        </article>
                    </div>

                    <div class="v6-suite-ticket-status__footer">
                        <p data-v6-ticket-status-note>{ticketStatusCopy.note}</p>
                        <button
                            type="button"
                            class="v6-suite-action is-secondary"
                            data-v6-ticket-status-refresh
                        >
                            {ticketStatusCopy.refresh}
                        </button>
                    </div>

                    <p class="v6-suite-ticket-status__message" data-v6-ticket-status-message hidden></p>
                </div>
            </div>
        </section>
    ) : null
}

<div class="v6-suite-shell v6-suite-surface-shell">
    {
        menuItems.length ? (
            <aside class="v6-suite-surface-rail" data-v6-suite-rail="surface">
                <p>{page.heading || ''}</p>
                <nav data-v6-section-nav="software-surface" aria-label={pageHeadUi.pageNavigationLabel || ''}>
                    {menuItems.map((item) => (
                        <a data-v6-section-link href={item.href}>{item.label}</a>
                    ))}
                </nav>
            </aside>
        ) : null
    }

    <div class="v6-suite-surface-shell__body">
        {
            hasShowcase ? (
                <section
                    id="v6-suite-surface-demo"
                    class:list={[
                        'v6-suite-showcase',
                        'v6-suite-surface-block',
                        'is-showcase',
                        `is-${showcaseKind}`,
                    ]}
                    data-v6-suite-showcase
                    data-v6-suite-surface-section="showcase"
                    data-v6-suite-surface-section-order={sectionIndexById['v6-suite-surface-demo'] || ''}
                    data-v6-suite-surface-kind={showcaseKind}
                >
                    <div class="v6-suite-showcase__stage">
                        <SoftwareMockupV6 mockup={mockup} />
                    </div>
                    <article class:list={['v6-suite-card', 'v6-suite-card--copy', `is-${showcaseKind}`]}>
                        <div class="v6-suite-surface-section-tag" data-v6-suite-surface-section-tag aria-hidden="true">
                            <span>{sectionIndexById['v6-suite-surface-demo'] || ''}</span>
                        </div>
                        {mockup.eyebrow ? <p>{mockup.eyebrow}</p> : null}
                        <h3>{mockup.title || page.heading}</h3>
                        {mockup.footer ? <span>{mockup.footer}</span> : null}
                    </article>
                </section>
            ) : null
        }

        {
            hasSteps ? (
                <section
                    id="v6-suite-surface-steps"
                    class:list={[
                        'v6-suite-section',
                        'is-tight',
                        'v6-suite-surface-block',
                        'is-steps',
                        'is-surface-steps',
                        `is-page-${surfacePageKey}`,
                    ]}
                    data-v6-suite-surface-section="steps"
                    data-v6-suite-surface-section-order={sectionIndexById['v6-suite-surface-steps'] || ''}
                >
                    <header class="v6-suite-section__head">
                        <div class="v6-suite-surface-section-tag" data-v6-suite-surface-section-tag aria-hidden="true">
                            <span>{sectionIndexById['v6-suite-surface-steps'] || ''}</span>
                        </div>
                        {steps.eyebrow ? <p>{steps.eyebrow}</p> : null}
                        <h2>{steps.title}</h2>
                    </header>

                    <div class:list={['v6-suite-steps', 'v6-suite-steps--surface', `is-page-${surfacePageKey}`]}>
                        {stepItems.map((item, index) => (
                            <article class:list={['v6-suite-step', 'v6-suite-surface-step', `is-page-${surfacePageKey}`]}>
                                <strong>{String(index + 1).padStart(2, '0')}</strong>
                                <p>{item}</p>
                            </article>
                        ))}
                    </div>
                </section>
            ) : null
        }

        {
            hasAdvantages ? (
                <section
                    id="v6-suite-surface-advantages"
                    class:list={[
                        'v6-suite-section',
                        'is-tight',
                        'v6-suite-surface-block',
                        'is-advantages',
                        'is-surface-advantages',
                        `is-page-${surfacePageKey}`,
                    ]}
                    data-v6-suite-surface-section="advantages"
                    data-v6-suite-surface-section-order={sectionIndexById['v6-suite-surface-advantages'] || ''}
                >
                    <header class="v6-suite-section__head">
                        <div class="v6-suite-surface-section-tag" data-v6-suite-surface-section-tag aria-hidden="true">
                            <span>{sectionIndexById['v6-suite-surface-advantages'] || ''}</span>
                        </div>
                        {advantages.eyebrow ? <p>{advantages.eyebrow}</p> : null}
                        <h2>{advantages.title}</h2>
                    </header>

                    <div
                        class:list={[
                            'v6-suite-grid',
                            'v6-suite-grid--three',
                            'v6-suite-surface-proof-grid',
                            'is-surface-advantages-grid',
                            `is-page-${surfacePageKey}`,
                        ]}
                    >
                        {advantageCards.map((card) => (
                            <article
                                class:list={[
                                    'v6-suite-card',
                                    'v6-suite-surface-proof',
                                    'v6-suite-surface-advantage',
                                    `is-page-${surfacePageKey}`,
                                ]}
                            >
                                <h3>{card.title}</h3>
                                {card.copy ? <span>{card.copy}</span> : null}
                            </article>
                        ))}
                    </div>
                </section>
            ) : null
        }

        {
            hasConnections ? (
                <section
                    id="v6-suite-surface-connections"
                    class:list={[
                        'v6-suite-section',
                        'is-tight',
                        'is-slate',
                        'v6-suite-surface-block',
                        'is-connections',
                        'is-surface-connections',
                        `is-page-${surfacePageKey}`,
                    ]}
                    data-v6-suite-surface-section="connections"
                    data-v6-suite-surface-section-order={sectionIndexById['v6-suite-surface-connections'] || ''}
                >
                    <header class="v6-suite-section__head">
                        <div class="v6-suite-surface-section-tag" data-v6-suite-surface-section-tag aria-hidden="true">
                            <span>{sectionIndexById['v6-suite-surface-connections'] || ''}</span>
                        </div>
                        {connections.eyebrow ? <p>{connections.eyebrow}</p> : null}
                        <h2>{connections.title}</h2>
                    </header>

                    <div
                        class:list={[
                            'v6-suite-list-grid',
                            'v6-suite-list-grid--surface',
                            'is-surface-connections-grid',
                            `is-page-${surfacePageKey}`,
                        ]}
                    >
                        {connectionItems.map((item) => (
                            <article
                                class:list={[
                                    'v6-suite-list-item',
                                    'v6-suite-surface-link',
                                    'v6-suite-surface-connection',
                                    `is-page-${surfacePageKey}`,
                                ]}
                            >
                                <strong>+</strong>
                                <p>{item}</p>
                            </article>
                        ))}
                    </div>
                </section>
            ) : null
        }

        {
            hasFinalCta ? (
                <section
                    id="v6-suite-surface-final"
                    class:list={[
                        'v6-suite-final',
                        'is-inline',
                        'v6-suite-surface-block',
                        'is-final',
                        'is-surface-final',
                        `is-page-${surfacePageKey}`,
                    ]}
                    data-v6-suite-surface-section="final"
                    data-v6-suite-surface-section-order={sectionIndexById['v6-suite-surface-final'] || ''}
                >
                    <div class:list={['v6-suite-final__shell', `is-page-${surfacePageKey}`]}>
                        <div>
                            <div class="v6-suite-surface-section-tag" data-v6-suite-surface-section-tag aria-hidden="true">
                                <span>{sectionIndexById['v6-suite-surface-final'] || ''}</span>
                            </div>
                            {finalCta.title ? <h2>{finalCta.title}</h2> : null}
                            {finalCta.deck ? <p>{finalCta.deck}</p> : null}
                            {
                                finalLinks.length ? (
                                    <div class="v6-suite-proof-links" data-v6-turnero-proof-links={surfacePageKey}>
                                        {finalLinks.map((link, index) => (
                                            <a
                                                class="v6-suite-proof-link"
                                                href={link.href}
                                                data-v6-turnero-presentation-link
                                                data-v6-turnero-presentation-link-order={String(index + 1).padStart(2, '0')}
                                            >
                                                {link.eyebrow ? <span>{link.eyebrow}</span> : null}
                                                <strong>{link.label}</strong>
                                                {link.note ? <small>{link.note}</small> : null}
                                            </a>
                                        ))}
                                    </div>
                                ) : null
                            }
                        </div>
                        {
                            finalActions.length ? (
                                <div class="v6-suite-actions v6-suite-actions--final">
                                    {finalActions.map((action) => (
                                        <a class:list={actionClass(action.variant)} href={action.href}>
                                            {action.label}
                                        </a>
                                    ))}
                                </div>
                            ) : null
                        }
                    </div>
                </section>
            ) : null
        }
    </div>
</div>
</div>

<script
    type="application/json"
    data-v6-turnero-demo-state={surfacePageKey}
    set:html={demoStateJson}
></script>
{
    isStatusSurface ? (
        <script
            type="application/json"
            data-v6-ticket-status-copy
            set:html={ticketStatusCopyJson}
        ></script>
    ) : null
}
{
    isStatusSurface ? (
        <script is:inline>
            (() => {
                const root = document.querySelector('[data-v6-ticket-status-root]');
                if (!(root instanceof HTMLElement)) {
                    return;
                }
                const panel = root.querySelector('[data-v6-ticket-status-panel]');

                const copyNode = document.querySelector('[data-v6-ticket-status-copy]');
                let copy = {};
                try {
                    copy = JSON.parse(copyNode?.textContent || '{}');
                } catch (error) {
                    copy = {};
                }

                const params = new URLSearchParams(window.location.search);
                const hasTicketParam = params.has('ticket');
                if (!hasTicketParam) {
                    return;
                }

                const normalizeTicket = (value) =>
                    String(value || '')
                        .trim()
                        .toUpperCase()
                        .replace(/[^A-Z0-9-]/g, '');
                const rawTicket = String(params.get('ticket') || '').trim();
                const ticket = normalizeTicket(rawTicket);
                const isValidTicket = /^[A-Z]-\d{3,4}$/.test(ticket);
                const apiUrl =
                    root.dataset.apiUrl || '/api.php?resource=queue-public-ticket';
                const codeNode = root.querySelector('[data-v6-ticket-status-code]');
                const updatedNode = root.querySelector(
                    '[data-v6-ticket-status-updated]'
                );
                const stateLabelNode = root.querySelector(
                    '[data-v6-ticket-status-state-label]'
                );
                const detailNode = root.querySelector(
                    '[data-v6-ticket-status-detail]'
                );
                const roomNode = root.querySelector('[data-v6-ticket-status-room]');
                const messageNode = root.querySelector(
                    '[data-v6-ticket-status-message]'
                );
                const refreshButton = root.querySelector(
                    '[data-v6-ticket-status-refresh]'
                );
                const callingList = root.querySelector(
                    '[data-v6-ticket-status-calling-list]'
                );
                const nextList = root.querySelector(
                    '[data-v6-ticket-status-next-list]'
                );
                const localeSwitch = document.querySelector(
                    '[data-v6-page-head] .v6-corp-head__lang-option[href]'
                );
                const metricNodes = {
                    position: root.querySelector(
                        '[data-v6-ticket-status-value="position"]'
                    ),
                    ahead: root.querySelector(
                        '[data-v6-ticket-status-value="ahead"]'
                    ),
                    wait: root.querySelector(
                        '[data-v6-ticket-status-value="wait"]'
                    ),
                };

                const formatCopy = (template, values = {}) =>
                    String(template || '').replace(/\{(\w+)\}/g, (_, key) =>
                        String(values[key] ?? '')
                    );

                const setMetric = (metric, value) => {
                    const node = metricNodes[metric];
                    if (node instanceof HTMLElement) {
                        node.textContent = value;
                    }
                };

                const setMessage = (message, state = 'info') => {
                    if (!(messageNode instanceof HTMLElement)) {
                        return;
                    }

                    const safeMessage =
                        typeof message === 'string' ? message.trim() : '';
                    if (!safeMessage) {
                        messageNode.hidden = true;
                        messageNode.textContent = '';
                        messageNode.removeAttribute('data-state');
                        return;
                    }

                    messageNode.hidden = false;
                    messageNode.dataset.state = state;
                    messageNode.textContent = safeMessage;
                };

                const formatDateTime = (isoDate) => {
                    if (!isoDate) {
                        return '';
                    }

                    const parsed = new Date(isoDate);
                    if (Number.isNaN(parsed.getTime())) {
                        return '';
                    }

                    try {
                        return new Intl.DateTimeFormat(copy.localeTag || undefined, {
                            day: '2-digit',
                            month: 'short',
                            hour: '2-digit',
                            minute: '2-digit',
                        }).format(parsed);
                    } catch (error) {
                        return isoDate;
                    }
                };

                const setUpdatedAt = (isoDate) => {
                    if (!(updatedNode instanceof HTMLElement)) {
                        return;
                    }

                    const formatted = formatDateTime(isoDate);
                    updatedNode.textContent = formatted
                        ? `${copy.updated || 'Updated'}: ${formatted}`
                        : copy.updated || 'Updated';
                };

                const preserveLocaleSwitch = () => {
                    if (!(localeSwitch instanceof HTMLAnchorElement)) {
                        return;
                    }

                    try {
                        const nextUrl = new URL(localeSwitch.href, window.location.origin);
                        nextUrl.searchParams.set('ticket', ticket || rawTicket);
                        localeSwitch.href =
                            nextUrl.pathname +
                            nextUrl.search +
                            nextUrl.hash;
                    } catch (error) {
                        // Ignore locale switch parsing errors in the static shell.
                    }
                };

                const clearList = (listNode) => {
                    if (!(listNode instanceof HTMLElement)) {
                        return;
                    }
                    while (listNode.firstChild) {
                        listNode.removeChild(listNode.firstChild);
                    }
                };

                const renderCallingNow = (items) => {
                    if (!(callingList instanceof HTMLElement)) {
                        return;
                    }

                    clearList(callingList);
                    if (!Array.isArray(items) || !items.length) {
                        const emptyItem = document.createElement('li');
                        emptyItem.textContent =
                            copy.noCallingNow || 'No live calls right now.';
                        callingList.appendChild(emptyItem);
                        return;
                    }

                    items.forEach((item) => {
                        const row = document.createElement('li');
                        const code = document.createElement('strong');
                        code.textContent = String(item?.ticketCode || '--');
                        const detail = document.createElement('span');
                        const room = Number.parseInt(
                            String(item?.assignedConsultorio || ''),
                            10
                        );
                        detail.textContent = Number.isFinite(room)
                            ? `${copy.consultorio || 'Room'} ${room}`
                            : copy.called || 'Called';
                        row.appendChild(code);
                        row.appendChild(detail);
                        callingList.appendChild(row);
                    });
                };

                const renderNextTickets = (items) => {
                    if (!(nextList instanceof HTMLElement)) {
                        return;
                    }

                    clearList(nextList);
                    if (!Array.isArray(items) || !items.length) {
                        const emptyItem = document.createElement('li');
                        emptyItem.textContent =
                            copy.noNextTickets || 'No visible waiting tickets.';
                        nextList.appendChild(emptyItem);
                        return;
                    }

                    items.forEach((item) => {
                        const row = document.createElement('li');
                        const code = document.createElement('strong');
                        code.textContent = String(item?.ticketCode || '--');
                        const detail = document.createElement('span');
                        const position = Number.parseInt(
                            String(item?.position || ''),
                            10
                        );
                        const wait = Number.parseInt(
                            String(item?.estimatedWaitMin || ''),
                            10
                        );
                        const chunks = [];
                        if (Number.isFinite(position)) {
                            chunks.push(`#${position}`);
                        }
                        if (Number.isFinite(wait)) {
                            chunks.push(`${wait} min`);
                        }
                        detail.textContent = chunks.join(' · ');
                        row.appendChild(code);
                        row.appendChild(detail);
                        nextList.appendChild(row);
                    });
                };

                const resetMetrics = () => {
                    setMetric('position', '--');
                    setMetric('ahead', '--');
                    setMetric('wait', '--');
                };

                const renderError = (message, code = '') => {
                    root.hidden = false;
                    if (panel instanceof HTMLElement) {
                        panel.dataset.state = 'error';
                    }
                    if (codeNode instanceof HTMLElement) {
                        codeNode.textContent = ticket || rawTicket || '--';
                    }
                    if (stateLabelNode instanceof HTMLElement) {
                        stateLabelNode.textContent = copy.unknown || 'Ticket status';
                    }
                    if (detailNode instanceof HTMLElement) {
                        detailNode.textContent = message || copy.loadError || '';
                    }
                    if (roomNode instanceof HTMLElement) {
                        roomNode.textContent = '';
                    }
                    setUpdatedAt('');
                    resetMetrics();
                    renderCallingNow([]);
                    renderNextTickets([]);
                    setMessage(message, code === 'queue_bad_request' ? 'error' : 'warning');
                };

                const renderState = (payload) => {
                    const ticketData =
                        payload && typeof payload === 'object' && payload.ticket
                            ? payload.ticket
                            : {};
                    const status = String(ticketData?.status || 'waiting');
                    const room = Number.parseInt(
                        String(ticketData?.assignedConsultorio || ''),
                        10
                    );
                    let label = copy.unknown || 'Ticket status';
                    let detail = copy.noPositionDetail || '';

                    if (status === 'waiting') {
                        label = copy.waiting || 'Waiting';
                        detail =
                            typeof payload?.aheadCount === 'number'
                                ? formatCopy(copy.waitingDetail, {
                                      aheadCount: String(payload.aheadCount),
                                  })
                                : copy.noPositionDetail || '';
                    } else if (status === 'called') {
                        label = copy.called || 'Called';
                        detail = Number.isFinite(room)
                            ? formatCopy(copy.calledDetail, { room: String(room) })
                            : copy.called || 'Called';
                    } else if (status === 'completed') {
                        label = copy.completed || 'Completed';
                        detail = copy.completedDetail || '';
                    } else if (status === 'no_show') {
                        label = copy.noShow || 'No-show';
                        detail = copy.noShowDetail || '';
                    } else if (status === 'cancelled') {
                        label = copy.cancelled || 'Cancelled';
                        detail = copy.cancelledDetail || '';
                    }

                    root.hidden = false;
                    if (panel instanceof HTMLElement) {
                        panel.dataset.state = status;
                    }
                    if (codeNode instanceof HTMLElement) {
                        codeNode.textContent = String(ticketData?.ticketCode || ticket || '--');
                    }
                    if (stateLabelNode instanceof HTMLElement) {
                        stateLabelNode.textContent = label;
                    }
                    if (detailNode instanceof HTMLElement) {
                        detailNode.textContent = detail;
                    }
                    if (roomNode instanceof HTMLElement) {
                        roomNode.textContent =
                            Number.isFinite(room) && status === 'called'
                                ? `${copy.consultorio || 'Room'} ${room}`
                                : '';
                    }

                    setMetric(
                        'position',
                        typeof payload?.position === 'number'
                            ? String(payload.position)
                            : '--'
                    );
                    setMetric(
                        'ahead',
                        typeof payload?.aheadCount === 'number'
                            ? String(payload.aheadCount)
                            : '--'
                    );
                    setMetric(
                        'wait',
                        typeof payload?.estimatedWaitMin === 'number'
                            ? `${payload.estimatedWaitMin} min`
                            : status === 'called'
                                ? copy.waitNow || 'Now'
                                : '--'
                    );
                    setUpdatedAt(
                        String(
                            payload?.updatedAt ||
                                ticketData?.calledAt ||
                                ticketData?.createdAt ||
                                ''
                        )
                    );
                    renderCallingNow(payload?.callingNow);
                    renderNextTickets(payload?.nextTickets);
                    setMessage('');
                };

                const resolveErrorMessage = (payload, responseStatus) => {
                    const code =
                        payload && typeof payload.code === 'string'
                            ? payload.code
                            : '';
                    const message =
                        payload && typeof payload.error === 'string'
                            ? payload.error
                            : '';

                    if (code === 'queue_bad_request') {
                        return {
                            code,
                            message: copy.invalid || message || 'Invalid ticket code.',
                        };
                    }
                    if (code === 'queue_ticket_not_found' || responseStatus === 404) {
                        return {
                            code: 'queue_ticket_not_found',
                            message:
                                copy.notFound ||
                                message ||
                                'Ticket not found.',
                        };
                    }
                    return {
                        code,
                        message: message || copy.loadError || 'Ticket lookup failed.',
                    };
                };

                let requestInFlight = false;
                const fetchStatus = async ({ manual = false } = {}) => {
                    if (requestInFlight) {
                        return;
                    }
                    requestInFlight = true;

                    if (manual) {
                        setMessage(copy.loading || 'Loading...', 'pending');
                    }
                    if (refreshButton instanceof HTMLButtonElement) {
                        refreshButton.disabled = true;
                    }

                    try {
                        const separator = apiUrl.includes('?') ? '&' : '?';
                        const response = await fetch(
                            `${apiUrl}${separator}ticket=${encodeURIComponent(ticket)}`,
                            {
                                method: 'GET',
                                headers: {
                                    Accept: 'application/json',
                                },
                                credentials: 'same-origin',
                            }
                        );
                        const payload = await response.json().catch(() => null);
                        if (!response.ok || !payload || payload.ok !== true) {
                            const errorState = resolveErrorMessage(
                                payload || {},
                                response.status
                            );
                            renderError(errorState.message, errorState.code);
                            return;
                        }

                        renderState(payload.data || {});
                    } catch (error) {
                        const message =
                            error instanceof Error && error.message
                                ? error.message
                                : copy.loadError || 'Ticket lookup failed.';
                        renderError(message);
                    } finally {
                        requestInFlight = false;
                        if (refreshButton instanceof HTMLButtonElement) {
                            refreshButton.disabled = false;
                        }
                    }
                };

                preserveLocaleSwitch();
                root.hidden = false;
                if (codeNode instanceof HTMLElement) {
                    codeNode.textContent = ticket || rawTicket || '--';
                }
                if (!isValidTicket) {
                    renderError(copy.invalid || 'Invalid ticket code.', 'queue_bad_request');
                    return;
                }

                if (refreshButton instanceof HTMLButtonElement) {
                    refreshButton.addEventListener('click', () => {
                        fetchStatus({ manual: true });
                    });
                }

                fetchStatus();
                window.setInterval(() => {
                    fetchStatus();
                }, 15000);
            })();
        </script>
    ) : null
}
