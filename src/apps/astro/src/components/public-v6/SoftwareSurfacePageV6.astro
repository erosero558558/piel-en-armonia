{
    hasInteractiveDemo ? (
        <script is:inline>
            (() => {
                const root = document.querySelector('[data-v6-demo-sandbox-root]');
                if (!(root instanceof HTMLElement)) {
                    return;
                }

                const stateNode = document.querySelector(
                    '[data-v6-turnero-demo-state="demo"]'
                );
                const copyNode = document.querySelector('[data-v6-demo-sandbox-copy]');

                let demoState = {};
                let copy = {};
                try {
                    demoState = JSON.parse(stateNode?.textContent || '{}');
                } catch (error) {
                    demoState = {};
                }
                try {
                    copy = JSON.parse(copyNode?.textContent || '{}');
                } catch (error) {
                    copy = {};
                }

                const sandbox =
                    demoState && typeof demoState.sandbox === 'object'
                        ? demoState.sandbox
                        : {};
                const queue =
                    demoState && typeof demoState.queue === 'object'
                        ? demoState.queue
                        : {};

                const normalizeText = (value) =>
                    typeof value === 'string' && value.trim().length
                        ? value.trim()
                        : '';
                const normalizeTicket = (value) =>
                    normalizeText(value)
                        .toUpperCase()
                        .replace(/[^A-Z0-9-]/g, '');
                const formatWait = (value) =>
                    Number.isFinite(value) ? `${value} min` : '--';
                const uniqueTickets = (items) => {
                    const seen = new Set();
                    return items.filter((item) => {
                        if (!item || !item.ticketCode || seen.has(item.ticketCode)) {
                            return false;
                        }
                        seen.add(item.ticketCode);
                        return true;
                    });
                };

                const scheduledTicket = normalizeTicket(
                    sandbox.scheduledTicket || queue.nextTicket || 'A-042'
                );
                const walkInTicket = normalizeTicket(
                    sandbox.walkInTicket || 'B-117'
                );
                const currentTicket = normalizeTicket(queue.currentTicket || 'A-041');
                const currentRoom = normalizeText(queue.currentRoom || '1');
                const scheduledWait = Number.isFinite(queue.waitingMinutes)
                    ? Math.max(4, Math.round(queue.waitingMinutes / 2))
                    : 6;
                const walkInWait = Number.isFinite(queue.waitingMinutes)
                    ? queue.waitingMinutes + 8
                    : 14;
                const callRoom = normalizeText(sandbox.callRoom || 'Consultorio 2');

                const nodes = {
                    kioskDetail: root.querySelector('[data-v6-demo-sandbox-kiosk-detail]'),
                    ticketCode: root.querySelector('[data-v6-demo-sandbox-ticket-code]'),
                    ticketState: root.querySelector('[data-v6-demo-sandbox-ticket-state]'),
                    ticketChannel: root.querySelector(
                        '[data-v6-demo-sandbox-ticket-channel]'
                    ),
                    ticketWait: root.querySelector('[data-v6-demo-sandbox-ticket-wait]'),
                    operatorDetail: root.querySelector(
                        '[data-v6-demo-sandbox-operator-detail]'
                    ),
                    scheduledButton: root.querySelector(
                        '[data-v6-demo-sandbox-checkin="scheduled"]'
                    ),
                    walkInButton: root.querySelector(
                        '[data-v6-demo-sandbox-checkin="walkin"]'
                    ),
                    callButton: root.querySelector('[data-v6-demo-sandbox-call]'),
                    resetButton: root.querySelector('[data-v6-demo-sandbox-reset]'),
                    callingList: root.querySelector('[data-v6-demo-sandbox-calling-list]'),
                    nextList: root.querySelector('[data-v6-demo-sandbox-next-list]'),
                    stageNodes: Array.from(
                        root.querySelectorAll('[data-v6-demo-sandbox-stage]')
                    ),
                };

                const setText = (node, value) => {
                    if (node instanceof HTMLElement) {
                        node.textContent = value;
                    }
                };

                const renderList = (node, items, emptyMessage) => {
                    if (!(node instanceof HTMLElement)) {
                        return;
                    }
                    node.innerHTML = '';
                    if (!items.length) {
                        const emptyItem = document.createElement('li');
                        emptyItem.textContent = emptyMessage;
                        node.appendChild(emptyItem);
                        return;
                    }

                    items.forEach((item) => {
                        const entry = document.createElement('li');
                        const ticket = document.createElement('strong');
                        ticket.textContent = item.ticketCode;
                        const detail = document.createElement('span');
                        detail.textContent = item.detail;
                        entry.append(ticket, detail);
                        node.appendChild(entry);
                    });
                };

                const state = {
                    stage: 'kiosk',
                    mode: '',
                    ticketCode: '',
                    channel: '',
                    waitLabel: '--',
                };

                const applyQueuedMode = (mode) => {
                    state.stage = 'queued';
                    state.mode = mode;
                    state.ticketCode =
                        mode === 'walkin' ? walkInTicket : scheduledTicket;
                    state.channel =
                        mode === 'walkin'
                            ? copy.walkInChannel ||
                              sandbox.walkInChannel ||
                              'Recepcion'
                            : copy.scheduledChannel ||
                              sandbox.scheduledChannel ||
                              'QR cita';
                    state.waitLabel =
                        mode === 'walkin'
                            ? formatWait(walkInWait)
                            : formatWait(scheduledWait);
                    render();
                };

                const buildQueueLists = () => {
                    if (state.stage === 'kiosk') {
                        return {
                            calling: [],
                            next: [],
                        };
                    }

                    if (state.stage === 'queued') {
                        return {
                            calling: [
                                {
                                    ticketCode: currentTicket,
                                    detail: `${copy.callRoomLabel || 'Consultorio'} ${currentRoom}`,
                                },
                            ],
                            next: uniqueTickets([
                                {
                                    ticketCode: state.ticketCode,
                                    detail: state.waitLabel,
                                },
                                {
                                    ticketCode:
                                        state.ticketCode === scheduledTicket
                                            ? walkInTicket
                                            : scheduledTicket,
                                    detail:
                                        state.ticketCode === scheduledTicket
                                            ? formatWait(walkInWait)
                                            : formatWait(scheduledWait),
                                },
                            ]),
                        };
                    }

                    return {
                        calling: [
                            {
                                ticketCode: state.ticketCode,
                                detail: callRoom,
                            },
                        ],
                        next: uniqueTickets([
                            {
                                ticketCode:
                                    state.ticketCode === scheduledTicket
                                        ? walkInTicket
                                        : scheduledTicket,
                                detail:
                                    state.ticketCode === scheduledTicket
                                        ? formatWait(walkInWait)
                                        : formatWait(scheduledWait),
                            },
                            {
                                ticketCode: normalizeTicket(queue.nextTicket || ''),
                                detail: formatWait(
                                    Number.isFinite(queue.waitingMinutes)
                                        ? queue.waitingMinutes
                                        : 18
                                ),
                            },
                        ]),
                    };
                };

                const render = () => {
                    root.dataset.state = state.stage;

                    nodes.stageNodes.forEach((node) => {
                        if (!(node instanceof HTMLElement)) {
                            return;
                        }
                        node.classList.toggle(
                            'is-active',
                            node.dataset.v6DemoSandboxStage === state.stage
                        );
                    });

                    if (nodes.scheduledButton instanceof HTMLButtonElement) {
                        nodes.scheduledButton.disabled = state.stage !== 'kiosk';
                    }
                    if (nodes.walkInButton instanceof HTMLButtonElement) {
                        nodes.walkInButton.disabled = state.stage !== 'kiosk';
                    }
                    if (nodes.callButton instanceof HTMLButtonElement) {
                        nodes.callButton.disabled = state.stage !== 'queued';
                    }
                    if (nodes.resetButton instanceof HTMLButtonElement) {
                        nodes.resetButton.disabled = state.stage === 'kiosk';
                    }

                    if (state.stage === 'kiosk') {
                        setText(nodes.kioskDetail, copy.kioskIdle || '');
                        setText(nodes.ticketCode, '--');
                        setText(nodes.ticketState, copy.ticketIdle || '');
                        setText(nodes.ticketChannel, '--');
                        setText(nodes.ticketWait, '--');
                        setText(nodes.operatorDetail, copy.operatorIdle || '');
                    } else if (state.stage === 'queued') {
                        setText(nodes.kioskDetail, copy.kioskQueued || '');
                        setText(nodes.ticketCode, state.ticketCode);
                        setText(nodes.ticketState, copy.ticketQueued || '');
                        setText(nodes.ticketChannel, state.channel);
                        setText(nodes.ticketWait, state.waitLabel);
                        setText(nodes.operatorDetail, copy.operatorQueued || '');
                    } else {
                        setText(nodes.kioskDetail, copy.kioskCalled || '');
                        setText(nodes.ticketCode, state.ticketCode);
                        setText(nodes.ticketState, copy.ticketCalled || '');
                        setText(nodes.ticketChannel, state.channel);
                        setText(nodes.ticketWait, copy.waitNow || 'Ahora');
                        setText(
                            nodes.operatorDetail,
                            `${copy.operatorCalled || ''} · ${callRoom}`.trim()
                        );
                    }

                    const queueLists = buildQueueLists();
                    renderList(
                        nodes.callingList,
                        queueLists.calling,
                        copy.queueEmpty || 'Sin ticket demo'
                    );
                    renderList(
                        nodes.nextList,
                        queueLists.next,
                        copy.queueEmpty || 'Sin ticket demo'
                    );
                };

                if (nodes.scheduledButton instanceof HTMLButtonElement) {
                    nodes.scheduledButton.addEventListener('click', () => {
                        applyQueuedMode('scheduled');
                    });
                }

                if (nodes.walkInButton instanceof HTMLButtonElement) {
                    nodes.walkInButton.addEventListener('click', () => {
                        applyQueuedMode('walkin');
                    });
                }

                if (nodes.callButton instanceof HTMLButtonElement) {
                    nodes.callButton.addEventListener('click', () => {
                        if (state.stage !== 'queued') {
                            return;
                        }
                        state.stage = 'called';
                        render();
                    });
                }

                if (nodes.resetButton instanceof HTMLButtonElement) {
                    nodes.resetButton.addEventListener('click', () => {
                        state.stage = 'kiosk';
                        state.mode = '';
                        state.ticketCode = '';
                        state.channel = '';
                        state.waitLabel = '--';
                        render();
                    });
                }

                render();
            })();
        </script>
    ) : null
}
