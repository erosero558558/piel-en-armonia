---
import { getWhatsappNumber } from '../../lib/whatsapp-config.js';
const {
    eyebrow = '',
    title = '',
    deck = '',
    locale = 'es',
    tone = 'porcelain',
} = Astro.props;
const telemedicineHref = locale === 'en' ? '/en/telemedicine/' : '/es/telemedicina/';
---

<section
    class="support-band-v5 support-band-v3"
    data-support-band
    data-template-block="legal_support_v5"
    data-section-tone={tone}
>
    <div>
        <p>{eyebrow}</p>
        <h2>{title}</h2>
        <p>{deck}</p>
    </div>
    <div class="support-band-v5__actions support-band-v3__actions">
        <a
            href="#v5-booking"
            class="hero-stage__cta hero-stage__cta--primary"
            data-analytics-event="open_public_cta"
            data-entry-surface="support_band_booking"
            data-cta-target="booking"
        >
            {locale === 'en' ? 'Open secure booking' : 'Abrir booking seguro'}
        </a>
        <a
            href={telemedicineHref}
            class="hero-stage__cta hero-stage__cta--secondary"
            data-analytics-event="open_public_cta"
            data-entry-surface="support_band_telemedicine"
            data-cta-target="telemedicine"
            data-service-category="all"
            data-service-intent="remote"
            data-catalog-category="all"
            data-catalog-intent="remote"
        >
            {locale === 'en' ? 'Open telemedicine' : 'Abrir telemedicina'}
        </a>
        <a
            href={`https://wa.me/${getWhatsappNumber()}`}
            target="_blank"
            rel="noopener noreferrer"
            class="hero-stage__cta hero-stage__cta--secondary"
            data-analytics-event="open_public_cta"
            data-entry-surface="support_band_whatsapp"
            data-cta-target="whatsapp"
        >
            {locale === 'en' ? 'WhatsApp support' : 'Soporte por WhatsApp'}
        </a>
    </div>
</section>
