---
const { eyebrow = '', points = [], locale = 'es', tone = 'silver' } = Astro.props;
---

<section class="sony-tele-block sony-tele-block--fit" data-who-it-fits data-section-tone={tone} data-template-block="tele_fit_v5">
    <div class="sony-tele-block__head">
        <p>{eyebrow}</p>
        <h2>
            {locale === 'en'
                ? 'Cases that usually start in telemedicine.'
                : 'Casos que suelen iniciar en telemedicina.'}
        </h2>
    </div>
    <div class="sony-tele-block__grid">
        {
            points.map((point) => (
                <article>
                    <p>{point}</p>
                </article>
            ))
        }
    </div>
</section>
