---
const { mega = {}, locale = 'es', labels = {} } = Astro.props;

const intro = mega?.intro && typeof mega.intro === 'object' ? mega.intro : {};
const families = Array.isArray(mega?.families) ? mega.families : [];
const groups = Array.isArray(mega?.groups) ? mega.groups : [];
const featured = Array.isArray(mega?.featured) ? mega.featured : [];
---

<div class="public-mega-panel-v5" data-public-mega-v5>
    <div class="public-mega-panel-v5__intro">
        <p class="public-mega-panel-v5__eyebrow">{intro.eyebrow}</p>
        <h2>{intro.title}</h2>
        <p>{intro.deck}</p>
        {
            intro.href ? (
                <a href={intro.href} class="public-link-arrow">
                    {labels.openCatalogue ||
                        (locale === 'en' ? 'Open catalogue' : 'Abrir catalogo')}
                </a>
            ) : null
        }
    </div>

    <div class="public-mega-panel-v5__families">
        {
            families.map((family) => (
                <a href={family.href} class="public-mega-panel-v5__family">
                    <strong>{family.title}</strong>
                    <span>{family.deck}</span>
                </a>
            ))
        }
    </div>

    <div class="public-mega-panel-v5__groups">
        {
            groups.map((group) => (
                <section>
                    <h3>{group.title}</h3>
                    <ul>
                        {(group.items || []).map((item) => (
                            <li>
                                <a href={item.href}>{item.label}</a>
                            </li>
                        ))}
                    </ul>
                </section>
            ))
        }
    </div>

    <div class="public-mega-panel-v5__featured">
        <h3>
            {labels.featuredServices ||
                (locale === 'en' ? 'Featured services' : 'Servicios destacados')}
        </h3>
        {
            featured.map((item) => (
                <a href={item.href} class="public-mega-panel-v5__feature">
                    <span>{item.family}</span>
                    <strong>{item.title}</strong>
                </a>
            ))
        }
    </div>
</div>
