---
import { getWhatsappNumber } from '../../lib/whatsapp-config.js';
const {
    locale = 'es',
    footer = {},
    compact = false,
    bookingHref = '#v5-booking',
} = Astro.props;
const serviceHubHref = locale === 'en' ? '/en/services/' : '/es/servicios/';
const telemedicineHref = locale === 'en' ? '/en/telemedicine/' : '/es/telemedicina/';
const termsHref = locale === 'en' ? '/en/legal/terms/' : '/es/legal/terminos/';
const privacyHref = locale === 'en' ? '/en/legal/privacy/' : '/es/legal/privacidad/';
const cookiesHref = locale === 'en' ? '/en/legal/cookies/' : '/es/legal/cookies/';
const medicalHref = locale === 'en' ? '/en/legal/medical-disclaimer/' : '/es/legal/aviso-medico/';
const labels =
    locale === 'en'
        ? {
              services: 'Services',
              telemedicine: 'Telemedicine',
              bookNow: 'Book now',
              terms: 'Terms',
              privacy: 'Privacy',
              cookies: 'Cookie policy',
              medical: 'Medical disclaimer',
              whatsapp: 'WhatsApp support',
          }
        : {
              services: 'Servicios',
              telemedicine: 'Telemedicina',
              bookNow: 'Reservar',
              terms: 'Terminos',
              privacy: 'Privacidad',
              cookies: 'Politica de cookies',
              medical: 'Aviso medico',
              whatsapp: 'Soporte por WhatsApp',
          };
---

<footer class:list={['public-footer', 'public-footer--v5', compact && 'is-compact']} data-public-footer>
    <div class="public-footer__top">
        <div>
            <p class="public-footer__eyebrow">{footer.eyebrow}</p>
            <h2>{footer.title}</h2>
            <p>{footer.deck}</p>
        </div>
        <a
            href={bookingHref}
            class="public-footer__cta"
            data-analytics-event="open_public_cta"
            data-entry-surface="footer_booking_primary"
            data-cta-target="booking"
        >
            {footer.ctaLabel}
        </a>
    </div>
    <div class="public-footer__grid">
        <div>
            <h3>{footer.catalogTitle}</h3>
            <a href={serviceHubHref}>{labels.services}</a>
            {
                compact ? null : (
                    <>
                        <a href={`${serviceHubHref}?category=clinical`}>{footer.catalogClinical}</a>
                        <a href={`${serviceHubHref}?category=aesthetic`}>{footer.catalogAesthetic}</a>
                        <a href={`${serviceHubHref}?category=children`}>{footer.catalogChildren}</a>
                    </>
                )
            }
        </div>
        <div>
            <h3>{footer.careModesTitle}</h3>
            <a href={telemedicineHref}>{labels.telemedicine}</a>
            {compact ? null : <a href={bookingHref}>{labels.bookNow}</a>}
            <a href={`https://wa.me/${getWhatsappNumber()}`} target="_blank" rel="noopener noreferrer">{labels.whatsapp}</a>
        </div>
        <div>
            <h3>{footer.legalTitle}</h3>
            <a href={termsHref}>{labels.terms}</a>
            {
                compact ? null : (
                    <>
                        <a href={privacyHref}>{labels.privacy}</a>
                        <a href={cookiesHref}>{labels.cookies}</a>
                        <a href={medicalHref}>{labels.medical}</a>
                    </>
                )
            }
        </div>
        <div>
            <h3>{footer.clinicTitle}</h3>
            <p>{footer.clinicCity}</p>
            <p>{footer.clinicPhone}</p>
            <p>{footer.clinicHours}</p>
        </div>
    </div>
</footer>
