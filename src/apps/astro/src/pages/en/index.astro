---
import PublicShellV6 from '../../layouts/PublicShellV6.astro';
import HeroShowcaseV6 from '../../components/public-v6/HeroShowcaseV6.astro';
import NewsStripV6 from '../../components/public-v6/NewsStripV6.astro';
import EditorialGridV6 from '../../components/public-v6/EditorialGridV6.astro';
import CorporateMatrixV6 from '../../components/public-v6/CorporateMatrixV6.astro';
import BookingStatusV6 from '../../components/public-v6/BookingStatusV6.astro';
import { getV6HomeData, getV6NavigationModel } from '../../lib/public-v6.js';

const locale = 'en';
const pathname = '/en/';
const page = getV6HomeData(locale);
const navModel = getV6NavigationModel(locale, pathname);
---

<PublicShellV6
    title={page.title}
    description={page.description}
    locale={locale}
    canonicalPath={pathname}
    alternatePath="/es/"
    pathname={pathname}
    navModel={navModel}
    templateId="home_v6"
    ogImageSrc={page?.preloadImage?.src}
    preloadImageSrc={page?.preloadImage?.src}
    preloadImageSrcSet={page?.preloadImage?.srcset}
    preloadImageSizes="(max-width: 900px) 100vw, 38vw"
>
    <HeroShowcaseV6 hero={page.hero} locale={locale} />
    <NewsStripV6 item={page.newsStrip} navModel={navModel} locale={locale} />
    <EditorialGridV6 section={page.editorial} locale={locale} />
    <CorporateMatrixV6 section={page.corporateMatrix} locale={locale} />
    <BookingStatusV6 status={page.bookingStatus} locale={locale} />
</PublicShellV6>
