---
import PublicShellV6 from '../../../layouts/PublicShellV6.astro';
import LegalPageV6 from '../../../components/public-v6/LegalPageV6.astro';
import {
    getV6LegalAltSlug,
    getV6LegalData,
    getV6LegalIndex,
    getV6LegalPage,
    getV6NavigationModel,
} from '../../../lib/public-v6.js';

export async function getStaticPaths() {
    return ['terms', 'privacy', 'cookies', 'medical-disclaimer'].map((slug) => ({
        params: { slug },
    }));
}

const locale = 'en';
const { slug } = Astro.params;
const pathname = `/en/legal/${slug}/`;
const page = getV6LegalPage(locale, slug);
if (!page) throw new Error(`V6 legal page not found: ${slug}`);
const indexItems = getV6LegalIndex(locale);
const legalData = getV6LegalData(locale);
const navModel = getV6NavigationModel(locale, pathname);
const altSlug = getV6LegalAltSlug(locale, slug);
---

<PublicShellV6
    title={`${page.heading} | Piel en Armonia`}
    description={page.summary}
    locale={locale}
    canonicalPath={pathname}
    alternatePath={`/es/legal/${altSlug}/`}
    pathname={pathname}
    navModel={navModel}
    templateId="legal_v6"
    ogImageSrc={page.heroImage}
    preloadImageSrc={page.heroImage}
    preloadImageSizes="100vw"
>
    <LegalPageV6
        page={page}
        indexItems={indexItems}
        legalPages={legalData.pages}
        currentSlug={slug}
        locale={locale}
        navModel={navModel}
        ui={legalData.ui || {}}
    />
</PublicShellV6>
