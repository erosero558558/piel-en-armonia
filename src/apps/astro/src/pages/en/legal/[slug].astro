---
import PublicShellV3 from '../../../layouts/PublicShellV3.astro';
import LegalHeroV3 from '../../../components/public-v3/LegalHeroV3.astro';
import LegalPolicyTabsV3 from '../../../components/public-v3/LegalPolicyTabsV3.astro';
import LegalArticleLayoutV3 from '../../../components/public-v3/LegalArticleLayoutV3.astro';
import SupportBandV3 from '../../../components/public-v3/SupportBandV3.astro';
import BookingBridgeBandV3 from '../../../components/public-v3/BookingBridgeBandV3.astro';
import { getLegalIndex, getLegalPageV3Data, getPublicNavigationModel } from '../../../lib/public-v3.js';

export async function getStaticPaths() {
    return ['terms', 'privacy', 'cookies', 'medical-disclaimer'].map((slug) => ({ params: { slug } }));
}

const locale = 'en';
const { slug } = Astro.params;
const page = getLegalPageV3Data(slug, locale);
if (!page) throw new Error(`Legal page not found: ${slug}`);
const pathname = `/en/legal/${slug}/`;
const navModel = getPublicNavigationModel(locale, pathname);
const legalIndex = getLegalIndex(locale);
const altMap = { terms: 'terminos', privacy: 'privacidad', cookies: 'cookies', 'medical-disclaimer': 'aviso-medico' };
---

<PublicShellV3 title={`${page.title} | Piel en Armonia`} description={page.description} locale={locale} canonicalPath={pathname} alternatePath={`/es/legal/${altMap[slug]}/`} pathname={pathname} navModel={navModel}>
    <LegalHeroV3 page={page} />
    <LegalPolicyTabsV3 items={legalIndex} currentHref={pathname} />
    <LegalArticleLayoutV3 page={page} />
    <SupportBandV3 eyebrow={page.supportBand.eyebrow} title={page.supportBand.title} deck={page.supportBand.deck} tone={page.supportBand.tone} locale={locale} />
    <BookingBridgeBandV3 eyebrow={page.booking.eyebrow} title={page.booking.title} deck={page.booking.deck} actionLabel={page.booking.actionLabel} serviceHint={page.booking.serviceHint} tone={page.booking.tone} locale={locale} />
</PublicShellV3>

