---
import PublicShellV6 from '../../../../layouts/PublicShellV6.astro';
import SoftwareLandingV6 from '../../../../components/public-v6/SoftwareLandingV6.astro';
import {
    getV6SoftwareNavigationModel,
    getV6SoftwarePage,
    v6SoftwarePath,
} from '../../../../lib/public-v6.js';

const locale = 'en';
const pageKey = 'landing';
const pathname = v6SoftwarePath(locale, pageKey);
const page = getV6SoftwarePage(locale, pageKey);
if (!page) throw new Error('Software page not found in V6: landing');
const navModel = getV6SoftwareNavigationModel(locale, pathname);
---

<PublicShellV6
    title={page.title}
    description={page.description}
    locale={locale}
    canonicalPath={pathname}
    alternatePath={v6SoftwarePath('es', pageKey)}
    pathname={pathname}
    navModel={navModel}
    templateId="software_suite_v6"
>
    <SoftwareLandingV6 page={page} locale={locale} navModel={navModel} />
</PublicShellV6>
