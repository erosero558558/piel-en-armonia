---
import PublicShellV6 from '../../../../layouts/PublicShellV6.astro';
import SoftwareSurfacePageV6 from '../../../../components/public-v6/SoftwareSurfacePageV6.astro';
import {
    getV6SoftwareNavigationModel,
    getV6SoftwarePage,
    v6SoftwarePath,
} from '../../../../lib/public-v6.js';

const SURFACE_PAGE_MAP = {
    demo: 'demo',
    'queue-status': 'status',
    dashboard: 'dashboard',
};

export async function getStaticPaths() {
    return ['demo', 'queue-status', 'dashboard'].map((surface) => ({
        params: { surface },
    }));
}

const locale = 'en';
const { surface } = Astro.params;
const pageKey = SURFACE_PAGE_MAP[surface];
if (!pageKey) throw new Error(`Invalid software route in V6: ${surface}`);
const pathname = v6SoftwarePath(locale, pageKey);
const page = getV6SoftwarePage(locale, pageKey);
if (!page) throw new Error(`Software page not found in V6: ${pageKey}`);
const navModel = getV6SoftwareNavigationModel(locale, pathname);
---

<PublicShellV6
    title={page.title}
    description={page.description}
    locale={locale}
    canonicalPath={pathname}
    alternatePath={v6SoftwarePath('es', pageKey)}
    pathname={pathname}
    navModel={navModel}
    templateId="software_surface_v6"
>
    <SoftwareSurfacePageV6 page={page} locale={locale} navModel={navModel} />
</PublicShellV6>
