---
import PublicShellV3 from '../../../layouts/PublicShellV3.astro';
import TelemedicineHeroV3 from '../../../components/public-v3/TelemedicineHeroV3.astro';
import HowItWorksV3 from '../../../components/public-v3/HowItWorksV3.astro';
import WhoItFitsV3 from '../../../components/public-v3/WhoItFitsV3.astro';
import EscalationModelV3 from '../../../components/public-v3/EscalationModelV3.astro';
import BookingBridgeBandV3 from '../../../components/public-v3/BookingBridgeBandV3.astro';
import { getPublicNavigationModel, getTelemedicineV3Data } from '../../../lib/public-v3.js';

const locale = 'en';
const pathname = '/en/telemedicine/';
const page = getTelemedicineV3Data(locale);
const navModel = getPublicNavigationModel(locale, pathname);
---

<PublicShellV3 title={page.title} description={page.description} locale={locale} canonicalPath={pathname} alternatePath="/es/telemedicina/" pathname={pathname} navModel={navModel}>
    <TelemedicineHeroV3 hero={page.hero} />
    <HowItWorksV3 eyebrow={page.howItWorks.eyebrow} points={page.howItWorks.points} tone={page.howItWorks.tone} locale={locale} />
    <WhoItFitsV3 eyebrow={page.whoItFits.eyebrow} points={page.whoItFits.points} tone={page.whoItFits.tone} locale={locale} />
    <EscalationModelV3 eyebrow={page.escalation.eyebrow} points={page.escalation.points} tone={page.escalation.tone} locale={locale} />
    <BookingBridgeBandV3 eyebrow={page.booking.eyebrow} title={page.booking.title} deck={page.booking.deck} actionLabel={page.booking.actionLabel} serviceHint={page.booking.serviceHint} tone={page.booking.tone} locale={locale} />
</PublicShellV3>

