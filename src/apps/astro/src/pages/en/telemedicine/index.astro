---
import PublicShellV6 from '../../../layouts/PublicShellV6.astro';
import TelemedicinePageV6 from '../../../components/public-v6/TelemedicinePageV6.astro';
import { getV6NavigationModel, getV6TelemedicineData } from '../../../lib/public-v6.js';

const locale = 'en';
const pathname = '/en/telemedicine/';
const page = getV6TelemedicineData(locale);
const navModel = getV6NavigationModel(locale, pathname);
---

<PublicShellV6
    title={page.title}
    description={page.description}
    locale={locale}
    canonicalPath={pathname}
    alternatePath="/es/telemedicina/"
    pathname={pathname}
    navModel={navModel}
    templateId="telemedicine_v6"
    ogImageSrc={page?.heroImage?.src}
    preloadImageSrc={page?.heroImage?.src}
    preloadImageSrcSet={page?.heroImage?.srcset}
    preloadImageSizes="100vw"
>
    <TelemedicinePageV6 page={page} locale={locale} navModel={navModel} />
</PublicShellV6>
