---
import PublicShellV5 from '../../../layouts/PublicShellV5.astro';
import ServiceDetailV5 from '../../../components/public-v5/ServiceDetailV5.astro';
import BookingBandV5 from '../../../components/public-v5/BookingBandV5.astro';
import { getPublicNavigationModel, getServiceDetailV5Data } from '../../../lib/public-v5.js';
import { getServices, servicePath } from '../../../lib/content.js';

export async function getStaticPaths() {
    return getServices().map((service) => ({ params: { slug: service.slug } }));
}

const locale = 'en';
const { slug } = Astro.params;
const page = getServiceDetailV5Data(slug, locale);
if (!page) throw new Error(`Service not found: ${slug}`);
const pathname = servicePath(locale, slug);
const navModel = getPublicNavigationModel(locale, pathname);
const heroMediaMeta = page?.hero?.mediaMeta || {};
const heroMediaSources = Array.isArray(heroMediaMeta?.sources)
    ? heroMediaMeta.sources
    : [];
const preferredHeroSource =
    heroMediaSources.find((source) => source?.type === 'image/webp') ||
    heroMediaSources.find((source) => source?.type === 'image/avif') ||
    heroMediaSources[0] ||
    null;
const preferredHeroSrcSet = String(preferredHeroSource?.srcset || '').trim();
const preloadImageSrc =
    (preferredHeroSrcSet.split(',')[0] || '').trim().split(/\s+/u)[0] ||
    heroMediaMeta?.src ||
    page?.hero?.media ||
    '';
const preloadImageSrcSet = preferredHeroSrcSet || heroMediaMeta?.srcset || '';
const preloadImageSizes =
    heroMediaMeta?.sizes || '(max-width: 1024px) 100vw, 46vw';
const preloadImageType = String(preferredHeroSource?.type || 'image/webp').trim();
---

<PublicShellV5
    title={page.title}
    description={page.description}
    locale={locale}
    canonicalPath={pathname}
    alternatePath={servicePath('es', slug)}
    pathname={pathname}
    navModel={navModel}
    templateId="service_detail_v5"
    compactFooter={true}
    preloadImageSrc={preloadImageSrc}
    preloadImageSrcSet={preloadImageSrcSet}
    preloadImageSizes={preloadImageSizes}
    preloadImageType={preloadImageType}
>
    <ServiceDetailV5 page={page} locale={locale} />
    <BookingBandV5 eyebrow={page.booking.eyebrow} title={page.booking.title} deck={page.booking.deck} actionLabel={page.booking.actionLabel} serviceHint={page.booking.serviceHint} tone={page.booking.tone} locale={locale} />
</PublicShellV5>
