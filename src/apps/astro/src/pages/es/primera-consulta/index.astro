---
import FirstConsultationPageV6 from '../../../components/public-v6/FirstConsultationPageV6.astro';
import PublicShellV6 from '../../../layouts/PublicShellV6.astro';
import { getV6NavigationModel } from '../../../lib/public-v6.js';

const locale = 'es';
const pathname = '/es/primera-consulta/';
const navModel = getV6NavigationModel(locale, pathname);

const page = {
    title: 'Primera consulta en Aurora Derm | Que esperar antes de venir',
    description:
        'Guia de primera consulta en Aurora Derm: que esperar, que traer, duracion aproximada de 45 min, como llegar y estacionamiento cercano en Quito.',
    heading: 'Primera consulta en Aurora Derm',
    breadcrumb: [
        { label: 'Inicio', href: '/es/' },
        { label: 'Primera consulta', href: pathname },
    ],
    hero: {
        eyebrow: 'Guia para su primera visita',
        title: 'Sepa que traer, cuanto dura y como llegar antes de venir.',
        deck: 'Esta pagina existe para bajar incertidumbre. Queremos que llegue con contexto, sin adivinar si falta algo y sin sentir que va a perder el hilo de su caso.',
        image: '/images/optimized/v6-clinic-diagnostico-integral.webp',
        alt: 'Consulta dermatologica integral con lectura inicial estructurada',
    },
    reassurance: {
        title: 'La meta es que llegue tranquilo y salga con un plan claro.',
        body: 'No necesita traer una carpeta perfecta. Si ya tiene examenes, recetas, fotos o una lista de preguntas, eso ayuda. Si no, la primera consulta tambien sirve para ordenar desde cero.',
    },
    statement: {
        eyebrow: 'Antes de llegar',
        title: 'Lo mas util no es traer todo; es traer lo que si cambia la lectura clinica.',
        body: 'Fotos previas, tratamientos usados, alergias, embarazo, lactancia y cambios recientes ayudan mucho mas que intentar resolverlo solo antes de venir.',
        signature: 'Ruta de primera consulta, Quito',
        image: '/images/optimized/v6-clinic-clinic-environment.webp',
        alt: 'Consultorio dermatologico preparado para una evaluacion tranquila',
    },
    kpis: [
        { label: 'Duracion aproximada', value: '45 min' },
        { label: 'Objetivo', value: 'Entender primero' },
        { label: 'Salida esperada', value: 'Plan claro' },
    ],
    sections: [
        {
            id: 'v6-first-what-to-expect',
            title: 'Que esperar durante la consulta',
            deck: 'La primera visita sirve para entender el problema principal, ordenar prioridades y decidir el siguiente paso con criterio.',
            items: [
                'Revisamos que le preocupa hoy, cuanto tiempo lleva y que cambio recientemente.',
                'Vemos piel, cabello o unas segun su motivo principal y lo que convenga examinar en la misma visita.',
                'Le explicamos si hace falta dermatoscopia, seguimiento, tratamiento, teledermatologia o una consulta de control.',
                'Antes de terminar, usted debe salir sabiendo que sigue primero y que puede esperar del plan.',
            ],
        },
        {
            id: 'v6-first-what-to-bring',
            title: 'Que traer para aprovechar mejor la visita',
            deck: 'No es obligatorio traer todo, pero estas referencias ayudan a leer mejor el caso sin repetir pasos.',
            items: [
                'Lista de medicamentos, cremas, shampoo o procedimientos que ya haya usado recientemente.',
                'Fotos del brote o de la lesion si cambia por dias, semanas o meses y hoy no se ve igual.',
                'Examenes previos o recetas si otra consulta ya le dejo estudios o tratamientos en marcha.',
                'Sus preguntas mas importantes: dolor, picazon, tiempo de evolucion, embarazo, lactancia o alergias.',
            ],
        },
        {
            id: 'v6-first-before-you-leave',
            title: 'Antes de salir de casa',
            deck: 'Pequenos detalles practicos suelen ahorrar apuro al llegar.',
            items: [
                'Si puede, llegue 10 a 15 minutos antes para entrar con calma y ubicar el edificio sin correr.',
                'Traiga el area que quiere revisar sin maquillaje pesado ni productos recien aplicados si eso no le incomoda.',
                'Si la cita es para un nino, conviene traer una referencia simple de sintomas, brotes y que ha usado en casa.',
                'Si no sabe si algo vale la pena llevar, escribanos por WhatsApp y lo resolvemos antes de que salga.',
            ],
        },
    ],
    logistics: {
        eyebrow: 'Como llegar',
        title: 'Llegue con tiempo y sin adivinar el ultimo tramo.',
        deck: 'La consulta esta pensada para empezar sin prisa. Aqui le dejamos los puntos practicos que mas suelen preguntar antes de venir.',
        cards: [
            {
                title: 'Ubicacion',
                body: 'Estamos en Av. Republica de El Salvador, Quito. Revise la ruta en Google Maps antes de salir para llegar con una referencia clara del sector.',
                ctaLabel: 'Abrir Google Maps',
                ctaHref: 'https://www.google.com/maps?cid=15768128031462376471',
            },
            {
                title: 'Estacionamiento',
                body: 'En el sector suele encontrar parqueaderos privados y opciones cercanas. Si viene en auto, conviene salir con unos minutos extra para estacionarse con calma.',
            },
            {
                title: 'Tiempo y acompanamiento',
                body: 'La primera consulta suele durar alrededor de 45 min. Si necesita apoyo para movilizarse, puede venir con un acompanante sin problema.',
            },
        ],
    },
    bookingStatus: {
        eyebrow: 'Siguiente paso',
        title: 'Si quiere confirmar su primera consulta, escribanos por WhatsApp',
        description:
            'Si todavia tiene una duda sobre fotos, horario o como llegar, la resolvemos antes de que salga de casa.',
        ctaLabel: 'Escribir por WhatsApp',
        ctaHref:
            'https://wa.me/593982453672?text=Hola%2C%20quiero%20coordinar%20mi%20primera%20consulta%20en%20Aurora%20Derm',
    },
    ui: {
        railTitle: 'Secciones',
        railAria: 'Secciones de primera consulta',
        kpiAria: 'Resumen rapido de primera consulta',
        sectionsEyebrow: 'Preparacion',
        sectionsTitle: 'Que vale la pena saber antes de venir',
        sectionsDeck: 'Le dejamos una guia directa para llegar con menos ansiedad y sin perder tiempo en lo que no aporta.',
        menu: {
            overview: 'Resumen rapido',
            logistics: 'Como llegar',
            bookingStatus: 'Siguiente paso',
        },
    },
};
---

<PublicShellV6
    title={page.title}
    description={page.description}
    locale={locale}
    canonicalPath={pathname}
    alternatePath=""
    pathname={pathname}
    navModel={navModel}
    templateId="first_consultation_v6"
    ogImageSrc={page.hero.image}
    preloadImageSrc={page.hero.image}
    preloadImageSizes="(max-width: 1100px) 100vw, 60vw"
>
    <FirstConsultationPageV6 page={page} locale={locale} navModel={navModel} />
</PublicShellV6>
