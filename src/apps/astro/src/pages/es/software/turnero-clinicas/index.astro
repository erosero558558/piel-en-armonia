---
import PublicShellV6 from '../../../../layouts/PublicShellV6.astro';
import SoftwareLandingV6 from '../../../../components/public-v6/SoftwareLandingV6.astro';
import {
    getV6SoftwareNavigationModel,
    getV6SoftwarePage,
    v6SoftwarePath,
} from '../../../../lib/public-v6.js';

const locale = 'es';
const pageKey = 'landing';
const pathname = v6SoftwarePath(locale, pageKey);
const page = getV6SoftwarePage(locale, pageKey);
if (!page) throw new Error('Pagina de software no encontrada en V6: landing');
const navModel = getV6SoftwareNavigationModel(locale, pathname);
---

<PublicShellV6
    title={page.title}
    description={page.description}
    locale={locale}
    canonicalPath={pathname}
    alternatePath={v6SoftwarePath('en', pageKey)}
    pathname={pathname}
    navModel={navModel}
    templateId="software_suite_v6"
    ogImageSrc={page.ogImageSrc}
>
    <SoftwareLandingV6 page={page} locale={locale} navModel={navModel} />
    <script is:inline>
        (function(){try{var p=new URLSearchParams(window.location.search),r=p.get("ref")||sessionStorage.getItem("v6_b2b_referral");if(r){sessionStorage.setItem("v6_b2b_referral",r);document.querySelectorAll('a[href*="wa.me"]').forEach(function(a){try{var u=new URL(a.href);if(u.searchParams.has("text")){var t=u.searchParams.get("text");if(t.indexOf("(Referido")===-1){u.searchParams.set("text",t+" (Referido por: "+decodeURIComponent(r)+")");a.href=u.toString();}}}catch(e){}})}}catch(e){}})();
    </script>
</PublicShellV6>
