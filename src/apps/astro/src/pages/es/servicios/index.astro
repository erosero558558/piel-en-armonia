---
import PublicShellV6 from '../../../layouts/PublicShellV6.astro';
import ServiceHubV6 from '../../../components/public-v6/ServiceHubV6.astro';
import { getV6HubData, getV6NavigationModel } from '../../../lib/public-v6.js';

const locale = 'es';
const pathname = '/es/servicios/';
const page = getV6HubData(locale);
const navModel = getV6NavigationModel(locale, pathname);
---

<PublicShellV6
    title={page.title}
    description={page.description}
    locale={locale}
    canonicalPath={pathname}
    alternatePath="/en/services/"
    pathname={pathname}
    navModel={navModel}
    templateId="hub_v6"
    ogImageSrc={page?.heroImage?.src}
    preloadImageSrc={page?.preloadImage?.src}
    preloadImageSrcSet={page?.preloadImage?.srcset}
    preloadImageSizes="100vw"
>
    <ServiceHubV6 page={page} locale={locale} navModel={navModel} />
</PublicShellV6>
