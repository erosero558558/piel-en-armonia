---
import PublicShellV6 from '../../../layouts/PublicShellV6.astro';
import ServiceDetailV6 from '../../../components/public-v6/ServiceDetailV6.astro';
import {
    getV6NavigationModel,
    getV6ServiceBySlug,
    getV6ServiceData,
    getV6ServiceSlugs,
    v6ServicePath,
} from '../../../lib/public-v6.js';

export async function getStaticPaths() {
    return getV6ServiceSlugs('es').map((slug) => ({ params: { slug } }));
}

const locale = 'es';
const { slug } = Astro.params;
const pathname = v6ServicePath(locale, slug);
const navModel = getV6NavigationModel(locale, pathname);
const serviceData = getV6ServiceData(locale);
const service = getV6ServiceBySlug(locale, slug);
if (!service) throw new Error(`Servicio no encontrado en V6: ${slug}`);
const related = (service.related || [])
    .map((relatedSlug) => getV6ServiceBySlug(locale, relatedSlug))
    .filter(Boolean)
    .slice(0, 2)
    .map((item) => ({ ...item, href: v6ServicePath(locale, item.slug) }));
---

<PublicShellV6
    title={`${service.title} | Aurora Derm`}
    description={service.summary}
    locale={locale}
    canonicalPath={pathname}
    alternatePath={v6ServicePath('en', slug)}
    pathname={pathname}
    navModel={navModel}
    templateId="service_detail_v6"
    ogImageSrc={service.heroImage}
    preloadImageSrc={service.heroImage}
    preloadImageSrcSet={service.heroImageSrcset}
    preloadImageSizes="(max-width: 1100px) 100vw, 62vw"
>
    <ServiceDetailV6
        service={service}
        locale={locale}
        navModel={navModel}
        servicePath={pathname}
        hubPath="/es/servicios/"
        related={related}
        ui={serviceData?.ui || {}}
    />
</PublicShellV6>
