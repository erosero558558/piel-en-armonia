---
import PublicShellV3 from '../../../layouts/PublicShellV3.astro';
import ServiceHeroV3 from '../../../components/public-v3/ServiceHeroV3.astro';
import ServiceStoryLayoutV3 from '../../../components/public-v3/ServiceStoryLayoutV3.astro';
import ServiceEvidencePanelV3 from '../../../components/public-v3/ServiceEvidencePanelV3.astro';
import ServiceTimelineV3 from '../../../components/public-v3/ServiceTimelineV3.astro';
import RelatedProgramsV3 from '../../../components/public-v3/RelatedProgramsV3.astro';
import BookingBridgeBandV3 from '../../../components/public-v3/BookingBridgeBandV3.astro';
import { getPublicNavigationModel, getServiceDetailV3Data } from '../../../lib/public-v3.js';
import { getServices, servicePath } from '../../../lib/content.js';

export async function getStaticPaths() {
    return getServices().map((service) => ({ params: { slug: service.slug } }));
}

const locale = 'es';
const { slug } = Astro.params;
const page = getServiceDetailV3Data(slug, locale);
if (!page) throw new Error(`Servicio no encontrado: ${slug}`);
const pathname = servicePath(locale, slug);
const navModel = getPublicNavigationModel(locale, pathname);
---

<PublicShellV3 title={page.title} description={page.description} locale={locale} canonicalPath={pathname} alternatePath={servicePath('en', slug)} pathname={pathname} navModel={navModel} compatServiceBookingHref={`${pathname}?service=${encodeURIComponent(page.booking.serviceHint)}#citas`}>
    <ServiceHeroV3 hero={page.hero} locale={locale} />
    <ServiceStoryLayoutV3 story={page.story} locale={locale} />
    <ServiceEvidencePanelV3 evidence={page.evidence} locale={locale} />
    <ServiceTimelineV3 timeline={page.timeline} />
    <RelatedProgramsV3 items={page.related} locale={locale} />
    <BookingBridgeBandV3 eyebrow={page.booking.eyebrow} title={page.booking.title} deck={page.booking.deck} actionLabel={page.booking.actionLabel} serviceHint={page.booking.serviceHint} tone={page.booking.tone} locale={locale} />
</PublicShellV3>

