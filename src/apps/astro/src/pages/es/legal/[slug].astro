---
import PublicShellV5 from '../../../layouts/PublicShellV5.astro';
import LegalHeroV5 from '../../../components/public-v5/LegalHeroV5.astro';
import LegalPolicyTabsV5 from '../../../components/public-v5/LegalPolicyTabsV5.astro';
import LegalArticleLayoutV5 from '../../../components/public-v5/LegalArticleLayoutV5.astro';
import SupportBandV5 from '../../../components/public-v5/SupportBandV5.astro';
import BookingBandV5 from '../../../components/public-v5/BookingBandV5.astro';
import {
    getLegalIndexV5,
    getLegalPageV5Data,
    getPublicNavigationModel,
} from '../../../lib/public-v5.js';

export async function getStaticPaths() {
    return ['terminos', 'privacidad', 'cookies', 'aviso-medico'].map((slug) => ({ params: { slug } }));
}

const locale = 'es';
const { slug } = Astro.params;
const page = getLegalPageV5Data(slug, locale);
if (!page) throw new Error(`Pagina legal no encontrada: ${slug}`);
const pathname = `/es/legal/${slug}/`;
const navModel = getPublicNavigationModel(locale, pathname);
const legalIndex = getLegalIndexV5(locale);
const altMap = { terminos: 'terms', privacidad: 'privacy', cookies: 'cookies', 'aviso-medico': 'medical-disclaimer' };
---

<PublicShellV5 title={`${page.title} | Piel en Armonia`} description={page.description} locale={locale} canonicalPath={pathname} alternatePath={`/en/legal/${altMap[slug]}/`} pathname={pathname} navModel={navModel} templateId="legal_v5">
    <LegalHeroV5 page={page} locale={locale} />
    <LegalPolicyTabsV5 items={legalIndex} currentHref={pathname} />
    <LegalArticleLayoutV5 page={page} />
    <SupportBandV5 eyebrow={page.supportBand.eyebrow} title={page.supportBand.title} deck={page.supportBand.deck} tone={page.supportBand.tone} locale={locale} />
    <BookingBandV5 eyebrow={page.booking.eyebrow} title={page.booking.title} deck={page.booking.deck} actionLabel={page.booking.actionLabel} serviceHint={page.booking.serviceHint} tone={page.booking.tone} locale={locale} />
</PublicShellV5>
