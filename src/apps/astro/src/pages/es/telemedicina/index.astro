---
import PublicShellV5 from '../../../layouts/PublicShellV5.astro';
import TelemedicineHeroV5 from '../../../components/public-v5/TelemedicineHeroV5.astro';
import TelemedicineFlowV5 from '../../../components/public-v5/TelemedicineFlowV5.astro';
import TelemedicineFitV5 from '../../../components/public-v5/TelemedicineFitV5.astro';
import TelemedicineEscalationV5 from '../../../components/public-v5/TelemedicineEscalationV5.astro';
import BookingTeaserV5 from '../../../components/public-v5/BookingTeaserV5.astro';
import {
    getPublicNavigationModel,
    getTelemedicineV5Data,
} from '../../../lib/public-v5.js';

const locale = 'es';
const pathname = '/es/telemedicina/';
const page = getTelemedicineV5Data(locale);
const navModel = getPublicNavigationModel(locale, pathname);
const heroMediaMeta = page?.hero?.mediaMeta || {};
const preloadImageSrc = heroMediaMeta?.src || page?.hero?.media || '';
const preloadImageSrcSet = heroMediaMeta?.srcset || '';
const preloadImageSizes =
    heroMediaMeta?.sizes || '(max-width: 1024px) 100vw, 46vw';
---

<PublicShellV5
    title={page.title}
    description={page.description}
    locale={locale}
    canonicalPath={pathname}
    alternatePath="/en/telemedicine/"
    pathname={pathname}
    navModel={navModel}
    templateId="telemedicine_v5"
    enableRuntimeBridge={false}
    compactFooter={true}
    preloadImageSrc={preloadImageSrc}
    preloadImageSrcSet={preloadImageSrcSet}
    preloadImageSizes={preloadImageSizes}
>
    <TelemedicineHeroV5 hero={page.hero} locale={locale} />
    <TelemedicineFlowV5
        eyebrow={page.howItWorks.eyebrow}
        points={page.howItWorks.points}
        tone={page.howItWorks.tone}
        locale={locale}
    />
    <TelemedicineFitV5
        eyebrow={page.whoItFits.eyebrow}
        points={page.whoItFits.points}
        tone={page.whoItFits.tone}
        locale={locale}
    />
    <TelemedicineEscalationV5
        eyebrow={page.escalation.eyebrow}
        points={page.escalation.points}
        tone={page.escalation.tone}
        locale={locale}
    />
    <BookingTeaserV5
        locale={locale}
        serviceHint={page.booking.serviceHint}
        primaryHref="#v5-booking"
        primaryLabel={page.booking.actionLabel}
        tone={page.booking.tone}
        mountBookingShell={true}
    />
</PublicShellV5>
