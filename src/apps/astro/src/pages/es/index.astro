---
import '../../styles/public-v6/home.css';
import PublicShellV6 from '../../layouts/PublicShellV6.astro';
import HeroShowcaseV6 from '../../components/public-v6/HeroShowcaseV6.astro';
import NewsStripV6 from '../../components/public-v6/NewsStripV6.astro';
import EditorialGridV6 from '../../components/public-v6/EditorialGridV6.astro';
import TrustSignalsV6 from '../../components/public-v6/TrustSignalsV6.astro';
import GoogleReviewsV6 from '../../components/public-v6/GoogleReviewsV6.astro';
import CaseStoriesV6 from '../../components/public-v6/CaseStoriesV6.astro';
import CorporateMatrixV6 from '../../components/public-v6/CorporateMatrixV6.astro';
import BookingStatusV6 from '../../components/public-v6/BookingStatusV6.astro';
import { getV6HomeData, getV6NavigationModel } from '../../lib/public-v6.js';

const locale = 'es';
const pathname = '/es/';
const page = getV6HomeData(locale);
const navModel = getV6NavigationModel(locale, pathname);
---

<PublicShellV6
    title="Aurora Derm | Clínica Dermatológica"
    description={page.description}
    locale={locale}
    canonicalPath={pathname}
    alternatePath="/en/"
    pathname={pathname}
    navModel={navModel}
    templateId="home_v6"
    ogImageSrc="/images/optimized/v6-clinic-brand-hero-wide.jpg"
>
    <!-- Schema.org Dermatology JSON-LD -->
    <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "MedicalBusiness",
      "name": "Aurora Derm",
      "image": "https://pielarmonia.com/images/optimized/v6-clinic-brand-hero-wide.jpg",
      "url": "https://pielarmonia.com/es/",
      "telephone": "+593982453672",
      "medicalSpecialty": "Dermatology",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Av. de los Shyris y Naciones Unidas",
        "addressLocality": "Quito",
        "addressRegion": "Pichincha",
        "postalCode": "170135",
        "addressCountry": "EC"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -0.1764,
        "longitude": -78.4803
      },
      "priceRange": "$$"
    }
    </script>

    <!-- RB-05: Hero Cinemático -->
    <header class="reborn-hero" data-v6-hero>
        <picture class="reborn-hero__media">
            <source srcset="/images/optimized/v6-clinic-brand-hero-wide.webp" type="image/webp" />
            <img 
                src="/images/optimized/v6-clinic-brand-hero-wide.jpg" 
                alt="Clínica Aurora Derm - Dermatología Avanzada" 
                fetchpriority="high"
                decoding="sync"
            />
        </picture>
        <div class="reborn-hero__scrim"></div>
        <div class="reborn-hero__content">
            <h1 class="reborn-hero__title reborn-display">La ciencia detrás de tu piel</h1>
            <a href="/portal/agendar" class="reborn-hero__ghost reborn-hero__cta reborn-btn-primary" style="background-color: var(--v6-color-accent, #c6a87c); color: #fff; padding: 1rem 2rem; border-radius: 4px; font-weight: 600; font-size: 1.125rem;">Agendar ahora</a>
        </div>
    </header>

    <!-- RB-06: Bento Grid Layout -->
    <section class="reborn-bento">
        <a href="/es/servicios/diagnostico-integral/" class="reborn-bento__item reborn-bento__item--tall">
            <img class="reborn-bento__media" src="/images/optimized/v6-services-acne.webp" alt="Diagnóstico" loading="lazy" />
            <h3 class="reborn-bento__title">Diagnóstico Integral</h3>
            <p class="reborn-bento__desc">Evaluación dermatológica clínica completa con dermatoscopia.</p>
        </a>
        <a href="/es/servicios/laser-dermatologico/" class="reborn-bento__item reborn-bento__item--wide">
            <img class="reborn-bento__media" src="/images/optimized/v6-services-laser.webp" alt="Láser" loading="lazy" />
            <h3 class="reborn-bento__title">Láser Dermatológico</h3>
            <p class="reborn-bento__desc">Tratamientos avanzados con plataforma multi-láser de última generación.</p>
        </a>
        <a href="/es/servicios/botox/" class="reborn-bento__item">
            <h3 class="reborn-bento__title">Toxina Botulínica</h3>
            <p class="reborn-bento__desc">Rejuvenecimiento facial avalado clínicamente.</p>
        </a>
        <a href="/es/telemedicina/" class="reborn-bento__item">
            <h3 class="reborn-bento__title">Teledermatología</h3>
            <p class="reborn-bento__desc">Consulta remota HD.</p>
        </a>
    </section>

    <!-- Trust Signals & Social Proof -->
    <TrustSignalsV6 section={page.trustSignals} />
    <GoogleReviewsV6 section={page.googleReviews} locale={locale} />
    
</PublicShellV6>
