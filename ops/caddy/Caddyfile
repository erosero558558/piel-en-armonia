{
	admin 127.0.0.1:2019
	auto_https off
	persist_config off
}

http://www.pielarmonia.com {
	redir https://pielarmonia.com{uri} permanent
}

http://www.aurora-derm.com {
	redir https://aurora-derm.com{uri} permanent
}

http://pielarmonia.com, http://aurora-derm.com, http://127.0.0.1, http://localhost {
	root * {$PIELARMONIA_WORKSPACE_ROOT:C:/dev/pielarmonia-workspace}
	encode zstd gzip

	log {
		output file {$PIELARMONIA_CADDY_ACCESS_LOG:C:/dev/pielarmonia-workspace/data/runtime/hosting/caddy-access.log}
		format console
	}

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-origin"
		Content-Security-Policy "default-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'self'"
		X-XSS-Protection "1; mode=block"
	}

	@health path /healthz
	@removedUi path_regexp removedUi ^/(?:404\.html|500\.html|_astro(?:/.*)?|admin-openclaw-setup\.html|admin-v3\.css|admin\.js|admin\.html|app-downloads(?:/.*)?|desktop-updates(?:/.*)?|en(?:/.*)?|es(?:/.*)?|favicon\.ico|favicon\.svg|images(?:/.*)?|index\.html|js(?:/.*)?|kiosco-turnos\.html|kiosk-cie10-sandbox\.html|kiosk\.html|manifest\.json|ninos(?:/.*)?|operador-turnos\.html|queue-display\.html|queue-kiosk\.css|queue-kiosk\.html|queue-ops\.css|queue-operator\.html|robots\.txt|sala-turnos\.html|servicios(?:/.*)?|sitemap\.xml|stats\.html|sw\.js)$
	@blocked path_regexp blocked ^/(?:\..*|.*\.(?:log|md|ps1)|AGENTS\.md|composer\.(?:json|lock)|package(?:-lock)?\.json|phpunit\.xml|playwright\.config\.js|rollup\.config\.mjs)$
	@directPhp path_regexp directPhp ^/(?:admin-auth|api|backup-receiver|check-ai-response|cron|figo-ai-bridge|figo-backend|figo-chat|hosting-runtime|payment-lib|verify-backup)\.php$

	handle @health {
		respond "ok" 200
	}

	handle @blocked {
		respond 403
	}

	handle @removedUi {
		header Content-Type "application/json; charset=UTF-8"
		header Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
		respond "{\"ok\":false,\"code\":\"ui_surface_removed\",\"error\":\"This UI surface was removed. Aurora Derm now runs in backend-only mode.\"}" 410
	}

	handle @directPhp {
		php_fastcgi 127.0.0.1:9000 {
			capture_stderr
		}
	}

	handle {
		rewrite * /index.php
		php_fastcgi 127.0.0.1:9000 {
			capture_stderr
		}
	}
}
