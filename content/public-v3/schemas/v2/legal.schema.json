{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "public-v3/legal.v2.schema.json",
    "title": "Public V3 Legal Metadata V2",
    "type": "object",
    "required": ["supportBand", "booking", "pageOrder"],
    "properties": {
        "supportBand": {
            "type": "object",
            "required": ["eyebrow", "title", "deck", "tone"],
            "properties": {
                "eyebrow": {
                    "type": "string",
                    "minLength": 1
                },
                "title": {
                    "type": "string",
                    "minLength": 1
                },
                "deck": {
                    "type": "string",
                    "minLength": 1
                },
                "tone": {
                    "type": "string",
                    "enum": ["ink", "porcelain", "silver"]
                }
            }
        },
        "booking": {
            "type": "object",
            "required": [
                "eyebrow",
                "title",
                "deck",
                "actionLabel",
                "serviceHint",
                "tone"
            ],
            "properties": {
                "eyebrow": {
                    "type": "string",
                    "minLength": 1
                },
                "title": {
                    "type": "string",
                    "minLength": 1
                },
                "deck": {
                    "type": "string",
                    "minLength": 1
                },
                "actionLabel": {
                    "type": "string",
                    "minLength": 1
                },
                "serviceHint": {
                    "type": "string",
                    "minLength": 1
                },
                "tone": {
                    "type": "string",
                    "enum": ["ink", "porcelain", "silver"]
                }
            }
        },
        "pageOrder": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "string",
                "minLength": 1
            }
        }
    }
}
