{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "public-v3/hub.schema.json",
    "title": "Public V3 Hub",
    "type": "object",
    "required": ["title", "description", "hero", "telemedicine", "booking"],
    "properties": {
        "title": {
            "type": "string",
            "minLength": 1
        },
        "description": {
            "type": "string",
            "minLength": 1
        },
        "hero": {
            "type": "object",
            "required": ["eyebrow", "title", "deck", "media"],
            "properties": {
                "eyebrow": {
                    "type": "string",
                    "minLength": 1
                },
                "title": {
                    "type": "string",
                    "minLength": 1
                },
                "deck": {
                    "type": "string",
                    "minLength": 1
                },
                "media": {
                    "type": "string",
                    "minLength": 1
                }
            }
        },
        "telemedicine": {
            "type": "object",
            "required": ["eyebrow", "title", "deck", "href"],
            "properties": {
                "eyebrow": {
                    "type": "string",
                    "minLength": 1
                },
                "title": {
                    "type": "string",
                    "minLength": 1
                },
                "deck": {
                    "type": "string",
                    "minLength": 1
                },
                "href": {
                    "type": "string",
                    "minLength": 1
                }
            }
        },
        "booking": {
            "type": "object",
            "required": [
                "eyebrow",
                "title",
                "deck",
                "actionLabel",
                "serviceHint"
            ],
            "properties": {
                "eyebrow": {
                    "type": "string",
                    "minLength": 1
                },
                "title": {
                    "type": "string",
                    "minLength": 1
                },
                "deck": {
                    "type": "string",
                    "minLength": 1
                },
                "actionLabel": {
                    "type": "string",
                    "minLength": 1
                },
                "serviceHint": {
                    "type": "string",
                    "minLength": 1
                }
            }
        }
    }
}
