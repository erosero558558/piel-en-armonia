apiVersion: v1
kind: Secret
metadata:
  name: pielarmonia-secret
  namespace: pielarmonia
type: Opaque
stringData:
  # Template only. Nunca aplicar este archivo sin reemplazar todos los sentinels.
  # Verificacion previa recomendada:
  #   bash ./ops/check-secrets.sh --namespace pielarmonia --secret pielarmonia-secret
  AURORADERM_ADMIN_PASSWORD: "__REPLACE_AURORADERM_ADMIN_PASSWORD__"
  AURORADERM_STRIPE_SECRET_KEY: "__REPLACE_AURORADERM_STRIPE_SECRET_KEY__"
  AURORADERM_STRIPE_PUBLISHABLE_KEY: "__REPLACE_AURORADERM_STRIPE_PUBLISHABLE_KEY__"
  AURORADERM_STRIPE_WEBHOOK_SECRET: "__REPLACE_AURORADERM_STRIPE_WEBHOOK_SECRET__"
  AURORADERM_TURNSTILE_SITE_KEY: "__REPLACE_AURORADERM_TURNSTILE_SITE_KEY__"
  AURORADERM_TURNSTILE_SECRET_KEY: "__REPLACE_AURORADERM_TURNSTILE_SECRET_KEY__"
  FIGO_CHAT_ENDPOINT: "__REPLACE_FIGO_CHAT_ENDPOINT__"
  FIGO_CHAT_TOKEN: "__REPLACE_FIGO_CHAT_TOKEN__"
  FIGO_AI_ENDPOINT: "__REPLACE_FIGO_AI_ENDPOINT__"
  FIGO_AI_API_KEY: "__REPLACE_FIGO_AI_API_KEY__"
  AURORADERM_CRON_SECRET: "__REPLACE_AURORADERM_CRON_SECRET__"
  AURORADERM_SMTP_HOST: "__REPLACE_AURORADERM_SMTP_HOST__"
  AURORADERM_SMTP_USER: "__REPLACE_AURORADERM_SMTP_USER__"
  AURORADERM_SMTP_PASS: "__REPLACE_AURORADERM_SMTP_PASS__"
