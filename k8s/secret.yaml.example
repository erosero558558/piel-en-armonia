apiVersion: v1
kind: Secret
metadata:
  name: pielarmonia-secret
  namespace: pielarmonia
type: Opaque
stringData:
  # Rellenar con valores reales base64 o stringData en secrets reales
  AURORADERM_ADMIN_PASSWORD: "change-me"
  AURORADERM_STRIPE_SECRET_KEY: "sk_live_..."
  AURORADERM_STRIPE_PUBLISHABLE_KEY: "pk_live_..."
  AURORADERM_STRIPE_WEBHOOK_SECRET: "whsec_..."
  AURORADERM_TURNSTILE_SITE_KEY: "0x4AAAAAAABcDeFgHiJkLmNo"
  AURORADERM_TURNSTILE_SECRET_KEY: "0x4AAAAAAABcDeFgHiJkLmNoPqRsTuVwXyZ"
  FIGO_CHAT_ENDPOINT: "https://example.com/chat"
  FIGO_CHAT_TOKEN: "token"
  FIGO_AI_ENDPOINT: "https://openrouter.ai/api/v1/chat/completions"
  FIGO_AI_API_KEY: "sk-..."
  AURORADERM_CRON_SECRET: "long-secret-token"
  AURORADERM_BACKUP_VERIFY_TOKEN: "long-readonly-backup-verify-token"
  AURORADERM_SMTP_HOST: "smtp.gmail.com"
  AURORADERM_SMTP_USER: "user@example.com"
  AURORADERM_SMTP_PASS: "password"
